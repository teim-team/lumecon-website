# Cloudflare Pages / Netlify header config. Active once the site moves
# off GitHub Pages (GH Pages doesn't support custom headers). Until then
# this file is ignored by the GH Pages deploy.
#
# Goals:
# - Replace the meta-tag CSP with a real HTTP CSP that can enforce
#   frame-ancestors and use nonces.
# - Add HSTS, Strict-Referrer-Policy, X-Frame-Options.
# - Long-cache static assets with content hashes; never-cache HTML.

/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' mailto:; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https://ipapi.co; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin

# Hashed static assets — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/brand/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons + manifest can cache a long time but not immutable.
/favicon.ico
  Cache-Control: public, max-age=2592000

/site.webmanifest
  Cache-Control: public, max-age=604800

# HTML must revalidate so deploys are visible immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
