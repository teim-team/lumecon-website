---
/**
 * /glossary — plain-language definitions of the economic-impact terms
 * that show up across the site and in Cedar's answers (multipliers,
 * RPC, direct/indirect/induced, etc.). Gives first-timers a reference
 * and gives Cedar a stable page to point people to.
 *
 * Built on LegalLayout for the shared chrome + prose styling; the term
 * list is a semantic <dl> so it reads well to both people and crawlers.
 */
import LegalLayout from '../layouts/LegalLayout.astro';

const TERMS: Array<{ term: string; abbr?: string; def: string }> = [
  { term: 'Economic impact analysis', def: "A method for measuring the full economic footprint of an organization, project, or program — not just what it spends, but the additional activity that spending sets off across a region." },
  { term: 'Direct effect', def: "The activity of the project itself: its own spending, wages, and jobs." },
  { term: 'Indirect effect', def: "The activity at the suppliers a project buys from — the vendors, contractors, and businesses in its supply chain." },
  { term: 'Induced effect', def: "The activity created when workers from the direct and indirect activity spend their wages locally — groceries, rent, healthcare, and the rest of household spending." },
  { term: 'Total impact', def: "Direct, indirect, and induced effects added together — the headline number, with each layer shown separately so a reviewer can see where it comes from." },
  { term: 'Multiplier', def: "A factor estimating how each dollar of direct activity ripples into additional activity. Multipliers differ by industry and geography, which is why a casino in Connecticut has a different ripple than a wind farm in Nebraska." },
  { term: 'Regional purchase coefficient', abbr: 'RPC', def: "The share of a good or service a region actually buys locally rather than importing. RPCs decide how much of each dollar stays in-region versus leaking out to suppliers elsewhere." },
  { term: 'Input-output model', abbr: 'I-O', def: "The economic framework behind impact analysis: a matrix of how industries buy from and sell to one another, used to trace how spending flows through an economy. Built on the BEA national accounts and regionalized to your geography." },
  { term: 'Base year', def: "The reference year whose price levels and industry structure a study's data is anchored to." },
  { term: 'Labor income', def: "Wages, salaries, and benefits paid to workers — reported alongside jobs and output as one of the headline figures." },
  { term: 'Output', def: "The total value of production (sales or revenue) generated by the activity." },
  { term: 'Jobs (FTE)', def: "Employment supported by the activity, usually reported as full-time-equivalent positions across the direct, indirect, and induced layers." },
];

const site = 'https://lumecon.ai';
const definedTermSet = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': `${site}/glossary`,
  name: 'Economic impact analysis glossary',
  url: `${site}/glossary`,
  hasDefinedTerm: TERMS.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.abbr ? `${t.term} (${t.abbr})` : t.term,
    description: t.def,
    inDefinedTermSet: `${site}/glossary`,
  })),
};
---
<LegalLayout
  title="Glossary | Lumecon"
  description="Plain-language definitions of economic impact analysis terms: direct, indirect, and induced effects, multipliers, regional purchase coefficients (RPC), input-output models, base year, labor income, output, and jobs."
  canonical="https://lumecon.ai/glossary"
  keywords="economic impact glossary, what is a multiplier, regional purchase coefficient, RPC, direct indirect induced effects, input-output model, economic impact analysis terms, labor income, FTE jobs"
>
  <h1 class="hl-block hl-block--gold-b">Glossary</h1>
  <div class="date">Plain-language definitions</div>
  <p>The terms that come up most across economic impact analysis — and across Lumecon and Cedar. No economics degree required.</p>

  <dl class="glossary">
    {TERMS.map((t) => (
      <div class="glossary__row" id={t.term.toLowerCase().replace(/[^a-z]+/g, '-').replace(/^-|-$/g, '')}>
        <dt class="glossary__term">{t.term}{t.abbr && <span class="glossary__abbr"> ({t.abbr})</span>}</dt>
        <dd class="glossary__def">{t.def}</dd>
      </div>
    ))}
  </dl>

  <p class="glossary__foot">Want to see these in motion? Watch a live study on the <a href="/map" class="note-link">interactive map</a>, or ask <a href="/cedar" class="note-link">Cedar</a> to explain any of them.</p>

  <script type="application/ld+json" set:html={JSON.stringify(definedTermSet)} is:inline />
</LegalLayout>

<style>
  .glossary {
    margin: 2rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .glossary__row {
    scroll-margin-top: 6rem;
  }
  .glossary__term {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
    color: var(--navy);
    letter-spacing: -.01em;
    margin-bottom: .3rem;
  }
  .glossary__abbr {
    color: var(--accent-deep);
    font-weight: 600;
  }
  .glossary__def {
    font-size: .92rem;
    line-height: 1.7;
    color: var(--gray);
    font-weight: 500;
    padding-left: .9rem;
    border-left: 2px solid var(--rule-strong);
  }
  .glossary__foot {
    margin-top: 2rem;
  }
</style>
