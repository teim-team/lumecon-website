---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';

/**
 * Internships page — targeted SEO surface for Cornell + Ivy League
 * students searching for internships in software engineering, machine
 * learning, data analytics, marketing, and sales at an early-stage
 * Ivy-built startup. Each role carries JobPosting JSON-LD so Google
 * picks them up in Google for Jobs and student-targeted SERPs.
 */

const EDUCATION_TARGETS = 'Currently enrolled at Cornell, Dartmouth, Oxford, Stanford, MIT, Harvard, Princeton, Yale, UPenn, Brown, Columbia, Berkeley, Carnegie Mellon, or an equivalent program.';

const ROLES = [
  {
    slug: 'software-engineering-intern',
    title: 'Software Engineering Intern',
    short: 'Full-stack TypeScript, geographic visualization, and economic-modeling backend.',
    description: 'Build product surface across Lumecon\'s Local, Tribal, and Global Economic Impact platforms. Work in TypeScript with Astro, d3-geo, and a Python/Postgres modeling backend. Ship features that municipal governments, tribal nations, and federal grant programs use to run economic impact studies in-house. Five-person team — you\'ll work directly with the founder and ship code that real users rely on within your first month.',
    skills: 'TypeScript, JavaScript, Python, Astro, React, d3, SVG, Postgres, Git',
    employmentType: 'INTERN',
    educationRequirements: `${EDUCATION_TARGETS} CS, Operations Research, Information Science, Engineering Physics, or Statistics majors preferred.`,
  },
  {
    slug: 'machine-learning-intern',
    title: 'Machine Learning / AI Intern',
    short: 'Build Cedar — the AI assistant inside every Lumecon platform.',
    description: 'Work on Cedar, Lumecon\'s built-in AI assistant. Help Cedar read messy administrative uploads (budgets, payroll detail, council agendas, chapter audits, grant filings), surface each modeling assumption for human confirmation, and write a source record for every economic impact study. LLM evaluation, prompt engineering, document understanding, and structured-extraction pipelines. Direct collaboration with the founding team.',
    skills: 'Python, PyTorch, LLM evaluation, prompt engineering, document extraction, vector search, RAG, evals',
    employmentType: 'INTERN',
    educationRequirements: `${EDUCATION_TARGETS} CS, Statistics, Applied Math, Information Science, or AI / ML majors preferred.`,
  },
  {
    slug: 'data-analytics-intern',
    title: 'Data Analytics Intern',
    short: 'Economic data engineering — input-output modeling, IMPLAN/RIMS multipliers, tribal economies.',
    description: 'Work on the data backbone that drives every Lumecon impact study. Source, clean, and version the high-frequency public and private datasets that power our multipliers. Construct the proprietary regional bridges that handle small regions and tribal economies underserved by IMPLAN, RIMS II, and REMI. Work directly with the founder on what becomes the reference dataset for tribal-economy modeling.',
    skills: 'SQL, Python, pandas, geopandas, R, Stata, BEA / Census / BLS data sources, input-output modeling',
    employmentType: 'INTERN',
    educationRequirements: `${EDUCATION_TARGETS} Economics, Public Policy, Statistics, ORIE, ILR, Dyson Applied Economics & Management, or similar preferred.`,
  },
  {
    slug: 'marketing-growth-intern',
    title: 'Marketing & Growth Intern',
    short: 'Government outreach, tribal-nation engagement, SEO, and content for an Ivy-built startup.',
    description: 'Own marketing surface across content, SEO, and outreach to municipal governments, tribal nations, Alaska Native Corporations, Native Hawaiian Organizations, and economic development organizations. Write long-form pieces on input-output modeling, tribal economics, and policy analysis. Run search, university and CDFI partnerships, and grant-funder pipelines. Co-author the playbook for marketing a Cornell-built public-sector software startup.',
    skills: 'Writing, SEO, content strategy, partnerships, CRM, public-sector outreach, brand',
    employmentType: 'INTERN',
    educationRequirements: `${EDUCATION_TARGETS} Marketing, Communication, Public Policy, ILR, Dyson, or interdisciplinary majors preferred.`,
  },
  {
    slug: 'sales-business-development-intern',
    title: 'Sales & Business Development Intern',
    short: 'Pilot enrollment with governments, tribes, and mission-driven organizations.',
    description: 'Lead pilot enrollment with municipal governments, tribal nations, Alaska Native Corporations, Native Hawaiian Organizations, state agencies, universities, foundations, and CDFIs. Build the playbook for government and tribal procurement. Help structure annual subscription deals and federal grant-funded engagements. Operating experience that compounds — at a five-person team where every conversation matters.',
    skills: 'B2B sales, government procurement, RFP response, tribal sovereignty awareness, account management, CRM',
    employmentType: 'INTERN',
    educationRequirements: `${EDUCATION_TARGETS} Dyson Applied Economics & Management, ILR, Public Policy, Economics, or Engineering majors preferred.`,
  },
  {
    slug: 'economist-impact-modeling-intern',
    title: 'Economist / Economic Impact Modeling Intern',
    short: 'Input-output modeling, IMPLAN/RIMS/REMI multipliers, and small-region econometrics.',
    description: 'Work on the modeling core that drives every Lumecon impact study. Help construct the proprietary multipliers and regional bridges that handle small regions, tribal economies, and rural counties underserved by IMPLAN, RIMS II, and REMI. Co-author the methodology that becomes the reference for tribal-economy and small-region modeling. Strong fit for economics undergrads, master\'s, and PhD candidates who want to publish work AND ship product at the same time.',
    skills: 'Input-output modeling, IMPLAN, RIMS II, REMI, regional CGE, econometrics, Python / R / Stata, BEA / Census / BLS data sources, social accounting matrices',
    employmentType: 'INTERN',
    educationRequirements: `${EDUCATION_TARGETS} Economics, Applied Economics & Management (Dyson), Public Policy, Regional Science, or Agricultural & Resource Economics undergrad, master\'s, or PhD candidates preferred.`,
  },
];

const today = new Date().toISOString().slice(0, 10);
const oneYear = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const jsonLd = ROLES.map(role => ({
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": role.title,
  "description": role.description,
  "datePosted": today,
  "validThrough": oneYear,
  "employmentType": role.employmentType,
  "hiringOrganization": {
    "@type": "Organization",
    "name": site.legalName,
    "sameAs": site.url,
    "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
  },
  "applicantLocationRequirements": {
    "@type": "Country",
    "name": "United States",
  },
  "jobLocationType": "TELECOMMUTE",
  "directApply": false,
  "url": `${site.url}/internships#${role.slug}`,
  "skills": role.skills,
  "educationRequirements": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "Currently enrolled undergraduate or graduate student",
    "description": role.educationRequirements,
  },
  "qualifications": role.educationRequirements,
}));
---
<BaseLayout
  title="Internships at Lumecon | Undergrad + grad — Cornell, Stanford, MIT, Ivy League"
  description="Cornell-built economic impact analysis software hiring undergrad and graduate interns: software engineering, machine learning, data analytics, marketing, sales, and economic impact modeling. Unpaid early-stage roles at a five-person team. Cornell, Dartmouth, Stanford, MIT, Harvard, Princeton, Yale, UPenn, Brown, Columbia, Berkeley, CMU students. Econ undergrads, master's, and PhDs welcome."
  canonical="https://lumecon.ai/internships"
  keywords="Cornell internship, Cornell software engineering internship, Cornell machine learning internship, Cornell economics internship, Cornell PhD internship, Cornell graduate student internship, economics PhD internship, economic impact modeling internship, input-output modeling internship, IMPLAN internship, RIMS II internship, REMI internship, regional economics PhD internship, Ivy League AI internship, Cornell startup internship, Cornell Brooks School internship, Cornell Dyson internship, Cornell ILR internship, Cornell ORIE internship, Cornell CS internship, Dartmouth internship, Stanford internship, Stanford PhD internship, MIT internship, Harvard internship, Princeton internship, Princeton ORFE internship, Yale internship, UPenn Wharton internship, Brown internship, Columbia internship, Berkeley internship, Berkeley ARE internship, Carnegie Mellon internship, Cornell Operations Research internship, tribal economics internship, public policy internship, regional science internship, applied economics PhD internship, Cornell Information Science internship, data analytics internship Cornell, Cornell economic impact internship, machine learning startup internship, AI internship Ivy League, Cornell sales internship, Cornell marketing internship, Lumecon internship, Cornell entrepreneurship internship, early stage startup internship"
  ogTitle="Internships at Lumecon — undergrad + grad, Cornell + Ivy League peers"
  ogDescription="Software engineering, ML, data, marketing, sales, and economic impact modeling internships at a five-person Cornell-built startup. Undergrad, master's, and PhD candidates. Unpaid, real product surface from week one."
  jsonLd={jsonLd}
>
  <Nav />

  <main class="careers">
    <header class="careers-head">
      <p class="careers-eyebrow">Early-team internships · undergrad + grad · five-person team</p>
      <h1 class="careers-title">Get in early at a Cornell-born startup serving governments and tribal nations.</h1>
      <p class="careers-lede">
        The job market for undergrads and graduate students is tight right now. Operating experience compounds — and the right early-stage team is where you actually own product surface instead of being employee #500. Lumecon Inc. is a five-person, Cornell-built economic impact analysis software company looking for early teammates across software engineering, machine learning / AI, data analytics, marketing, sales, and economic impact modeling. Open to undergrads, master's, and PhD candidates.
      </p>
      <p class="careers-lede careers-lede--sub">
        These are <strong>unpaid roles</strong>. What you get instead: real product surface in front of council members, tribal leaders, and federal grant reviewers; a Cornell-built reference on your résumé; and the chance to be early at what we think can be the next big company in government technology. Open to current students at Cornell, Dartmouth, Oxford, Stanford, MIT, Harvard, Princeton, Yale, UPenn, Brown, Columbia, Berkeley, Carnegie Mellon, and equivalent programs.
      </p>
      <p class="careers-lede careers-lede--sub">
        <strong>Team background:</strong> Cornell, Dartmouth, Oxford, MIT, and Yale academic training, plus prior experience at the Federal Reserve Banks of Minneapolis and Philadelphia and the Federal Reserve Board of Governors in Washington, DC. If you'd be working on the modeling side, you'll be paired with people who understand input-output methodology from the inside.
      </p>
      <p class="careers-cta">
        <a href={`mailto:${site.email}?subject=Internship%20application%20—%20${encodeURIComponent('Lumecon')}&body=${encodeURIComponent('Hi Lumecon team,\n\nI am a [Cornell / Dartmouth / Ivy League] student interested in the [role] internship.\n\nMy academic program: \nMy resume: (attach or paste URL)\nLinkedIn: \n\nWhy Lumecon: \n')}`} class="btn">Apply via email</a>
        <a href="#open-roles" class="btn btn--ghost">See open roles ↓</a>
      </p>
    </header>

    <section class="careers-grid" id="open-roles" aria-labelledby="open-roles-title">
      <h2 class="careers-grid__title" id="open-roles-title">Open intern roles</h2>
      {ROLES.map(role => (
        <article class="role" id={role.slug}>
          <h3 class="role__title">{role.title}</h3>
          <p class="role__short">{role.short}</p>
          <p class="role__desc">{role.description}</p>
          <dl class="role__meta">
            <div class="role__meta-row">
              <dt>Skills</dt>
              <dd>{role.skills}</dd>
            </div>
            <div class="role__meta-row">
              <dt>Who fits</dt>
              <dd>{role.educationRequirements}</dd>
            </div>
            <div class="role__meta-row">
              <dt>Logistics</dt>
              <dd>Unpaid early-stage role. Remote-friendly. Five-person team — you work directly with the founder. Quarterly cohorts. Send a résumé and a one-paragraph note on what draws you to Lumecon\'s mission.</dd>
            </div>
          </dl>
          <p class="role__apply">
            <a href={`mailto:${site.email}?subject=${encodeURIComponent('Internship — ' + role.title)}`} class="btn btn--ghost">Apply for {role.title}</a>
          </p>
        </article>
      ))}
    </section>

    <section class="careers-about" aria-labelledby="about-title">
      <h2 id="about-title">About working at Lumecon</h2>
      <p>Lumecon Inc. is an early-stage, Cornell-built economic impact analysis software company. We replace the overpriced consultant and software stack that governments and mission-driven organizations have historically depended on for input-output modeling, fiscal multiplier analysis, and economic development reporting. The market we're going after is large, fragmented, and underserved — and we think Lumecon can be the next big company in government and tribal-economy technology.</p>
      <p>Our team is five people. Interns own real product surface — Cedar AI features, geographic visualizations, multiplier-data pipelines, government and tribal outreach, pilot deals — and ship work that ends up in front of council members, tribal leaders, foundation officers, and federal grant reviewers. There's no "intern queue." You work directly with the founder.</p>
      <p>Be honest with yourself on the trade: these are <strong>unpaid internships</strong>. What you get is the operating experience of being early at something that matters, in a job market where most internships are bullshit or canceled. Cornell CS, ORIE, Brooks School, Dyson, ILR, Information Science, Statistics, and Engineering students get a fast track in our review. Dartmouth, Oxford, Stanford, MIT, Harvard, Princeton, Yale, UPenn, Brown, Columbia, Berkeley, and Carnegie Mellon students are equally welcome.</p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .careers {
    background: var(--white);
    padding: clamp(6rem, 11vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
  }
  .careers-head {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }
  .careers-eyebrow {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .careers-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.08;
    letter-spacing: -.025em;
    color: var(--navy);
    margin: 0;
    max-width: 22ch;
  }
  .careers-lede {
    font-family: var(--font-sans);
    font-size: 1.12rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 1.4rem 0 0;
    max-width: 60ch;
  }
  .careers-lede--sub { margin-top: .8rem; }
  .careers-cta {
    margin: 2rem 0 0;
    display: flex;
    gap: .8rem;
    flex-wrap: wrap;
  }
  .careers-grid {
    max-width: 880px;
    margin: clamp(3rem, 6vw, 5rem) auto 0;
    padding: 0 var(--container-pad);
  }
  .careers-grid__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    color: var(--navy);
    letter-spacing: -.018em;
    margin: 0 0 1.6rem;
    padding-bottom: .8rem;
    border-bottom: 1px solid var(--rule);
  }
  .role {
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .role:last-child { border-bottom: 0; }
  .role__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--navy);
    letter-spacing: -.018em;
    margin: 0 0 .4rem;
  }
  .role__short {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.45;
    color: var(--ink-2);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  .role__desc {
    font-family: var(--font-sans);
    font-size: .96rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 64ch;
    font-weight: 400;
  }
  .role__meta {
    margin: 0 0 1.2rem;
    display: grid;
    gap: .6rem;
  }
  .role__meta-row {
    display: grid;
    grid-template-columns: minmax(110px, 130px) 1fr;
    gap: .6rem 1.2rem;
    align-items: baseline;
  }
  .role__meta-row dt {
    font-family: var(--font-mono);
    font-size: .68rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 500;
  }
  .role__meta-row dd {
    font-family: var(--font-sans);
    font-size: .9rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
  }
  .role__apply { margin: 0; }
  .careers-about {
    max-width: 880px;
    margin: clamp(3rem, 6vw, 5rem) auto 0;
    padding: 0 var(--container-pad);
  }
  .careers-about h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    color: var(--navy);
    letter-spacing: -.018em;
    margin: 0 0 1.4rem;
  }
  .careers-about p {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1rem;
    max-width: 64ch;
  }
  @media (max-width: 640px) {
    .role__meta-row { grid-template-columns: 1fr; gap: .3rem; }
  }
</style>
