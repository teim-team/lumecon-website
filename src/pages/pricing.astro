---
/**
 * /pricing — platform picker first, tiers second.
 *
 * The visitor flow:
 *   1. Land on the page.
 *   2. Pick the platform that matches their work — Tribal, Local,
 *      or Global. Global is gated as "Coming soon" at v1.
 *   3. Tier grid + comparison table + discount band reveal beneath
 *      the platform picker. The picked platform's name threads
 *      through tier CTAs and the comparison-table heading so the
 *      visitor sees their context echoed back to them.
 *
 * Why gate the tiers behind a platform pick: the four offerings
 * serve very different audiences (tribal nations vs. municipalities
 * vs. cross-border analysis vs. consulting firms), and showing every
 * tier on every platform at once would force a tribal-nation buyer
 * to mentally filter out "this isn't for me" rows. Gating cleans
 * that up.
 *
 * Prices are per-platform now (Local Sprout $10K, Tribal Sprout
 * $12.5K, etc.) so the tier-card price spans render placeholder
 * text on initial paint and are filled in by the picker script
 * from the picked tile's data-price-* attributes.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import IconTribal from '../components/icons/IconTribal.astro';
import IconLocal from '../components/icons/IconLocal.astro';
import IconGlobal from '../components/icons/IconGlobal.astro';
import IconArborist from '../components/icons/IconArborist.astro';
import { site } from '../config';
import {
  PUBLIC_PRICING_TIERS,
  COMPARISON_ROWS,
  ANNUAL_SUBSCRIPTION_DISCOUNTS,
  PRODUCT_LINES,
  CONSULTANT_TIER,
  TOOLBOX_ADDON,
} from '../data/pricing';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import '../styles/pricing.css';

const tiers = PUBLIC_PRICING_TIERS;
const platforms = PRODUCT_LINES;

const description = 'Pricing tiers for Lumecon. Pick your platform (Tribal, Local, or Global) and we will surface the tiers that fit. Annual subscriptions, prepayment options, and discount codes.';
---
<BaseLayout
  title="Pricing | Lumecon"
  description={description}
  canonical="https://lumecon.ai/pricing"
  keywords="Lumecon pricing, Tribal Economic Impact pricing, Local Economic Impact pricing, Global Economic Impact pricing, economic impact analysis pricing, economic impact software cost, alternative data, IMPLAN alternative pricing, Implan price, RIMS II alternative pricing, REMI alternative pricing, Remi, AI for government, AI for tribes, Cedar AI pricing, annual subscription, transparent pricing"
  ogTitle="Lumecon pricing: pick your platform, then your tier"
  ogDescription={description}
>
  <Nav />
  <main class="pricing">

    <!-- 1. Hero band — always visible. Frames the pick-your-platform
              decision the visitor is about to make. -->
    <section class="editorial-band editorial-band--white pricing-hero">
      <div class="editorial-band__inner">
        <header class="pricing-hero__head">
          <p class="pricing-hero__kicker">Pricing</p>
          <h1 class="editorial-question reveal-soft hl-block hl-block--green">Pick the Lumecon platform that fits.</h1>
          <p class="pricing-hero__lede">Lumecon ships three platforms tuned to different work, plus a Consultant plan for firms delivering studies to outside clients. Pick the one that fits to see its tiers. We know your time is limited, so there&rsquo;s no demo call to unlock a number. The pricing is right here.</p>
          <p class="pricing-hero__aside">Annual subscriptions across every platform. Model updates, data refreshes, and workflow improvements land on every tier as they ship; you don&rsquo;t pay again to stay current.</p>
        </header>

        <!-- 2. Platform picker. Three tiles with the same icons the
                  homepage uses for each product. Tribal + Local are
                  active; Global is "Coming soon." Picking a tile
                  reveals the tier section below. -->
        <ul class="pricing-platform-grid" aria-label="Platform picker">
          {platforms.map((p) => (
            <li>
              <button
                type="button"
                class={`pricing-platform-tile${p.comingSoon ? ' pricing-platform-tile--coming-soon' : ''}${p.kind === 'service' ? ' pricing-platform-tile--service' : ''}`}
                data-platform-id={p.id}
                data-platform-slug={p.slug}
                data-platform-short={p.shortName}
                data-platform-kind={p.kind}
                data-platform-coming-soon={p.comingSoon ? 'true' : 'false'}
                data-price-starter={p.tierPrices?.starter ?? ''}
                data-price-standard={p.tierPrices?.standard ?? ''}
                data-price-leader={p.tierPrices?.leader ?? ''}
                data-price-flat={p.tierPrices?.flat ?? ''}
                aria-pressed="false"
              >
                <span class="pricing-platform-tile__icon" aria-hidden="true">
                  {p.iconId === 'tribal'     && <IconTribal />}
                  {p.iconId === 'local'      && <IconLocal />}
                  {p.iconId === 'global'     && <IconGlobal />}
                  {p.iconId === 'consultant' && <IconArborist />}
                </span>
                <span class="pricing-platform-tile__name">{p.name}</span>
                <span class="pricing-platform-tile__fit">{p.fitIf}</span>
                {p.comingSoon && <span class="pricing-platform-tile__tag">Coming soon</span>}
              </button>
            </li>
          ))}
        </ul>
        <p class="pricing-platform-prompt" data-platform-prompt>Pick a platform above to see its tiers.</p>
      </div>
    </section>

    <!-- 3. Tier grid — hidden until a platform is picked. Two
              variants live in the markup: the regional Sprout /
              Sapling / Tree grid (shown for Local / Tribal / Global)
              and the single-card Consultant (Arborist) grid. The
              picker script flips which one is visible based on the
              picked tile's data-platform-kind. -->
    <section class="editorial-band editorial-band--white pricing-tiers" data-platform-section hidden aria-labelledby="tiers-h2">
      <div class="editorial-band__inner">
        <header class="pricing-tiers__head">
          <p class="pricing-tiers__kicker">Tiers for <span data-platform-name>your platform</span></p>
          <h2 class="pricing-compare__h2 reveal-soft hl-block hl-block--gold-b" id="tiers-h2" data-tiers-headline>Three tiers. Priced annually.</h2>
          <p class="pricing-compare__deck" data-tiers-deck>Reservation, county, state, and national results are included at every tier. Cedar starts at Sapling. Cedar Grove arrives on Tree.</p>
        </header>

        <!-- Regional tier grid (Sprout / Sapling / Tree). Prices are
             populated dynamically from the picked platform's
             tierPrices in script below. Initial "$—" placeholder
             keeps the layout stable during the swap. -->
        <ul class="pricing-tier-grid" aria-label="Pricing tiers" data-tier-grid="regional">
          {tiers.map((t) => (
              <li
                class={`pricing-tier-card${t.featured ? ' pricing-tier-card--featured' : ''}`}
                data-tier-id={t.id}
                data-tier-annual={t.priceAnnual}
              >
                <!-- Plant illustration. Icon files in /public/tier-icons.
                     Mapped by stable schema id (starter / standard / leader)
                     so renames of the user-facing name don't break the
                     mapping. The grow-out-of-the-ground animation lives
                     on .pricing-tier-card__icon in pricing.css with
                     nth-child stagger so the row reads as time-lapse
                     growth left to right. alt="" because the name <h3>
                     directly below already labels the tier. -->
                <img
                  class="pricing-tier-card__icon"
                  src={t.id === 'starter' ? '/tier-icons/sprout.svg' : t.id === 'standard' ? '/tier-icons/sapling.svg' : '/tier-icons/tree.svg'}
                  alt=""
                  aria-hidden="true"
                  width="200"
                  height="200"
                  loading="lazy"
                />
                <header class="pricing-tier-card__head">
                  <h3 class="pricing-tier-card__name">{t.name}</h3>
                  {t.featured
                    ? <span class="pricing-tier-card__tag">Most complete</span>
                    : null}
                </header>

                <div class="pricing-tier-card__price-row">
                  <span class="pricing-tier-card__price" data-tier-price-slot={t.id}>$—</span>
                  <span class="pricing-tier-card__period">/ year, flat</span>
                </div>

                <p class="pricing-tier-card__tagline">{t.tagline}</p>

                <ul class="pricing-tier-card__highlights" aria-label={`${t.name} highlights`}>
                  {t.highlights.map((h) => <li>{h}</li>)}
                </ul>

                <details class="pricing-tier-card__details">
                  <summary data-analytics={`pricing-${t.name}-details`}>Full capability list</summary>
                  <ul>
                    {t.features.map((f) => {
                      if (typeof f === 'string') return <li>{f}</li>;
                      return <li class="is-accent-gold">{f.text}</li>;
                    })}
                  </ul>
                </details>

                {t.note && <p class="pricing-tier-card__note">{t.note}</p>}

                <div class="pricing-tier-card__cta">
                  <a
                    class="btn"
                    href={`/signup?tier=${t.id}`}
                    data-analytics={`pricing-${t.name}-request-access`}
                    data-cta-base={`/signup?tier=${t.id}`}
                  >
                    Sign up
                  </a>
                </div>
              </li>
          ))}
        </ul>

        <!-- Consultant tier grid (single Arborist card). Hidden by
             default; shown only when the picked platform's kind is
             'service'. The flat price slot is filled from the
             Consultant tile's data-price-flat. -->
        <ul class="pricing-tier-grid pricing-tier-grid--single" aria-label="Pricing tiers" data-tier-grid="consultant" hidden>
          <li class="pricing-tier-card pricing-tier-card--featured" data-tier-id="arborist">
            <img
              class="pricing-tier-card__icon"
              src="/tier-icons/arborist.svg"
              alt=""
              aria-hidden="true"
              width="200"
              height="200"
              loading="lazy"
            />
            <header class="pricing-tier-card__head">
              <h3 class="pricing-tier-card__name">{CONSULTANT_TIER.name}</h3>
              <span class="pricing-tier-card__tag">For consultants</span>
            </header>

            <div class="pricing-tier-card__price-row">
              <span class="pricing-tier-card__price" data-tier-price-slot="flat">$—</span>
              <span class="pricing-tier-card__period">/ year, flat</span>
            </div>

            <p class="pricing-tier-card__tagline">{CONSULTANT_TIER.tagline}</p>

            <ul class="pricing-tier-card__highlights" aria-label="Arborist highlights">
              {CONSULTANT_TIER.highlights.map((h) => <li>{h}</li>)}
            </ul>

            <details class="pricing-tier-card__details">
              <summary data-analytics="pricing-Arborist-details">Full capability list</summary>
              <ul>
                {CONSULTANT_TIER.features.map((f) => <li>{f}</li>)}
              </ul>
            </details>

            <div class="pricing-tier-card__cta">
              <a
                class="btn"
                href="/signup?tier=arborist&platform=consultant"
                data-analytics="pricing-Arborist-request-access"
                data-cta-base="/signup?tier=arborist&platform=consultant"
              >
                Sign up
              </a>
            </div>
          </li>
        </ul>

        <!-- Toolbox add-on — sits under the tier grid for regional
             platforms only. Hidden whenever the picked platform's
             kind is 'service' (Consultant), and always hidden when
             no platform is picked. -->
        <aside class="pricing-addon" data-addon="toolbox" hidden aria-label="Toolbox add-on">
          <div class="pricing-addon__card">
            <img
              class="pricing-addon__icon"
              src="/tier-icons/toolbox.svg"
              alt=""
              aria-hidden="true"
              width="200"
              height="200"
              loading="lazy"
            />
            <div class="pricing-addon__body">
              <header class="pricing-addon__head">
                <p class="pricing-addon__eyebrow">Add-on</p>
                <h3 class="pricing-addon__name">{TOOLBOX_ADDON.name}</h3>
                <div class="pricing-addon__price-row">
                  <span class="pricing-addon__price">{TOOLBOX_ADDON.priceLabel}</span>
                  <span class="pricing-addon__period">{TOOLBOX_ADDON.period}</span>
                </div>
              </header>
              <p class="pricing-addon__tagline">{TOOLBOX_ADDON.tagline}</p>
              <ul class="pricing-addon__highlights" aria-label="Toolbox highlights">
                {TOOLBOX_ADDON.highlights.map((h) => <li>{h}</li>)}
              </ul>
              <details class="pricing-addon__details">
                <summary data-analytics="pricing-Toolbox-details">What&rsquo;s included</summary>
                <ul>
                  {TOOLBOX_ADDON.features.map((f) => <li>{f}</li>)}
                </ul>
              </details>
              <p class="pricing-addon__note">{TOOLBOX_ADDON.note}</p>
              <div class="pricing-addon__cta">
                <a
                  class="btn"
                  href={`mailto:${site.email}?subject=${encodeURIComponent('Add Toolbox to my subscription')}`}
                  data-analytics="pricing-Toolbox-add"
                  data-cta-base={`mailto:${site.email}?subject=${encodeURIComponent('Add Toolbox to my subscription')}`}
                >
                  Add Toolbox to a subscription
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- 4. Comparison band — same gating as the tier grid, plus an
              additional `data-regional-only` flag the script hides
              when the picked platform is the Consultant offering
              (there's only one tier to compare against itself). -->
    <section class="editorial-band editorial-band--white pricing-compare" data-platform-section data-regional-only hidden aria-labelledby="compare-h2">
      <div class="editorial-band__inner">
        <p class="pricing-compare__kicker">Compare the tiers</p>
        <h2 class="pricing-compare__h2 reveal-soft hl-block hl-block--b" id="compare-h2">The full picture, one row at a time.</h2>
        <p class="pricing-compare__deck">No clever section names or hidden &ldquo;contact us for details&rdquo; lines. What each tier actually includes.</p>

        <div class="pricing-compare__table-wrap" role="region" tabindex="0" aria-label="Tier comparison table, scroll horizontally on small screens">
          <table>
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col">Sprout</th>
                <th scope="col">Sapling</th>
                <th scope="col" class="pricing-compare__featured-head">Tree</th>
              </tr>
            </thead>
            <tbody>
              {COMPARISON_ROWS.map((row) => (
                <tr>
                  <th scope="row" class="pricing-compare__row-label">{row.capability}</th>
                  <td data-value={row.sprout === 'yes' ? 'yes' : row.sprout === 'none' ? 'none' : row.sprout === 'soon' ? 'soon' : 'text'}>
                    {row.sprout === 'yes' ? 'Included' : row.sprout === 'none' ? 'Not included' : row.sprout === 'soon' ? 'Coming soon' : row.sprout}
                  </td>
                  <td data-value={row.sapling === 'yes' ? 'yes' : row.sapling === 'none' ? 'none' : row.sapling === 'soon' ? 'soon' : 'text'}>
                    {row.sapling === 'yes' ? 'Included' : row.sapling === 'none' ? 'Not included' : row.sapling === 'soon' ? 'Coming soon' : row.sapling}
                  </td>
                  <td class="pricing-compare__featured" data-value={row.tree === 'yes' ? 'yes' : row.tree === 'none' ? 'none' : row.tree === 'soon' ? 'soon' : 'text'}>
                    {row.tree === 'yes' ? 'Included' : row.tree === 'none' ? 'Not included' : row.tree === 'soon' ? 'Coming soon' : row.tree}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- 5. Discount-code band — gated. The discount math is symbolic
              while prices are TBD; the input still validates the
              code and the status line confirms the percentage that
              will apply when pricing lands. -->
    <section class="editorial-band editorial-band--cream pricing-support" data-platform-section hidden aria-labelledby="support-h2">
      <div class="editorial-band__inner">
        <p class="pricing-support__kicker">Discount code</p>
        <div class="discount-code-panel">
          <h2 class="discount-code-panel__title" id="support-h2">Met us at an event?</h2>
          <p class="discount-code-panel__copy">Drop in your conference, pilot, or testing code. We&rsquo;ll apply it when you request access.</p>
          <form class="discount-code-panel__form" data-discount-form autocomplete="off">
            <div class="discount-code-panel__field">
              <input
                class="discount-code-panel__input"
                type="text"
                name="code"
                inputmode="text"
                autocapitalize="characters"
                autocorrect="off"
                spellcheck="false"
                maxlength="32"
                placeholder="e.g. CONF10"
                aria-describedby="discount-status"
                data-discount-input
              />
              <button type="submit" class="btn discount-code-panel__apply">Apply</button>
            </div>
            <p class="discount-code-panel__status" id="discount-status" data-discount-status>Conference, pilot, and testing codes are supported.</p>
          </form>
        </div>
      </div>
    </section>

    <!-- 6. Terms band — gated. Same prepay / data / price-change
              language regardless of platform. -->
    <section class="editorial-band editorial-band--navy pricing-terms" data-platform-section hidden aria-labelledby="terms-h2">
      <div class="editorial-band__inner">
        <header class="pricing-terms__head">
          <h2 class="pricing-terms__h2 reveal-soft hl-block hl-block--green-b" id="terms-h2">The fine print, unbolded.</h2>
          <a class="btn" href={`mailto:${site.email}?subject=Walkthrough`} data-analytics="pricing-request-walkthrough">Request a walkthrough</a>
        </header>

        <div class="pricing-terms__grid">
          <div class="pricing-terms__block">
            <h3>Prepay, save.</h3>
            <ul>
              {ANNUAL_SUBSCRIPTION_DISCOUNTS.map((d) => (
                <li>
                  <strong>{d.label}:</strong>{' '}
                  {d.discountPct === 0 ? 'standard annual subscription' : `${d.discountPct}% off`}
                  {d.note ? ` (${d.note})` : ''}
                </li>
              ))}
            </ul>
          </div>
          <div class="pricing-terms__block">
            <h3>You own your exports.</h3>
            <p>Analyses, assumptions, and tables come out in standard formats. Your data stays yours, and Lumecon does not sell, syndicate, or use your raw records to train models. Cross-study learning runs on anonymized, aggregated signals only.</p>
          </div>
          <div class="pricing-terms__block">
            <h3>Price changes, with notice.</h3>
            <p>Rate changes are posted at least 60 days before they take effect. Prepaid subscribers keep their rate through the end of the prepaid term.</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  /* Two concerns in one script:
       1. Platform picker — clicking an active tile flips the
          data-platform-section blocks visible, threads the chosen
          platform's name into tier CTAs + the kicker, and emits a
          telemetry event. Picking the same tile again deselects it.
       2. Discount code — validates against PRODUCT_DISCOUNT_CODES,
          updates the status line, and emits pricing.discount_applied.
          With prices set to 0 in the data file, the per-card
          discounted-price line is suppressed; the status line is
          where the visitor reads the confirmation. */
  import { getProductDiscountCode, type DiscountCode } from '../data/pricing';
  import { trackEvent } from '../lib/observability';

  function setStatus(el: HTMLElement | null, text: string, variant: 'info' | 'valid' | 'error'): void {
    if (!el) return;
    el.textContent = text;
    el.classList.remove('discount-code-panel__status--valid', 'discount-code-panel__status--error');
    if (variant === 'valid') el.classList.add('discount-code-panel__status--valid');
    if (variant === 'error') el.classList.add('discount-code-panel__status--error');
  }

  /** USD formatter — drops cents on whole-thousand amounts, prints
   *  "$12.5K" for half-thousand amounts. Mirrors the server-side
   *  `fmtUSD` so SSR and client-side formatting stay in sync. */
  function fmtUSD(n: number): string {
    if (!Number.isFinite(n) || n <= 0) return '$—';
    if (n % 1000 === 0) return `$${(n / 1000).toFixed(0)}K`;
    return `$${(n / 1000).toLocaleString('en-US', { maximumFractionDigits: 1 })}K`;
  }

  /** Picks the right tier grid for the platform kind, populates each
   *  tier's price from the tile's per-tier price data, and shows /
   *  hides the toolbox + comparison sections accordingly. */
  function applyPlatformToTiers(tile: HTMLButtonElement): void {
    const kind = tile.dataset.platformKind || 'regional';
    const regionalGrid = document.querySelector<HTMLElement>('[data-tier-grid="regional"]');
    const consultantGrid = document.querySelector<HTMLElement>('[data-tier-grid="consultant"]');
    const toolbox = document.querySelector<HTMLElement>('[data-addon="toolbox"]');
    const regionalOnlySections = document.querySelectorAll<HTMLElement>('[data-regional-only]');

    if (kind === 'service') {
      // Consultant: single tier card, no toolbox, no comparison.
      if (regionalGrid) regionalGrid.hidden = true;
      if (consultantGrid) consultantGrid.hidden = false;
      if (toolbox) toolbox.hidden = true;
      regionalOnlySections.forEach((s) => { s.hidden = true; });
      const flat = Number(tile.dataset.priceFlat || 0);
      const flatSlot = document.querySelector<HTMLElement>('[data-tier-price-slot="flat"]');
      if (flatSlot) flatSlot.textContent = fmtUSD(flat);
      return;
    }

    // Regional: Sprout / Sapling / Tree grid + toolbox + comparison.
    if (regionalGrid) regionalGrid.hidden = false;
    if (consultantGrid) consultantGrid.hidden = true;
    if (toolbox) toolbox.hidden = false;
    regionalOnlySections.forEach((s) => { s.hidden = false; });

    const prices: Record<string, number> = {
      starter:  Number(tile.dataset.priceStarter  || 0),
      standard: Number(tile.dataset.priceStandard || 0),
      leader:   Number(tile.dataset.priceLeader   || 0),
    };
    Object.entries(prices).forEach(([tierId, price]) => {
      const slot = document.querySelector<HTMLElement>(`[data-tier-price-slot="${tierId}"]`);
      if (slot) slot.textContent = fmtUSD(price);
    });
  }

  function showSections(show: boolean, tile: HTMLButtonElement | null): void {
    const sections = document.querySelectorAll<HTMLElement>('[data-platform-section]');
    sections.forEach((s) => { s.hidden = !show; });
    const platformShort = tile?.dataset.platformShort || '';
    const platformKind  = tile?.dataset.platformKind  || 'regional';
    const platformName  = platformKind === 'service'
      ? 'the Consultant plan'
      : `${platformShort} Economic Impact`;
    document.querySelectorAll<HTMLElement>('[data-platform-name]').forEach((el) => {
      el.textContent = show ? platformName : 'your platform';
    });

    /* Headline + deck swap for service vs regional platforms. */
    const headline = document.querySelector<HTMLElement>('[data-tiers-headline]');
    const deck     = document.querySelector<HTMLElement>('[data-tiers-deck]');
    if (show && platformKind === 'service') {
      if (headline) headline.textContent = 'One tier. Two projects. One fiscal year.';
      if (deck) deck.textContent = 'Built for consultants delivering studies to outside clients. All geographies included. Cedar and the Toolbox add-on are not part of this plan.';
    } else if (show) {
      if (headline) headline.textContent = 'Three tiers. Priced annually.';
      if (deck) deck.textContent = 'Reservation, county, state, and national results are included at every tier. Cedar starts at Sapling. Cedar Grove arrives on Tree.';
    }

    if (show && tile) applyPlatformToTiers(tile);

    /* Re-trigger the sprout/sapling/tree grow-from-ground
       animation each time the tier section reveals. The icons'
       CSS animation only fires on initial render, so without this
       reset, a visitor who picks a platform after the page has
       loaded never sees the staggered grow. Strip the inline
       animation, force a reflow, then put it back — the classic
       restart-animation trick. */
    if (show) {
      const icons = document.querySelectorAll<HTMLElement>('.pricing-tier-card__icon');
      icons.forEach((icon) => {
        icon.style.animation = 'none';
        // Force layout flush so the browser registers the reset.
        void icon.offsetHeight;
        icon.style.animation = '';
      });
    }
    /* Bake the platform short name into each tier card's CTA.
       Active-tier CTAs route to /signup?tier=X and pick up the
       chosen platform as &platform=Y so the signup page can
       greet the visitor with what they picked. Notify-me CTAs
       stay as mailto and append "for X" to the email subject. */
    document.querySelectorAll<HTMLAnchorElement>('.pricing-tier-card__cta a, .pricing-addon__cta a').forEach((cta) => {
      const base = cta.dataset.ctaBase;
      if (!base) return;
      if (!show || !platformShort) { cta.setAttribute('href', base); return; }
      if (base.startsWith('/signup')) {
        const sep = base.includes('?') ? '&' : '?';
        // Don't double-append platform= if the base already has one.
        cta.setAttribute('href', /[?&]platform=/.test(base) ? base : `${base}${sep}platform=${platformShort.toLowerCase()}`);
      } else {
        const sep = base.includes('?') ? '%20for%20' : '?subject=';
        cta.setAttribute('href', `${base}${sep}${encodeURIComponent(platformShort)}`);
      }
    });
  }

  function setupPlatformPicker(): void {
    const tiles = document.querySelectorAll<HTMLButtonElement>('.pricing-platform-tile');
    const prompt = document.querySelector<HTMLElement>('[data-platform-prompt]');
    let active: HTMLButtonElement | null = null;

    tiles.forEach((tile) => {
      tile.addEventListener('click', () => {
        if (tile.dataset.platformComingSoon === 'true') {
          if (prompt) prompt.textContent = "Global is launching after Local and Tribal stabilize. Pick Local or Tribal to see tiers; email contact@lumecon.ai to be notified when Global ships.";
          trackEvent('pricing.platform_coming_soon_click', { platformId: tile.dataset.platformId });
          return;
        }

        const isReselect = active === tile;
        if (active) {
          active.classList.remove('is-active');
          active.setAttribute('aria-pressed', 'false');
        }

        if (isReselect) {
          active = null;
          showSections(false, null);
          if (prompt) prompt.textContent = 'Pick a platform above to see its tiers.';
          return;
        }

        active = tile;
        tile.classList.add('is-active');
        tile.setAttribute('aria-pressed', 'true');
        const shortName = tile.dataset.platformShort || '';
        const platformId = tile.dataset.platformId || '';
        const kind = tile.dataset.platformKind || 'regional';
        if (prompt) {
          prompt.textContent = kind === 'service'
            ? `Showing the ${shortName} plan. Pick another platform to switch.`
            : `Showing tiers for ${shortName} Economic Impact. Pick another platform to switch.`;
        }
        showSections(true, tile);
        trackEvent('pricing.platform_picked', { platformId, platformShort: shortName, kind });

        /* Scroll the tier section into view so the visitor doesn't
           have to hunt for what just appeared. requestAnimationFrame
           lets the hidden=false flip paint first. */
        requestAnimationFrame(() => {
          const next = document.querySelector<HTMLElement>('[data-platform-section]:not([hidden])');
          next?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    });
  }

  function setupDiscount(): void {
    const form = document.querySelector<HTMLFormElement>('[data-discount-form]');
    if (!form) return;
    const input = form.querySelector<HTMLInputElement>('[data-discount-input]');
    const status = form.querySelector<HTMLElement>('[data-discount-status]');
    if (!input || !status) return;

    const handle = (raw: string): void => {
      const trimmed = (raw || '').trim();
      if (!trimmed) {
        setStatus(status, 'Conference, pilot, and testing codes are supported.', 'info');
        return;
      }
      const match: DiscountCode | null = getProductDiscountCode(trimmed);
      if (!match) {
        setStatus(status, 'Code not recognized.', 'error');
        return;
      }
      /* Prices aren't locked yet (priceAnnual is 0 in the data file),
         so we describe the discount that will apply when pricing
         lands instead of computing a dollar amount. */
      setStatus(status, `${match.label}: ${match.discountPct}% off annual pricing, applied when pricing is finalized.`, 'valid');
      trackEvent('pricing.discount_applied', { code: match.code, discountPct: match.discountPct });
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      handle(input.value);
    });
    input.addEventListener('input', () => handle(input.value));
  }

  function setup(): void {
    setupPlatformPicker();
    setupDiscount();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
