---
/**
 * /pricing — platform picker first, tiers second.
 *
 * The visitor flow:
 *   1. Land on the page.
 *   2. Pick the platform that matches their work — Tribal, Local,
 *      or Global. Global is gated as "Coming soon" at v1.
 *   3. Tier grid + comparison table + discount band reveal beneath
 *      the platform picker. The picked platform's name threads
 *      through tier CTAs and the comparison-table heading so the
 *      visitor sees their context echoed back to them.
 *
 * Why gate the tiers behind a platform pick: the three platforms
 * serve very different audiences (tribal nations vs. municipalities
 * vs. cross-border analysis), and showing every tier on every
 * platform at once would force a tribal-nation buyer to mentally
 * filter out "this isn't for me" rows. Gating cleans that up.
 *
 * Dollar figures are intentionally hidden — finance hasn't locked
 * prices yet and we don't want placeholder numbers leaking out as
 * if they were real. Each tier card renders "Pricing TBD" until
 * src/data/pricing.ts has real prices populated.
 *
 * Ported from the spec written against
 * `src/pages/Pricing.jsx` on branch
 * `claude/explore-lumecon-foundation-BDWKd`. That branch isn't
 * fetchable from this isolated working tree, so this is a from-spec
 * implementation in Astro rather than a JSX-to-Astro port.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import IconTribal from '../components/icons/IconTribal.astro';
import IconLocal from '../components/icons/IconLocal.astro';
import IconGlobal from '../components/icons/IconGlobal.astro';
import { site } from '../config';
import {
  PUBLIC_PRICING_TIERS,
  COMPARISON_ROWS,
  ANNUAL_SUBSCRIPTION_DISCOUNTS,
  PRODUCT_LINES,
} from '../data/pricing';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import '../styles/pricing.css';

const tiers = PUBLIC_PRICING_TIERS;
const platforms = PRODUCT_LINES;

const description = 'Pricing tiers for Lumecon. Pick your platform — Tribal, Local, or Global — and we will surface the tiers that fit. Annual subscriptions, prepayment options, and discount codes.';
---
<BaseLayout
  title="Pricing | Lumecon"
  description={description}
  canonical="https://lumecon.ai/pricing"
  keywords="Lumecon pricing, Tribal Economic Impact pricing, Local Economic Impact pricing, Global Economic Impact pricing, economic impact analysis pricing, IMPLAN alternative pricing, RIMS II alternative pricing, REMI alternative pricing, Cedar AI pricing, annual subscription"
  ogTitle="Lumecon pricing: pick your platform, then your tier"
  ogDescription={description}
>
  <Nav />
  <main class="pricing">

    <!-- 1. Hero band — always visible. Frames the pick-your-platform
              decision the visitor is about to make. -->
    <section class="editorial-band editorial-band--white pricing-hero">
      <div class="editorial-band__inner">
        <header class="pricing-hero__head">
          <h1 class="editorial-question">Pick the platform that fits.</h1>
          <p class="pricing-hero__lede">Lumecon runs as three platforms tuned to different work. Pick the one that matches yours — we&rsquo;ll surface the tiers from there.</p>
          <p class="pricing-hero__aside">Annual subscriptions across every platform. Model updates, data refreshes, and workflow improvements land on every tier as they ship; you don&rsquo;t pay again to stay current.</p>
        </header>

        <!-- 2. Platform picker. Three tiles with the same icons the
                  homepage uses for each product. Tribal + Local are
                  active; Global is "Coming soon." Picking a tile
                  reveals the tier section below. -->
        <ul class="pricing-platform-grid" aria-label="Platform picker">
          {platforms.map((p) => (
            <li>
              <button
                type="button"
                class={`pricing-platform-tile${p.comingSoon ? ' pricing-platform-tile--coming-soon' : ''}`}
                data-platform-id={p.id}
                data-platform-short={p.shortName}
                data-platform-coming-soon={p.comingSoon ? 'true' : 'false'}
                aria-pressed="false"
              >
                <span class="pricing-platform-tile__icon" aria-hidden="true">
                  {p.iconId === 'tribal' && <IconTribal />}
                  {p.iconId === 'local'  && <IconLocal />}
                  {p.iconId === 'global' && <IconGlobal />}
                </span>
                <span class="pricing-platform-tile__name">{p.name}</span>
                <span class="pricing-platform-tile__fit">{p.fitIf}</span>
                {p.comingSoon && <span class="pricing-platform-tile__tag">Coming soon</span>}
              </button>
            </li>
          ))}
        </ul>
        <p class="pricing-platform-prompt" data-platform-prompt>Pick a platform above to see its tiers.</p>
      </div>
    </section>

    <!-- 3. Tier grid — hidden until a platform is picked. The
              `data-platform-section` flag is flipped by the script
              below when the visitor clicks an active tile. -->
    <section class="editorial-band editorial-band--white pricing-tiers" data-platform-section hidden aria-labelledby="tiers-h2">
      <div class="editorial-band__inner">
        <header class="pricing-tiers__head">
          <p class="pricing-tiers__kicker">Tiers for <span data-platform-name>your platform</span></p>
          <h2 class="pricing-compare__h2" id="tiers-h2">Three tiers. Priced annually.</h2>
          <p class="pricing-compare__deck">Reservation, state, and national results are included at every tier. Cedar starts at Sapling. Cedar Grove is part of Tree.</p>
        </header>

        <ul class="pricing-tier-grid" aria-label="Pricing tiers">
          {tiers.map((t) => {
            const subject = encodeURIComponent(t.comingSoon ? `Notify me when ${t.name} ships` : t.ctaSubject);
            return (
              <li
                class={`pricing-tier-card${t.featured ? ' pricing-tier-card--featured' : ''}${t.comingSoon ? ' pricing-tier-card--coming-soon' : ''}`}
                data-tier-id={t.id}
                data-tier-annual={t.priceAnnual}
              >
                <!-- Plant illustration. Icon files in /public/tier-icons.
                     Mapped by stable schema id (starter / standard / leader)
                     so renames of the user-facing name don't break the
                     mapping. The grow-out-of-the-ground animation lives
                     on .pricing-tier-card__icon in pricing.css with
                     nth-child stagger so the row reads as time-lapse
                     growth left to right. alt="" because the name <h3>
                     directly below already labels the tier. -->
                <img
                  class="pricing-tier-card__icon"
                  src={t.id === 'starter' ? '/tier-icons/sprout.svg' : t.id === 'standard' ? '/tier-icons/sapling.svg' : '/tier-icons/tree.svg'}
                  alt=""
                  aria-hidden="true"
                  width="200"
                  height="200"
                  loading="lazy"
                />
                <header class="pricing-tier-card__head">
                  <h3 class="pricing-tier-card__name">{t.name}</h3>
                  {t.comingSoon
                    ? <span class="pricing-tier-card__tag">Coming soon</span>
                    : t.featured
                      ? <span class="pricing-tier-card__tag">Most complete</span>
                      : <span class="pricing-tier-card__tag">v1</span>}
                </header>

                <div class="pricing-tier-card__price-row">
                  {t.price
                    ? <>
                        <span class="pricing-tier-card__price">{t.price}</span>
                        <span class="pricing-tier-card__period">{t.period}</span>
                      </>
                    : <span class="pricing-tier-card__price-tbd">Pricing TBD</span>}
                </div>

                <p class="pricing-tier-card__tagline">{t.tagline}</p>

                <ul class="pricing-tier-card__highlights" aria-label={`${t.name} highlights`}>
                  {t.highlights.map((h) => <li>{h}</li>)}
                </ul>

                <details class="pricing-tier-card__details">
                  <summary data-analytics={`pricing-${t.name}-details`}>Full capability list</summary>
                  <ul>
                    {t.features.map((f) => {
                      if (typeof f === 'string') return <li>{f}</li>;
                      return <li class="is-accent-gold">{f.text}</li>;
                    })}
                  </ul>
                </details>

                {t.note && <p class="pricing-tier-card__note">{t.note}</p>}

                <div class="pricing-tier-card__cta">
                  <a
                    class={t.comingSoon ? 'btn btn--ghost' : 'btn'}
                    href={`mailto:${site.email}?subject=${subject}`}
                    data-analytics={`pricing-${t.name}-request-access`}
                    data-cta-base={`mailto:${site.email}?subject=${subject}`}
                  >
                    {t.comingSoon ? 'Notify me' : 'Request access'}
                  </a>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- 4. Comparison band — same gating as the tier grid. -->
    <section class="editorial-band editorial-band--white pricing-compare" data-platform-section hidden aria-labelledby="compare-h2">
      <div class="editorial-band__inner">
        <p class="pricing-compare__kicker">Compare the tiers</p>
        <h2 class="pricing-compare__h2" id="compare-h2">The full picture, one row at a time.</h2>
        <p class="pricing-compare__deck">No clever section names or hidden &ldquo;contact us for details&rdquo; lines. What each tier actually includes.</p>

        <div class="pricing-compare__table-wrap" role="region" tabindex="0" aria-label="Tier comparison table, scroll horizontally on small screens">
          <table>
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col">Sprout</th>
                <th scope="col">Sapling</th>
                <th scope="col" class="pricing-compare__featured-head">Tree</th>
              </tr>
            </thead>
            <tbody>
              {COMPARISON_ROWS.map((row) => (
                <tr>
                  <th scope="row" class="pricing-compare__row-label">{row.capability}</th>
                  <td data-value={row.sprout === 'yes' ? 'yes' : row.sprout === 'none' ? 'none' : row.sprout === 'soon' ? 'soon' : 'text'}>
                    {row.sprout === 'yes' ? 'Included' : row.sprout === 'none' ? '—' : row.sprout === 'soon' ? 'Coming soon' : row.sprout}
                  </td>
                  <td data-value={row.sapling === 'yes' ? 'yes' : row.sapling === 'none' ? 'none' : row.sapling === 'soon' ? 'soon' : 'text'}>
                    {row.sapling === 'yes' ? 'Included' : row.sapling === 'none' ? '—' : row.sapling === 'soon' ? 'Coming soon' : row.sapling}
                  </td>
                  <td class="pricing-compare__featured" data-value={row.tree === 'yes' ? 'yes' : row.tree === 'none' ? 'none' : row.tree === 'soon' ? 'soon' : 'text'}>
                    {row.tree === 'yes' ? 'Included' : row.tree === 'none' ? '—' : row.tree === 'soon' ? 'Coming soon' : row.tree}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- 5. Discount-code band — gated. The discount math is symbolic
              while prices are TBD; the input still validates the
              code and the status line confirms the percentage that
              will apply when pricing lands. -->
    <section class="editorial-band editorial-band--cream pricing-support" data-platform-section hidden aria-labelledby="support-h2">
      <div class="editorial-band__inner">
        <p class="pricing-support__kicker">Discount code</p>
        <div class="discount-code-panel">
          <h2 class="discount-code-panel__title" id="support-h2">Met us at an event?</h2>
          <p class="discount-code-panel__copy">Drop in your conference, pilot, or testing code. We&rsquo;ll apply it when you request access.</p>
          <form class="discount-code-panel__form" data-discount-form autocomplete="off">
            <div class="discount-code-panel__field">
              <input
                class="discount-code-panel__input"
                type="text"
                name="code"
                inputmode="text"
                autocapitalize="characters"
                autocorrect="off"
                spellcheck="false"
                maxlength="32"
                placeholder="e.g. CONF10"
                aria-describedby="discount-status"
                data-discount-input
              />
              <button type="submit" class="btn discount-code-panel__apply">Apply</button>
            </div>
            <p class="discount-code-panel__status" id="discount-status" data-discount-status>Conference, pilot, and testing codes are supported.</p>
          </form>
        </div>
      </div>
    </section>

    <!-- 6. Terms band — gated. Same prepay / data / price-change
              language regardless of platform. -->
    <section class="editorial-band editorial-band--navy pricing-terms" data-platform-section hidden aria-labelledby="terms-h2">
      <div class="editorial-band__inner">
        <header class="pricing-terms__head">
          <h2 class="pricing-terms__h2" id="terms-h2">The fine print, unbolded.</h2>
          <a class="btn" href={`mailto:${site.email}?subject=Walkthrough`} data-analytics="pricing-request-walkthrough">Request a walkthrough</a>
        </header>

        <div class="pricing-terms__grid">
          <div class="pricing-terms__block">
            <h3>Prepay, save.</h3>
            <ul>
              {ANNUAL_SUBSCRIPTION_DISCOUNTS.map((d) => (
                <li>
                  <strong>{d.label}:</strong>{' '}
                  {d.discountPct === 0 ? 'standard annual subscription' : `${d.discountPct}% off`}
                  {d.note ? ` (${d.note})` : ''}
                </li>
              ))}
            </ul>
          </div>
          <div class="pricing-terms__block">
            <h3>You own your exports.</h3>
            <p>Analyses, assumptions, and tables come out in standard formats. Your data stays yours; Lumecon does not resell, syndicate, or train on it.</p>
          </div>
          <div class="pricing-terms__block">
            <h3>Price changes, with notice.</h3>
            <p>Rate changes are posted at least 60 days before they take effect. Prepaid subscribers keep their rate through the end of the prepaid term.</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  /* Two concerns in one script:
       1. Platform picker — clicking an active tile flips the
          data-platform-section blocks visible, threads the chosen
          platform's name into tier CTAs + the kicker, and emits a
          telemetry event. Picking the same tile again deselects it.
       2. Discount code — validates against PRODUCT_DISCOUNT_CODES,
          updates the status line, and emits pricing.discount_applied.
          With prices set to 0 in the data file, the per-card
          discounted-price line is suppressed; the status line is
          where the visitor reads the confirmation. */
  import { getProductDiscountCode, type DiscountCode } from '../data/pricing';
  import { trackEvent } from '../lib/observability';

  function setStatus(el: HTMLElement | null, text: string, variant: 'info' | 'valid' | 'error'): void {
    if (!el) return;
    el.textContent = text;
    el.classList.remove('discount-code-panel__status--valid', 'discount-code-panel__status--error');
    if (variant === 'valid') el.classList.add('discount-code-panel__status--valid');
    if (variant === 'error') el.classList.add('discount-code-panel__status--error');
  }

  function showSections(show: boolean, platformShort: string): void {
    const sections = document.querySelectorAll<HTMLElement>('[data-platform-section]');
    sections.forEach((s) => { s.hidden = !show; });
    document.querySelectorAll<HTMLElement>('[data-platform-name]').forEach((el) => {
      el.textContent = show ? `${platformShort} Economic Impact` : 'your platform';
    });
    /* Bake the platform short name into each tier card's CTA so the
       request goes in with the right subject ("Sprout tier — Tribal"
       vs "Sprout tier — Local"). */
    document.querySelectorAll<HTMLAnchorElement>('.pricing-tier-card__cta a').forEach((cta) => {
      const base = cta.dataset.ctaBase;
      if (!base) return;
      if (show) {
        const sep = base.includes('?') ? '%20%E2%80%94%20' : '?subject=';
        cta.setAttribute('href', `${base}${sep}${encodeURIComponent(platformShort)}`);
      } else {
        cta.setAttribute('href', base);
      }
    });
  }

  function setupPlatformPicker(): void {
    const tiles = document.querySelectorAll<HTMLButtonElement>('.pricing-platform-tile');
    const prompt = document.querySelector<HTMLElement>('[data-platform-prompt]');
    let active: HTMLButtonElement | null = null;

    tiles.forEach((tile) => {
      tile.addEventListener('click', () => {
        if (tile.dataset.platformComingSoon === 'true') {
          if (prompt) prompt.textContent = "Global is launching after Local and Tribal stabilize. Pick Local or Tribal to see tiers; email contact@lumecon.ai to be notified when Global ships.";
          trackEvent('pricing.platform_coming_soon_click', { platformId: tile.dataset.platformId });
          return;
        }

        const isReselect = active === tile;
        if (active) {
          active.classList.remove('is-active');
          active.setAttribute('aria-pressed', 'false');
        }

        if (isReselect) {
          active = null;
          showSections(false, '');
          if (prompt) prompt.textContent = 'Pick a platform above to see its tiers.';
          return;
        }

        active = tile;
        tile.classList.add('is-active');
        tile.setAttribute('aria-pressed', 'true');
        const shortName = tile.dataset.platformShort || '';
        const platformId = tile.dataset.platformId || '';
        if (prompt) prompt.textContent = `Showing tiers for ${shortName} Economic Impact. Pick another platform to switch.`;
        showSections(true, shortName);
        trackEvent('pricing.platform_picked', { platformId, platformShort: shortName });

        /* Scroll the tier section into view so the visitor doesn't
           have to hunt for what just appeared. requestAnimationFrame
           lets the hidden=false flip paint first. */
        requestAnimationFrame(() => {
          const next = document.querySelector<HTMLElement>('[data-platform-section]:not([hidden])');
          next?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    });
  }

  function setupDiscount(): void {
    const form = document.querySelector<HTMLFormElement>('[data-discount-form]');
    if (!form) return;
    const input = form.querySelector<HTMLInputElement>('[data-discount-input]');
    const status = form.querySelector<HTMLElement>('[data-discount-status]');
    if (!input || !status) return;

    const handle = (raw: string): void => {
      const trimmed = (raw || '').trim();
      if (!trimmed) {
        setStatus(status, 'Conference, pilot, and testing codes are supported.', 'info');
        return;
      }
      const match: DiscountCode | null = getProductDiscountCode(trimmed);
      if (!match) {
        setStatus(status, 'Code not recognized.', 'error');
        return;
      }
      /* Prices aren't locked yet (priceAnnual is 0 in the data file),
         so we describe the discount that will apply when pricing
         lands instead of computing a dollar amount. */
      setStatus(status, `${match.label}: ${match.discountPct}% off annual pricing — applied when pricing is finalized.`, 'valid');
      trackEvent('pricing.discount_applied', { code: match.code, discountPct: match.discountPct });
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      handle(input.value);
    });
    input.addEventListener('input', () => handle(input.value));
  }

  function setup(): void {
    setupPlatformPicker();
    setupDiscount();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
