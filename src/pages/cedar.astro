---
/**
 * /cedar — standalone Cedar page.
 *
 * Three blocks:
 *   1. Hero with a one-sentence framing of what Cedar is.
 *   2. "How Cedar works" — three steps.
 *   3. Inline Cedar chat — same runtime as the FAB, mounted here
 *      as a docked panel so the visitor can try Cedar without
 *      hunting for the bottom-right tree button.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import IconUpload from '../components/icons/IconUpload.astro';
import IconSurfaceAssumption from '../components/icons/IconSurfaceAssumption.astro';
import IconSourceRecord from '../components/icons/IconSourceRecord.astro';
import { INTENTS, CHIP_IDS } from '../data/cedarIntents';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import '../styles/cedar-page.css';
import '../styles/cedar-chat.css';

const chips = CHIP_IDS
  .map((id) => INTENTS.find((i) => i.id === id))
  .filter((i): i is NonNullable<typeof i> => i != null && i.chip != null);
---
<BaseLayout
  title="Cedar | Lumecon"
  description="Cedar is Lumecon's AI analyst. It reads messy data, surfaces every modeling assumption, and reshapes the same study for every audience. RAG-based, grounded in your files."
  canonical="https://lumecon.ai/cedar"
  keywords="Cedar AI, Lumecon Cedar, AI economic analyst, RAG economic impact, AI for economists, AI grant narrative, AI council memo, Cedar Lumecon assistant, AI impact analysis"
  ogTitle="Cedar: built for the tedious parts of economic impact analysis"
  ogDescription="Reads messy data, surfaces every assumption for your sign-off, and reshapes the study for the audience in front of you. RAG-based and grounded in your files."
>
  <Nav />
  <main class="cedar-page">

    <!-- Hero: what Cedar is, in a sentence, with the call-to-action
         to engage the inline chat below. -->
    <header class="cedar-page__hero">
      <p class="cedar-page__eyebrow">Cedar</p>
      <h1 class="cedar-page__title reveal-soft hl-block hl-block--green">Built for the tedious parts of economic impact analysis.</h1>
      <p class="cedar-page__lede">
        Cedar is Lumecon's AI analyst. It reads messy data, surfaces every assumption for your sign-off, and reshapes the study for the audience in front of you. Because Cedar is RAG-based, answers stay grounded in your actual files, not generic model output. Cedar does the heavy lift; your team stays in control of what the study says.
      </p>
      <p class="cedar-page__call">
        Try the inline Cedar below, or open Cedar from the green tree button on any page.
      </p>
    </header>

    <!-- What Cedar does — three-step explainer. -->
    <section class="cedar-page__how" aria-labelledby="cedar-how-title">
      <p class="cedar-page__kicker">How Cedar works</p>
      <h2 class="cedar-page__h2 reveal-soft hl-block hl-block--b" id="cedar-how-title">Three things, well.</h2>
      <ol class="cedar-page__steps" aria-label="What Cedar does">
        <li class="cedar-page__step">
          <span class="cedar-page__step-icon"><IconUpload /></span>
          <h3 class="cedar-page__step-head">Works with the data you actually have</h3>
          <p class="cedar-page__step-body">Budgets, payroll, council agendas, board reports, audits, and grant filings. Cedar turns messy departmental files into usable study inputs, no matter what shape they arrive in.</p>
        </li>
        <li class="cedar-page__step">
          <span class="cedar-page__step-icon"><IconSurfaceAssumption /></span>
          <h3 class="cedar-page__step-head">Shows its work before it runs</h3>
          <p class="cedar-page__step-body">Every multiplier, regional bridge, and base-year choice is named with a plain-English rationale. You confirm, adjust, or override, and the audit trail builds as the study moves.</p>
        </li>
        <li class="cedar-page__step">
          <span class="cedar-page__step-icon"><IconSourceRecord /></span>
          <h3 class="cedar-page__step-head">Adapts the same analysis to every audience</h3>
          <p class="cedar-page__step-body">Council meeting, grant filing, board memo, or public release. Cedar redraws the same result for the next use case, without your team copying numbers across five different decks.</p>
        </li>
      </ol>
    </section>

    <!-- Inline Cedar chat. Same DOM structure the FAB uses; the
         bootChat() runtime below wires it up. surface: 'inline' so
         analytics can distinguish inline conversations from FAB
         conversations. -->
    <section class="cedar-page__try" aria-labelledby="cedar-try-title">
      <p class="cedar-page__kicker">Try it</p>
      <h2 class="cedar-page__h2 reveal-soft hl-block hl-block--gold" id="cedar-try-title">Ask Cedar a question.</h2>
      <p class="cedar-page__deck">
        This is the same Cedar that lives in the green tree button at the bottom of every page. Ask anything about Lumecon, the platforms, the data, the team, or the pricing. Pick a starter question or type your own.
      </p>

      <div class="cedar-page__chat-panel" id="cedarInlinePanel">
        <div class="cedar-chat">
          <header class="cedar-chat__header">
            <span class="cedar-chat__brand">
              <span class="cedar-chat__name">Cedar</span>
            </span>
            <span class="cedar-chat__status" aria-label="Online">
              <span class="cedar-chat__status-dot" aria-hidden="true"></span>
              <span class="cedar-chat__status-label">Online</span>
            </span>
          </header>
          <div class="cedar-chat__transcript" data-cedar-transcript role="log" aria-live="polite" aria-label="Cedar conversation">
            <div class="cedar-msg cedar-msg--bot">
              <span class="cedar-msg__avatar" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none">
                  <path d="M12 3 L8 9 L10 9 L7 14 L9.5 14 L5 20 L19 20 L14.5 14 L17 14 L14 9 L16 9 Z" fill="currentColor"/>
                </svg>
              </span>
              <div class="cedar-msg__bubble cedar-msg__bubble--welcome">
                <p class="cedar-msg__line">Hi, I'm Cedar. Ask me anything about Lumecon, or pick a question below.</p>
                <div class="cedar-quickreply" data-cedar-chips>
                  {chips.slice(0, 6).map((intent) => (
                    <button class="cedar-chip" type="button" data-intent={intent.id}>{intent.chip}</button>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <form class="cedar-chat__form" data-cedar-form autocomplete="off">
            <label class="cedar-chat__inputwrap">
              <span class="visually-hidden">Ask Cedar</span>
              <input
                data-cedar-input
                class="cedar-chat__input"
                type="text"
                name="q"
                placeholder="Ask Cedar a question..."
                maxlength="280"
                autocomplete="off"
                autocorrect="off"
                autocapitalize="sentences"
                spellcheck="true"
                enterkeyhint="send"
                inputmode="text"
                aria-label="Ask Cedar a question"
              />
            </label>
            <button class="cedar-chat__send" type="submit" aria-label="Send">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                <path d="M4 12L20 4L16 20L12 13L4 12Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="miter"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </section>

  </main>

  <script>
    /* Mount the same Cedar runtime the FAB uses, but on the
       inline panel anchored to /cedar. surface: 'inline' tags the
       analytics so we can tell inline conversations apart from
       FAB conversations. */
    import { bootChat } from '../lib/cedarChat';
    function mount() {
      const panel = document.getElementById('cedarInlinePanel');
      if (panel) bootChat(panel as HTMLElement, { surface: 'inline' });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount);
    } else {
      mount();
    }
    document.addEventListener('astro:page-load', mount);
  </script>

  <Footer />
</BaseLayout>
