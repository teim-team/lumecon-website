---
<BaseLayout
  title="Lumecon | Economic Impact Analysis Software"
  description="Economic impact analysis software, with the Cedar AI assistant, for governments, tribal nations, enterprises, and mission-driven organizations. Built by alumni of the Federal Reserve System, Cornell, Dartmouth, Oxford, MIT, and Duke for teams that demand credible data and models at a price that lets them integrate impact analysis into their everyday workflow rather than treating it as a once-a-year consulting expense."
  canonical="https://lumecon.ai/"
  keywords="economic impact analysis, economic impact analysis software, economic impact study software, how to measure economic impact, IMPLAN, IMPLAN alternative, Implan, Implan alternative, RIMS II, RIMS 2, RIMS II alternative, BEA RIMS, REMI, Remi, REMI alternative, Lightcast, EMSI, Emsi, input-output modeling, fiscal multiplier, economic multipliers, alternative data, AI for government, AI for local government, AI for tribes, AI for tribal governments, AI for economic development, government AI software, tribal economic impact, tribal economic development software, reservation economics, ANCSA regions, Alaska Native Corporations, Native Hawaiian Organizations, AIANNH, Cedar AI, economic impact for grants, grant economic impact report, policy analysis software, government software, public-sector analytics, mission-driven organizations, CDFI, economic development organizations, Bureau of Economic Analysis, direct indirect induced effects, jobs output earnings, Cornell University, Cornell Brooks School, Ivy League, Cornell Law, Dartmouth, Federal Reserve, Center for Indian Country Development"
  ogTitle="Economic Impact Analysis Software"
  ogDescription="Economic impact analysis software for governments, enterprises, and mission-driven organizations. Built by alumni of the Federal Reserve System, Cornell, Dartmouth, Oxford, MIT, and Duke for teams that demand credible data and models at a price that lets them integrate impact analysis into their everyday workflow."
  ogImageAlt="Lumecon. Economic Impact Analysis Software for governments, enterprises, and mission-driven organizations. Built by alumni of the Federal Reserve System, Cornell, Dartmouth, Oxford, MIT, and Duke."
  bodyClass="home-page"
  jsonLd={jsonLd}
>
  <div class="scroll-progress" id="scrollProgress"></div>
  <Nav isHome={true} />
  <main>
    <Hero />
    <ProductsSection />
    <WhySection />
    <ContactSection />
  </main>
  <Footer isHome={true} />
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<script>
  // Scroll & reveal constants
  const NAV_SCROLL_THRESHOLD = 40; // px before nav gets 'scrolled' class
  const STAGGER_DELAY_PER_ITEM = 150; // ms between staggered reveals
  const REVEAL_THRESHOLD = 0.08;
  const REVEAL_ROOT_MARGIN = '0px 0px -30px 0px';
  const SECTION_ACTIVE_ROOT_MARGIN = '-40% 0px -55% 0px';

  // Scroll progress indicator + nav scroll state
  (function() {
    const nav = document.getElementById('nav');
    const progressBar = document.getElementById('scrollProgress');
    if (!nav || !progressBar) return;
    let ticking = false;

    const onScroll = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = progress + '%';
      nav.classList.toggle('scrolled', scrollTop > NAV_SCROLL_THRESHOLD);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
    }, { passive: true });
  })();

  // Intersection observer for reveal animations (staggered product blocks)
  const obs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        const stagger = el.dataset.stagger;
        if (stagger) {
          setTimeout(() => el.classList.add('seen'), parseInt(stagger) * STAGGER_DELAY_PER_ITEM);
        } else {
          el.classList.add('seen');
        }
        obs.unobserve(e.target);
      }
    });
  }, { threshold: REVEAL_THRESHOLD, rootMargin: REVEAL_ROOT_MARGIN });
  document.querySelectorAll('.reveal,.reveal-soft,.reveal-left,.reveal-right,.reveal-diagonal').forEach(el => obs.observe(el));

  // Active section highlighting in nav
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .nav-links a[href^="/#"]');
  const sectionObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const href = link.getAttribute('href') || '';
          const match = href === '#' + id || href === '/#' + id;
          link.classList.toggle('nav-active', match);
          if (match) link.setAttribute('aria-current', 'location');
          else link.removeAttribute('aria-current');
        });
      }
    });
  }, { threshold: 0, rootMargin: SECTION_ACTIVE_ROOT_MARGIN });
  sections.forEach(s => sectionObs.observe(s));
</script>
