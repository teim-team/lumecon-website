    "@type": ["Organization", "SoftwareApplication"],
    "@id": `${site.url}#org`,
    "name": site.legalName,
    "legalName": site.legalName,
    "alternateName": ["Lumecon", "Lumecon.ai", site.name],
    "disambiguatingDescription": "Lumecon Inc. is an AI-assisted economic impact analysis software company, headquartered online at lumecon.ai. Not affiliated with any unrelated trademark-similar businesses in other industries.",
    "applicationCategory": "BusinessApplication",
    "applicationSubCategory": "Economic Impact Analysis Software",
    "operatingSystem": "Web",
    "url": site.url,
    "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
    "image": `${site.url}/lumecon-og-image-1200x630.png`,
    "description": "Lumecon Inc. builds economic impact analysis software for governments, enterprises, and mission-driven organizations. Built by alumni of the Federal Reserve System, Cornell, Dartmouth, Oxford, MIT, and Duke for teams that demand credible data and models at a price that lets them integrate impact analysis into their everyday workflow rather than treating it as a once-a-year consulting expense.",
    "email": site.email,
