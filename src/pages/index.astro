---
<BaseLayout
  title="Lumecon: Economic impact analysis software | IMPLAN, RIMS II, REMI alternative"
  description="Lumecon Inc. is economic and policy analysis software for governments and mission-driven organizations. A modern alternative to IMPLAN, RIMS II, REMI, and BEA RIMS multipliers, with built-in Cedar AI to read messy data across departments. Built at Cornell."
  canonical="https://lumecon.ai/"
  keywords="economic impact analysis, IMPLAN, IMPLAN alternative, RIMS II, RIMS II alternative, BEA RIMS, REMI, REMI Policy Insight, input-output modeling, fiscal multiplier, economic multipliers, tribal economic impact, reservation economics, Alaska Native Corporations, Native Hawaiian Organizations, AIANNH, Cedar AI, policy analysis software, government software, public-sector analytics, mission-driven organizations, CDFI, economic development organizations, Bureau of Economic Analysis, direct indirect induced effects, jobs output earnings, Cornell University, Cornell Brooks School, Ivy League, Cornell Law, Dartmouth"
  ogTitle="Lumecon: Economic impact analysis software for governments"
  ogDescription="A modern alternative to IMPLAN, RIMS II, and REMI. Run economic impact studies in-house, on your own data, with Cedar AI handling the messy parts. Built at Cornell, designed for governments and mission-driven organizations."
  ogImageAlt="Lumecon: economic and policy analysis software for governments and mission-driven organizations. An alternative to IMPLAN, RIMS II, REMI, and BEA RIMS multipliers, built at Cornell University."
  bodyClass="home-page"
  jsonLd={jsonLd}
>
  <div class="scroll-progress" id="scrollProgress"></div>
  <Nav isHome={true} />
  <main>
    <Hero />
    <WhySection />
    <ProductsSection />
    <CedarSection />
    <FAQSection />
    <ContactSection />
  </main>
  <Footer isHome={true} />
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<script>
  // Scroll & reveal constants
  const NAV_SCROLL_THRESHOLD = 40; // px before nav gets 'scrolled' class
  const STAGGER_DELAY_PER_ITEM = 150; // ms between staggered reveals
  const REVEAL_THRESHOLD = 0.08;
  const REVEAL_ROOT_MARGIN = '0px 0px -30px 0px';
  const SECTION_ACTIVE_ROOT_MARGIN = '-40% 0px -55% 0px';

  // Scroll progress indicator + nav scroll state
  (function() {
    const nav = document.getElementById('nav');
    const progressBar = document.getElementById('scrollProgress');
    if (!nav || !progressBar) return;
    let ticking = false;

    const onScroll = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = progress + '%';
      nav.classList.toggle('scrolled', scrollTop > NAV_SCROLL_THRESHOLD);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
    }, { passive: true });
  })();

  // Intersection observer for reveal animations (staggered product blocks)
  const obs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        const stagger = el.dataset.stagger;
        if (stagger) {
          setTimeout(() => el.classList.add('seen'), parseInt(stagger) * STAGGER_DELAY_PER_ITEM);
        } else {
          el.classList.add('seen');
        }
        obs.unobserve(e.target);
      }
    });
  }, { threshold: REVEAL_THRESHOLD, rootMargin: REVEAL_ROOT_MARGIN });
  document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-diagonal').forEach(el => obs.observe(el));

  // Active section highlighting in nav
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .nav-links a[href^="/#"]');
  const sectionObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const href = link.getAttribute('href') || '';
          const match = href === '#' + id || href === '/#' + id;
          link.classList.toggle('nav-active', match);
          if (match) link.setAttribute('aria-current', 'location');
          else link.removeAttribute('aria-current');
        });
      }
    });
  }, { threshold: 0, rootMargin: SECTION_ACTIVE_ROOT_MARGIN });
  sections.forEach(s => sectionObs.observe(s));
</script>
