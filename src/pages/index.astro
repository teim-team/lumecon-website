---
import { site } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import WhySection from '../components/WhySection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import CedarSection from '../components/CedarSection.astro';
import ContactSection from '../components/ContactSection.astro';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": site.legalName,
    "legalName": site.legalName,
    "alternateName": site.name,
    "url": site.url,
    "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
    "description": "Lumecon Inc. — economic and policy analysis software for governments and mission-driven organizations. Parent brand of Local, Tribal, and Global Economic Impact platforms.",
    "email": site.email,
    "slogan": site.tagline,
    "sameAs": ["https://www.linkedin.com/company/lumecon-ai"],
    "foundingLocation": { "@type": "Place", "name": site.builtAt },
    "knowsAbout": [
      "Economic Impact Analysis",
      "Policy Analysis",
      "RIMS II",
      "IMPLAN",
      "Tribal Economics",
      "Fiscal Multiplier",
      "Input-Output Modeling"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Economic impact analysis software",
    "name": site.products.local.name,
    "url": site.products.local.url,
    "provider": { "@type": "Organization", "name": site.legalName },
    "areaServed": { "@type": "Country", "name": "United States" },
    "audience": { "@type": "Audience", "audienceType": "Municipal governments, EDOs, enterprises" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Economic impact analysis software",
    "name": site.products.tribal.name,
    "url": site.products.tribal.url,
    "provider": { "@type": "Organization", "name": site.legalName },
    "areaServed": { "@type": "Country", "name": "United States" },
    "audience": { "@type": "Audience", "audienceType": "Tribes, ANCs, NHOs, reservation economies" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Economic impact analysis software",
    "name": site.products.global.name,
    "url": site.products.global.url,
    "provider": { "@type": "Organization", "name": site.legalName },
    "audience": { "@type": "Audience", "audienceType": "Multinationals, NGOs, cross-border programs" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Platforms", "item": `${site.url}/#products` },
      { "@type": "ListItem", "position": 3, "name": "Cedar", "item": `${site.url}/#cedar` },
      { "@type": "ListItem", "position": 4, "name": "Contact", "item": `${site.url}/#contact` }
    ]
  }
];
---
<BaseLayout
  title="Lumecon Inc. — Economic and policy analysis software for governments"
  description="Lumecon Inc. is the parent brand for three specialized platforms — Local, Tribal, and Global Economic Impact. Affordable, web-based economic and policy analysis software for governments. An alternative to RIMS II and IMPLAN, with Cedar AI assistance."
  canonical="https://lumecon.ai/"
  keywords="Lumecon Inc, economic impact analysis, policy analysis, local economic impact, tribal economic impact, global economic impact, economic development, fiscal multiplier, economic modeling, Cedar AI, RIMS II, RIMS II alternative, IMPLAN alternative, Eric Trevan, Jonathan Taylor, Alan Meister, tribal economics, impact analysis, input-output analysis, economic multiplier, Cornell University, Dartmouth, Brooks Public Policy, reservation economics, tribal government, economic development organizations"
  ogTitle="Lumecon Inc. — Economic and policy analysis software for governments"
  ogDescription="Parent brand for three platforms — Local, Tribal, and Global Economic Impact. Affordable, web-based modeling that organizations of any size can act on."
  bodyClass="home-page"
  jsonLd={jsonLd}
>
  <div class="scroll-progress" id="scrollProgress"></div>
  <Nav isHome={true} />
  <main>
    <Hero />
    <WhySection />
    <ProductsSection />
    <CedarSection />
    <ContactSection />
  </main>
  <Footer isHome={true} />
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<script>
  // Scroll & reveal constants
  const NAV_SCROLL_THRESHOLD = 40; // px before nav gets 'scrolled' class
  const STAGGER_DELAY_PER_ITEM = 150; // ms between staggered reveals
  const REVEAL_THRESHOLD = 0.08;
  const REVEAL_ROOT_MARGIN = '0px 0px -30px 0px';
  const SECTION_ACTIVE_ROOT_MARGIN = '-40% 0px -55% 0px';

  // Scroll progress indicator + nav scroll state
  (function() {
    const nav = document.getElementById('nav');
    const progressBar = document.getElementById('scrollProgress');
    if (!nav || !progressBar) return;
    let ticking = false;

    const onScroll = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = progress + '%';
      nav.classList.toggle('scrolled', scrollTop > NAV_SCROLL_THRESHOLD);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
    }, { passive: true });
  })();

  // Intersection observer for reveal animations (staggered product blocks)
  const obs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        const stagger = el.dataset.stagger;
        if (stagger) {
          setTimeout(() => el.classList.add('seen'), parseInt(stagger) * STAGGER_DELAY_PER_ITEM);
        } else {
          el.classList.add('seen');
        }
        obs.unobserve(e.target);
      }
    });
  }, { threshold: REVEAL_THRESHOLD, rootMargin: REVEAL_ROOT_MARGIN });
  document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-diagonal').forEach(el => obs.observe(el));

  // Active section highlighting in nav
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .nav-links a[href^="/#"]');
  const sectionObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const href = link.getAttribute('href') || '';
          const match = href === '#' + id || href === '/#' + id;
          link.classList.toggle('nav-active', match);
          if (match) link.setAttribute('aria-current', 'location');
          else link.removeAttribute('aria-current');
        });
      }
    });
  }, { threshold: 0, rootMargin: SECTION_ACTIVE_ROOT_MARGIN });
  sections.forEach(s => sectionObs.observe(s));
</script>
