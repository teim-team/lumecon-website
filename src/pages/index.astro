---
import { site } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import WhySection from '../components/WhySection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import CedarSection from '../components/CedarSection.astro';
import ContactSection from '../components/ContactSection.astro';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": site.name,
  "url": site.url,
  "description": "Economic and policy analysis platform offering affordable, web-based tools for local, tribal, and global economic impact and policy analysis.",
  "email": site.email,
  "slogan": site.tagline,
  "foundingLocation": { "@type": "Place", "name": site.builtAt },
  "founder": {
    "@type": "Person",
    "name": "Elijah Moreno",
    "alumniOf": [
      { "@type": "CollegeOrUniversity", "name": "Cornell University" },
      { "@type": "CollegeOrUniversity", "name": "Dartmouth College" }
    ]
  },
  "knowsAbout": [
    "Economic Impact Analysis",
    "Policy Analysis",
    "RIMS II",
    "IMPLAN",
    "Tribal Economics",
    "Fiscal Multiplier",
    "Input-Output Modeling"
  ]
};
---
<BaseLayout
  title="Lumecon — We luminate economies | Economic Impact & Policy Analysis Platform"
  description="Lumecon is an economic and policy analysis platform built at Cornell University by Elijah Moreno. Affordable, web-based tools for local, tribal, and global economic impact analysis. An alternative to RIMS II and IMPLAN. Cedar AI-powered analysis assistant."
  canonical="https://lumecon.ai/"
  keywords="economic impact analysis, policy analysis, local economic impact, tribal economic impact, global economic impact, economic development, fiscal multiplier, economic modeling, Cedar AI, Lumecon, RIMS II, RIMS II alternative, IMPLAN alternative, alocal, Eric Trevan, Jonathan Taylor, Alan Meister, tribal economics, impact analysis, input-output analysis, economic multiplier, Elijah Moreno, Cornell University, Dartmouth, brooks public policy, cornell economics, cscglobal, compliance, economic consulting, reservation economics, tribal government, economic development organizations"
  ogTitle="Lumecon — Economic and policy analysis anyone can act on"
  ogDescription="Affordable, web-based economic impact and policy analysis for local, tribal, and global economies. Built by social scientists and engineers at Cornell University. An alternative to RIMS II and IMPLAN."
  bodyClass="home-page"
  jsonLd={jsonLd}
>
  <div class="scroll-progress" id="scrollProgress"></div>
  <Nav isHome={true} />
  <main>
    <Hero />
    <WhySection />
    <ProductsSection />
    <CedarSection />
    <ContactSection />
  </main>
  <Footer isHome={true} />

  <!-- Back to top button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<script>
  // Scroll & reveal constants
  const NAV_SCROLL_THRESHOLD = 40; // px before nav gets 'scrolled' class
  const STAGGER_DELAY_PER_ITEM = 150; // ms between staggered reveals
  const REVEAL_THRESHOLD = 0.08;
  const REVEAL_ROOT_MARGIN = '0px 0px -30px 0px';
  const SECTION_ACTIVE_ROOT_MARGIN = '-40% 0px -55% 0px';

  // Scroll progress indicator + nav scroll state
  (function() {
    const nav = document.getElementById('nav');
    const progressBar = document.getElementById('scrollProgress');
    const backToTop = document.getElementById('backToTop');
    if (!nav || !progressBar || !backToTop) return;
    let ticking = false;

    const onScroll = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;

      progressBar.style.width = progress + '%';
      nav.classList.toggle('scrolled', scrollTop > NAV_SCROLL_THRESHOLD);
      backToTop.classList.toggle('visible', scrollTop > window.innerHeight);
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });

    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();

  // Intersection observer for reveal animations (staggered product blocks)
  const obs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        const stagger = el.dataset.stagger;
        if (stagger) {
          setTimeout(() => el.classList.add('seen'), parseInt(stagger) * STAGGER_DELAY_PER_ITEM);
        } else {
          el.classList.add('seen');
        }
        obs.unobserve(e.target);
      }
    });
  }, { threshold: REVEAL_THRESHOLD, rootMargin: REVEAL_ROOT_MARGIN });
  document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-diagonal').forEach(el => obs.observe(el));

  // Active section highlighting in nav
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .nav-links a[href^="/#"]');
  const sectionObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const href = link.getAttribute('href') || '';
          link.classList.toggle('nav-active', href === '#' + id || href === '/#' + id);
        });
      }
    });
  }, { threshold: 0, rootMargin: SECTION_ACTIVE_ROOT_MARGIN });
  sections.forEach(s => sectionObs.observe(s));
</script>
