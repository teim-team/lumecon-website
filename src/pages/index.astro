---
import { site } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import WhySection from '../components/WhySection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import CedarSection from '../components/CedarSection.astro';
import ContactSection from '../components/ContactSection.astro';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "SoftwareApplication"],
    "name": site.legalName,
    "legalName": site.legalName,
    "alternateName": site.name,
    "applicationCategory": "BusinessApplication",
    "applicationSubCategory": "Economic Impact Analysis Software",
    "operatingSystem": "Web",
    "url": site.url,
    "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
    "image": `${site.url}/lumecon-og-image-1200x630.png`,
    "description": "Lumecon Inc. builds economic and policy analysis software for governments and mission-driven organizations. A modern, web-based alternative to IMPLAN, RIMS II, REMI, and BEA RIMS workflows, with Cedar AI to handle messy data across departments.",
    "email": site.email,
    "slogan": site.tagline,
    "sameAs": ["https://www.linkedin.com/company/lumecon-ai"],
    "foundingLocation": { "@type": "Place", "name": site.builtAt },
    "knowsAbout": [
      "Economic Impact Analysis",
      "Policy Analysis",
      "Input-Output Modeling",
      "IMPLAN",
      "IMPLAN alternative",
      "RIMS II",
      "RIMS II alternative",
      "BEA RIMS II",
      "REMI",
      "REMI Policy Insight alternative",
      "Bureau of Economic Analysis multipliers",
      "Fiscal Multiplier",
      "Economic Multipliers",
      "Tribal Economics",
      "Indigenous Economic Development",
      "Reservation Economics",
      "Alaska Native Corporations",
      "Native Hawaiian Organizations",
      "AIANNH geography",
      "Direct, Indirect, and Induced Effects",
      "Jobs, Output, and Earnings",
      "Economic Development Organizations",
      "Municipal Finance",
      "State and Local Government Software",
      "Public Sector Analytics",
      "Mission-Driven Organizations",
      "CDFIs",
      "Foundation Reporting",
      "Cornell University",
      "Cornell Brooks School of Public Policy",
      "Ivy League research",
      "Cornell Law Entrepreneurship Law Clinic",
      "Dartmouth College"
    ],
    "keywords": "economic impact analysis, IMPLAN alternative, RIMS II alternative, REMI alternative, BEA multipliers, input-output modeling, tribal economic impact, policy analysis software, government analytics, Cornell, Ivy League",
    "potentialAction": {
      "@type": "ContactAction",
      "target": `mailto:${site.email}`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Economic impact analysis software",
    "name": site.products.local.name,
    "url": site.products.local.url,
    "provider": { "@type": "Organization", "name": site.legalName },
    "areaServed": { "@type": "Country", "name": "United States" },
    "audience": { "@type": "Audience", "audienceType": "Municipal governments, EDOs, enterprises" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Economic impact analysis software",
    "name": site.products.tribal.name,
    "url": site.products.tribal.url,
    "provider": { "@type": "Organization", "name": site.legalName },
    "areaServed": { "@type": "Country", "name": "United States" },
    "audience": { "@type": "Audience", "audienceType": "Tribes, ANCs, NHOs, reservation economies" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Economic impact analysis software",
    "name": site.products.global.name,
    "url": site.products.global.url,
    "provider": { "@type": "Organization", "name": site.legalName },
    "audience": { "@type": "Audience", "audienceType": "Multinationals, NGOs, cross-border programs" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Platforms", "item": `${site.url}/#products` },
      { "@type": "ListItem", "position": 3, "name": "Cedar", "item": `${site.url}/#cedar` },
      { "@type": "ListItem", "position": 4, "name": "Contact", "item": `${site.url}/#contact` }
    ]
  }
];
---
<BaseLayout
  title="Lumecon: Economic impact analysis software | IMPLAN, RIMS II, REMI alternative"
  description="Lumecon Inc. is economic and policy analysis software for governments and mission-driven organizations. A modern alternative to IMPLAN, RIMS II, REMI, and BEA RIMS multipliers, with built-in Cedar AI to read messy data across departments. Built at Cornell."
  canonical="https://lumecon.ai/"
  keywords="economic impact analysis, IMPLAN, IMPLAN alternative, RIMS II, RIMS II alternative, BEA RIMS, REMI, REMI Policy Insight, input-output modeling, fiscal multiplier, economic multipliers, tribal economic impact, reservation economics, Alaska Native Corporations, Native Hawaiian Organizations, AIANNH, Cedar AI, policy analysis software, government software, public-sector analytics, mission-driven organizations, CDFI, economic development organizations, Bureau of Economic Analysis, direct indirect induced effects, jobs output earnings, Cornell University, Cornell Brooks School, Ivy League, Cornell Law, Dartmouth"
  ogTitle="Lumecon: Economic impact analysis software for governments"
  ogDescription="A modern alternative to IMPLAN, RIMS II, and REMI. Run economic impact studies in-house, on your own data, with Cedar AI handling the messy parts. Built at Cornell, designed for governments and mission-driven organizations."
  ogImageAlt="Lumecon: economic and policy analysis software for governments and mission-driven organizations. An alternative to IMPLAN, RIMS II, REMI, and BEA RIMS multipliers, built at Cornell University."
  bodyClass="home-page"
  jsonLd={jsonLd}
>
  <div class="scroll-progress" id="scrollProgress"></div>
  <Nav isHome={true} />
  <main>
    <Hero />
    <WhySection />
    <ProductsSection />
    <CedarSection />
    <ContactSection />
  </main>
  <Footer isHome={true} />
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<script>
  // Scroll & reveal constants
  const NAV_SCROLL_THRESHOLD = 40; // px before nav gets 'scrolled' class
  const STAGGER_DELAY_PER_ITEM = 150; // ms between staggered reveals
  const REVEAL_THRESHOLD = 0.08;
  const REVEAL_ROOT_MARGIN = '0px 0px -30px 0px';
  const SECTION_ACTIVE_ROOT_MARGIN = '-40% 0px -55% 0px';

  // Scroll progress indicator + nav scroll state
  (function() {
    const nav = document.getElementById('nav');
    const progressBar = document.getElementById('scrollProgress');
    if (!nav || !progressBar) return;
    let ticking = false;

    const onScroll = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = progress + '%';
      nav.classList.toggle('scrolled', scrollTop > NAV_SCROLL_THRESHOLD);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
    }, { passive: true });
  })();

  // Intersection observer for reveal animations (staggered product blocks)
  const obs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        const stagger = el.dataset.stagger;
        if (stagger) {
          setTimeout(() => el.classList.add('seen'), parseInt(stagger) * STAGGER_DELAY_PER_ITEM);
        } else {
          el.classList.add('seen');
        }
        obs.unobserve(e.target);
      }
    });
  }, { threshold: REVEAL_THRESHOLD, rootMargin: REVEAL_ROOT_MARGIN });
  document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-diagonal').forEach(el => obs.observe(el));

  // Active section highlighting in nav
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .nav-links a[href^="/#"]');
  const sectionObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const href = link.getAttribute('href') || '';
          const match = href === '#' + id || href === '/#' + id;
          link.classList.toggle('nav-active', match);
          if (match) link.setAttribute('aria-current', 'location');
          else link.removeAttribute('aria-current');
        });
      }
    });
  }, { threshold: 0, rootMargin: SECTION_ACTIVE_ROOT_MARGIN });
  sections.forEach(s => sectionObs.observe(s));
</script>
