---
/**
 * /about — who built Lumecon and why.
 *
 * Two sections only, kept deliberately lean:
 *   - Hero with a highlighted h1 and the founding story (the rest
 *     behind a `<details>`).
 *   - "How we work" cross-functional grid. Every person is named
 *     here, and each name links to that person's /team/<slug> page,
 *     so there's no separate roster grid to maintain.
 *
 * Team data lives in src/data/team.ts. Adding a person is one
 * entry there, not five edits across the markup.
 *
 * SEO: page emits AboutPage + Person + BreadcrumbList JSON-LD
 * derived from the same team data, so Google's knowledge graph
 * connects each person to their alumniOf institutions and prior
 * affiliations (Fed Minneapolis CICD, NCAI, Modsy, Chime, etc.)
 * without us hand-writing structured data twice.
 */
import { site } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { TEAM, TEAM_BY_GROUP, TEAM_BY_SLUG, WORKING_AREAS, personPath, type Person } from '../data/team';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import '../styles/about-page.css';

const team = TEAM_BY_GROUP.team;

/* ---------- JSON-LD ---------- */
/* Build a schema.org Person entry per team member. alumniOf and
   affiliation arrays power entity disambiguation in search: when
   someone queries "Elijah Moreno Cornell" or "Laurel Wheeler
   Federal Reserve", the connection is explicit in the structured
   data rather than buried in prose. */
function personJsonLd(p: Person) {
  const personUrl = `${site.url}${personPath(p.slug)}`;
  const node: Record<string, unknown> = {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": personUrl,
    "name": p.name,
    "url": personUrl,
    "jobTitle": p.title,
    "description": p.summary,
    "worksFor": { "@type": "Organization", "@id": `${site.url}#org`, "name": site.legalName },
  };
  if (p.email) node.email = `mailto:${p.email}`;
  const sameAs = [p.linkedin, p.scholar].filter(Boolean);
  if (sameAs.length) node.sameAs = sameAs;
  if (p.alumniOf && p.alumniOf.length) {
    node.alumniOf = p.alumniOf.map((n) => ({ "@type": "EducationalOrganization", "name": n }));
  }
  if (p.prevAffiliations && p.prevAffiliations.length) {
    node.affiliation = p.prevAffiliations.map((n) => ({ "@type": "Organization", "name": n }));
  }
  return node;
}

const founders = TEAM.filter((p) => p.founder);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "url": `${site.url}/about`,
    "name": "About Lumecon",
    "description": "Lumecon was founded by brothers Elijah and Michael Moreno, enrolled members of the Coastal Band of the Chumash Nation. The team builds economic impact analysis software for governments, tribal nations, foundations, and community-serving organizations.",
    "isPartOf": { "@type": "WebSite", "@id": `${site.url}#website` },
    "about": { "@type": "Organization", "@id": `${site.url}#org` },
    "mainEntity": {
      "@type": "Organization",
      "@id": `${site.url}#org`,
      "name": site.legalName,
      "url": site.url,
      "founder": founders.map((p) => ({ "@type": "Person", "@id": `${site.url}${personPath(p.slug)}`, "name": p.name })),
      "employee": team.map((p) => ({ "@type": "Person", "@id": `${site.url}${personPath(p.slug)}`, "name": p.name })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "About", "item": `${site.url}/about` },
    ],
  },
  ...TEAM.map(personJsonLd),
];
---
<BaseLayout
  title="About | Lumecon"
  description="Lumecon was founded by brothers Elijah and Michael Moreno, enrolled members of the Coastal Band of the Chumash Nation, to make economic impact analysis accessible, transparent, and useful for governments, tribal nations, foundations, and community-serving organizations. Team: Cornell, Dartmouth, Duke, Oxford, MIT, Wisconsin–Madison, Maryland, Illinois Urbana-Champaign. Prior experience at the Center for Indian Country Development (Federal Reserve Bank of Minneapolis), National Congress of American Indians, Federal Reserve Bank of Philadelphia, Federal Reserve Board of Governors, Modsy, Chime."
  canonical="https://lumecon.ai/about"
  keywords="Lumecon team, Lumecon founders, Elijah Moreno, Michael Moreno, Coastal Band of the Chumash Nation, Center for Indian Country Development, CICD, Federal Reserve Bank of Minneapolis, Wilma Mankiller Fellow, National Congress of American Indians, Taylor Policy Group, Cornell eHub, Human Spirit Entrepreneurship Fellows, Cornell Law Entrepreneurship Law Clinic, Laurel Wheeler, Kaylyn Lee, Isabella Agnes, Francesca Agnes, Brian Kim, Havala Hanson, Vod Vilfort, tribal economic impact, economic impact analysis software"
  ogTitle="About Lumecon: economic impact analysis built with the communities it serves"
  ogDescription="Founded by brothers Elijah and Michael Moreno, enrolled members of the Coastal Band of the Chumash Nation. Team brings together Cornell, Dartmouth, Duke, Oxford, MIT, and Federal Reserve experience to make economic impact analysis accessible to governments, tribal nations, foundations, and community-serving organizations."
  ogImageAlt="About Lumecon. Founded by brothers Elijah and Michael Moreno, enrolled members of the Coastal Band of the Chumash Nation. Economic impact analysis software for governments, tribal nations, foundations, and community-serving organizations."
  jsonLd={jsonLd}
>
  <Nav />
  <main class="about-page">

    <header class="about-page__hero">
      <div class="about-page__inner">
        <p class="about-page__kicker">About</p>
        <h1 class="about-page__title reveal-soft hl-block hl-block--green">Built with the communities it serves.</h1>
        <p class="about-page__lede">
          Lumecon was founded by brothers Elijah Moreno and Michael Moreno, enrolled members of the Coastal Band of the Chumash Nation. The company began with their own savings and a shared belief that economic impact analysis should be more accessible, transparent, and useful for the communities too often priced out of it.
        </p>
        <details class="about-page__more">
          <summary class="about-page__more-summary">
            <span>The longer version</span>
            <span class="about-page__chev" aria-hidden="true"></span>
          </summary>
          <div class="about-page__more-body">
            <p>Economic impact analysis is powerful, but too often it is expensive, opaque, and difficult to adapt to the communities being studied. Lumecon builds software that helps organizations turn real administrative, financial, and program data into credible economic impact analysis, with clear assumptions, reusable source records, and outputs designed for decision-making.</p>
            <p class="about-page__belief">Our work starts from a simple belief: communities should not need massive consulting budgets, or advanced degrees in economics, to understand and communicate the economic value they create.</p>
            <p>Lumecon combines economic research, public policy, software, data infrastructure, and responsible AI to help organizations produce analysis that is easier to run, easier to audit, and easier to explain. We are especially focused on communities and institutions that are often economically visible in the real world but underrepresented in standard data tools.</p>
          </div>
        </details>
        <p class="about-page__ecosystem">
          Supported by Cornell&rsquo;s entrepreneurship ecosystem, including the Human Spirit Entrepreneurship Fellows program through Cornell eHub and the Cornell Law School Entrepreneurship Law Clinic.
        </p>
      </div>
    </header>

    <!-- How We Work: explains the cross-functional structure
         BEFORE individual bios so visitors read the overlap on
         the team cards as intentional rather than messy. Each
         area is a <details> showing the lead + contributors +
         advisory roster; the description paragraph hides until
         opened. -->
    <section class="about-page__how-we-work" aria-labelledby="about-how-title">
      <div class="about-page__inner">
        <p class="about-page__kicker">How we work</p>
        <h2 class="about-page__h2 reveal-soft hl-block hl-block--smear" id="about-how-title">Cross-functional, by design.</h2>
        <p class="about-page__lede about-page__lede--how">
          Lumecon is built by a cross-functional team where each person has a clear lead area, but no part of the product is developed in isolation. Economic impact software only works when the economics, platform, data systems, and user workflow are designed together. Each team member has a primary role, and the company is intentionally collaborative across these areas.
        </p>
        <ul class="about-page__areas" aria-label="Working areas">
          {WORKING_AREAS.map((area) => {
            const lead = TEAM_BY_SLUG[area.leadSlug];
            const advisory = (area.advisorySlugs ?? []).map((s) => TEAM_BY_SLUG[s]).filter(Boolean);
            const contributors = (area.contributorSlugs ?? []).map((s) => TEAM_BY_SLUG[s]).filter(Boolean);
            return (
              <li>
                <details class="area-card" id={area.slug}>
                  <summary class="area-card__head">
                    <span class="area-card__name">{area.name}</span>
                    <span class="area-card__roster">
                      <span class="area-card__role">
                        <span class="area-card__role-label">Lead</span>{' '}
                        <a class="area-card__person" href={personPath(lead.slug)}>{lead.name}</a>
                      </span>
                      {advisory.length > 0 && (
                        <span class="area-card__role">
                          <span class="area-card__role-label">Advisory</span>{' '}
                          {advisory.map((p) => (
                            <a class="area-card__person" href={personPath(p.slug)}>{p.name}</a>
                          ))}
                        </span>
                      )}
                      {contributors.length > 0 && (
                        <span class="area-card__role">
                          <span class="area-card__role-label">Contributors</span>{' '}
                          {contributors.map((p) => (
                            <a class="area-card__person" href={personPath(p.slug)}>{p.name}</a>
                          ))}
                        </span>
                      )}
                    </span>
                    <span class="area-card__chev" aria-hidden="true"></span>
                  </summary>
                  <p class="area-card__desc">{area.description}</p>
                </details>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- Closing cross-link: send team-page visitors to /join so
         they can apply once they've read who they would be
         working with. Mirrors the "Meet the team" bridge at the
         end of /join. -->
    <aside class="about-bridge" aria-label="Join the team">
      <div class="about-page__inner">
        <p class="about-bridge__kicker">Want to build with us?</p>
        <p class="about-bridge__copy">We are a six-person team looking for early teammates across software engineering, machine learning, data, economic impact modeling, marketing, and sales. The /join page has the role-by-role breakdown and a short application.</p>
        <a href="/join" class="btn">Join the team &rarr;</a>
      </div>
    </aside>

  </main>
  <Footer />
</BaseLayout>
