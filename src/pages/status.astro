---
import { site } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';

const builtAt = new Date().toISOString();
const brandAssets = [
  '/brand/lumecon-logo-horizontal-transparent.png',
  '/brand/lumecon-logo-mark-transparent.png',
  '/favicon.ico',
  '/site.webmanifest',
  '/.well-known/security.txt',
];
---
<BaseLayout
  title="Status — Lumecon Inc."
  description="Lumecon Inc. status page: deploy time, brand-asset paths, build info."
  canonical={`${site.url}/status`}
  keywords="lumecon status, lumecon deploy"
>
  <Nav />
  <main class="status">
    <div class="status__inner">
      <h1>Status</h1>
      <dl class="status__list">
        <dt>Build</dt>
        <dd><time datetime={builtAt}>{builtAt}</time> (UTC)</dd>
        <dt>Brand</dt>
        <dd>
          <ul>
            {brandAssets.map(p => <li><a href={p}>{p}</a></li>)}
          </ul>
        </dd>
        <dt>Contact</dt>
        <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
        <dt>LinkedIn</dt>
        <dd><a href="https://www.linkedin.com/company/lumecon-ai" rel="me">linkedin.com/company/lumecon-ai</a></dd>
      </dl>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .status { padding: 7rem 0 5rem; min-height: 60vh; }
  .status__inner { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
  .status h1 {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    letter-spacing: -.025em;
    color: var(--navy);
    margin: 0 0 2rem;
  }
  .status__list { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 3fr); gap: .8rem 1.5rem; margin: 0; }
  .status__list dt {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 500;
    align-self: center;
  }
  .status__list dd { margin: 0; color: var(--ink-2); font-size: .95rem; line-height: 1.6; }
  .status__list ul { list-style: none; padding: 0; margin: 0; }
  .status__list a { color: var(--navy); text-decoration: underline; text-underline-offset: .25em; }
  .status__list a:hover { color: var(--gold); }
</style>
