---
import { site } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';

const builtAt = new Date().toISOString();
const brandAssets = [
  '/brand/lumecon-logo-horizontal-transparent.png',
  '/brand/lumecon-logo-mark-transparent.png',
  '/favicon.ico',
  '/site.webmanifest',
  '/.well-known/security.txt',
];

/* "What's new" changelog — high-level, public-facing notes that show the
   product is actively moving. Add a new entry at the top each time
   something ships; keep them plain-language (not internal commit speak). */
const CHANGELOG: Array<{ date: string; title: string; body: string }> = [
  {
    date: 'May 2026',
    title: 'Cedar gets more conversational',
    body: 'Cedar now keeps context across a conversation, tolerates typos, reveals answers as it composes them, and hands off to the team when a question is outside its scope.',
  },
  {
    date: 'May 2026',
    title: 'Accessibility + dark mode pass',
    body: 'A pass for keyboard focus, reduced-motion, high-contrast, and a dark-mode theme across the site.',
  },
  {
    date: 'Spring 2026',
    title: 'Interactive impact map',
    body: 'Run a live example study on any U.S. state, county, or tribal land, with direct, indirect, induced, and total impact updating in seconds.',
  },
  {
    date: 'Spring 2026',
    title: 'Tribal & Local Economic Impact platforms',
    body: 'The Tribal and Local Economic Impact platforms are live, with studies underway alongside partner organizations. Global Economic Impact is on the roadmap.',
  },
];
---
<BaseLayout
  title="What's new | Lumecon Inc."
  description="What's new at Lumecon: recent updates to Cedar, the interactive impact map, the Tribal and Local Economic Impact platforms, and the site."
  canonical={`${site.url}/status`}
  keywords="lumecon changelog, lumecon updates, what's new, Cedar updates, economic impact platform updates"
>
  <Nav />
  <main class="status">
    <div class="status__inner">
      <h1>What&rsquo;s new</h1>
      <p class="status__intro">Recent updates to Cedar, the impact map, and the platforms. We ship continuously.</p>
      <ol class="changelog">
        {CHANGELOG.map((e) => (
          <li class="changelog__item">
            <span class="changelog__date mono">{e.date}</span>
            <div class="changelog__body">
              <h2 class="changelog__title">{e.title}</h2>
              <p class="changelog__text">{e.body}</p>
            </div>
          </li>
        ))}
      </ol>

      <h2 class="status__tech-head">Build &amp; technical</h2>
      <dl class="status__list">
        <dt>Build</dt>
        <dd><time datetime={builtAt}>{builtAt}</time> (UTC)</dd>
        <dt>Brand</dt>
        <dd>
          <ul>
            {brandAssets.map(p => <li><a href={p}>{p}</a></li>)}
          </ul>
        </dd>
        <dt>Contact</dt>
        <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
        <dt>LinkedIn</dt>
        <dd><a href="https://www.linkedin.com/company/lumecon-ai" rel="me">linkedin.com/company/lumecon-ai</a></dd>
      </dl>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .status { padding: 7rem 0 5rem; min-height: 60vh; }
  .status__inner { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
  .status h1 {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    letter-spacing: -.025em;
    color: var(--navy);
    margin: 0 0 .6rem;
  }
  .status__intro {
    color: var(--ink-2);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 2.5rem;
    max-width: 60ch;
  }
  /* Changelog timeline: a teal rail with date-stamped entries. */
  .changelog {
    list-style: none;
    margin: 0 0 3rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .changelog__item {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1.2rem;
    padding-left: 1.1rem;
    border-left: 2px solid var(--accent);
  }
  .changelog__date {
    font-size: .7rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent-text);
    font-weight: 600;
    padding-top: .15rem;
  }
  .changelog__title {
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 600;
    color: var(--navy);
    margin: 0 0 .3rem;
    letter-spacing: -.01em;
  }
  .changelog__text { margin: 0; color: var(--ink-2); font-size: .94rem; line-height: 1.6; }
  .status__tech-head {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  @media (max-width: 560px) {
    .changelog__item { grid-template-columns: 1fr; gap: .35rem; }
  }
  .status__list { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 3fr); gap: .8rem 1.5rem; margin: 0; }
  .status__list dt {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 500;
    align-self: center;
  }
  .status__list dd { margin: 0; color: var(--ink-2); font-size: .95rem; line-height: 1.6; }
  .status__list ul { list-style: none; padding: 0; margin: 0; }
  .status__list a { color: var(--navy); text-decoration: underline; text-underline-offset: .25em; }
  .status__list a:hover { color: var(--accent-text); }
</style>
