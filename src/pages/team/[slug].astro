---
/**
 * /team/<slug> — one succinct page per person.
 *
 * The /about page lists everyone as a compact card and links here for
 * the bio. The page shows only the person's own bio (summary + the
 * paragraphs from src/data/team.ts) and their contact / profile links
 * — nothing beyond what their bio already said.
 */
import { site } from '../../config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { TEAM, personPath, type Person } from '../../data/team';
import '../../styles/global.css';
import '../../styles/nav.css';
import '../../styles/footer.css';
import '../../styles/person-page.css';

export function getStaticPaths() {
  return TEAM.map((person) => ({ params: { slug: person.slug }, props: { person } }));
}

interface Props { person: Person }
const { person } = Astro.props;
const p = person;

const groupLabel = p.group === 'advisor' ? 'Advisor & Contributor' : 'Team';

const linkedinIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>`;
const scholarIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 3 1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v3.92L12 21l7-3.9v-3.92L12 17l-7-3.82z"/></svg>`;

const personUrl = `${site.url}${personPath(p.slug)}`;
const personNode: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": personUrl,
  "name": p.name,
  "url": personUrl,
  "jobTitle": p.title,
  "description": p.summary,
  "worksFor": { "@type": "Organization", "@id": `${site.url}#org`, "name": site.legalName },
};
if (p.email) personNode.email = `mailto:${p.email}`;
const sameAs = [p.linkedin, p.scholar].filter(Boolean);
if (sameAs.length) personNode.sameAs = sameAs;
if (p.alumniOf?.length) personNode.alumniOf = p.alumniOf.map((n) => ({ "@type": "EducationalOrganization", "name": n }));
if (p.prevAffiliations?.length) personNode.affiliation = p.prevAffiliations.map((n) => ({ "@type": "Organization", "name": n }));

const pubs = p.publications ?? [];
/* The person's name as it appears in author lists (without any
   credential suffix like ", PhD" / ", MPP"), used to bold their entry
   within each publication's author line. */
const meName = p.name.replace(/,\s*(PhD|MPP)$/i, '');
const boldMe = (authors: string) =>
  authors.replaceAll(meName, `<strong class="person-pub__me">${meName}</strong>`);

const jsonLd = [
  personNode,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "About", "item": `${site.url}/about` },
      { "@type": "ListItem", "position": 3, "name": p.name, "item": personUrl },
    ],
  },
  ...pubs.map((pub) => {
    const node: Record<string, unknown> = {
      "@context": "https://schema.org",
      "@type": pub.type === 'book' ? "Book" : "ScholarlyArticle",
      "name": pub.title,
      "datePublished": pub.year,
      "author": { "@type": "Person", "@id": personUrl, "name": p.name },
      "publisher": { "@type": "Organization", "name": pub.venue },
    };
    if (pub.url) node.url = pub.url;
    return node;
  }),
];
---
<BaseLayout
  title={`${p.name} | Lumecon`}
  description={`${p.name} — ${p.title} at Lumecon. ${p.summary}`}
  canonical={`https://lumecon.ai${personPath(p.slug)}`}
  keywords={[p.name, p.title, 'Lumecon', ...(p.alumniOf ?? []), ...(p.prevAffiliations ?? [])].join(', ')}
  ogTitle={`${p.name} — ${p.title} at Lumecon`}
  ogDescription={p.summary}
  jsonLd={jsonLd}
>
  <Nav />
  <main class="person-page">
    <div class="person-page__inner">

      <a class="person-page__back" href="/about">
        <span aria-hidden="true">&larr;</span> The team
      </a>

      <header class="person-page__head">
        <span class="person-page__avatar" aria-hidden="true">{p.initials}</span>
        <div class="person-page__head-main">
          <p class="person-page__kicker">{groupLabel}</p>
          <h1 class="person-page__name reveal-soft hl-block hl-block--green">{p.name}</h1>
          <p class="person-page__role">{p.title}</p>
        </div>
      </header>

      {(p.email || p.linkedin || p.scholar) && (
        <div class="person-page__links">
          {p.email && <a class="person-page__email" href={`mailto:${p.email}`}>{p.email}</a>}
          {p.linkedin && <a class="person-page__social" href={p.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${p.name} on LinkedIn`} set:html={linkedinIcon}></a>}
          {p.scholar && <a class="person-page__social" href={p.scholar} target="_blank" rel="noopener noreferrer" aria-label={`${p.name} on Google Scholar`} set:html={scholarIcon}></a>}
        </div>
      )}

      <div class="person-page__bio">
        {p.bio.map((para) => <p>{para}</p>)}
      </div>

      {pubs.length > 0 && (
        <section class="person-page__work">
          <h2 class="person-page__sub">Selected work</h2>
          <ul class="person-pubs">
            {pubs.map((pub) => (
              <li class="person-pub">
                <p class="person-pub__venue">{pub.venue} &middot; {pub.year}</p>
                <h3 class="person-pub__title">
                  {pub.url
                    ? <a href={pub.url} target="_blank" rel="noopener noreferrer">{pub.title}</a>
                    : pub.title}
                </h3>
                <p class="person-pub__authors" set:html={boldMe(pub.authors)}></p>
                <p class="person-pub__summary">{pub.summary}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <a class="person-page__back person-page__back--bottom" href="/about">
        <span aria-hidden="true">&larr;</span> Back to the team
      </a>

    </div>
  </main>
  <Footer />
</BaseLayout>
