---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import IconCode from '../components/icons/IconCode.astro';
import IconML from '../components/icons/IconML.astro';
import IconData from '../components/icons/IconData.astro';
import IconEconomist from '../components/icons/IconEconomist.astro';
import IconMegaphone from '../components/icons/IconMegaphone.astro';
import IconChat from '../components/icons/IconChat.astro';

/**
 * Join-the-team page. WHY-first layout: open with what Lumecon does
 * in the world, then who we hire and how we work, then the roles, then
 * apply. Editorial / typographic, not card-grid. Schools live in meta
 * keywords for SEO, not in visible copy.
 */

const ROLES = [
  { Icon: IconCode,      title: 'Software engineering',          blurb: 'TypeScript, Python, Astro, d3-geo. Build the product surface across the Local, Tribal, and Global Economic Impact platforms.' },
  { Icon: IconML,        title: 'Machine learning and AI',       blurb: 'Build Cedar. The assistant that reads messy administrative uploads, surfaces every modeling assumption, and writes the source record.' },
  { Icon: IconData,      title: 'Data analytics',                blurb: 'Source and version the high-frequency public and private datasets that drive every multiplier.' },
  { Icon: IconEconomist, title: 'Economist and impact modeling', blurb: 'Input-output modeling, IMPLAN / RIMS II / REMI multipliers, regional bridges, small-region econometrics. Undergrad, master\'s, and PhD candidates welcome.' },
  { Icon: IconMegaphone, title: 'Marketing and growth',          blurb: 'SEO, content, government outreach, tribal-nation engagement, partnerships with universities and CDFIs.' },
  { Icon: IconChat,      title: 'Sales and business development', blurb: 'Pilot enrollment with municipal, tribal, and mission-driven organizations. Build the procurement playbook.' },
];

const today = new Date().toISOString().slice(0, 10);
const oneYear = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const mailto = (subject: string, body = '') =>
  `mailto:${site.email}?subject=${encodeURIComponent(subject)}` + (body ? `&body=${encodeURIComponent(body)}` : '');

const applyBody = `Hi Lumecon team,

I'd like to be considered for an early-teammate role at Lumecon Inc.

Name:
School / program:
Year:
Track of interest (Engineering / ML / Data / Economist / Marketing / Sales):
LinkedIn:
Résumé: (paste a public URL or attach the file)

One paragraph on what draws me to the work:
`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Join the Lumecon team",
    "url": `${site.url}/join`,
    "description": "Lumecon Inc. is looking for early teammates across software engineering, machine learning, data analytics, economic impact modeling, marketing, and sales. Open to undergraduate and graduate students. Unpaid early-stage roles. We mentor people who are persistent.",
    "publisher": { "@id": `${site.url}#org` },
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Early teammate, software engineering, ML, data, economist, marketing, sales",
    "description": "Lumecon Inc. is looking for early teammates across software engineering, machine learning / AI, data analytics, economic impact modeling, marketing, and sales. Built for governments and mission-driven organizations. We mentor people who are persistent. Send a résumé and we'll reach back when a fit opens.",
    "datePosted": today,
    "validThrough": oneYear,
    "employmentType": ["FULL_TIME", "INTERN"],
    "hiringOrganization": {
      "@type": "Organization",
      "name": site.legalName,
      "sameAs": site.url,
      "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
    },
    "applicantLocationRequirements": { "@type": "Country", "name": "United States" },
    "jobLocationType": "TELECOMMUTE",
    "url": `${site.url}/join`,
    "skills": "TypeScript, Python, Astro, d3, machine learning, LLM evaluation, SQL, geospatial data, input-output modeling, IMPLAN, RIMS II, REMI, government procurement, B2B sales, SEO",
  },
];
---
<BaseLayout
  title="Join the Lumecon team | Build economic impact analysis software for governments and mission-driven organizations"
  description="Lumecon Inc. is a Cornell-built, five-person economic impact analysis software company. We're looking for early teammates across software engineering, machine learning, data analytics, economic impact modeling, marketing, and sales. Open to undergraduate and graduate students. Unpaid early-stage roles. We mentor people who are persistent."
  canonical="https://lumecon.ai/join"
  keywords="join Lumecon, Lumecon careers, Lumecon team, Lumecon early team, Cornell startup, Cornell entrepreneurship, software engineering Cornell, machine learning Cornell, AI startup Cornell, data analytics Cornell, economic impact modeling Cornell, input-output modeling internship, IMPLAN internship, RIMS II internship, REMI internship, regional economics PhD, applied economics PhD, Cornell PhD, Cornell graduate student, Cornell Brooks School, Cornell Dyson, Cornell ILR, Cornell ORIE, Cornell CS, Cornell Information Science, Cornell economics, Dartmouth, Oxford, Stanford, MIT, Harvard, Princeton, Yale, UPenn Wharton, Brown, Columbia, Berkeley, Carnegie Mellon, Princeton ORFE, Berkeley ARE, Yale SOM, Oxford PPE, Federal Reserve, mission-driven startup, government technology, tribal economic impact, public sector software, send resume Lumecon"
  ogTitle="Join the Lumecon team"
  ogDescription="Cornell-built, five-person economic impact analysis software company. Looking for early teammates across engineering, ML, data, economist, marketing, and sales. We mentor people who are persistent."
  jsonLd={jsonLd}
>
  <Nav />

  <main class="join">

    <!-- WHY: open with what Lumecon does in the world. -->
    <header class="join-hero">
      <p class="join-eyebrow">Why we're building this</p>
      <h1 class="join-title">We illuminate economies.</h1>
      <div class="join-why">
        <p>A lot of people have real impact, and can't show it.</p>
        <p>That matters because money is on the line. Money that houses people, feeds people, creates jobs. Money that flows from grant programs, foundations, federal agencies, banks, and budget committees to the organizations that put it to work on the ground.</p>
        <p>When impact gets measured, the next round of capital follows it. That's the feedback loop. We build the software that closes it.</p>
        <p class="join-why__list">Lumecon's work shows up in front of <strong>governments</strong>, <strong>tribal nations</strong>, <strong>foundations</strong>, <strong>banks</strong>, <strong>universities</strong>, and the <strong>people</strong> those institutions serve.</p>
      </div>
    </header>

    <!-- WHO we hire and HOW we work. Persistence over perfection. -->
    <section class="join-team" aria-labelledby="team-title">
      <p class="join-section-kicker">The team</p>
      <h2 class="join-section-title" id="team-title">We mentor people who are persistent.</h2>
      <div class="join-team-body">
        <p>Lumecon Inc. is a five-person team, built at Cornell University. We're looking for early teammates across engineering, ML, data, economic impact modeling, marketing, and sales.</p>
        <p>If you don't have every skill on a role description, apply anyway. We're early enough that everyone is wearing several hats, and we'd rather hire someone who learns quickly and finishes things than someone who already knows the job. We'll fill the gaps with you on the way.</p>
        <p>What we look for: kindness, curiosity, ownership, and the willingness to ship work you're proud of. The roles are <strong>unpaid early-stage roles</strong>, open to undergraduate and graduate students. If that doesn't work for you right now, we understand, and we keep résumés on file for when we can pay.</p>
      </div>
    </section>

    <!-- Roles. Editorial list, no cards. Animated icons per role. -->
    <section class="join-roles" id="roles" aria-labelledby="roles-title">
      <p class="join-section-kicker">Open tracks</p>
      <h2 class="join-section-title" id="roles-title">Where you might fit.</h2>
      <ol class="role-list">
        {ROLES.map(({ Icon, title, blurb }, i) => (
          <li class="role-row">
            <span class="role-row__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="role-row__icon" aria-hidden="true"><Icon /></span>
            <div class="role-row__body">
              <h3 class="role-row__title">{title}</h3>
              <p class="role-row__blurb">{blurb}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Apply. -->
    <section class="join-apply" aria-labelledby="apply-title">
      <p class="join-section-kicker">Send a résumé</p>
      <h2 class="join-section-title" id="apply-title">Tell us what draws you to the work.</h2>
      <p class="join-apply-body">
        A résumé, the track you're interested in, and one paragraph on what draws you to the work. That's the whole application. We read every submission.
      </p>
      <div class="join-cta">
        <a href={mailto('Lumecon early-teammate application', applyBody)} class="btn">Send a résumé</a>
        <a href={`mailto:${site.email}`} class="btn btn--ghost">Email directly</a>
      </div>
      <p class="join-apply-note">
        Or email <a href={`mailto:${site.email}`} class="join-apply-email">{site.email}</a> with your résumé and a short note.
      </p>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .join {
    background: var(--white);
    padding: clamp(6rem, 11vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
  }
  .join-hero,
  .join-team,
  .join-roles,
  .join-apply {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }

  /* ---------- Hero: WHY ---------- */
  .join-eyebrow {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 1.1rem;
  }
  .join-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.04;
    letter-spacing: -.028em;
    color: var(--navy);
    margin: 0 0 1.8rem;
    max-width: 22ch;
  }
  .join-why p {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1rem;
    max-width: 60ch;
    font-weight: 400;
  }
  .join-why p:first-child {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    line-height: 1.35;
    color: var(--navy);
    letter-spacing: -.012em;
    border-left: 2px solid var(--gold);
    padding-left: 1.1rem;
    margin-bottom: 1.6rem;
  }
  .join-why__list strong {
    color: var(--navy);
    font-weight: 600;
  }

  /* ---------- Section frame (no cards) ---------- */
  .join-team,
  .join-roles,
  .join-apply { margin-top: clamp(4rem, 7vw, 6rem); }

  .join-section-kicker {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 500;
    margin: 0 0 .8rem;
    padding-bottom: .8rem;
    border-bottom: 1px solid var(--rule);
  }
  .join-section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--navy);
    letter-spacing: -.022em;
    line-height: 1.12;
    margin: 0 0 1.6rem;
    max-width: 24ch;
  }

  .join-team-body p {
    font-family: var(--font-sans);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1rem;
    max-width: 62ch;
    font-weight: 400;
  }
  .join-team-body strong { color: var(--navy); font-weight: 600; }

  /* ---------- Roles list (editorial, no cards) ---------- */
  .role-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .role-row {
    display: grid;
    grid-template-columns: 2.4rem 3rem 1fr;
    gap: 1rem 1.4rem;
    align-items: start;
    padding: 1.4rem 0;
    border-top: 1px solid var(--rule);
  }
  .role-row:last-child { border-bottom: 1px solid var(--rule); }
  .role-row__num {
    font-family: var(--font-mono);
    font-size: .82rem;
    color: var(--ink-3);
    letter-spacing: .04em;
    padding-top: .35rem;
  }
  .role-row__icon {
    display: inline-flex;
    color: var(--navy);
    align-items: center;
    justify-content: center;
    padding-top: .15rem;
  }
  .role-row__icon svg { width: 36px; height: 36px; display: block; }
  .role-row__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    color: var(--navy);
    letter-spacing: -.014em;
    margin: 0 0 .35rem;
  }
  .role-row__blurb {
    font-family: var(--font-sans);
    font-size: .98rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
    font-weight: 400;
  }

  /* ---------- Apply ---------- */
  .join-apply-body {
    font-family: var(--font-sans);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1.6rem;
    max-width: 58ch;
    font-weight: 400;
  }
  .join-cta { display: flex; gap: .8rem; flex-wrap: wrap; }
  .join-apply-note {
    font-family: var(--font-sans);
    font-size: .92rem;
    color: var(--ink-3);
    margin: 1.2rem 0 0;
  }
  .join-apply-email {
    font-family: var(--font-mono);
    color: var(--navy);
    border-bottom: 1px solid var(--rule-strong);
  }

  @media (max-width: 600px) {
    .role-row {
      grid-template-columns: 1.9rem 2.2rem 1fr;
      gap: 0 .75rem;
      padding: 1.2rem 0;
      align-items: start;
    }
    .role-row__num { font-size: .76rem; padding-top: .4rem; }
    .role-row__icon { padding-top: .15rem; }
    .role-row__icon svg { width: 26px; height: 26px; }
    .role-row__title { font-size: 1.05rem; }
    .role-row__blurb { font-size: .92rem; }
  }
</style>
