---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import IconCode from '../components/icons/IconCode.astro';
import IconML from '../components/icons/IconML.astro';
import IconData from '../components/icons/IconData.astro';
import IconMegaphone from '../components/icons/IconMegaphone.astro';
import IconChat from '../components/icons/IconChat.astro';
import IconAcademic from '../components/icons/IconAcademic.astro';
import IconRemote from '../components/icons/IconRemote.astro';
import IconImpact from '../components/icons/IconImpact.astro';
import IconEconomist from '../components/icons/IconEconomist.astro';

/**
 * Join-the-team page. Single recruiting surface. Folds in what /interns
 * used to do (specific role list + JobPosting schema) so we don't have
 * two pages doing the same job.
 *
 * Tone: honest and short. The roles are unpaid; we say that plainly
 * once and don't dwell on it. The schools list lives in meta keywords
 * for SEO, not in visible copy — we don't want to read like we're
 * making a case from desperation.
 */

const ROLES = [
  { Icon: IconCode,       title: 'Software Engineering',           blurb: 'TypeScript, Python, Astro, d3-geo. Product surface across the Local, Tribal, and Global Economic Impact platforms.' },
  { Icon: IconML,         title: 'Machine Learning / AI',          blurb: 'Build Cedar — the AI assistant that reads messy administrative uploads, surfaces each modeling assumption, and writes the source record.' },
  { Icon: IconData,       title: 'Data Analytics',                 blurb: 'Source and version the high-frequency public and private datasets that drive every multiplier.' },
  { Icon: IconEconomist,  title: 'Economist / Impact Modeling',    blurb: 'Input-output modeling, IMPLAN / RIMS II / REMI multipliers, regional bridges, and small-region econometrics. Undergrad, master\'s, and PhD candidates welcome.' },
  { Icon: IconMegaphone,  title: 'Marketing & Growth',             blurb: 'SEO, content, government outreach, tribal-nation engagement, and partnerships with universities and CDFIs.' },
  { Icon: IconChat,       title: 'Sales & Business Development',   blurb: 'Pilot enrollment with municipal, tribal, and mission-driven organizations. Build the procurement playbook.' },
];

const VALUES = [
  { Icon: IconAcademic, title: 'Cornell-built',          blurb: 'Built at Cornell, with counsel from the Cornell Law Entrepreneurship Law Clinic. The team\'s academic background spans Cornell, Dartmouth, Oxford, MIT, and Yale. Prior professional experience includes the Federal Reserve Banks of Minneapolis and Philadelphia and the Federal Reserve Board of Governors in Washington, DC.' },
  { Icon: IconImpact,   title: 'Real users, real work',  blurb: 'Your work lands in front of council members, tribal leaders, foundation officers, and federal grant reviewers — not in a demo or a deck.' },
  { Icon: IconRemote,   title: 'Remote-friendly',        blurb: 'Distributed team. Async by default, with synchronous time reserved for product reviews and government calls.' },
];

const today = new Date().toISOString().slice(0, 10);
const oneYear = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const mailto = (subject: string, body = '') =>
  `mailto:${site.email}?subject=${encodeURIComponent(subject)}` + (body ? `&body=${encodeURIComponent(body)}` : '');

const applyBody = `Hi Lumecon team,

I'd like to be considered for an early-teammate role at Lumecon Inc.

Name:
School / program:
Year:
Track of interest (Engineering / ML / Data / Economist / Marketing / Sales):
LinkedIn:
Résumé: (paste a public URL or attach the file)

One paragraph on what draws me to the work:
`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Join the Lumecon team",
    "url": `${site.url}/join`,
    "description": "Lumecon Inc. is looking for early teammates. Send a résumé even without a posted role — we maintain a talent network for students and full-time hires in software engineering, machine learning, data analytics, economic impact modeling, marketing, and sales.",
    "publisher": { "@id": `${site.url}#org` },
  },
  // A general open-call JobPosting so Google for Jobs picks the page up.
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Early teammate — software engineering, ML, data, economist, marketing, sales",
    "description": "Lumecon Inc. is looking for early teammates across software engineering, machine learning / AI, data analytics, economic impact modeling, marketing, and sales. Built for governments and mission-driven organizations. Send a résumé and we'll reach back when a fit opens.",
    "datePosted": today,
    "validThrough": oneYear,
    "employmentType": ["FULL_TIME", "INTERN"],
    "hiringOrganization": {
      "@type": "Organization",
      "name": site.legalName,
      "sameAs": site.url,
      "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
    },
    "applicantLocationRequirements": { "@type": "Country", "name": "United States" },
    "jobLocationType": "TELECOMMUTE",
    "url": `${site.url}/join`,
    "skills": "TypeScript, Python, Astro, d3, machine learning, LLM evaluation, SQL, geospatial data, input-output modeling, IMPLAN, RIMS II, REMI, government procurement, B2B sales, SEO",
  },
];
---
<BaseLayout
  title="Join the Lumecon team | Build economic impact analysis software for governments and mission-driven organizations"
  description="Lumecon Inc. is a Cornell-built, five-person economic impact analysis software company. We're looking for early teammates across software engineering, machine learning, data analytics, economic impact modeling, marketing, and sales. Open to undergraduate and graduate students. Unpaid early-stage roles."
  canonical="https://lumecon.ai/join"
  keywords="join Lumecon, Lumecon careers, Lumecon team, Lumecon early team, Cornell startup, Cornell entrepreneurship, software engineering Cornell, machine learning Cornell, AI startup Cornell, data analytics Cornell, economic impact modeling Cornell, input-output modeling internship, IMPLAN internship, RIMS II internship, REMI internship, regional economics PhD, applied economics PhD, Cornell PhD, Cornell graduate student, Cornell Brooks School, Cornell Dyson, Cornell ILR, Cornell ORIE, Cornell CS, Cornell Information Science, Cornell economics, Dartmouth, Oxford, Stanford, MIT, Harvard, Princeton, Yale, UPenn Wharton, Brown, Columbia, Berkeley, Carnegie Mellon, Princeton ORFE, Berkeley ARE, Yale SOM, Oxford PPE, Federal Reserve, mission-driven startup, government technology, tribal economic impact, public sector software, send resume Lumecon"
  ogTitle="Join the Lumecon team"
  ogDescription="Cornell-built, five-person economic impact analysis software company looking for early teammates across engineering, ML, data, economist, marketing, and sales. Send a résumé."
  jsonLd={jsonLd}
>
  <Nav />

  <main class="join">
    <header class="join-hero">
      <p class="join-eyebrow">Looking for early teammates · five-person team</p>
      <h1 class="join-title">Build economic impact analysis software for governments and mission-driven organizations.</h1>
      <p class="join-lede">
        Lumecon Inc. is a Cornell-built, five-person team. We're looking for early teammates across software engineering, machine learning, data analytics, economic impact modeling, marketing, and sales. Open to undergraduate and graduate students. <strong>These are unpaid early-stage roles.</strong> Send a résumé and a one-paragraph note on what draws you to the work.
      </p>
      <div class="join-cta">
        <a href={mailto('Lumecon early-teammate application', applyBody)} class="btn">Send a résumé</a>
        <a href="#roles" class="btn btn--ghost">See the roles ↓</a>
      </div>
      <p class="join-cta-note">
        Or email <a href={`mailto:${site.email}`} class="join-cta-email">{site.email}</a> directly with your résumé and a short note.
      </p>
    </header>

    <section class="join-roles" id="roles" aria-labelledby="roles-title">
      <h2 class="join-section-title" id="roles-title">Roles</h2>
      <div class="role-grid">
        {ROLES.map(({ Icon, title, blurb }) => (
          <article class="role-card">
            <span class="role-card__icon" aria-hidden="true"><Icon /></span>
            <h3 class="role-card__title">{title}</h3>
            <p class="role-card__blurb">{blurb}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="join-values" aria-labelledby="values-title">
      <h2 class="join-section-title" id="values-title">About the team</h2>
      <div class="value-grid">
        {VALUES.map(({ Icon, title, blurb }) => (
          <article class="value-card">
            <span class="value-card__icon" aria-hidden="true"><Icon /></span>
            <h3 class="value-card__title">{title}</h3>
            <p class="value-card__blurb">{blurb}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="join-manifesto" aria-labelledby="manifesto-title">
      <h2 class="join-section-title join-section-title--manifesto" id="manifesto-title">Who we work with</h2>
      <p class="join-manifesto-body">
        People who are <strong>kind</strong>, <strong>creative</strong>, and <strong>care</strong>. People who <strong>question assumptions</strong> and <strong>take ownership</strong>.
      </p>
      <p class="join-manifesto-body join-manifesto-body--quiet">
        Not buzzwords. The world is changing fast — help us change it, or get left behind.
      </p>
    </section>

    <section class="join-final" aria-labelledby="final-title">
      <h2 class="join-section-title" id="final-title">Send a résumé</h2>
      <p class="join-final-body">
        We read every submission. Include your school, the track you're interested in, and one paragraph on what draws you to the work.
      </p>
      <div class="join-cta">
        <a href={mailto('Lumecon early-teammate application', applyBody)} class="btn">Send a résumé</a>
        <a href={`mailto:${site.email}`} class="btn btn--ghost">Email directly</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .join {
    background: var(--white);
    padding: clamp(6rem, 11vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
  }
  .join-hero, .join-roles, .join-values, .join-manifesto, .join-final {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }
  .join-eyebrow {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .join-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -.025em;
    color: var(--navy);
    margin: 0;
    max-width: 24ch;
  }
  .join-lede {
    font-family: var(--font-sans);
    font-size: 1.12rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 1.4rem 0 0;
    max-width: 64ch;
  }
  .join-lede strong { color: var(--navy); font-weight: 600; }
  .join-cta { display: flex; gap: .8rem; flex-wrap: wrap; margin: 2rem 0 0; }
  .join-cta-note {
    font-family: var(--font-sans);
    font-size: .92rem;
    color: var(--ink-3);
    margin: 1rem 0 0;
  }
  .join-cta-email {
    font-family: var(--font-mono);
    color: var(--navy);
    border-bottom: 1px solid var(--rule-strong);
  }
  .join-section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    color: var(--navy);
    letter-spacing: -.02em;
    margin: 0 0 1.6rem;
    padding-bottom: .8rem;
    border-bottom: 1px solid var(--rule);
  }
  .join-roles { margin-top: clamp(3rem, 6vw, 5rem); }
  .role-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.6rem 2rem;
  }
  .role-card {
    padding: 1.4rem;
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: 8px;
    transition: border-color .18s var(--ease), transform .18s var(--ease);
  }
  .role-card:hover {
    border-color: var(--navy);
    transform: translateY(-2px);
  }
  .role-card__icon {
    display: inline-flex;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  .role-card__icon svg { width: 32px; height: 32px; display: block; }
  .role-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.12rem;
    color: var(--navy);
    letter-spacing: -.012em;
    margin: 0 0 .5rem;
  }
  .role-card__blurb {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    font-weight: 400;
  }

  .join-values { margin-top: clamp(3rem, 6vw, 5rem); }
  .value-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.6rem 2rem;
  }
  .value-card {
    padding: 0;
    border-left: 2px solid var(--gold);
    padding-left: 1.2rem;
  }
  .value-card__icon {
    display: inline-flex;
    color: var(--navy);
    margin-bottom: .8rem;
  }
  .value-card__icon svg { width: 28px; height: 28px; display: block; }
  .value-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.08rem;
    color: var(--navy);
    letter-spacing: -.012em;
    margin: 0 0 .5rem;
  }
  .value-card__blurb {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    font-weight: 400;
  }

  .join-manifesto {
    margin-top: clamp(3rem, 6vw, 5rem);
    padding: clamp(2rem, 4vw, 3rem) clamp(2rem, 4vw, 3rem);
    background: var(--navy);
    color: var(--white);
    border-radius: 8px;
    max-width: calc(1040px - 2 * var(--container-pad));
  }
  .join-manifesto .join-section-title--manifesto {
    color: var(--white);
    border-bottom-color: rgba(255, 255, 255, .14);
    margin-bottom: 1.4rem;
  }
  .join-manifesto-body {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    line-height: 1.35;
    letter-spacing: -.012em;
    color: var(--white);
    margin: 0 0 1.2rem;
    max-width: 64ch;
  }
  .join-manifesto-body strong {
    color: var(--gold);
    font-weight: 600;
  }
  .join-manifesto-body--quiet {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    font-weight: 400;
    color: rgba(255, 255, 255, .82);
    margin-bottom: 0;
  }

  .join-final {
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--rule);
  }
  .join-final-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 1.4rem;
    max-width: 60ch;
  }
</style>
