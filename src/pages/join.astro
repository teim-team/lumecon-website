---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import IconCode from '../components/icons/IconCode.astro';
import IconML from '../components/icons/IconML.astro';
import IconData from '../components/icons/IconData.astro';
import IconEconomist from '../components/icons/IconEconomist.astro';
import IconMegaphone from '../components/icons/IconMegaphone.astro';
import IconChat from '../components/icons/IconChat.astro';
// Section-header icons (one per narrative section on this page)
import IconRipple from '../components/icons/IconRipple.astro';
import IconShift from '../components/icons/IconShift.astro';
import IconMentor from '../components/icons/IconMentor.astro';

/**
 * Join-the-team page. WHY-first layout: open with what Lumecon does
 * in the world, then who we hire and how we work, then the roles, then
 * apply. Editorial / typographic, not card-grid. Schools live in meta
 * keywords for SEO, not in visible copy.
 */

const ROLES = [
  { Icon: IconCode,      title: 'Software engineering',          blurb: 'Python, TypeScript, AWS, Astro, d3-geo. Build the product surface across the Local, Tribal, and Global Economic Impact platforms.' },
  { Icon: IconML,        title: 'Machine learning and AI',       blurb: 'Build Cedar, the assistant that reads messy administrative uploads, surfaces every modeling assumption, and writes the source record.' },
  { Icon: IconData,      title: 'Data analytics',                blurb: 'Source and version the high-frequency public and private datasets that feed Lumecon\'s economic impact studies.' },
  { Icon: IconEconomist, title: 'Economist and impact modeling', blurb: 'Design the methodology behind Lumecon\'s multipliers. Input-output modeling, regional bridges, and small-region econometrics for the geographies the legacy tools struggle with. Undergrad, master\'s, and PhD candidates welcome.' },
  { Icon: IconMegaphone, title: 'Marketing and growth',          blurb: 'SEO, content, government outreach, tribal-nation engagement, partnerships with universities and CDFIs.' },
  { Icon: IconChat,      title: 'Sales and business development', blurb: 'Pilot enrollment with municipal, tribal, and mission-driven organizations. Build the procurement playbook.' },
];

const today = new Date().toISOString().slice(0, 10);
const oneYear = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const mailto = (subject: string, body = '') =>
  `mailto:${site.email}?subject=${encodeURIComponent(subject)}` + (body ? `&body=${encodeURIComponent(body)}` : '');

const applyBody = `Hi Lumecon team,

I'd like to be considered for an early-teammate role at Lumecon Inc.

Name:
School / program:
Year:
Track of interest (Engineering / ML / Data / Economist / Marketing / Sales):
LinkedIn:
Résumé: (paste a public URL or attach the file)

One paragraph on what draws me to the work:
`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Join the Lumecon team",
    "url": `${site.url}/join`,
    "description": "Lumecon Inc. is looking for early teammates across software engineering, machine learning, data analytics, economic impact modeling, marketing, and sales. Open to undergraduate and graduate students. Unpaid early-stage roles. We mentor people who are persistent.",
    "publisher": { "@id": `${site.url}#org` },
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Early teammate, software engineering, ML, data, economist, marketing, sales",
    "description": "Lumecon Inc. is looking for early teammates across software engineering, machine learning / AI, data analytics, economic impact modeling, marketing, and sales. Built for governments and mission-driven organizations. We mentor people who are persistent. Send a résumé and we'll reach back when a fit opens.",
    "datePosted": today,
    "validThrough": oneYear,
    "employmentType": ["FULL_TIME", "INTERN"],
    "hiringOrganization": {
      "@type": "Organization",
      "name": site.legalName,
      "sameAs": site.url,
      "logo": `${site.url}/brand/lumecon-logo-horizontal-transparent.png`,
    },
    "applicantLocationRequirements": { "@type": "Country", "name": "United States" },
    "jobLocationType": "TELECOMMUTE",
    "url": `${site.url}/join`,
    "skills": "TypeScript, Python, Astro, d3, machine learning, LLM evaluation, SQL, geospatial data, input-output modeling, IMPLAN, RIMS II, REMI, government procurement, B2B sales, SEO",
  },
];
---
<BaseLayout
  title="Join the Lumecon team | Build economic impact analysis software for governments, enterprises, and mission-driven organizations"
  description="Six-person economic impact analysis software company built at Ivy League and peer schools. Hiring early teammates across engineering, ML, data, economic modeling, marketing, and sales. Undergraduate and graduate students welcome. Unpaid early-stage roles."
  canonical="https://lumecon.ai/join"
  keywords="join Lumecon, Lumecon careers, Lumecon team, Lumecon early team, Cornell startup, Cornell entrepreneurship, software engineering Cornell, machine learning Cornell, AI startup Cornell, data analytics Cornell, economic impact modeling Cornell, input-output modeling internship, IMPLAN internship, RIMS II internship, REMI internship, regional economics PhD, applied economics PhD, Cornell PhD, Cornell graduate student, Cornell Brooks School, Cornell Dyson, Cornell ILR, Cornell ORIE, Cornell CS, Cornell Information Science, Cornell economics, Dartmouth, Oxford, Stanford, MIT, Harvard, Princeton, Yale, UPenn Wharton, Brown, Columbia, Berkeley, Carnegie Mellon, Princeton ORFE, Berkeley ARE, Yale SOM, Oxford PPE, Federal Reserve, mission-driven startup, government technology, tribal economic impact, public sector software, send resume Lumecon"
  ogTitle="Join the Lumecon team"
  ogDescription="Six-person economic impact analysis software company built at Ivy League and peer schools. Looking for early teammates across engineering, ML, data, economist, marketing, and sales. We mentor people who are persistent."
  jsonLd={jsonLd}
>
  <Nav />

  <main class="join">

    <!-- WHY: open with what Lumecon does in the world. The lede
         quote stays always visible; the rest collapses. -->
    <header class="join-hero">
      <div class="join-section-icon" aria-hidden="true"><IconRipple /></div>
      <p class="join-eyebrow reveal-soft">Why we're building this</p>
      <h1 class="join-title reveal-soft hl-block hl-block--green" data-stagger="1">We <em class="lumin">luminate</em> economies.</h1>
      <div class="join-why">
        <p class="join-why__lede reveal-soft" data-stagger="2">A lot of organizations have real economic impact, and no way to show it.</p>
        <details class="join-collapse">
          <summary class="join-collapse__toggle">
            <span class="join-collapse__label join-collapse__label--closed">Why that matters</span>
            <span class="join-collapse__label join-collapse__label--open">Less</span>
            <span class="join-collapse__chev" aria-hidden="true"></span>
          </summary>
          <div class="join-collapse__body">
            <p>That matters because the next round of capital follows the evidence. When economic impact gets measured, budgets get approved, foundations write the check, councils pass the bill, banks underwrite the loan, communities support the project. When it doesn't get measured, none of that happens.</p>
            <p>Lumecon's work shows up in front of <strong>governments</strong>, <strong>tribal nations</strong>, <strong>foundations</strong>, <strong>banks</strong>, <strong>universities</strong>, and the communities those institutions serve. We build the software that makes the economic impact legible, so the dollars that house, feed, and employ people keep moving.</p>
          </div>
        </details>
      </div>
    </header>

    <!-- Quick credentials strip — small, plain, monospaced. Same
         pattern as the hero proof points on the home page. The
         credentials end with a link to /about so applicants can
         see the existing team in detail before they apply. -->
    <ul class="join-cred reveal-soft" aria-label="Team credentials" data-stagger="3">
      <li>Built at Ivy League and peer schools</li>
      <li>Six people</li>
      <li>Federal Reserve experience</li>
      <li>Patent pending</li>
      <li><a class="join-cred__link" href="/about">Meet the team &rarr;</a></li>
    </ul>

    <!-- The world is changing. Headline carries the message; body
         is opt-in. -->
    <section class="join-transition" aria-labelledby="transition-title">
      <div class="join-section-icon" aria-hidden="true"><IconShift /></div>
      <p class="join-section-kicker reveal-soft">The moment</p>
      <h2 class="join-section-title reveal-soft hl-block hl-block--b" id="transition-title">The world is changing fast. Most organizations are still figuring out the transition.</h2>
      <details class="join-collapse">
        <summary class="join-collapse__toggle">
          <span class="join-collapse__label join-collapse__label--closed">Read the full picture</span>
          <span class="join-collapse__label join-collapse__label--open">Less</span>
          <span class="join-collapse__chev" aria-hidden="true"></span>
        </summary>
        <div class="join-collapse__body">
          <p>Public agencies, tribal governments, foundations, and universities are being asked to do more with the same headcount, on shorter cycles, against tougher questions about value and return. The legacy tools weren't built for that.</p>
          <p>We're using AI to make the work easier, not to replace people. The aim is to <strong>create</strong> jobs by helping the organizations that fund them tell a stronger economic story, not to automate anyone out of one.</p>
        </div>
      </details>
    </section>

    <!-- WHO we hire and HOW we work. Persistence over perfection. -->
    <section class="join-team" aria-labelledby="team-title">
      <div class="join-section-icon" aria-hidden="true"><IconMentor /></div>
      <p class="join-section-kicker reveal-soft">The team</p>
      <h2 class="join-section-title reveal-soft hl-block hl-block--gold" id="team-title">We mentor people who are persistent.</h2>
      <details class="join-collapse">
        <summary class="join-collapse__toggle">
          <span class="join-collapse__label join-collapse__label--closed">What that means in practice</span>
          <span class="join-collapse__label join-collapse__label--open">Less</span>
          <span class="join-collapse__chev" aria-hidden="true"></span>
        </summary>
        <div class="join-collapse__body">
          <p>Lumecon Inc. is a six-person team built at Ivy League and peer schools. We're looking for early teammates across engineering, ML, data, economic impact modeling, marketing, and sales.</p>
          <p>If you don't have every skill on a role description, apply anyway. We're early enough that everyone is wearing several hats, and we'd rather work with someone who learns quickly and finishes things than someone who already knows the job. We'll fill the gaps with you on the way.</p>
          <p>What we look for: kindness, curiosity, ownership, and the willingness to ship work you're proud of. The roles are <strong>unpaid early-stage roles</strong>, open to undergraduate and graduate students.</p>
          <p>We're looking for people who want to stick around and help build a strong team. We can't make any promises, but the early teammates who put in the work are the ones we'd want with us when Lumecon raises capital and starts generating revenue.</p>
        </div>
      </details>
    </section>

    <!-- Roles. Editorial list, no numbers — icons + title + blurb. -->
    <section class="join-roles" id="roles" aria-labelledby="roles-title">
      <p class="join-section-kicker reveal-soft">Open tracks</p>
      <h2 class="join-section-title reveal-soft hl-block hl-block--green-b" id="roles-title">Where you might fit.</h2>
      <ul class="role-list">
        {ROLES.map(({ Icon, title, blurb }, i) => (
          <li class="role-row reveal-soft" data-stagger={i + 1}>
            <details class="role-row__details">
              <summary class="role-row__head">
                <span class="role-row__icon" aria-hidden="true"><Icon /></span>
                <h3 class="role-row__title">{title}</h3>
                <span class="role-row__chev" aria-hidden="true"></span>
              </summary>
              <p class="role-row__blurb">{blurb}</p>
            </details>
          </li>
        ))}
      </ul>
    </section>

    <!-- Apply. Panelled so the CTAs read as the deliberate end of
         the page instead of trailing copy. -->
    <section class="join-apply" aria-labelledby="apply-title">
      <div class="join-apply__panel">
        <p class="join-section-kicker join-apply__kicker reveal-soft">Send a résumé</p>
        <h2 class="join-section-title reveal-soft hl-block hl-block--c" id="apply-title">Tell us what draws you to the work.</h2>
        <p class="join-apply-body reveal-soft" data-stagger="1">
          A résumé, the track you're interested in, and one paragraph on what draws you to the work. That's the whole application. We read every submission.
        </p>
        <div class="join-cta reveal-soft" data-stagger="2">
          <a href={mailto('Lumecon early-teammate application', applyBody)} class="btn">Send a résumé</a>
          <a href={`mailto:${site.email}`} class="btn btn--ghost">Email directly</a>
        </div>
        <p class="join-apply-note reveal-soft" data-stagger="3">
          Or email <a href={`mailto:${site.email}`} class="join-apply-email">{site.email}</a> with your résumé and a short note.
        </p>
      </div>
    </section>

    <!-- Closing cross-link: send applicants to the existing team
         page so they can see who they would be working with before
         they hit send. -->
    <aside class="join-bridge" aria-label="Meet the existing team">
      <div class="join-bridge__inner">
        <p class="join-bridge__kicker">Before you apply</p>
        <p class="join-bridge__copy">See who you would be building Lumecon with. The team page lists every current teammate, their lead area, prior affiliations (Federal Reserve, Cornell, Dartmouth, Duke, Oxford, MIT), and the cross-functional structure they work inside.</p>
        <a href="/about" class="btn">Meet the team &rarr;</a>
      </div>
    </aside>

  </main>

  <Footer />
</BaseLayout>

<style>
  .join {
    background: var(--white);
    padding: clamp(6rem, 11vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
  }
  /* Each major join section reads as a self-contained "page": at
     least one viewport tall, vertically centered content, snap-
     aligned so the visitor lands cleanly on the next chunk. The
     global html scroll-snap-type: y proximity (in global.css) does
     the snapping; these blocks supply the snap targets. */
  .join-hero,
  .join-transition,
  .join-team,
  .join-roles,
  .join-apply {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4.5rem) var(--container-pad);
    min-block-size: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    scroll-snap-align: start;
  }
  /* Alternate-section backgrounds (cream on the even sections) so
     the page reads as five distinct "chapters" rather than one
     undifferentiated wash of text. box-shadow + clip-path extends
     the chapter's background full-bleed without breaking the
     1200px max-width content constraint. */
  .join-transition,
  .join-roles {
    background: var(--cream);
    box-shadow: 0 0 0 50vmax var(--cream);
    clip-path: inset(0 -50vmax);
  }
  /* The hero already gets its top-padding from .join. Don't double
     it. */
  .join-hero { padding-top: 0; }
  /* Section-icon layout: on desktop the section becomes a 2-col
     grid with the icon vertically centered against the headline.
     On mobile the icon stacks above the headline. */
  @media (min-width: 881px) {
    .join-hero,
    .join-transition,
    .join-team {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 180px;
      column-gap: clamp(2rem, 4vw, 3rem);
      align-items: center;
      /* Center the row inside the 100dvh section so the content
         actually reads as a centered "page" rather than sticking
         to the top. */
      align-content: center;
    }
    .join-section-icon {
      grid-column: 2;
      grid-row: 1 / span 99;
      width: 160px;
      height: 160px;
      align-self: center;
      justify-self: end;
    }
  }
  .join-section-icon {
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .join-section-icon :global(svg) { width: 100%; height: 100%; display: block; }
  @media (max-width: 880px) {
    .join-section-icon {
      width: 88px;
      height: 88px;
      margin-bottom: 1.1rem;
    }
  }
  /* "luminate" picks up font + glow from the shared .lumin class in
     global.css; this block adjusts visual weight for the join hero. */
  .join-title em.lumin { font-size: 1.05em; padding: 0 .08em; }

  /* ---------- Hero: WHY ---------- */
  .join-eyebrow {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 1.1rem;
  }
  .join-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.04;
    letter-spacing: -.028em;
    color: var(--navy);
    margin: 0 0 1.8rem;
    max-width: 22ch;
    /* Reserve space on desktop so the title doesn't run under the
       absolutely-positioned section icon. */
    padding-right: 0;
  }
  .join-why__lede {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    line-height: 1.35;
    color: var(--navy);
    letter-spacing: -.012em;
    border-left: 2px solid var(--accent);
    padding-left: 1.1rem;
    margin: 0 0 1.4rem;
    max-width: 60ch;
  }

  /* ---------- Collapsible narrative blocks ----------
     'Why that matters', 'The moment', 'The team' bodies all sit
     behind a small toggle so the page reads as headlines first,
     detail-on-demand. */
  .join-collapse { margin: 0; }
  .join-collapse__toggle {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--navy);
    padding: .55rem .85rem .55rem 1rem;
    border: 1px solid var(--rule-strong, rgba(14,21,48,.18));
    border-radius: 999px;
    transition: background .18s var(--ease), color .18s var(--ease), border-color .18s var(--ease);
  }
  .join-collapse__toggle::-webkit-details-marker { display: none; }
  .join-collapse__toggle:hover {
    background: var(--navy);
    color: var(--white);
    border-color: var(--navy);
  }
  .join-collapse__toggle:hover .join-collapse__chev { border-color: var(--white); }
  .join-collapse__toggle:hover .join-collapse__chev::before {
    border-right-color: var(--white);
    border-bottom-color: var(--white);
  }
  .join-collapse__label--open { display: none; }
  .join-collapse[open] .join-collapse__label--closed { display: none; }
  .join-collapse[open] .join-collapse__label--open { display: inline; }
  .join-collapse__chev {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid var(--rule-strong, rgba(14,21,48,.18));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color .2s var(--ease);
  }
  .join-collapse__chev::before {
    content: '';
    width: 5px;
    height: 5px;
    border-right: 1.4px solid var(--navy);
    border-bottom: 1.4px solid var(--navy);
    transform: rotate(45deg) translate(-1px, -1px);
    transition: transform .25s var(--ease), border-color .2s var(--ease);
  }
  .join-collapse[open] .join-collapse__chev::before {
    transform: rotate(225deg) translate(-1px, -1px);
  }
  .join-collapse__body {
    margin-top: 1.2rem;
    animation: join-collapse-in .25s var(--ease);
  }
  .join-collapse__body p {
    font-family: var(--font-sans);
    font-size: clamp(1.08rem, 1.55vw, 1.2rem);
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1rem;
    max-width: 62ch;
    font-weight: 400;
  }
  .join-collapse__body p:last-child { margin-bottom: 0; }
  .join-collapse__body strong { color: var(--navy); font-weight: 600; }
  @keyframes join-collapse-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .join-collapse__body { animation: none; }
  }

  /* ---------- Section frame (no cards) ---------- */
  .join-transition,
  .join-team,
  .join-roles,
  .join-apply { margin-top: clamp(4rem, 7vw, 6rem); }

  .join-section-kicker {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 .8rem;
    padding-bottom: .8rem;
    border-bottom: 1px solid var(--rule);
  }
  .join-section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--navy);
    letter-spacing: -.022em;
    line-height: 1.12;
    margin: 0 0 1.6rem;
    max-width: 24ch;
  }

  .join-team-body p {
    font-family: var(--font-sans);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1rem;
    max-width: 62ch;
    font-weight: 400;
  }
  .join-team-body strong { color: var(--navy); font-weight: 600; }

  /* ---------- Roles list (editorial, no cards, no numbers) ---------- */
  .role-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .role-row {
    padding: 0;
    margin: 0 -1.2rem;
    border-top: 1px solid var(--rule);
    border-radius: 8px;
    transition: background .2s var(--ease);
  }
  .role-row:last-child { border-bottom: 1px solid var(--rule); }
  .role-row:hover { background: var(--paper); }
  .role-row:hover .role-row__title { color: var(--accent); }
  .role-row__title { transition: color .2s var(--ease); }

  /* Each row is a <details>; its summary is the always-visible card
     head (icon + title + chevron). Body is just the blurb. */
  .role-row__details { width: 100%; }
  .role-row__head {
    display: grid;
    grid-template-columns: 64px 1fr 28px;
    gap: 1rem 1.6rem;
    align-items: center;
    padding: 1.5rem 1.2rem;
    cursor: pointer;
    list-style: none;
  }
  .role-row__head::-webkit-details-marker { display: none; }
  .role-row__icon {
    display: inline-flex;
    color: var(--navy);
    align-items: center;
    justify-content: center;
  }
  /* Icon components render their SVG without this page's scope attr,
     so :global(svg) is required for the size rule to bind. */
  .role-row__icon :global(svg) { width: 52px; height: 52px; display: block; }
  .role-row__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.15rem, 1.9vw, 1.35rem);
    color: var(--navy);
    letter-spacing: -.014em;
    margin: 0;
  }
  .role-row__chev {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--rule-strong, rgba(14,21,48,.16));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background .2s var(--ease), border-color .2s var(--ease);
    justify-self: end;
  }
  .role-row__chev::before {
    content: '';
    width: 7px;
    height: 7px;
    border-right: 1.5px solid var(--navy);
    border-bottom: 1.5px solid var(--navy);
    transform: rotate(45deg) translate(-1px, -1px);
    transition: transform .25s var(--ease), border-color .2s var(--ease);
  }
  .role-row:hover .role-row__chev { background: var(--accent); border-color: var(--accent); }
  .role-row__details[open] .role-row__chev::before {
    transform: rotate(225deg) translate(-1px, -1px);
  }
  .role-row__blurb {
    font-family: var(--font-sans);
    font-size: .98rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    padding: 0 1.2rem 1.5rem calc(64px + 1.6rem + 1.2rem);
    max-width: 70ch;
    font-weight: 400;
    animation: role-row-body-in .25s var(--ease);
  }
  @keyframes role-row-body-in {
    from { opacity: 0; transform: translateY(-3px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .role-row__blurb { animation: none; }
  }

  /* ---------- Credentials strip below the hero ---------- */
  .join-cred {
    list-style: none;
