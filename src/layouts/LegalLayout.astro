---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/footer.css';
import '../styles/legal.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  keywords: string;
}

const { title, description, canonical, keywords } = Astro.props;

// Minimal but valid WebPage schema so legal pages aren't barren in
// structured-data audits. Tied to the homepage Organization @id.
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    url: canonical,
    description,
    isPartOf: { '@id': `${site.url}#website` },
    publisher: { '@id': `${site.url}#org` },
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: title.split('|')[0].trim(), item: canonical },
    ],
  },
];
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  keywords={keywords}
  jsonLd={jsonLd}
  bodyClass="legal-page"
>
  <Nav isHome={false} />
  <main>
    <slot />
  </main>
  <Footer isHome={false} />
</BaseLayout>
