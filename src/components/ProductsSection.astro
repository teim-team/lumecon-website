---
import { site } from '../config';
import '../styles/products.css';
const { local, tribal, global: globalProduct } = site.products;
const platforms = [local, tribal, globalProduct];
---
<section class="platforms" id="products">
  <div class="platforms-inner">
    <header class="platforms-head">
      <p class="platforms-eyebrow">Platforms</p>
      <h2 class="platforms-lead">Built for the economies they serve.</h2>
      <p class="platforms-body">
        Local, tribal, and global economies don&rsquo;t answer the same questions. Each platform uses the modeling methods that fit its work.
      </p>
    </header>

    {platforms.map((p, i) => (
      <a class={`platform platform--${i === 0 ? 'local' : i === 1 ? 'tribal' : 'global'}`} href={p.url}>
        <div class="platform__name-wrap">
          <h3 class="platform__name">{p.name}</h3>
          <span class="platform__url">{p.domain}</span>
        </div>
        <p class="platform__desc">
          {i === 0 && (
            <>Rigorous economic and policy analysis for US municipal governments, enterprises, nonprofits, and economic development organizations &mdash; without the cost or complexity of traditional tools.</>
          )}
          {i === 1 && (
            <>Built for economies that don&rsquo;t fit standard assumptions. Designed from day one for tribes, Alaska Native Corporations, Native Hawaiian Organizations, and reservation economies, with Indigenous data sovereignty in the foundation.</>
          )}
          {i === 2 && (
            <>The same modeling backbone, applied across borders. Cross-border and multiregional analysis for multinationals, NGOs, and governments &mdash; comparable methods, comparable results.</>
          )}
        </p>
        <span class="platform__status">{p.status}</span>
      </a>
    ))}
  </div>
</section>
