---
import { site } from '../config';
import '../styles/products.css';
import IconLocal from './icons/IconLocal.astro';
import IconTribal from './icons/IconTribal.astro';
import IconGlobal from './icons/IconGlobal.astro';
const { local, tribal, global: globalProduct } = site.products;
const platforms = [local, tribal, globalProduct];
---
<section class="platforms" id="products">
  <div class="platforms-inner">
    <header class="platforms-head">
      <p class="platforms-eyebrow">Platforms</p>
      <h2 class="platforms-lead">Three platforms, built for the economies they serve.</h2>
      <p class="platforms-body">
        Local, tribal, and cross-border economies don't answer the same questions. Each Lumecon platform uses the modeling methods that fit its work.
      </p>
    </header>

    {platforms.map((p, i) => {
      const slug = i === 0 ? 'local' : i === 1 ? 'tribal' : 'global';
      const badge = i === 0 ? 'In active development'
                  : i === 1 ? 'In active development'
                  : 'Future development';
      const badgeKind = i === 0 ? 'active' : i === 1 ? 'active' : 'future';
      return (
        <details class={`platform platform--${slug}`}>
          <summary class="platform__summary">
            <div class="platform__name-wrap">
              <span class="platform__icon">
                {i === 0 && <IconLocal />}
                {i === 1 && <IconTribal />}
                {i === 2 && <IconGlobal />}
              </span>
              <h3 class="platform__name">{p.name}</h3>
              <span class="platform__url">{p.domain}</span>
            </div>
            <p class="platform__tag">
              {i === 0 && 'Turn your budget data into an economic impact study you can present.'}
              {i === 1 && 'Modeled on tribal terms, not adapted from a state model.'}
              {i === 2 && 'For organizations whose work crosses borders.'}
            </p>
            <span class={`platform__badge platform__badge--${badgeKind}`}>{badge}</span>
            <span class="platform__chev" aria-hidden="true"></span>
          </summary>
          <div class="platform__body">
            <p class="platform__desc">
              {i === 0 && 'For cities, counties, state agencies, economic development organizations, and the enterprises and nonprofits that work with them. Produce the jobs, tax, and labor-income evidence a grant application, council packet, or board memo asks for &mdash; in-house, on your own data, in days instead of months, without waiting on a contractor or vendor procurement cycle.'}
              {i === 1 && 'For tribal nations, Alaska Native Corporations, Native Hawaiian Organizations, and reservation economies. Indigenous data sovereignty is built in, not added on.'}
              {i === 2 && 'For governments, multinationals, NGOs, and foundations whose work crosses borders. Same modeling backbone, so a project in one country is directly comparable to a project in another.'}
            </p>
            <a class="platform__visit" href={p.url}>Visit {p.domain} →</a>
          </div>
        </details>
      );
    })}
  </div>
</section>
