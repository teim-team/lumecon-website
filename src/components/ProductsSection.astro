---
import { site } from '../config';
import '../styles/products.css';
import IconLocal from './icons/IconLocal.astro';
import IconTribal from './icons/IconTribal.astro';
import IconGlobal from './icons/IconGlobal.astro';
const { local, tribal, global: globalProduct } = site.products;
const platforms = [local, tribal, globalProduct];
---
<section class="platforms" id="products">
  <div class="platforms-inner">
    <header class="platforms-head">
      <p class="platforms-eyebrow">Platforms</p>
      <h2 class="platforms-lead">Three platforms, built for the economies they serve.</h2>
      <p class="platforms-body">
        Local economies, tribal economies, and cross-border economies don't answer the same questions. Each Lumecon platform uses the modeling methods that fit its work, so the results land with the audience that asked the question.
      </p>
    </header>

    {platforms.map((p, i) => {
      const slug = i === 0 ? 'local' : i === 1 ? 'tribal' : 'global';
      const badge = i === 0 ? 'In active development'
                  : i === 1 ? 'Patent pending'
                  : 'Future development';
      const badgeKind = i === 0 ? 'active' : i === 1 ? 'patent' : 'future';
      return (
        <a class={`platform platform--${slug}`} href={p.url}>
          <div class="platform__name-wrap">
            <span class="platform__icon">
              {i === 0 && <IconLocal />}
              {i === 1 && <IconTribal />}
              {i === 2 && <IconGlobal />}
            </span>
            <h3 class="platform__name">{p.name}</h3>
            <span class="platform__url">{p.domain}</span>
          </div>
          <div class="platform__copy">
            <p class="platform__tag">
              {i === 0 && 'Turn your budget data into an economic impact study you can present.'}
              {i === 1 && 'Modeled on tribal terms, not adapted from a state model.'}
              {i === 2 && 'Cross-border programs measured against one shared baseline.'}
            </p>
            <p class="platform__desc">
              {i === 0 && 'For cities, counties, state agencies, economic development organizations, and the nonprofits and enterprises that work with them. Run the study in-house, on your own data, without a consultant or a six-figure software license.'}
              {i === 1 && 'For tribal nations, Alaska Native Corporations, Native Hawaiian Organizations, and reservation economies. Indigenous data sovereignty is built in, not added on.'}
              {i === 2 && 'For multinationals, NGOs, and governments. The same modeling backbone applied across borders, so impact in one country is directly comparable to impact in another.'}
            </p>
          </div>
          <span class={`platform__badge platform__badge--${badgeKind}`}>{badge}</span>
        </a>
      );
    })}
  </div>
</section>
