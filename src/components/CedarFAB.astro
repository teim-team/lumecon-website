---
/**
 * Persistent Cedar launcher pill anchored to the bottom-right of every
 * page, styled to match the Ask Cedar launcher in the TEIM app (status
 * dot + "Ask Cedar" label + context line on a bordered surface card).
 * Click toggles a self-contained Cedar chat panel that lives entirely
 * inside this component, so it works the same on the homepage, /join,
 * /privacy, /terms, and the prerendered /demo/* scenes.
 *
 * A one-time-per-session nudge bubble (#cedarNudge) pops up above the
 * pill a few seconds after load, offering help with any questions. It
 * is skipped on /cedar (the inline chat page), hides as soon as the
 * chat opens, and stays dismissed for the rest of the session.
 *
 * The chat conversation logic itself (classification, API call,
 * transcript rendering) lives in src/lib/cedarChat.ts. This
 * component is responsible only for the FAB chrome + open/close
 * behaviour; bootChat() does the rest.
 *
 * The chat surface markup itself (.cedar-chat, header, transcript,
 * chips, form) is the shared <CedarChat /> component, so the FAB and
 * the inline /cedar panel render the exact same surface and can't
 * drift. Surface styles come from src/styles/cedar-chat.css, imported
 * by that component.
 */
import CedarChat from './CedarChat.astro';
---

<button
  type="button"
  class="cedar-fab"
  id="cedarFab"
  aria-label="Ask Cedar a question"
  aria-expanded="false"
  aria-controls="cedarFabPanel"
  title="Ask Cedar"
>
  <span class="cedar-fab__dot" aria-hidden="true"></span>
  <span class="cedar-fab__icon cedar-fab__icon--close" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      width="22"
      height="22"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
    >
      <line x1="6" y1="6" x2="18" y2="18"></line>
      <line x1="18" y1="6" x2="6" y2="18"></line>
    </svg>
  </span>
  <span class="cedar-fab__copy">
    <span class="cedar-fab__label cedar-fab__label--ask">Ask Cedar</span>
    <span class="cedar-fab__context">Questions about Lumecon</span>
  </span>
  <span class="cedar-fab__label cedar-fab__label--close">Close</span>
</button>

<!-- One-time-per-session helper nudge. Hidden until the timer in the
     script below shows it; role="status" announces the offer politely
     to screen readers when it appears. -->
<div class="cedar-nudge" id="cedarNudge" role="status" hidden>
  <button
    type="button"
    class="cedar-nudge__dismiss"
    id="cedarNudgeDismiss"
    aria-label="Dismiss this message"
  >
    <svg
      viewBox="0 0 24 24"
      width="14"
      height="14"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <line x1="6" y1="6" x2="18" y2="18"></line>
      <line x1="18" y1="6" x2="6" y2="18"></line>
    </svg>
  </button>
  <p class="cedar-nudge__text">
    Hi, I'm Cedar. If you have any questions about Lumecon or economic impact analysis, I'm
    happy to help.
  </p>
  <button type="button" class="cedar-nudge__cta" id="cedarNudgeCta">Ask a question</button>
</div>

<!-- Self-contained Cedar chat panel. Hidden until the FAB opens it.
     Class-scoped (cedar-fab-panel + child .cedar-chat etc.) so it
     coexists with the inline Cedar chat on the homepage without
     element-id collisions. -->
<div
  class="cedar-fab-panel"
  id="cedarFabPanel"
  role="dialog"
  aria-label="Ask Cedar"
  aria-hidden="true"
  hidden
>
  <CedarChat />
</div>

<script>
  /* Bundled module: imports the shared Cedar chat runtime + the
     observability surface from src/lib. Re-runs on view transitions
     via astro:page-load. */
  import { bootChat } from '../lib/cedarChat';
  import { trackEvent } from '../lib/observability';

  function setup(): void {
    const fab = document.getElementById('cedarFab');
    const panel = document.getElementById('cedarFabPanel');
    if (!fab || !panel) return;

    // Boot the chat runtime (idempotent — guards on data-cedar-booted).
    bootChat(panel, { surface: 'fab' });

    // FAB-specific open/close handlers. Guard against double-binding
    // when astro:page-load re-fires this script.
    if ((fab as HTMLElement & { __cedarBound?: boolean }).__cedarBound) return;
    (fab as HTMLElement & { __cedarBound?: boolean }).__cedarBound = true;

    // ---- Helper nudge (one per browser session) ----
    const nudge = document.getElementById('cedarNudge');
    const NUDGE_KEY = 'lumecon-cedar-nudge-seen';
    const NUDGE_DELAY_MS = 4000;
    const nudgeSeen = (): boolean => {
      try {
        return sessionStorage.getItem(NUDGE_KEY) === '1';
      } catch {
        return true; // storage unavailable: never show rather than nag every load
      }
    };
    const markNudgeSeen = (): void => {
      try {
        sessionStorage.setItem(NUDGE_KEY, '1');
      } catch {
        /* storage unavailable */
      }
    };
    const hideNudge = (): void => {
      if (nudge && !nudge.hidden) nudge.hidden = true;
    };

    const open = () => {
      markNudgeSeen();
      hideNudge();
      panel.hidden = false;
      panel.setAttribute('aria-hidden', 'false');
      document.body.classList.add('cedar-popped');
      fab.setAttribute('aria-expanded', 'true');
      const input = panel.querySelector<HTMLInputElement>('[data-cedar-input]');
      window.setTimeout(() => input?.focus({ preventScroll: true }), 180);
      trackEvent('cedar.fab.open');
    };
    const close = () => {
      // If focus is inside the panel when it closes, hand it back to the
      // FAB so keyboard users aren't dropped at the top of the document.
      const returnFocus = panel.contains(document.activeElement);
      panel.hidden = true;
      panel.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('cedar-popped');
      fab.setAttribute('aria-expanded', 'false');
      if (returnFocus) (fab as HTMLElement).focus({ preventScroll: true });
      trackEvent('cedar.fab.close');
    };

    // The panel is a modal-ish dialog: while it's open, keep Tab focus
    // cycling between the FAB (which is the Close control in this state)
    // and the panel's controls so keyboard users can't tab out into the
    // page behind it. Queried live each time so dynamically added chips,
    // feedback, and follow-up buttons are included.
    const focusables = (): HTMLElement[] => {
      const sel =
        'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';
      const inPanel = Array.from(panel.querySelectorAll<HTMLElement>(sel)).filter(
        (el) => !el.hidden && el.offsetParent !== null,
      );
      return [fab as HTMLElement, ...inPanel];
    };

    fab.addEventListener('click', (e) => {
      e.stopPropagation();
      if (document.body.classList.contains('cedar-popped')) close();
      else open();
    });

    // Show the nudge a few seconds after load, once per session. Skipped
    // on /cedar, where the inline chat already fills the page.
    if (nudge && !window.location.pathname.startsWith('/cedar')) {
      const cta = document.getElementById('cedarNudgeCta');
      const dismiss = document.getElementById('cedarNudgeDismiss');
      cta?.addEventListener('click', (e) => {
        // Stop the click reaching the document-level outside-click
        // handler, which would immediately close the panel open() shows.
        e.stopPropagation();
        trackEvent('cedar.nudge.open');
        open(); // open() records the nudge as seen and hides it
      });
      dismiss?.addEventListener('click', () => {
        markNudgeSeen();
        const returnFocus = nudge.contains(document.activeElement);
        hideNudge();
        if (returnFocus) (fab as HTMLElement).focus({ preventScroll: true });
        trackEvent('cedar.nudge.dismiss');
      });
      window.setTimeout(() => {
        if (nudgeSeen()) return;
        if (document.body.classList.contains('cedar-popped')) return;
        nudge.hidden = false;
        trackEvent('cedar.nudge.show');
      }, NUDGE_DELAY_MS);
    }
    document.addEventListener('keydown', (e) => {
      if (!document.body.classList.contains('cedar-popped')) return;
      if (e.key === 'Escape') {
        close();
        return;
      }
      if (e.key !== 'Tab') return;
      const items = focusables();
      if (items.length < 2) return;
      const first = items[0];
      const last = items[items.length - 1];
      const active = document.activeElement as HTMLElement;
      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      } else if (active !== fab && !panel.contains(active)) {
        // Focus escaped the dialog — pull it back to the first control.
        e.preventDefault();
        first.focus();
      }
    });
    document.addEventListener('click', (e) => {
      if (!document.body.classList.contains('cedar-popped')) return;
      // Use composedPath rather than panel.contains(target): a chip
      // click handler inside the panel may detach the clicked
      // element (e.g. the follow-up chip row removes itself before
      // the click finishes bubbling). composedPath captures the
      // original ancestor chain at dispatch time, so it still
      // recognises the click as inside the panel.
      const path = e.composedPath();
      if (path.includes(panel) || path.includes(fab)) return;
      close();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
  document.addEventListener('astro:page-load', setup);
</script>

<style>
  .cedar-fab {
    position: fixed;
    /* Lift the bottom-anchored FAB above iOS Safari's home-indicator
       strip on notch iPhones (viewport-fit=cover lets the viewport
       extend under it). env() falls back to 0 on hosts without a
       safe area. */
    right: calc(clamp(0.9rem, 2.2vw, 1.5rem) + env(safe-area-inset-right, 0px));
    bottom: calc(clamp(0.9rem, 2.2vw, 1.5rem) + env(safe-area-inset-bottom, 0px));
    z-index: 80;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    background: var(--white);
    color: var(--ink);
    border: 1px solid var(--rule-strong);
    border-radius: 0.875rem;
    box-shadow:
      0 4px 12px rgba(10, 15, 38, 0.08),
      0 8px 24px rgba(10, 15, 38, 0.04);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    transition:
      background 0.2s var(--ease),
      box-shadow 0.2s var(--ease),
      transform 0.2s var(--ease);
  }
  /* Closed state = the launcher pill from the TEIM app: a bordered
     surface card with the green status dot and two lines of copy. */
  .cedar-fab:hover {
    background: var(--cream);
    transform: translateY(-2px);
    box-shadow:
      0 6px 16px rgba(10, 15, 38, 0.1),
      0 12px 32px rgba(10, 15, 38, 0.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .cedar-fab {
      transition: none;
    }
    .cedar-fab:hover {
      transform: none;
    }
  }
  .cedar-fab:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .cedar-fab__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 1px var(--rule-strong);
    flex: 0 0 auto;
  }
  .cedar-fab__copy {
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  .cedar-fab__label--ask {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .cedar-fab__context {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--ink-3);
    line-height: 1.2;
    margin-top: 0.1rem;
  }
  .cedar-fab__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cedar-fab__icon svg {
    display: block;
  }
  .cedar-fab__icon--close,
  .cedar-fab__label--close {
    display: none;
  }
  .cedar-fab__icon--close {
    width: 22px;
    height: 22px;
  }

  /* Open state = a clear navy "Close" pill (the launcher steps aside). */
  body.cedar-popped .cedar-fab {
    background: var(--navy);
    color: var(--white);
    border-color: transparent;
    gap: 0.5rem;
    padding: 0.7rem 1.05rem;
    border-radius: 999px;
    box-shadow: 0 6px 16px rgba(10, 15, 38, 0.3);
  }
  body.cedar-popped .cedar-fab:hover {
    background: var(--navy2);
    transform: none;
  }
  body.cedar-popped .cedar-fab__dot,
  body.cedar-popped .cedar-fab__copy {
    display: none;
  }
  body.cedar-popped .cedar-fab__icon--close {
    display: inline-flex;
  }
  body.cedar-popped .cedar-fab__label--close {
    display: inline;
  }

  /* ---------- The self-contained chat panel ---------- */
  .cedar-fab-panel {
    position: fixed;
    bottom: calc(clamp(4.5rem, 6vw, 5.5rem) + env(safe-area-inset-bottom, 0px));
    right: calc(clamp(0.9rem, 2.2vw, 1.5rem) + env(safe-area-inset-right, 0px));
    width: min(380px, calc(100vw - 1.8rem));
    max-height: calc(100dvh - 7.5rem);
    z-index: 85;
    display: flex;
    flex-direction: column;
    animation: cedar-pop-in 0.25s var(--ease);
  }
  .cedar-fab-panel[hidden] {
    display: none;
  }
  .cedar-fab-panel :global(.cedar-chat) {
    width: 100%;
    max-height: calc(100dvh - 7.5rem);
    display: flex;
    flex-direction: column;
    box-shadow:
      0 24px 60px -16px rgba(10, 15, 38, 0.28),
      0 4px 16px rgba(10, 15, 38, 0.14);
  }
  .cedar-fab-panel :global(.cedar-chat__transcript) {
    flex: 1 1 auto;
    min-height: 180px;
  }
  @keyframes cedar-pop-in {
    from {
      transform: translateY(12px) scale(0.97);
      opacity: 0;
    }
    to {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cedar-fab-panel {
      animation: none;
    }
  }

  /* ---------- The helper nudge ---------- */
  .cedar-nudge {
    position: fixed;
    right: calc(clamp(0.9rem, 2.2vw, 1.5rem) + env(safe-area-inset-right, 0px));
    bottom: calc(clamp(0.9rem, 2.2vw, 1.5rem) + env(safe-area-inset-bottom, 0px) + 4.15rem);
    z-index: 79;
    width: min(280px, calc(100vw - 1.8rem));
    padding: 0.9rem 1rem 0.85rem;
    background: var(--white);
    color: var(--ink);
    border: 1px solid var(--rule-strong);
    border-radius: 0.875rem;
    box-shadow:
      0 12px 32px rgba(10, 15, 38, 0.14),
      0 4px 12px rgba(10, 15, 38, 0.08);
    animation: cedar-pop-in 0.25s var(--ease);
  }
  /* Speech-bubble tail: a rotated square hanging off the bottom edge,
     pointing down at the launcher pill. It shares the bubble's surface
     and border so the two read as one shape; the half that overlaps the
     bubble covers the border line behind it. */
  .cedar-nudge::after {
    content: '';
    position: absolute;
    bottom: -7px;
    right: 30px;
    width: 12px;
    height: 12px;
    background: var(--white);
    border-right: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    transform: rotate(45deg);
  }
  .cedar-nudge[hidden] {
    display: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .cedar-nudge {
      animation: none;
    }
  }
  .cedar-nudge__text {
    margin: 0 1.25rem 0.65rem 0;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--ink);
  }
  .cedar-nudge__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.9rem;
    background: var(--accent-chip);
    color: #ffffff;
    border: 0;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s var(--ease);
  }
  .cedar-nudge__cta:hover {
    background: var(--accent-chip-hover);
  }
  .cedar-nudge__cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .cedar-nudge__dismiss {
    position: absolute;
    top: 0.45rem;
    right: 0.45rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    padding: 0;
    background: transparent;
    color: var(--ink-3);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
  }
  .cedar-nudge__dismiss:hover {
    color: var(--ink);
    background: var(--cream);
  }
  .cedar-nudge__dismiss:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Mobile: cap the panel so it doesn't fill the screen edge to edge
     on a phone. The closed FAB is already a compact pill. */
  @media (max-width: 600px) {
    /* Cap the panel so it doesn't fill the screen edge to edge on a
       phone. */
    .cedar-fab-panel {
      bottom: 5rem;
      max-height: min(calc(100dvh - 7rem), 520px);
      width: calc(100vw - 1.4rem);
    }
    .cedar-fab-panel :global(.cedar-chat) {
      max-height: min(calc(100dvh - 7rem), 520px);
    }
    .cedar-fab-panel :global(.cedar-chat__transcript) {
      max-height: 260px;
    }
  }
</style>
