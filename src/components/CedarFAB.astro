---
/**
 * Persistent Cedar FAB — round floating action button anchored to
 * the bottom-right of every page. Click toggles a self-contained
 * Cedar chat panel that lives entirely inside this component, so
 * it works the same on the homepage, /join, /privacy, /terms, and
 * the prerendered /demo/* scenes.
 *
 * The chat conversation logic itself (classification, API call,
 * transcript rendering) lives in src/lib/cedarChat.ts. This
 * component is responsible only for the FAB chrome + open/close
 * behaviour; bootChat() does the rest.
 *
 * Surface styles (.cedar-chat, .cedar-msg, .cedar-chip, ...) come
 * from src/styles/cedar-chat.css, also shared.
 */
import { INTENTS, CHIP_IDS } from '../data/cedarIntents';
import '../styles/cedar-chat.css';

const chips = CHIP_IDS
  .map((id) => INTENTS.find((i) => i.id === id))
  .filter((i): i is NonNullable<typeof i> => i != null && i.chip != null);
---
<button
  type="button"
  class="cedar-fab"
  id="cedarFab"
  aria-label="Ask Cedar a question"
  aria-expanded="false"
  aria-controls="cedarFabPanel"
  title="Ask Cedar"
>
  <span class="cedar-fab__icon cedar-fab__icon--mark" aria-hidden="true">
    <img src="/brand/lumecon-logo-mark-transparent.png" alt="" width="20" height="20" />
  </span>
  <span class="cedar-fab__icon cedar-fab__icon--close" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="6"  y1="6"  x2="18" y2="18"/>
      <line x1="18" y1="6"  x2="6"  y2="18"/>
    </svg>
  </span>
  <span class="cedar-fab__label cedar-fab__label--ask">Ask Cedar</span>
  <span class="cedar-fab__label cedar-fab__label--close">Close</span>
</button>

<!-- Self-contained Cedar chat panel. Hidden until the FAB opens it.
     Class-scoped (cedar-fab-panel + child .cedar-chat etc.) so it
     coexists with the inline Cedar chat on the homepage without
     element-id collisions. -->
<div class="cedar-fab-panel" id="cedarFabPanel" role="dialog" aria-label="Ask Cedar" aria-hidden="true" hidden>
  <div class="cedar-chat">
    <header class="cedar-chat__header">
      <span class="cedar-chat__brand">
        <span class="cedar-chat__avatar cedar-chat__avatar--header" aria-hidden="true">
          <img src="/brand/lumecon-logo-mark-transparent.png" alt="" width="18" height="18" loading="lazy" />
        </span>
        <span class="cedar-chat__name">Cedar</span>
      </span>
      <span class="cedar-chat__status" aria-label="Online">
        <span class="cedar-chat__status-dot" aria-hidden="true"></span>
        <span class="cedar-chat__status-label">Online</span>
      </span>
    </header>
    <div class="cedar-chat__transcript" data-cedar-transcript role="log" aria-live="polite" aria-label="Cedar conversation">
      <div class="cedar-msg cedar-msg--bot">
        <span class="cedar-msg__avatar" aria-hidden="true">
          <img src="/brand/lumecon-logo-mark-transparent.png" alt="" width="18" height="18" />
        </span>
        <div class="cedar-msg__bubble cedar-msg__bubble--welcome">
          <p class="cedar-msg__line">Hi, I'm Cedar. Ask me anything about Lumecon, or pick a question below.</p>
          <div class="cedar-quickreply" data-cedar-chips>
            {chips.slice(0, 8).map((intent, i) => (
              <button class:list={['cedar-chip', { 'cedar-chip--extra': i >= 3 }]} type="button" data-intent={intent.id} hidden={i >= 3}>{intent.chip}</button>
            ))}
            {chips.length > 3 && (
              <button class="cedar-chip-more" type="button" data-cedar-more>More suggestions</button>
            )}
          </div>
        </div>
      </div>
    </div>
    <form class="cedar-chat__form" data-cedar-form autocomplete="off">
      <label class="cedar-chat__inputwrap">
        <span class="visually-hidden">Ask Cedar</span>
        <input
          data-cedar-input
          class="cedar-chat__input"
          type="text"
          name="q"
          placeholder="Ask Cedar a question..."
          maxlength="280"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="sentences"
          spellcheck="true"
          enterkeyhint="send"
          inputmode="text"
          aria-label="Ask Cedar a question"
        />
      </label>
      <button class="cedar-chat__send" type="submit" aria-label="Send">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
          <path d="M4 12L20 4L16 20L12 13L4 12Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="miter"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  /* Bundled module: imports the shared Cedar chat runtime + the
     observability surface from src/lib. Re-runs on view transitions
     via astro:page-load. */
  import { bootChat } from '../lib/cedarChat';
  import { trackEvent } from '../lib/observability';

  function setup(): void {
    const fab = document.getElementById('cedarFab');
    const panel = document.getElementById('cedarFabPanel');
    if (!fab || !panel) return;

    // Boot the chat runtime (idempotent — guards on data-cedar-booted).
    bootChat(panel, { surface: 'fab' });

    // FAB-specific open/close handlers. Guard against double-binding
    // when astro:page-load re-fires this script.
    if ((fab as HTMLElement & { __cedarBound?: boolean }).__cedarBound) return;
    (fab as HTMLElement & { __cedarBound?: boolean }).__cedarBound = true;

    const open = () => {
      panel.hidden = false;
      panel.setAttribute('aria-hidden', 'false');
      document.body.classList.add('cedar-popped');
      fab.setAttribute('aria-expanded', 'true');
      const input = panel.querySelector<HTMLInputElement>('[data-cedar-input]');
      window.setTimeout(() => input?.focus({ preventScroll: true }), 180);
      trackEvent('cedar.fab.open');
    };
    const close = () => {
      panel.hidden = true;
      panel.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('cedar-popped');
      fab.setAttribute('aria-expanded', 'false');
      trackEvent('cedar.fab.close');
    };

    fab.addEventListener('click', (e) => {
      e.stopPropagation();
      if (document.body.classList.contains('cedar-popped')) close();
      else open();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.body.classList.contains('cedar-popped')) close();
    });
    document.addEventListener('click', (e) => {
      if (!document.body.classList.contains('cedar-popped')) return;
      // Use composedPath rather than panel.contains(target): a chip
      // click handler inside the panel may detach the clicked
      // element (e.g. the follow-up chip row removes itself before
      // the click finishes bubbling). composedPath captures the
      // original ancestor chain at dispatch time, so it still
      // recognises the click as inside the panel.
      const path = e.composedPath();
      if (path.includes(panel) || path.includes(fab)) return;
      close();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
  document.addEventListener('astro:page-load', setup);
</script>

<style>
  .cedar-fab {
    position: fixed;
    right: clamp(.9rem, 2.2vw, 1.5rem);
    bottom: clamp(.9rem, 2.2vw, 1.5rem);
    z-index: 80;
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: .7rem 1.05rem .7rem .85rem;
    background: var(--navy);
    color: var(--white);
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: .88rem;
    font-weight: 600;
    letter-spacing: -.005em;
    box-shadow:
      0 4px 14px rgba(10, 15, 38, .28),
      0 1px 3px rgba(10, 15, 38, .12);
    transition: transform .18s var(--ease), box-shadow .18s var(--ease), background .18s var(--ease);
    cursor: pointer;
    border: 0;
  }
  .cedar-fab:hover {
    background: var(--navy2);
    transform: translateY(-2px);
    box-shadow:
      0 8px 22px rgba(10, 15, 38, .34),
      0 1px 3px rgba(10, 15, 38, .15);
  }
  .cedar-fab:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .cedar-fab__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, .14);
    flex-shrink: 0;
  }
  .cedar-fab__icon svg,
  .cedar-fab__icon img { display: block; }
  /* The logo mark sits on a white disc so the brand colours read on
     the navy button; the close X keeps the translucent disc. */
  .cedar-fab__icon--mark { background: var(--white); }
  .cedar-fab__icon--mark img { width: 20px; height: 20px; object-fit: contain; }

  /* Open / closed states swap which icon + label is visible so the
     same FAB does double duty as "Ask Cedar" and "Close". */
  .cedar-fab__icon--close,
  .cedar-fab__label--close { display: none; }
  body.cedar-popped .cedar-fab__icon--mark,
  body.cedar-popped .cedar-fab__label--ask { display: none; }
  body.cedar-popped .cedar-fab__icon--close { display: inline-flex; }
  body.cedar-popped .cedar-fab__label--close { display: inline; }

  /* When the FAB pops the panel, kill the ambient pulse — the panel
     is now the focus, not the button. */
  body.cedar-popped .cedar-fab::before { animation: none; opacity: 0; }
  body.cedar-popped .cedar-fab { background: var(--navy); }
  body.cedar-popped .cedar-fab:hover { background: var(--navy2); box-shadow: 0 6px 16px rgba(10, 15, 38, .3); }

  /* ---------- The self-contained chat panel ---------- */
  .cedar-fab-panel {
    position: fixed;
    bottom: clamp(4.5rem, 6vw, 5.5rem);
    right: clamp(.9rem, 2.2vw, 1.5rem);
    width: min(380px, calc(100vw - 1.8rem));
    max-height: calc(100vh - 7.5rem);
    z-index: 85;
    display: flex;
    flex-direction: column;
    animation: cedar-pop-in .25s var(--ease);
  }
  .cedar-fab-panel[hidden] { display: none; }
  .cedar-fab-panel :global(.cedar-chat) {
    width: 100%;
    max-height: calc(100vh - 7.5rem);
    display: flex;
    flex-direction: column;
    box-shadow:
      0 24px 60px -16px rgba(10, 15, 38, .28),
      0 4px 16px rgba(10, 15, 38, .14);
  }
  .cedar-fab-panel :global(.cedar-chat__transcript) {
    flex: 1 1 auto;
    min-height: 180px;
  }
  @keyframes cedar-pop-in {
    from { transform: translateY(12px) scale(.97); opacity: 0; }
    to   { transform: translateY(0)    scale(1);   opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cedar-fab-panel { animation: none; }
  }

  /* Subtle ambient pulse so the FAB feels alive but doesn't beg. */
  .cedar-fab::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, .5);
    opacity: 0;
    animation: cedar-fab-pulse 3.6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes cedar-fab-pulse {
    0%, 100% { transform: scale(1);    opacity: 0;   }
    50%      { transform: scale(1.07); opacity: .35; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cedar-fab::before { animation: none; }
  }

  /* Mobile: collapse to icon-only so the FAB doesn't dominate the
     bottom of small screens. The label still shows on hover/focus. */
  @media (max-width: 600px) {
    .cedar-fab { padding: .7rem; }
    .cedar-fab__label { display: none; }
    /* Cap the panel so it doesn't fill the screen edge to edge on a
       phone. */
    .cedar-fab-panel {
      bottom: 5rem;
      max-height: min(calc(100vh - 7rem), 520px);
      width: calc(100vw - 1.4rem);
    }
    .cedar-fab-panel :global(.cedar-chat) {
      max-height: min(calc(100vh - 7rem), 520px);
    }
    .cedar-fab-panel :global(.cedar-chat__transcript) {
      max-height: 260px;
    }
  }
</style>
