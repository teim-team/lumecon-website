---
/**
 * Persistent Cedar FAB — round floating action button anchored to
 * the bottom-right of every page. Click jumps you into the Cedar
 * chat: on the homepage that's a smooth scroll to the #cedar
 * section with the chat input pre-focused; on other pages it routes
 * to the homepage Cedar surface.
 *
 * The button itself reads as a product chrome element rather than a
 * marketing flourish — cedar-green background, white tree mark, soft
 * shadow, subtle hover lift, accessible label.
 */
---
<button
  type="button"
  class="cedar-fab"
  id="cedarFab"
  aria-label="Ask Cedar a question"
  aria-expanded="false"
  title="Ask Cedar"
>
  <span class="cedar-fab__icon cedar-fab__icon--tree" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="miter">
      <path d="M12 3 L8 9 L10 9 L7 14 L9.5 14 L5 20 L19 20 L14.5 14 L17 14 L14 9 L16 9 Z" fill="currentColor"/>
      <line x1="12" y1="20" x2="12" y2="22" stroke-linecap="butt" stroke-width="2"/>
    </svg>
  </span>
  <span class="cedar-fab__icon cedar-fab__icon--close" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="6"  y1="6"  x2="18" y2="18"/>
      <line x1="18" y1="6"  x2="6"  y2="18"/>
    </svg>
  </span>
  <span class="cedar-fab__label cedar-fab__label--ask">Ask Cedar</span>
  <span class="cedar-fab__label cedar-fab__label--close">Close</span>
</button>

<script is:inline>
  (function () {
    const fab = document.getElementById('cedarFab');
    if (!fab) return;

    const closePop = () => {
      if (!document.body.classList.contains('cedar-popped')) return;
      document.body.classList.remove('cedar-popped');
      fab.setAttribute('aria-expanded', 'false');
    };
    const openPop = () => {
      document.body.classList.add('cedar-popped');
      fab.setAttribute('aria-expanded', 'true');
      const input = document.getElementById('cedarInput');
      if (input) window.setTimeout(() => input.focus({ preventScroll: true }), 200);
    };

    fab.addEventListener('click', (e) => {
      const cedar = document.getElementById('cedar');
      if (!cedar) {
        // The Cedar surface only renders on the homepage. From any
        // other page (e.g. /join), route the visitor home and land
        // them on the Cedar section so the click still does
        // something.
        e.preventDefault();
        window.location.assign('/#cedar');
        return;
      }
      e.stopPropagation();
      if (document.body.classList.contains('cedar-popped')) {
        closePop();
      } else {
        openPop();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePop();
    });
  })();
</script>

<style>
  .cedar-fab {
    position: fixed;
    right: clamp(.9rem, 2.2vw, 1.5rem);
    bottom: clamp(.9rem, 2.2vw, 1.5rem);
    z-index: 80;
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: .7rem 1.05rem .7rem .85rem;
    background: var(--cedar);
    color: var(--white);
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: .88rem;
    font-weight: 600;
    letter-spacing: -.005em;
    box-shadow:
      0 4px 14px rgba(14, 88, 58, .35),
      0 1px 3px rgba(10, 15, 38, .12);
    transition: transform .18s var(--ease), box-shadow .18s var(--ease), background .18s var(--ease);
    cursor: pointer;
  }
  .cedar-fab:hover {
    background: var(--green-deep);
    transform: translateY(-2px);
    box-shadow:
      0 8px 22px rgba(14, 88, 58, .42),
      0 1px 3px rgba(10, 15, 38, .15);
  }
  .cedar-fab:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .cedar-fab__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, .14);
    flex-shrink: 0;
  }
  .cedar-fab__icon svg { display: block; }

  /* Open / closed states swap which icon + label is visible so the
     same FAB does double duty as "Ask Cedar" and "Close". */
  .cedar-fab__icon--close,
  .cedar-fab__label--close { display: none; }
  body.cedar-popped .cedar-fab__icon--tree,
  body.cedar-popped .cedar-fab__label--ask { display: none; }
  body.cedar-popped .cedar-fab__icon--close { display: inline-flex; }
  body.cedar-popped .cedar-fab__label--close { display: inline; }

  /* When the FAB pops the Cedar chat, kill the ambient pulse — the
     panel is now the focus, not the button. */
  body.cedar-popped .cedar-fab::before { animation: none; opacity: 0; }
  body.cedar-popped .cedar-fab { background: var(--navy); }
  body.cedar-popped .cedar-fab:hover { background: var(--navy2); box-shadow: 0 6px 16px rgba(10, 15, 38, .3); }

  /* ---------- Popped chat panel ----------
     The Cedar chat normally lives inline in the Cedar section. When
     body.cedar-popped is set, we yank the existing .cedar-chat
     element into a fixed-position panel anchored above the FAB. The
     section's right-column placeholder shows a "popped out" hint so
     the page layout doesn't collapse around the missing element. */
  :global(body.cedar-popped #cedar .cedar-chat) {
    position: fixed;
    bottom: clamp(4.5rem, 6vw, 5.5rem);
    right: clamp(.9rem, 2.2vw, 1.5rem);
    width: min(380px, calc(100vw - 1.8rem));
    max-height: calc(100vh - 7.5rem);
    z-index: 85;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 24px 60px -16px rgba(10, 15, 38, .28),
      0 4px 16px rgba(10, 15, 38, .14);
    animation: cedar-pop-in .25s var(--ease);
  }
  :global(body.cedar-popped #cedar .cedar-chat__transcript) {
    flex: 1 1 auto;
    min-height: 180px;
  }
  :global(body.cedar-popped #cedar .cedar-about__right)::before {
    content: 'Chat popped out';
    display: block;
    padding: 1.5rem 1rem;
    font-family: var(--font-mono);
    font-size: .68rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-3);
    border: 1px dashed var(--rule);
    border-radius: 14px;
    text-align: center;
    min-height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* .ask-cedar wrapper collapses naturally once its only visible
     child (.cedar-chat) is lifted via position:fixed. The placeholder
     ::before above gives the column its size. */
  :global(body.cedar-popped #cedar .cedar-about__right) > :global(.ask-cedar) {
    height: 0;
    overflow: hidden;
  }
  @keyframes cedar-pop-in {
    from { transform: translateY(12px) scale(.97); opacity: 0; }
    to   { transform: translateY(0)    scale(1);   opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(body.cedar-popped #cedar .cedar-chat) { animation: none; }
  }

  /* Subtle ambient pulse so the FAB feels alive but doesn't beg. */
  .cedar-fab::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 999px;
    border: 1.5px solid var(--cedar-light);
    opacity: 0;
    animation: cedar-fab-pulse 3.6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes cedar-fab-pulse {
    0%, 100% { transform: scale(1);    opacity: 0;   }
    50%      { transform: scale(1.07); opacity: .35; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cedar-fab::before { animation: none; }
  }

  /* Mobile: collapse to icon-only so the FAB doesn't dominate the
     bottom of small screens. The label still shows on hover/focus. */
  @media (max-width: 600px) {
    .cedar-fab { padding: .7rem; }
    .cedar-fab__label { display: none; }
    .cedar-fab__icon { background: transparent; }
    /* Cap the popped panel so it doesn't fill the screen edge to
       edge on a phone. */
    :global(body.cedar-popped #cedar .cedar-chat) {
      bottom: 5rem;
      max-height: min(calc(100vh - 7rem), 520px);
      width: calc(100vw - 1.4rem);
    }
    :global(body.cedar-popped #cedar .cedar-chat__transcript) {
      max-height: 260px;
    }
  }
</style>
