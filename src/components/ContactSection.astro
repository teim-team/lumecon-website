---
import { site } from '../config';
import '../styles/cta.css';
---
<section class="cta" id="contact">
  <div class="cta-inner">
    <div class="cta-left">
      <p class="cta-eyebrow">Available for pilots</p>
      <h2 class="cta-display reveal delay-1">Let&rsquo;s prove your impact, together.</h2>
      <p class="cta-lede reveal delay-2">Piloting with governments and mission-driven organizations, including councils, grant programs, reservation economies, and university research labs.</p>
      <a href={`mailto:${site.email}`} class="cta-email reveal delay-3">{site.email}</a>
    </div>
    <div class="cta-form reveal delay-2">
      <label for="fname">Name</label>
      <input type="text" id="fname" name="name" placeholder="Your name" required>
      <div class="form-validation-error" id="fnameError">Please enter your name</div>
      <label for="femail">Email</label>
      <input type="email" id="femail" name="email" placeholder="you@organization.com" required>
      <div class="form-validation-error" id="femailError">Please enter a valid email</div>
      <label for="fmsg">Message</label>
      <textarea id="fmsg" name="message" placeholder="Briefly: who you are and what brought you here."></textarea>
      <a id="formSend" href="mailto:contact@lumecon.ai?subject=Lumecon%20inquiry">Send by email</a>

      <div class="form-success-overlay" id="formSuccess">
        <div class="form-success-check">
          <svg viewBox="0 0 24 24"><polyline points="4 12 10 18 20 6"/></svg>
        </div>
        <div class="form-success-text">Message sent!</div>
        <div class="form-success-sub">We'll be in touch soon.</div>
      </div>
    </div>
  </div>
</section>

<script>
  const SUCCESS_SHOW_DELAY = 800; // ms after mailto opens
  const FORM_RESET_DELAY = 6000; // ms before form clears

  (function() {
    const sendBtn = document.getElementById('formSend') as HTMLAnchorElement | null;
    const formSuccess = document.getElementById('formSuccess');
    const nameInput = document.getElementById('fname') as HTMLInputElement | null;
    const emailInput = document.getElementById('femail') as HTMLInputElement | null;
    const nameError = document.getElementById('fnameError');
    const emailError = document.getElementById('femailError');
    if (!sendBtn || !formSuccess || !nameInput || !emailInput || !nameError || !emailError) return;

    const validateEmail = (email: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

    const clearErrors = () => {
      nameInput.classList.remove('error');
      emailInput.classList.remove('error');
      nameError.classList.remove('show');
      emailError.classList.remove('show');
    };

    sendBtn.addEventListener('click', (ev) => {
      ev.preventDefault();
      clearErrors();
      const n = nameInput.value.trim();
      const e = emailInput.value.trim();
      const i = '';
      const m = (document.getElementById('fmsg') as HTMLTextAreaElement | null)?.value ?? '';
      let valid = true;

      if (!n) {
        nameInput.classList.add('error');
        nameError.classList.add('show');
        valid = false;
      }
      if (!e || !validateEmail(e)) {
        emailInput.classList.add('error');
        emailError.classList.add('show');
        valid = false;
      }
      if (!valid) return;

      sendBtn.setAttribute('aria-busy', 'true');
      const original = sendBtn.textContent;
      sendBtn.textContent = 'Opening\u2026';

      window.location.href = 'mailto:contact@lumecon.ai?subject=' +
        encodeURIComponent('Lumecon inquiry') +
        '&body=' + encodeURIComponent('Name: ' + n + '\nEmail: ' + e + '\n\n' + m);

      setTimeout(() => {
        formSuccess.classList.add('show');
        sendBtn.removeAttribute('aria-busy');
        sendBtn.textContent = original || 'Send by email';
      }, SUCCESS_SHOW_DELAY);

      setTimeout(() => {
        formSuccess.classList.remove('show');
        nameInput.value = '';
        emailInput.value = '';
        const msgEl = document.getElementById('fmsg') as HTMLTextAreaElement | null;
        if (msgEl) msgEl.value = '';
      }, FORM_RESET_DELAY);
    });

    nameInput.addEventListener('input', () => { nameInput.classList.remove('error'); nameError.classList.remove('show'); });
    emailInput.addEventListener('input', () => { emailInput.classList.remove('error'); emailError.classList.remove('show'); });
  })();
</script>
