---
/**
 * NetworkSection — network-effect / continual-learning explainer.
 *
 * Positions the platform's differentiator honestly: yes, Lumecon
 * trains on customer data (with permission) — that's the whole
 * point of a network that compounds. What the visitor needs to
 * trust is that the SHAPE of that training is anonymised and
 * aggregated across the network, and that their own workspace
 * results stay theirs.
 *
 * The incumbent posture is different: existing economic-impact
 * tools ship administrative data as a static product on a
 * multi-year vintage cycle. We don't claim they refuse to learn —
 * that's not the kind of thing you can prove from outside — but
 * leading with what we DO lets visitors draw the comparison.
 *
 * Important: any "data never leaves your workspace" wording is
 * misleading. We do train on customer data. The honest framing is:
 * (1) results in your workspace are yours, (2) cross-customer
 * learning runs on anonymised aggregates, (3) the result is that
 * every new client makes the next study sharper for everyone.
 */
import '../styles/network.css';
---
<section class="network" id="network" aria-labelledby="network-title">
  <div class="network-inner">
    <div class="network-text">
      <p class="network-kicker">The network</p>
      <h2 class="network-title" id="network-title">Your work stays yours. The model gets sharper for everyone.</h2>
      <p class="network-lede">Every new client makes every other client's next economic impact study a little better. We train on the network &mdash; anonymised, aggregated signals across thousands of studies &mdash; so the regional multipliers, the assumption defaults, and Cedar's harmonization rules keep tightening as more organizations join.</p>

      <ul class="network-points">
        <li class="network-point">
          <h3 class="network-point__head">Anonymised, aggregated training</h3>
          <p class="network-point__body">Cross-customer learning runs on anonymised aggregates, not row-level uploads. Identifiers, sensitive fields, and study-specific labels are stripped before any signal reaches the shared model.</p>
        </li>
        <li class="network-point">
          <h3 class="network-point__head">Your workspace is yours</h3>
          <p class="network-point__body">Your raw files, your study outputs, and your audit trail stay in your tenant. What you publish is what you choose to publish; the network sees patterns, not your specific results.</p>
        </li>
        <li class="network-point">
          <h3 class="network-point__head">Compounds with every economic impact study</h3>
          <p class="network-point__body">More historic studies on file, more current studies running, more geographies covered &mdash; each one tightens the next regional multiplier estimate and the next Cedar harmonization pass. The incumbents treat administrative data as a static product; we treat the network as a living signal.</p>
        </li>
      </ul>
    </div>

    <!-- Network diagram: five client nodes around a central
         Lumecon node. Dashed lines from each client send aggregated
         signals INWARD (animated pulse). The visual reads as
         "many tenants, one shared model — but the lines are dashed,
         not solid, so the eye registers that something less than
         raw data is moving across." -->
    <div class="network-diagram" aria-hidden="true">
      <svg viewBox="0 0 240 240" fill="none">
        <!-- Outer client nodes -->
        <g class="network-diagram__client">
          <circle cx="120" cy="32"  r="14" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5"/>
          <text x="120" y="36" text-anchor="middle" font-family="JetBrains Mono, ui-monospace" font-size="6" fill="var(--ink-3)">Tribe</text>
        </g>
        <g class="network-diagram__client">
          <circle cx="208" cy="92"  r="14" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5"/>
          <text x="208" y="96" text-anchor="middle" font-family="JetBrains Mono, ui-monospace" font-size="6" fill="var(--ink-3)">City</text>
        </g>
        <g class="network-diagram__client">
          <circle cx="174" cy="200" r="14" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5"/>
          <text x="174" y="204" text-anchor="middle" font-family="JetBrains Mono, ui-monospace" font-size="5.5" fill="var(--ink-3)">State</text>
        </g>
        <g class="network-diagram__client">
          <circle cx="66"  cy="200" r="14" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5"/>
          <text x="66"  y="204" text-anchor="middle" font-family="JetBrains Mono, ui-monospace" font-size="5" fill="var(--ink-3)">Found.</text>
        </g>
        <g class="network-diagram__client">
          <circle cx="32"  cy="92"  r="14" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5"/>
          <text x="32"  y="96" text-anchor="middle" font-family="JetBrains Mono, ui-monospace" font-size="5" fill="var(--ink-3)">Univ.</text>
        </g>

        <!-- Dashed connection lines from each client to the centre.
             stroke-dasharray + offset animation creates the inward
             pulse so the eye reads "aggregated signal flowing in." -->
        <g class="network-diagram__edges" stroke="var(--accent)" stroke-width="1.2" stroke-dasharray="3 4" fill="none">
          <line class="network-diagram__edge network-diagram__edge--a" x1="120" y1="46"  x2="120" y2="106"/>
          <line class="network-diagram__edge network-diagram__edge--b" x1="194" y1="92"  x2="134" y2="120"/>
          <line class="network-diagram__edge network-diagram__edge--c" x1="164" y1="190" x2="128" y2="134"/>
          <line class="network-diagram__edge network-diagram__edge--d" x1="76"  y1="190" x2="112" y2="134"/>
          <line class="network-diagram__edge network-diagram__edge--e" x1="46"  y1="92"  x2="106" y2="120"/>
        </g>

        <!-- Central Lumecon node — slightly bigger, gold ring to
             match the brand source colour. The pulse animation makes
             it read as "alive" without being aggressive. -->
        <g class="network-diagram__hub">
          <circle cx="120" cy="120" r="28" fill="var(--navy)" stroke="var(--gold)" stroke-width="2"/>
          <text x="120" y="118" text-anchor="middle" font-family="Inter, system-ui" font-weight="700" font-size="7" fill="var(--white)" letter-spacing="0.5">LUMECON</text>
          <text x="120" y="128" text-anchor="middle" font-family="JetBrains Mono, ui-monospace" font-size="5" fill="var(--gold)">model</text>
        </g>

        <!-- Lock icon next to the hub to telegraph the federation /
             security framing. -->
        <g class="network-diagram__lock" transform="translate(154 92)">
          <rect x="-7" y="-3" width="14" height="11" rx="1.5" fill="var(--cream)" stroke="var(--navy)" stroke-width="1.2"/>
          <path d="M-4 -3 V -7 a 4 4 0 0 1 8 0 V -3" stroke="var(--navy)" stroke-width="1.2" fill="none"/>
          <circle cx="0" cy="2.5" r="1.2" fill="var(--navy)"/>
        </g>
      </svg>
    </div>
  </div>
</section>
