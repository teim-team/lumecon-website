---
/**
 * Featured studies — a curated rail of 6 example economic impact
 * studies, each linking to its prerendered /demo/<slug> page. Gives
 * the demo catalog real internal link equity (previously the demo
 * pages were only reachable via the sitemap) and shows visitors a
 * concrete sample of the kind of analyses Lumecon produces.
 *
 * Picks are biased toward customer-facing scenarios: state agencies,
 * city/county governments, school districts, EDOs, hospital systems,
 * and tribal nations. The mix is deliberate (2 state, 3 county, 1
 * reservation) so the rail reads as the full audience instead of
 * any one segment.
 */
import { SCENES, sceneSlug, type Scene } from '../data/scenes';

/* Curated set of featured scene chips. Keep this list short and
   intentional — these are the studies a visitor sees on the home
   page, so they should each represent a distinct buyer scenario. */
const FEATURED_CHIPS = [
  'COUNTY · School district bond · Harris County, TX · 2026',
  'STATE · Film and TV tax credit · Georgia · 2026',
  'COUNTY · Hospital campus expansion · Olmsted County, MN · 2026',
  'STATE · Water infrastructure · Michigan · 2026',
  'COUNTY · Convention expansion · Clark County, NV · 2026',
  'RESERVATION · Tribal health clinic + IHS partnership · Navajo Nation · 2026',
];

const fmt$ = (v: number): string => {
  if (v >= 1_000_000) return '$' + (v / 1_000_000).toFixed(v >= 10_000_000 ? 0 : 1) + 'M';
  if (v >= 1_000) return '$' + Math.round(v / 1_000) + 'K';
  return '$' + Math.round(v);
};

/* Build the cards: look up each chip in SCENES, fail loud (at build
   time) if any chip in FEATURED_CHIPS no longer matches a scene. */
type Card = { scene: Scene; slug: string; locationLine: string; projectLine: string };
const cards: Card[] = FEATURED_CHIPS.map((chip) => {
  const scene = SCENES.find((s) => s.chip === chip);
  if (!scene) throw new Error(`FeaturedStudies: no scene matches chip "${chip}"`);
  // chip format: "LEVEL · Project · Location · Year"
  const parts = scene.chip.split(' · ');
  const levelTag = parts[0] ?? '';
  const projectLine = parts[1] ?? '';
  const locationLine = parts[2] ?? '';
  return {
    scene,
    slug: sceneSlug(scene),
    locationLine: levelTag === 'RESERVATION' ? `Reservation · ${locationLine}` : locationLine,
    projectLine,
  };
});
---
<section class="featured" id="examples" aria-labelledby="featured-title">
  <div class="featured__inner">
    <header class="featured__head">
      <p class="featured__kicker reveal-soft">Featured studies</p>
      <h2 class="featured__title reveal-soft" id="featured-title" data-stagger="1">
        Real studies for real decisions.
      </h2>
      <p class="featured__lede reveal-soft" data-stagger="2">
        A sample of the economic impact studies Lumecon produces for governments, enterprises, and mission-driven organizations.
      </p>
    </header>

    <ul class="featured__grid">
      {cards.map((card, i) => (
        <li class="featured__cell reveal-soft" data-stagger={i + 1}>
          <a class="featured__card" href={`/demo/${card.slug}`} aria-label={`See the ${card.projectLine} study for ${card.locationLine}`}>
            <span class="featured__meta">
              <span class="featured__amount">{fmt$(card.scene.amount.v)}</span>
              <span class="featured__activity">{card.scene.activity.label}</span>
            </span>
            <h3 class="featured__project">{card.projectLine}</h3>
            <p class="featured__location">{card.locationLine}</p>
            <span class="featured__cta" aria-hidden="true">
              See the study
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7 H 11 M 7 3 L 11 7 L 7 11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="miter"/>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .featured {
    background: var(--cream);
    padding: clamp(5rem, 9vw, 7rem) 0;
    border-bottom: 1px solid var(--rule);
    scroll-snap-align: start;
    min-block-size: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .featured__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
    width: 100%;
  }
  .featured__head {
    display: flex;
    flex-direction: column;
    gap: .9rem;
    max-width: 800px;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .featured__kicker {
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0;
  }
  .featured__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.1rem, 4.2vw, 3.2rem);
    line-height: 1.1;
    letter-spacing: -.022em;
    color: var(--navy);
    margin: 0;
    max-width: 26ch;
  }
  .featured__lede {
    font-family: var(--font-sans);
    font-size: clamp(1.08rem, 1.55vw, 1.22rem);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 62ch;
  }

  /* Card grid: 3 columns on desktop, 2 on tablet, 1 on small mobile.
     Cards stay roughly the same shape regardless of column count so
     the rail still reads as a rail rather than a list. */
  .featured__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(.9rem, 1.6vw, 1.4rem);
  }
  @media (max-width: 960px) {
    .featured__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .featured__grid { grid-template-columns: 1fr; }
  }

  .featured__cell { margin: 0; padding: 0; }
  .featured__card {
    display: flex;
    flex-direction: column;
    gap: .65rem;
    height: 100%;
    padding: clamp(1.1rem, 1.8vw, 1.4rem);
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: 12px;
    text-decoration: none;
    color: var(--navy);
    transition: border-color .2s var(--ease), box-shadow .2s var(--ease), transform .2s var(--ease);
    position: relative;
  }
  .featured__card:hover,
  .featured__card:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 12px 28px -16px rgba(14, 21, 48, .22);
    transform: translateY(-2px);
    outline: none;
  }
  .featured__card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .featured__meta {
    display: inline-flex;
    align-items: baseline;
    gap: .55rem;
    flex-wrap: wrap;
  }
  .featured__amount {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.2vw, 1.7rem);
    color: var(--navy);
    letter-spacing: -.018em;
    line-height: 1;
  }
  .featured__activity {
    font-family: var(--font-mono);
    font-size: .68rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }
  .featured__project {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.25;
    letter-spacing: -.014em;
    color: var(--navy);
    margin: 0;
  }
  .featured__location {
    font-family: var(--font-sans);
    font-size: .95rem;
    line-height: 1.4;
    color: var(--ink-3);
    margin: 0;
  }
  .featured__cta {
    margin-top: auto;
    padding-top: .8rem;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
    transition: color .2s var(--ease), gap .2s var(--ease);
  }
  .featured__card:hover .featured__cta,
  .featured__card:focus-visible .featured__cta {
    color: var(--accent);
    gap: .6rem;
  }
  .featured__cta svg {
    transition: transform .2s var(--ease);
  }
  .featured__card:hover .featured__cta svg,
  .featured__card:focus-visible .featured__cta svg {
    transform: translateX(2px);
  }
</style>
