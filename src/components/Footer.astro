---
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const prefix = isHome ? '' : 'index.html';
---
<footer class={isHome ? 'paper-tex paper-tex-dark' : ''}>
  <div class="footer-w">
    <div class="footer-top">
      <div>
        <div class="footer-brand-name">LUMECON</div>
        <div class="footer-brand-tag">We luminate economies</div>
      </div>
      <div class="footer-links">
        <a href={`${prefix}#products`}>Products</a>
        <a href={`${prefix}#cedar`}>Cedar</a>
        <a href={`${prefix}#contact`}>Partnerships</a>
        <a href="terms.html">Terms</a>
        <a href="privacy.html">Privacy</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-legal">&copy; 2026 Moreno Ventures LLC d/b/a Lumecon. All rights reserved. Patent pending. Built at Cornell University. Counsel: Cornell Law Entrepreneurship Law Clinic.</div>
      <a href="mailto:contact@lumecon.ai" class="footer-email">contact@lumecon.ai</a>
    </div>
  </div>
</footer>
