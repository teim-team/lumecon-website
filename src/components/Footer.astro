---
import { site, navLinks } from '../config';
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const prefix = isHome ? '' : '/';
---
<footer class={isHome ? 'paper-tex paper-tex-dark' : ''}>
  <div class="footer-w">
    <div class="footer-top">
      <div class="footer-brand">
        <img class="footer-brand-img" src="/brand/lumecon-logo-horizontal-transparent.png" alt={site.legalName} width="180" height="40" loading="lazy" />
        <div class="footer-brand-tag">{site.tagline}&trade;</div>
      </div>
      <div class="footer-links">
        {navLinks.map(link => (
          <a href={`${prefix}${link.href}`}>{link.label}</a>
        ))}
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href="https://www.linkedin.com/company/lumecon-ai" target="_blank" rel="noopener noreferrer" aria-label="Lumecon on LinkedIn">LinkedIn</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-legal">&copy; {site.copyrightYear} {site.legalEntity} All rights reserved. Patent pending. Built at {site.builtAt}. Counsel: {site.counsel}.</div>
      <a href={`mailto:${site.email}`} class="footer-email">{site.email}</a>
    </div>
  </div>
</footer>
