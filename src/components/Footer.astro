---
/**
 * Footer — four lean columns plus a copyright row.
 *
 * The previous layout mixed product lines (Local / Tribal / Global)
 * with feature pages (Cedar / Map / Pricing) under one "Platforms"
 * header, which was conceptually muddled, and stacked 20 link items
 * across four columns. Now:
 *
 *   Platforms — the three Lumecon product lines.
 *   Explore   — the three deep feature pages (Map, Cedar, Pricing).
 *   Company   — three company links (no mailto-only items).
 *   Legal     — two pages.
 *
 * The cedar tree mark sits next to the wordmark in the brand
 * column so the brand reads as one thing instead of three across
 * the site (FAB + Cedar tile + bare wordmark).
 */
import { site } from '../config';
import BrandWordmark from './BrandWordmark.astro';
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const prefix = isHome ? '' : '/';
---
<footer class={isHome ? 'footer footer--home' : 'footer'}>
  <div class="footer-w">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-brand__wordmark">
          <BrandWordmark size="md" invert={true} ariaLabel={`${site.legalName} home`} />
          <span class="footer-brand__mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 3 L8 9 L10 9 L7 14 L9.5 14 L5 20 L19 20 L14.5 14 L17 14 L14 9 L16 9 Z"/>
              <line x1="12" y1="20" x2="12" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="butt"/>
            </svg>
          </span>
        </div>
        <div class="footer-brand-pitch">{site.pitch}</div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <div class="footer-col__head mono">Platforms</div>
          <a href={site.products.local.url}>Local Economic Impact</a>
          <a href={site.products.tribal.url}>Tribal Economic Impact</a>
          <a href={site.products.global.url}>Global Economic Impact</a>
        </div>
        <div class="footer-col">
          <div class="footer-col__head mono">Explore</div>
          <a href="/map">Live map</a>
          <a href="/cedar">Cedar</a>
          <a href="/pricing">Pricing</a>
        </div>
        <div class="footer-col">
          <div class="footer-col__head mono">Company</div>
          <a href="/join">Join the team</a>
          <a href={`${prefix}#contact`}>Contact</a>
          <a href="https://www.linkedin.com/company/lumecon-ai" target="_blank" rel="noopener noreferrer me">LinkedIn</a>
        </div>
        <div class="footer-col">
          <div class="footer-col__head mono">Legal</div>
          <a href="/terms">Terms of Service</a>
          <a href="/privacy">Privacy Policy</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-legal">
        &copy; {site.copyrightYear} {site.legalEntity} &middot; All rights reserved.
      </div>
      <a href={`mailto:${site.email}`} class="footer-email mono">{site.email}</a>
    </div>
  </div>
</footer>
