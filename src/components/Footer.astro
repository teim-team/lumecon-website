---
import { site, navLinks } from '../config';
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const prefix = isHome ? '' : '/';
---
<footer class={isHome ? 'paper-tex paper-tex-dark' : ''}>
  <div class="footer-w">
    <div class="footer-top">
      <div>
        <div class="footer-brand-name">{site.name.toUpperCase()}</div>
        <div class="footer-brand-tag">{site.tagline}</div>
      </div>
      <div class="footer-links">
        {navLinks.map(link => (
          <a href={`${prefix}${link.href}`}>{link.label}</a>
        ))}
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-legal">&copy; {site.copyrightYear} {site.legalEntity}. All rights reserved. Patent pending. Built at {site.builtAt}. Counsel: {site.counsel}.</div>
      <a href={`mailto:${site.email}`} class="footer-email">{site.email}</a>
    </div>
  </div>
</footer>
