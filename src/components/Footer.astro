---
/**
 * Footer — four lean columns plus a copyright row.
 *
 * The previous layout mixed product lines (Local / Tribal / Global)
 * with feature pages (Cedar / Map / Pricing) under one "Platforms"
 * header, which was conceptually muddled, and stacked 20 link items
 * across four columns. Now:
 *
 *   Platforms — the three Lumecon product lines.
 *   Explore   — the three deep feature pages (Map, Cedar, Pricing).
 *   Company   — three company links (no mailto-only items).
 *   Legal     — two pages.
 *
 * The cedar tree mark sits next to the wordmark in the brand
 * column so the brand reads as one thing instead of three across
 * the site (FAB + Cedar tile + bare wordmark).
 */
import { site } from '../config';
import { REGIONAL_PLATFORMS } from '../data/platforms';
import BrandWordmark from './BrandWordmark.astro';
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const prefix = isHome ? '' : '/';
---

<footer class={isHome ? 'footer footer--home' : 'footer'}>
  <div class="footer-w">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-brand__wordmark">
          <BrandWordmark size="md" ariaLabel={`${site.legalName} home`} />
        </div>
        <div class="footer-brand-pitch">{site.pitch}</div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <div class="footer-col__head mono">Platforms</div>
          {REGIONAL_PLATFORMS.map((p) => <a href={p.url}>{p.name}</a>)}
        </div>
        <div class="footer-col">
          <div class="footer-col__head mono">Explore</div>
          <a href="/map">See your impact</a>
          <a href="/cedar">Cedar</a>
          <a href="/pricing">Pricing</a>
          <a href="/glossary">Glossary</a>
        </div>
        <div class="footer-col">
          <div class="footer-col__head mono">Company</div>
          <a href="/about">About</a>
          <a href="/join">Join the team</a>
          <a class="footer-col__contact" href={`${prefix}#contact`}>Contact</a>
          <a
            href="https://www.linkedin.com/company/lumecon-ai"
            target="_blank"
            rel="noopener noreferrer me">LinkedIn</a
          >
        </div>
        <div class="footer-col">
          <div class="footer-col__head mono">Legal</div>
          <a href="/terms">Terms of Service</a>
          <a href="/privacy">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Compact navy strip for copyright + contact email so the
       dominant footer surface stays light and the navy footprint
       shrinks to a single thin bar. -->
  <div class="footer-bar">
    <div class="footer-w">
      <div class="footer-bottom">
        <div class="footer-legal">
          &copy; <span id="copyrightYear">{site.copyrightYear}</span>
          {site.legalEntity} &middot; All rights reserved.
        </div>
        <a href={`mailto:${site.email}`} class="footer-email mono">{site.email}</a>
      </div>
    </div>
  </div>
</footer>

<script>
  // Keep the copyright year current even between deploys. The build-time
  // value rendered above is the no-JS fallback and the initial paint;
  // this refreshes it to the visitor's current year on load.
  function setCopyrightYear(): void {
    const el = document.getElementById('copyrightYear');
    if (el) el.textContent = String(new Date().getFullYear());
  }
  setCopyrightYear();
  document.addEventListener('astro:page-load', setCopyrightYear);
</script>
