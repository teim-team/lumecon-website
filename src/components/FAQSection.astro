---
/**
 * Ask Cedar — the FAQ surface restyled as a Cedar chat so the section
 * demos the product narrative instead of being a generic FAQ list.
 *
 * Honest framing: marketing-page Cedar runs from a fixed Q&A set (no
 * upstream LLM call). We say so plainly in the section subtitle and
 * in llms.txt. The Q&As pair with FAQPage JSON-LD on the homepage so
 * search + AI crawlers see the same content.
 *
 * No-JS fallback: the static <details> FAQ list ships in the DOM and
 * is the visible state when JS doesn't hydrate. JS swaps to the chat
 * UI once it loads.
 */
const faqs = [
  {
    q: 'What is Lumecon?',
    a: 'Lumecon Inc. is economic impact analysis software for governments and mission-driven organizations. A modern alternative to IMPLAN, RIMS II, and REMI. Built at Cornell University. Use Cedar AI to read messy administrative data and run impact studies in-house.',
  },
  {
    q: 'Who uses Lumecon?',
    a: 'Municipal governments, tribal nations, Alaska Native Corporations, Native Hawaiian Organizations, state agencies, federal programs, universities and research labs, foundations, CDFIs, and economic development organizations.',
  },
  {
    q: 'Is Lumecon an IMPLAN / RIMS II / REMI alternative?',
    a: 'Yes. Lumecon was built as a modern, AI-assisted alternative to IMPLAN, RIMS II, REMI Policy Insight, and BEA RIMS II multipliers for organizations that need to run economic impact studies in-house, on their own data, without per-region licensing fees.',
  },
  {
    q: 'What geographies does Lumecon cover?',
    a: 'All federally recognized tribal nations and reservations, Alaska Native Corporation regions, Native Hawaiian Home Lands, every U.S. county, every U.S. state, and the entire country, all in one annual subscription, not priced per geography.',
  },
  {
    q: 'What is Cedar?',
    a: 'Cedar is the AI assistant built into every Lumecon platform. Cedar reads the files your departments already share, surfaces each assumption the model is about to use, asks you to confirm or override, and writes a record of every source and method so the work is traceable end to end.',
  },
  {
    q: 'Can Lumecon run historical or forward-looking analyses?',
    a: 'Yes. Look back historically for a longitudinal analysis, or model forward to plan a budget, grant proposal, or capital project. Studies improve over time as more of your data accumulates in the system.',
  },
  {
    q: 'Where was Lumecon built?',
    a: 'Lumecon Inc. was built at Cornell University, with counsel from the Cornell Law Entrepreneurship Law Clinic. The team\'s academic background spans Cornell, Dartmouth, Oxford, MIT, and Yale. Prior professional experience includes the Federal Reserve Banks of Minneapolis and Philadelphia and the Federal Reserve Board of Governors in Washington, DC.',
  },
];
---
<section class="ask-cedar" id="faq" aria-labelledby="faq-title">
  <div class="ask-cedar__inner">
    <p class="ask-cedar__eyebrow">Frequently asked</p>
    <h2 class="ask-cedar__title" id="faq-title">Ask Cedar.</h2>
    <p class="ask-cedar__note">Cedar is the AI assistant inside every Lumecon platform. This marketing-page Cedar runs from a fixed answer set. Live reasoning over your data lives in the product.</p>

    <!-- Cedar chat (JS-hydrated). Hidden until script reveals it so a
         no-JS visitor goes straight to the <details> fallback below. -->
    <div class="cedar-chat" id="cedarChat" hidden>
      <div class="cedar-chat__transcript" id="cedarTranscript" role="log" aria-live="polite" aria-label="Cedar conversation">
        <div class="cedar-msg cedar-msg--bot">
          <span class="cedar-msg__avatar" aria-hidden="true">C</span>
          <div class="cedar-msg__bubble">Hi, I'm Cedar, Lumecon's AI assistant. Pick a question and I'll answer.</div>
        </div>
      </div>
      <div class="cedar-chat__chips" id="cedarChips">
        {faqs.map((f, i) => <button class="cedar-chip" type="button" data-q={i}>{f.q}</button>)}
      </div>
      <p class="cedar-chat__email">
        Question not here? <a href="mailto:contact@lumecon.ai?subject=Cedar%20question">Email contact@lumecon.ai</a>. A human reads every one.
      </p>
    </div>

    <!-- No-JS fallback + SEO-readable static FAQ. JS hides this once
         it hydrates the chat UI above. -->
    <div class="faq-list" id="cedarFallback">
      {faqs.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </div>

  <script type="application/json" id="cedarFaqData" set:html={JSON.stringify(faqs)}></script>
</section>

<script is:inline>
  (function () {
  const dataEl = document.getElementById('cedarFaqData');
  const chat = document.getElementById('cedarChat');
  const fallback = document.getElementById('cedarFallback');
  const transcript = document.getElementById('cedarTranscript');
  const chipsEl = document.getElementById('cedarChips');

  if (!(dataEl && chat && fallback && transcript && chipsEl)) return;
  const FAQS = JSON.parse(dataEl.textContent || '[]');

  // Hydrate: hide static FAQ, show chat
  chat.removeAttribute('hidden');
  fallback.setAttribute('hidden', '');

  function appendMessage(variant, body) {
    const wrap = document.createElement('div');
    wrap.className = 'cedar-msg cedar-msg--' + variant;
    if (variant === 'bot') {
      const av = document.createElement('span');
      av.className = 'cedar-msg__avatar';
      av.setAttribute('aria-hidden', 'true');
      av.textContent = 'C';
      wrap.appendChild(av);
    }
    const bubble = document.createElement('div');
    bubble.className = 'cedar-msg__bubble';
    if (typeof body === 'string') bubble.textContent = body;
    else bubble.appendChild(body);
    wrap.appendChild(bubble);
    transcript.appendChild(wrap);
    transcript.scrollTo({ top: transcript.scrollHeight, behavior: 'smooth' });
    return wrap;
  }

  chipsEl.addEventListener('click', function (e) {
    const btn = e.target.closest('.cedar-chip');
    if (!btn) return;
    const idx = parseInt(btn.dataset.q || '-1', 10);
    const item = FAQS[idx];
    if (!item) return;
    btn.disabled = true;
    btn.classList.add('cedar-chip--used');
    appendMessage('user', item.q);
    const dots = document.createElement('span');
    dots.className = 'cedar-typing';
    dots.innerHTML = '<span></span><span></span><span></span>';
    const typing = appendMessage('bot', dots);
    window.setTimeout(function () {
      const bubble = typing.querySelector('.cedar-msg__bubble');
      if (bubble) bubble.textContent = item.a;
    }, 650);
  });
  })();
</script>

<style>
  .ask-cedar {
    background: var(--white);
    padding: clamp(4rem, 8vw, 6rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .ask-cedar__inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }
  .ask-cedar__eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    color: var(--ink-3);
    margin: 0 0 1.2rem;
    text-transform: uppercase;
    font-weight: 500;
  }
  .ask-cedar__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: -.02em;
    color: var(--navy);
    margin: 0 0 .8rem;
  }
  .ask-cedar__note {
    font-family: var(--font-sans);
    font-size: .92rem;
    line-height: 1.55;
    color: var(--ink-3);
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  /* ---------- Cedar chat surface ---------- */
  /* :global() so dynamically-created bubbles (added by JS, no Astro
     scope attr) still get styled. */
  :global(.cedar-chat) {
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--paper);
    padding: 1.5rem;
    box-shadow:
      0 1px 2px rgba(14, 21, 48, .04),
      0 8px 24px -8px rgba(14, 21, 48, .08);
  }
  :global(.cedar-chat__transcript) {
    display: flex;
    flex-direction: column;
    gap: .9rem;
    max-height: 420px;
    overflow-y: auto;
    padding-right: .25rem;
    scroll-behavior: smooth;
  }
  :global(.cedar-msg) {
    display: flex;
    gap: .7rem;
    align-items: flex-start;
    max-width: 86%;
    animation: cedar-fade-in .25s var(--ease) both;
  }
  :global(.cedar-msg--user) {
    align-self: flex-end;
    flex-direction: row-reverse;
  }
  :global(.cedar-msg__avatar) {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--cedar);
    color: var(--white);
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: .85rem;
    letter-spacing: -.01em;
  }
  :global(.cedar-msg__bubble) {
    background: var(--white);
    border: 1px solid var(--rule);
    padding: .75rem .95rem;
    border-radius: 12px;
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.5;
    color: var(--ink-2);
  }
  :global(.cedar-msg--bot .cedar-msg__bubble) { border-top-left-radius: 4px; }
  :global(.cedar-msg--user .cedar-msg__bubble) {
    background: var(--navy);
    color: var(--white);
    border-color: var(--navy);
    border-top-right-radius: 4px;
  }
  @keyframes cedar-fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: none; }
  }

  /* Typing dots inside a Cedar bubble (JS-created, so :global). */
  :global(.cedar-typing) {
    display: inline-flex;
    gap: .3rem;
    padding: .15rem 0;
  }
  :global(.cedar-typing span) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ink-3);
    animation: cedar-bounce 1.2s ease-in-out infinite;
  }
  :global(.cedar-typing span:nth-child(2)) { animation-delay: .15s; }
  :global(.cedar-typing span:nth-child(3)) { animation-delay: .3s; }
  @keyframes cedar-bounce {
    0%, 100% { transform: translateY(0);    opacity: .5; }
    50%      { transform: translateY(-4px); opacity: 1;  }
  }

  .cedar-chat__chips {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
  }
  .cedar-chip {
    padding: .5rem .9rem;
    background: var(--white);
    border: 1px solid var(--rule-strong);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: .85rem;
    font-weight: 500;
    color: var(--navy);
    cursor: pointer;
    transition: background .15s var(--ease), color .15s var(--ease), border-color .15s var(--ease);
    letter-spacing: -.005em;
  }
  .cedar-chip:hover:not(:disabled) {
    background: var(--navy);
    color: var(--white);
    border-color: var(--navy);
  }
  .cedar-chip:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .cedar-chip--used {
    opacity: .35;
    cursor: default;
  }
  .cedar-chat__email {
    margin: 1.2rem 0 0;
    font-family: var(--font-sans);
    font-size: .85rem;
    color: var(--ink-3);
  }
  .cedar-chat__email a {
    font-family: var(--font-mono);
    color: var(--navy);
    border-bottom: 1px solid var(--rule-strong);
  }

  /* ---------- No-JS / SEO-readable fallback ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule);
  }
  /* [hidden] needs to win over display:flex above so JS-hydration
     actually removes the static FAQ list from view. */
  .faq-list[hidden] { display: none; }
  .faq-item {
    border-bottom: 1px solid var(--rule);
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: var(--navy);
    padding: 1.1rem 0;
    cursor: pointer;
    letter-spacing: -.01em;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink-3);
    transition: transform .2s var(--ease);
  }
  .faq-item[open] .faq-q::after { transform: rotate(45deg); }
  .faq-a {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 64ch;
    font-weight: 400;
  }

  @media (max-width: 600px) {
    :global(.cedar-chat) { padding: 1.1rem; }
    :global(.cedar-msg) { max-width: 92%; }
    :global(.cedar-chat__transcript) { max-height: 360px; }
    .ask-cedar__title { font-size: 1.8rem; }
  }
</style>
