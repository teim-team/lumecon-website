---
/**
 * FAQ section — disambiguation + canonical answers to common queries
 * about Lumecon Inc. Pairs with the FAQPage JSON-LD on the homepage so
 * Google + AI search read the same content from both surfaces.
 *
 * Disambiguation note: we focus on what Lumecon IS (AI economic impact
 * analysis software for governments) rather than calling out unrelated
 * trademark-similar businesses by name.
 */
const faqs = [
  {
    q: 'What is Lumecon?',
    a: 'Lumecon Inc. is economic impact analysis software for governments and mission-driven organizations — a modern alternative to IMPLAN, RIMS II, and REMI. Built at Cornell University. Use Cedar AI to read messy administrative data and run impact studies in-house.',
  },
  {
    q: 'Who uses Lumecon?',
    a: 'Municipal governments, tribal nations, Alaska Native Corporations, Native Hawaiian Organizations, state agencies, federal programs, universities and research labs, foundations, CDFIs, and economic development organizations.',
  },
  {
    q: 'Is Lumecon an IMPLAN / RIMS II / REMI alternative?',
    a: 'Yes. Lumecon was built as a modern, AI-assisted alternative to IMPLAN, RIMS II, REMI Policy Insight, and BEA RIMS II multipliers for organizations that need to run economic impact studies in-house, on their own data, without per-region licensing fees.',
  },
  {
    q: 'What geographies does Lumecon cover?',
    a: 'All federally recognized tribal nations and reservations, Alaska Native Corporation regions, Native Hawaiian Home Lands, every U.S. county, every U.S. state, and the entire country — all in one annual subscription, not priced per geography.',
  },
  {
    q: 'What is Cedar?',
    a: 'Cedar is the AI assistant built into every Lumecon platform. Cedar reads the files your departments already share (budgets, payroll detail, council agendas, chapter audits, grant filings), surfaces each assumption the model is about to use, asks you to confirm or override, and writes a record of every source and method so the work is traceable end to end.',
  },
  {
    q: 'Can Lumecon run historical or forward-looking analyses?',
    a: 'Yes. Look back historically for a longitudinal analysis, or model forward to plan a budget, grant proposal, or capital project. Studies improve over time as more of your data accumulates in the system.',
  },
  {
    q: 'Where was Lumecon built?',
    a: 'Lumecon Inc. was built at Cornell University, with counsel from the Cornell Law Entrepreneurship Law Clinic. The team\'s academic background spans Cornell and Dartmouth.',
  },
];
---
<section class="faq" id="faq" aria-labelledby="faq-title">
  <div class="faq-inner">
    <p class="faq-eyebrow">Frequently asked</p>
    <h2 class="faq-title" id="faq-title">About Lumecon Inc.</h2>
    <div class="faq-list">
      {faqs.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
<style>
  .faq {
    background: var(--white);
    padding: clamp(4rem, 8vw, 6rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .faq-inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }
  .faq-eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    color: var(--ink-3);
    margin: 0 0 1.2rem;
    text-transform: uppercase;
    font-weight: 500;
  }
  .faq-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: -.02em;
    color: var(--navy);
    margin: 0 0 2rem;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule);
  }
  .faq-item {
    border-bottom: 1px solid var(--rule);
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: var(--navy);
    padding: 1.1rem 0;
    cursor: pointer;
    letter-spacing: -.01em;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink-3);
    transition: transform .2s var(--ease);
  }
  .faq-item[open] .faq-q::after { transform: rotate(45deg); }
  .faq-a {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 64ch;
    font-weight: 400;
  }
</style>
