---
/**
 * Ask Cedar. The FAQ surface restyled as a Cedar chat so the section
 * demos the product narrative instead of being a generic FAQ list.
 *
 * Cedar here is hard-coded. The user can type free-form questions; a
 * keyword-classifier maps the input to one of ~25 intent buckets and
 * replies with the matching scripted answer. The intent bank, chip
 * lists, and static FAQ subset all live in src/data/cedarIntents.ts.
 * The static <details> fallback below ships the curated subset for
 * no-JS visitors and powers the FAQPage JSON-LD on the homepage.
 */
import {
  INTENTS,
  OUT_OF_SCOPE_ANSWER,
  FALLBACK_ANSWER,
  OUT_OF_SCOPE_TRIGGERS,
  CHIP_IDS,
  STATIC_FAQ_IDS,
  STATIC_FAQ_QUESTIONS,
} from '../data/cedarIntents';
// Chat-surface styles (.cedar-chat, .cedar-msg, .cedar-chip, ...)
// live in cedar-chat.css and are shared with CedarFAB.astro so the
// FAB panel renders styled on pages where FAQSection isn't rendered.
import '../styles/cedar-chat.css';
// The 200+ lines of intent definitions, chip lists, and static FAQ
// configuration that used to live here now live in cedarIntents.ts so
// they can be reused and audited independently of the chat UI.

// Build the chat surface + SEO subset off the imported tables.
const staticFaqs = STATIC_FAQ_IDS.map((id) => {
  const intent = INTENTS.find((i) => i.id === id)!;
  return { q: STATIC_FAQ_QUESTIONS[id], a: intent.answer };
});
const chips = CHIP_IDS.map((id) => INTENTS.find((i) => i.id === id)!).filter(Boolean);

const cedarData = {
  intents: INTENTS,
  outOfScope: { answer: OUT_OF_SCOPE_ANSWER, triggers: OUT_OF_SCOPE_TRIGGERS },
  fallback: { answer: FALLBACK_ANSWER },
};
interface Props {
  /** When true, render only the chat panel (no section wrapper,
      no title / byline / note). Used when embedding inside the
      Cedar section. */
  compact?: boolean;
}
const { compact = false } = Astro.props as Props;
const Wrapper = compact ? 'div' : 'section';
const wrapperClass = compact ? 'ask-cedar ask-cedar--compact' : 'ask-cedar';
---
<Wrapper class={wrapperClass} id="faq" aria-labelledby={compact ? undefined : 'faq-title'}>
  <div class="ask-cedar__inner">
    {!compact && (
      <>
        <p class="ask-cedar__eyebrow reveal-soft">Ask Cedar</p>
        <h2 class="ask-cedar__title reveal-soft" id="faq-title" data-stagger="1">Ask Cedar anything.</h2>
      </>
    )}

    <!-- Cedar chat (JS-hydrated). Hidden until script reveals it so a
         no-JS visitor goes straight to the <details> fallback below.
         Chips ride inside the welcome bubble as quick-reply
         suggestions; they collapse the first time the user picks
         one or types a question. -->
    <div class="cedar-chat" id="cedarChat" hidden>
      <header class="cedar-chat__header">
        <span class="cedar-chat__brand">
          <span class="cedar-chat__name">Cedar</span>
        </span>
        <span class="cedar-chat__status" aria-label="Online">
          <span class="cedar-chat__status-dot" aria-hidden="true"></span>
          <span class="cedar-chat__status-label">Online</span>
        </span>
      </header>
      <div class="cedar-chat__transcript" id="cedarTranscript" role="log" aria-live="polite" aria-label="Cedar conversation">
        <div class="cedar-msg cedar-msg--bot">
          <span class="cedar-msg__avatar" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none">
              <path d="M12 3 L8 9 L10 9 L7 14 L9.5 14 L5 20 L19 20 L14.5 14 L17 14 L14 9 L16 9 Z" fill="currentColor"/>
            </svg>
          </span>
          <div class="cedar-msg__bubble cedar-msg__bubble--welcome">
            <p class="cedar-msg__line">Hi, I'm Cedar. Ask me anything about Lumecon, or pick a question below.</p>
            <div class="cedar-quickreply" id="cedarChips">
              {chips.slice(0, 5).map((intent) => (
                <button class="cedar-chip" type="button" data-intent={intent.id}>{intent.chip}</button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <form class="cedar-chat__form" id="cedarForm" autocomplete="off">
        <label class="cedar-chat__inputwrap">
          <span class="visually-hidden">Ask Cedar</span>
          <input
            id="cedarInput"
            class="cedar-chat__input"
            type="text"
            name="q"
            placeholder="Ask Cedar a question..."
            maxlength="280"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="sentences"
            spellcheck="true"
            enterkeyhint="send"
            inputmode="text"
            aria-label="Ask Cedar a question"
          />
        </label>
        <button class="cedar-chat__send" type="submit" aria-label="Send">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
            <path d="M4 12L20 4L16 20L12 13L4 12Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="miter"/>
          </svg>
        </button>
      </form>
    </div>

    <p class="cedar-foot">
      Need a human? <a href="mailto:contact@lumecon.ai?subject=Cedar%20question">Email contact@lumecon.ai</a>.
    </p>

    <!-- No-JS fallback + SEO-readable static FAQ. JS hides this once
         it hydrates the chat UI above. -->
    <div class="faq-list" id="cedarFallback">
      {staticFaqs.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </div>

  <script type="application/json" id="cedarFaqData" set:html={JSON.stringify(cedarData)}></script>
</Wrapper>

<script is:inline>
  (function () {
  const dataEl = document.getElementById('cedarFaqData');
  const chat = document.getElementById('cedarChat');
  const fallback = document.getElementById('cedarFallback');
  const transcript = document.getElementById('cedarTranscript');
  const chipsEl = document.getElementById('cedarChips');
  const form = document.getElementById('cedarForm');
  const input = document.getElementById('cedarInput');

  if (!(dataEl && chat && fallback && transcript && chipsEl && form && input)) return;
  const BANK = JSON.parse(dataEl.textContent || '{}');
  const INTENTS = BANK.intents || [];

  chat.removeAttribute('hidden');
  fallback.setAttribute('hidden', '');

  function appendMessage(variant, body) {
    const wrap = document.createElement('div');
    wrap.className = 'cedar-msg cedar-msg--' + variant;
    if (variant === 'bot') {
      const av = document.createElement('span');
      av.className = 'cedar-msg__avatar';
      av.setAttribute('aria-hidden', 'true');
      av.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" fill="none"><path d="M12 3 L8 9 L10 9 L7 14 L9.5 14 L5 20 L19 20 L14.5 14 L17 14 L14 9 L16 9 Z" fill="currentColor"/></svg>';
      wrap.appendChild(av);
    }
    const bubble = document.createElement('div');
    bubble.className = 'cedar-msg__bubble';
    if (typeof body === 'string') bubble.textContent = body;
    else bubble.appendChild(body);
    wrap.appendChild(bubble);
    transcript.appendChild(wrap);
    transcript.scrollTo({ top: transcript.scrollHeight, behavior: 'smooth' });
    return wrap;
  }

  // Normalize a string: lowercase, collapse whitespace, strip punctuation
  // we don't care about. Wrap with spaces so word-boundary checks work
  // ('this'.includes('hi') is true; ' this '.includes(' hi ') is false).
  function normalize(s) {
    return ' ' + (s || '').toLowerCase()
      .replace(/[?!.,;:"'`()\[\]]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim() + ' ';
  }

  function classify(rawText) {
    const text = normalize(rawText);
    if (text.trim() === '') return { intent: null, score: 0 };
    let best = null;
    let bestScore = 0;
    for (let i = 0; i < INTENTS.length; i++) {
      const intent = INTENTS[i];
      let score = 0;
      for (let t = 0; t < intent.triggers.length; t++) {
        const trig = normalize(intent.triggers[t]);
        if (trig.trim() === '') continue;
        if (text.indexOf(trig) !== -1) {
          // Longer phrases are worth more; "who are you" beats a single
          // -word "cedar" hit when scoring against the same intent.
          score += Math.max(1, trig.trim().split(' ').length);
        }
      }
      if (score > bestScore) { bestScore = score; best = intent; }
    }
    return { intent: best, score: bestScore };
  }

  function isOutOfScope(rawText) {
    const text = normalize(rawText);
    const trigs = (BANK.outOfScope && BANK.outOfScope.triggers) || [];
    for (let i = 0; i < trigs.length; i++) {
      const t = normalize(trigs[i]);
      if (t.trim() === '') continue;
      if (text.indexOf(t) !== -1) return true;
    }
    return false;
  }

  function answerFor(rawText) {
    const c = classify(rawText);
    if (c.intent && c.score >= 1) return c.intent.answer;
    if (isOutOfScope(rawText)) return BANK.outOfScope.answer;
    return BANK.fallback.answer;
  }

  function reply(rawText, echoText) {
    appendMessage('user', echoText != null ? echoText : rawText);
    const dots = document.createElement('span');
    dots.className = 'cedar-typing';
    dots.innerHTML = '<span></span><span></span><span></span>';
    const typing = appendMessage('bot', dots);
    window.setTimeout(function () {
      const bubble = typing.querySelector('.cedar-msg__bubble');
      if (bubble) bubble.textContent = answerFor(rawText);
    }, 650);
  }

  function collapseQuickReplies() {
    if (chipsEl && !chipsEl.classList.contains('is-collapsed')) {
      chipsEl.classList.add('is-collapsed');
    }
  }

  chipsEl.addEventListener('click', function (e) {
    const btn = e.target.closest('.cedar-chip');
    if (!btn) return;
    const id = btn.dataset.intent;
    const intent = INTENTS.find(function (x) { return x.id === id; });
    if (!intent) return;
    collapseQuickReplies();
    reply(intent.chip, intent.chip);
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    const q = (input.value || '').trim();
    if (!q) return;
    input.value = '';
    collapseQuickReplies();
    reply(q, q);
  });
  })();
</script>

<style>
  .ask-cedar {
    background: var(--white);
    padding: clamp(4rem, 8vw, 6rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .ask-cedar__inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }
  /* Compact form: drop the section-level chrome so the chat sits
     cleanly inside another container (the Cedar section's right col). */
  .ask-cedar--compact {
    background: none;
    padding: 0;
    border-bottom: 0;
    width: 100%;
  }
  .ask-cedar--compact .ask-cedar__inner {
    max-width: none;
    padding: 0;
    margin: 0;
  }
  .ask-cedar__eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    color: var(--accent);
    margin: 0 0 1.2rem;
    text-transform: uppercase;
    font-weight: 600;
  }
  .ask-cedar__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: -.02em;
    color: var(--navy);
    margin: 0 0 .8rem;
  }
  .ask-cedar__note {
    font-family: var(--font-sans);
    font-size: .92rem;
    line-height: 1.55;
    color: var(--ink-3);
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  /* Chat-surface styles (.cedar-chat, .cedar-msg, .cedar-chip,
     .cedar-typing, .cedar-quickreply, .visually-hidden) are loaded
     from src/styles/cedar-chat.css (imported at the top of this
     file + by CedarFAB.astro). */

  /* Subtle line below the chat container instead of an internal foot. */
  .cedar-foot {
    margin: .9rem 0 0;
    font-family: var(--font-sans);
    font-size: .85rem;
    color: var(--ink-3);
    text-align: center;
  }
  .cedar-foot a {
    font-family: var(--font-mono);
    color: var(--navy);
    border-bottom: 1px solid var(--rule-strong);
  }

  /* ---------- No-JS / SEO-readable fallback ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule);
  }
  .faq-list[hidden] { display: none; }
  .faq-item {
    border-bottom: 1px solid var(--rule);
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: var(--navy);
    padding: 1.1rem 0;
    cursor: pointer;
    letter-spacing: -.01em;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink-3);
    transition: transform .2s var(--ease);
  }
  .faq-item[open] .faq-q::after { transform: rotate(45deg); }
  .faq-a {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 64ch;
    font-weight: 400;
  }

  @media (max-width: 600px) {
    .ask-cedar__title { font-size: 1.8rem; }
  }
</style>
