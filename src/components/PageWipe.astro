---
interface Props {
  /** Edge the panel slides off toward on page load. */
  direction?: 'right' | 'left' | 'up' | 'down';
  /** Panel color. Defaults to the brand teal. */
  color?: string;
}
const { direction = 'right', color = 'var(--accent, #0FB5A5)' } = Astro.props;
---
<div class={`page-wipe page-wipe--${direction}`} style={`--wipe-color:${color}`} aria-hidden="true"></div>

<style>
  .page-wipe {
    position: fixed;
    inset: 0;
    z-index: 95;            /* under the nav (z 100), over page content, FAB, and consent */
    background: var(--wipe-color);
    pointer-events: none;   /* never blocks clicks */
    will-change: transform;
  }

  /* Reveal on each page load: the panel starts covering the viewport, then
     slides off the chosen edge. Pure CSS that auto-plays on every real page
     load (Astro static MPA), so no router or JS is needed. `forwards` parks
     it off-screen after. */
  .page-wipe--right { animation: page-wipe-right .5s cubic-bezier(.76, 0, .24, 1) forwards; }
  .page-wipe--left  { animation: page-wipe-left  .5s cubic-bezier(.76, 0, .24, 1) forwards; }
  .page-wipe--up    { animation: page-wipe-up    .5s cubic-bezier(.76, 0, .24, 1) forwards; }
  .page-wipe--down  { animation: page-wipe-down  .5s cubic-bezier(.76, 0, .24, 1) forwards; }

  @keyframes page-wipe-right { from { transform: translateX(0); } to { transform: translateX(101%); } }
  @keyframes page-wipe-left  { from { transform: translateX(0); } to { transform: translateX(-101%); } }
  @keyframes page-wipe-up    { from { transform: translateY(0); } to { transform: translateY(-101%); } }
  @keyframes page-wipe-down  { from { transform: translateY(0); } to { transform: translateY(101%); } }

  /* Respect reduced-motion: no wipe, instant page. */
  @media (prefers-reduced-motion: reduce) { .page-wipe { display: none; } }
</style>
