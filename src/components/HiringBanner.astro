---
/**
 * Compact recruiting strip. Sits between FAQ and Contact on the
 * homepage, giving /join a contextual entry point without bloating
 * the page or competing with the primary "Request a demo" CTA.
 * Framed as 'Looking for early teammates' (not 'We're hiring') so we
 * don't imply paid roles where there aren't any.
 *
 * Right side carries a small animated network graph that grows from
 * a single node to a team of nodes-with-edges, visualizing the team
 * expansion the banner is asking the visitor to help build.
 */
---
<aside class="hiring" aria-labelledby="hiring-title">
  <div class="hiring-inner">
    <div class="hiring-text">
      <p class="hiring-eyebrow reveal-soft">Looking for early teammates · five-person team</p>
      <p class="hiring-title reveal-soft" id="hiring-title" data-stagger="1">Help us <em>luminate</em> economies.</p>
      <p class="hiring-sub reveal-soft" data-stagger="2">Undergrad and graduate students across engineering, ML, data, economic impact modeling, marketing, and sales. We mentor people who are persistent. Unpaid early-stage roles.</p>
      <div class="hiring-ctas reveal-soft" data-stagger="3">
        <a href="/join" class="btn">See roles + apply</a>
      </div>
    </div>
    <div class="hiring-graph" aria-hidden="true">
      <!-- Procedurally generated each cycle by the script below.
           The viewBox is fixed; the contents (root, 2-4 inner
           branches, 1-4 children per branch) regenerate every ~7s
           so visitors who linger see the team graph evolve
           rather than loop the same shape. -->
      <svg id="hgSvg" viewBox="0 0 240 220" preserveAspectRatio="xMidYMid meet"></svg>
    </div>
  </div>
</aside>

<script is:inline>
  /* Procedural team-graph generator. Three rules guide the look:
       1. No edge overlap. Each spawn picks the angle with the widest
          'free arc' around the parent node, then tries a few distances
          and rejects positions that would cross any existing edge.
       2. Infinite growth, no reset. The graph keeps extending; old
          nodes outside the visible camera fade out instead of
          everything snapping back.
       3. The camera pans. Nodes live on a large virtual canvas; the
          visible viewBox is a 240x220 window that smoothly slides
          toward the latest active growth area. When the current
          area gets crowded, an outward leaf becomes the new growth
          seed and the camera follows it. */
  (function () {
    const svg = document.getElementById('hgSvg');
    if (!svg) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const VBW = 240, VBH = 220; // visible window size
    const reducedMotion = window.matchMedia
      && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const rand = (a, b) => a + Math.random() * (b - a);
    const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
    const dist = (a, b) => Math.hypot(a.x - b.x, a.y - b.y);

    /** @type {Array<{node: SVGCircleElement, edge: SVGLineElement|null, parent: number|null, x: number, y: number, r: number, gen: number, childCount: number}|null>} */
    const nodes = [];
    let generation = 0;

    const layerEdges = document.createElementNS(SVG_NS, 'g');
    const layerNodes = document.createElementNS(SVG_NS, 'g');
    svg.appendChild(layerEdges);
    svg.appendChild(layerNodes);

    // Camera state. The viewBox starts centered on (0,0) and pans
    // smoothly toward `camTarget` as growth pushes outward.
    let camX = 0, camY = 0;
    let camTargetX = 0, camTargetY = 0;
    function setViewBox() {
      svg.setAttribute('viewBox', `${camX - VBW / 2} ${camY - VBH / 2} ${VBW} ${VBH}`);
    }
    setViewBox();

    // Line-segment intersection helper (used to reject spawn positions
    // whose new edge would cross any existing edge).
    function segmentsIntersect(a1, a2, b1, b2) {
      function cross(ox, oy, ax, ay, bx, by) {
        return (ax - ox) * (by - oy) - (ay - oy) * (bx - ox);
      }
      const d1 = cross(b1.x, b1.y, b2.x, b2.y, a1.x, a1.y);
      const d2 = cross(b1.x, b1.y, b2.x, b2.y, a2.x, a2.y);
      const d3 = cross(a1.x, a1.y, a2.x, a2.y, b1.x, b1.y);
      const d4 = cross(a1.x, a1.y, a2.x, a2.y, b2.x, b2.y);
      if (((d1 > 0 && d2 < 0) || (d1 < 0 && d2 > 0)) &&
          ((d3 > 0 && d4 < 0) || (d3 < 0 && d4 > 0))) return true;
      return false;
    }

    function mkCircle(x, y, r, fill, className) {
      const c = document.createElementNS(SVG_NS, 'circle');
      c.setAttribute('cx', String(x));
      c.setAttribute('cy', String(y));
      c.setAttribute('r', String(r));
      c.setAttribute('fill', fill);
      if (className) c.setAttribute('class', className);
      layerNodes.appendChild(c);
      return c;
    }
    function mkLine(x1, y1, x2, y2) {
      const l = document.createElementNS(SVG_NS, 'line');
      l.setAttribute('x1', String(x1));
      l.setAttribute('y1', String(y1));
      l.setAttribute('x2', String(x2));
      l.setAttribute('y2', String(y2));
      l.setAttribute('stroke', 'currentColor');
      l.setAttribute('stroke-width', '1');
      l.setAttribute('stroke-linecap', 'butt');
      l.setAttribute('fill', 'none');
      layerEdges.appendChild(l);
      return l;
    }

    function spawnNode(parentIdx, x, y, r) {
      const parent = parentIdx !== null && parentIdx >= 0 ? nodes[parentIdx] : null;
      const edge = parent ? mkLine(parent.x, parent.y, x, y) : null;
      const node = mkCircle(x, y, r, 'currentColor', 'hg-node hg-node--leaf');
      node.style.opacity = '0';
      const entry = { node, edge, parent: parentIdx, x, y, r, gen: ++generation, childCount: 0 };
      const idx = nodes.length;
      nodes.push(entry);
      if (parent) parent.childCount++;

      if (reducedMotion) { node.style.opacity = '1'; return idx; }

      // Line draws first, dot fades in at the terminus during the
      // last 30% of the draw — line and dot read as one motion.
      const drawMs = 540;
      if (edge) {
        const len = Math.hypot(x - parent.x, y - parent.y);
        edge.setAttribute('stroke-dasharray', String(len));
        edge.setAttribute('stroke-dashoffset', String(len));
        edge.animate(
          [{ strokeDashoffset: len }, { strokeDashoffset: 0 }],
          { duration: drawMs, fill: 'forwards', easing: 'cubic-bezier(.4,.05,.2,1)' }
        );
      }
      const dotDelay = edge ? drawMs * 0.7 : 0;
      node.animate(
        [{ opacity: 0 }, { opacity: 1 }],
        { duration: drawMs * 0.3, delay: dotDelay, fill: 'forwards', easing: 'ease-out' }
      );
      node.animate(
        [
          { fill: '#F0A91A', offset: 0 },
          { fill: '#F0A91A', offset: .4 },
          { fill: 'currentColor', offset: 1 },
        ],
        { duration: 900, delay: dotDelay, fill: 'forwards' }
      );
      return idx;
    }

    function fadeOutNode(idx) {
      const entry = nodes[idx];
      if (!entry || entry.childCount > 0) return false;
      const cleanup = () => {
        if (entry.edge && entry.edge.parentNode) entry.edge.parentNode.removeChild(entry.edge);
        if (entry.node.parentNode) entry.node.parentNode.removeChild(entry.node);
        const parent = entry.parent !== null && entry.parent >= 0 ? nodes[entry.parent] : null;
        if (parent) parent.childCount--;
        nodes[idx] = null;
      };
      if (reducedMotion) { cleanup(); return true; }
      entry.node.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 700, fill: 'forwards', easing: 'ease-in' });
      if (entry.edge) entry.edge.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 700, fill: 'forwards', easing: 'ease-in' });
      setTimeout(cleanup, 720);
      return true;
    }

    // Try to find an overlap-free position for a child of `parent`.
    // We pick the angle with the widest free arc around the parent
    // (no nearby siblings/relatives in that direction), then verify
    // the candidate edge doesn't cross any existing edge and the
    // candidate node has clearance from every other live node.
    function tryPosition(parent) {
      const NEAR = 90; // radius of "neighborhood" for arc analysis
      const angles = [];
      for (const n of nodes) {
        if (!n || n === parent) continue;
        if (dist(parent, n) > NEAR) continue;
        angles.push(Math.atan2(n.y - parent.y, n.x - parent.x));
      }
      // If there's a parent of `parent`, prefer continuing outward.
      const gp = parent.parent !== null && parent.parent >= 0 ? nodes[parent.parent] : null;
      const outwardAngle = gp ? Math.atan2(parent.y - gp.y, parent.x - gp.x) : null;

      // Sample candidate angles. Pick the one with the largest gap
      // to every nearby angle, weighted toward outward continuation.
      const candidates = [];
      const samples = 24;
      for (let i = 0; i < samples; i++) {
        const ang = (i / samples) * Math.PI * 2 - Math.PI;
        let minGap = Math.PI;
        for (const a of angles) {
          let g = Math.abs(((ang - a + Math.PI * 3) % (Math.PI * 2)) - Math.PI);
          if (g < minGap) minGap = g;
        }
        let score = minGap;
        if (outwardAngle !== null) {
          let dAng = Math.abs(((ang - outwardAngle + Math.PI * 3) % (Math.PI * 2)) - Math.PI);
          // Bonus for continuing in the parent's outward direction
          score += (Math.PI - dAng) * 0.4;
        }
        candidates.push({ ang, score });
      }
      candidates.sort((a, b) => b.score - a.score);

      // Try the top candidates with various distances.
      for (let i = 0; i < Math.min(8, candidates.length); i++) {
        const baseAng = candidates[i].ang;
        for (let attempt = 0; attempt < 3; attempt++) {
          const ang = baseAng + rand(-0.18, 0.18);
          const d = rand(34, 52);
          const x = parent.x + Math.cos(ang) * d;
          const y = parent.y + Math.sin(ang) * d;

          // Reject if too close to any other live node.
          let tooClose = false;
          for (const n of nodes) {
            if (!n || n === parent) continue;
            if (dist({ x, y }, n) < 22) { tooClose = true; break; }
          }
          if (tooClose) continue;

          // Reject if the proposed edge would cross any existing edge.
          let crosses = false;
          const a1 = { x: parent.x, y: parent.y };
          const a2 = { x, y };
          for (const n of nodes) {
            if (!n || !n.edge || n === parent) continue;
            const eParent = n.parent !== null && n.parent >= 0 ? nodes[n.parent] : null;
            if (!eParent) continue;
            // Skip edges that share an endpoint with the new edge.
            if (eParent === parent || n === parent) continue;
            const b1 = { x: eParent.x, y: eParent.y };
            const b2 = { x: n.x, y: n.y };
            if (segmentsIntersect(a1, a2, b1, b2)) { crosses = true; break; }
          }
          if (crosses) continue;

          return { x, y };
        }
      }
      return null;
    }

    // Focal node: the active branching point. Walks outward as we
    // spawn from it; once it's grown enough children (or stops being
    // productive), the camera retargets to a fresh outward leaf.
    let focalIdx = -1;
    let spawnsFromFocal = 0;
    let focalBudget = 2 + Math.floor(Math.random() * 2);

    function chooseNewFocal() {
      // Pick the outward leaf most aligned with our preferred growth
      // direction (away from camera center, into open space).
      let best = focalIdx;
      let bestScore = -Infinity;
      for (let i = 0; i < nodes.length; i++) {
        const e = nodes[i];
        if (!e || e.childCount > 0) continue;
        // Prefer leaves far from camera center (push outward)
        const distFromCam = Math.hypot(e.x - camTargetX, e.y - camTargetY);
        // Prefer newer leaves
        const recency = e.gen;
        const score = distFromCam * 0.6 + recency * 0.8;
        if (score > bestScore) { bestScore = score; best = i; }
      }
      return best;
    }

    function panCameraToFocal() {
      const focal = nodes[focalIdx];
      if (!focal) return;
      // The target keeps the focal node visible but biased toward
      // the "outward" side so there's room ahead for growth.
      const gp = focal.parent !== null && focal.parent >= 0 ? nodes[focal.parent] : null;
      let outX = 0, outY = 0;
      if (gp) {
        const a = Math.atan2(focal.y - gp.y, focal.x - gp.x);
        outX = Math.cos(a) * 50;
        outY = Math.sin(a) * 50;
      }
      camTargetX = focal.x + outX;
      camTargetY = focal.y + outY;
    }

    // Smoothly tween the camera toward its target each frame.
    function tickCamera() {
      const ease = 0.06;
      camX += (camTargetX - camX) * ease;
      camY += (camTargetY - camY) * ease;
      setViewBox();
      if (!reducedMotion) requestAnimationFrame(tickCamera);
    }

    function pruneOffscreen() {
      // Anything more than half-a-viewport beyond the visible window
      // is a candidate for fade-out. Don't orphan parents.
      const xMin = camX - VBW * 0.9;
      const xMax = camX + VBW * 0.9;
      const yMin = camY - VBH * 0.9;
      const yMax = camY + VBH * 0.9;
      for (let i = 1; i < nodes.length; i++) {
        const e = nodes[i];
        if (!e || e.childCount > 0) continue;
        if (e.x < xMin || e.x > xMax || e.y < yMin || e.y > yMax) {
          fadeOutNode(i);
        }
      }
    }

    function tick() {
      if (focalIdx < 0 || !nodes[focalIdx]) focalIdx = 0;
      const parent = nodes[focalIdx];
      if (!parent) return;
      const pos = tryPosition(parent);
      if (!pos) {
        // Cul-de-sac: jump to a fresh outward leaf and pan camera.
        focalIdx = chooseNewFocal();
        spawnsFromFocal = 0;
        focalBudget = 2 + Math.floor(Math.random() * 2);
        panCameraToFocal();
        return;
      }
      const r = rand(2.8, 4.4);
      spawnNode(focalIdx, pos.x, pos.y, r);
      spawnsFromFocal++;

      // Camera follows: once focal has spawned its budget, walk on.
      if (spawnsFromFocal >= focalBudget) {
        focalIdx = chooseNewFocal();
        spawnsFromFocal = 0;
        focalBudget = 2 + Math.floor(Math.random() * 2);
        panCameraToFocal();
      }

      // Trim nodes that have wandered off camera.
      pruneOffscreen();
    }

    // Seed: a single root at origin.
    const rootIdx = spawnNode(null, 0, 0, 7);
    nodes[rootIdx].node.setAttribute('class', 'hg-node hg-node--center');
    nodes[rootIdx].node.setAttribute('fill', '#F0A91A');
    nodes[rootIdx].node.style.opacity = '1';
    nodes[rootIdx].node.getAnimations && nodes[rootIdx].node.getAnimations().forEach(a => a.cancel());
    nodes[rootIdx].node.setAttribute('fill', '#F0A91A');
    focalIdx = rootIdx;

    if (!reducedMotion) {
      requestAnimationFrame(tickCamera);
      function schedule() {
        setTimeout(() => { tick(); schedule(); }, 800 + Math.random() * 500);
      }
      schedule();
    } else {
      // Static: spawn a small seed tree without animation.
      for (let i = 0; i < 5; i++) tick();
    }
  })();
</script>



<style>
  .hiring {
    background: var(--cream);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .hiring-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hiring-eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 .55rem;
  }
  .hiring-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    line-height: 1.2;
    letter-spacing: -.018em;
    color: var(--navy);
    margin: 0 0 .6rem;
    max-width: 32ch;
  }
  .hiring-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 600;
    animation: luminate-glow 3.4s ease-in-out infinite;
  }
  @keyframes luminate-glow {
    0%, 100% {
      text-shadow: 0 0 0 rgba(240, 169, 26, 0);
      filter: brightness(1);
    }
    50% {
      text-shadow:
        0 0 12px rgba(240, 169, 26, .5),
        0 0 24px rgba(240, 169, 26, .3);
      filter: brightness(1.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hiring-title em { animation: none; }
  }
  .hiring-sub {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 60ch;
    font-weight: 400;
  }
  .hiring-ctas {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
    margin-top: .25rem;
  }

  /* ---------- Network graph ---------- */
  .hiring-graph {
    color: var(--navy);
    width: 100%;
    max-width: 340px;
    justify-self: end;
  }
  .hiring-graph svg { width: 100%; height: auto; display: block; }

  /* Nodes + edges are positioned and animated entirely from JS now
     (see the inline script at the bottom of this file). CSS only
     supplies the gentle center-pulse and a transform-box hint so
     each circle scales around its own center. */
  .hg-node {
    transform-box: fill-box;
    transform-origin: center;
  }
  .hg-node--center {
    animation: hg-pulse 6s ease-in-out infinite;
  }
  @keyframes hg-pulse {
    0%, 100% { transform: scale(1);   filter: drop-shadow(0 0 0 rgba(240, 169, 26, 0)); }
    50%      { transform: scale(1.15); filter: drop-shadow(0 0 4px rgba(240, 169, 26, .55)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hg-node--center { animation: none !important; }
  }

  @media (max-width: 720px) {
    .hiring-inner { grid-template-columns: 1fr; }
    .hiring-graph { max-width: 260px; margin: 0 auto; justify-self: center; }
  }
</style>
