---
/**
 * Compact recruiting strip. Sits between FAQ and Contact on the
 * homepage, giving /join a contextual entry point without bloating
 * the page or competing with the primary "Request a demo" CTA.
 * Framed as 'Looking for early teammates' (not 'We're hiring') so we
 * don't imply paid roles where there aren't any.
 */
---
<aside class="hiring" aria-labelledby="hiring-title">
  <div class="hiring-inner">
    <div class="hiring-text">
      <p class="hiring-eyebrow">Looking for early teammates · five-person team</p>
      <p class="hiring-title" id="hiring-title">Help us <em>illuminate</em> economies.</p>
      <p class="hiring-sub">Undergrad and graduate students across engineering, ML, data, economic impact modeling, marketing, and sales. We mentor people who are persistent. Unpaid early-stage roles.</p>
    </div>
    <div class="hiring-ctas">
      <a href="/join" class="btn">See roles + apply</a>
    </div>
  </div>
</aside>
<style>
  .hiring {
    background: var(--cream);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .hiring-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.6rem 3rem;
    align-items: center;
  }
  .hiring-eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 .55rem;
  }
  .hiring-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    line-height: 1.2;
    letter-spacing: -.018em;
    color: var(--navy);
    margin: 0 0 .5rem;
    max-width: 32ch;
  }
  .hiring-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 600;
  }
  .hiring-sub {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
    font-weight: 400;
  }
  .hiring-ctas {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
  }
  @media (max-width: 720px) {
    .hiring-inner { grid-template-columns: 1fr; }
    .hiring-ctas { margin-top: .4rem; }
  }
</style>
