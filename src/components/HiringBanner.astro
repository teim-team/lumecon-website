---
/**
 * Compact recruiting strip. Sits between FAQ and Contact on the
 * homepage, giving /join a contextual entry point without bloating
 * the page or competing with the primary "Request a demo" CTA.
 * Framed as 'Looking for early teammates' (not 'We're hiring') so we
 * don't imply paid roles where there aren't any.
 *
 * Right side carries a small animated network graph that grows from
 * a single node to a team of nodes-with-edges, visualizing the team
 * expansion the banner is asking the visitor to help build.
 */
---
<aside class="hiring" aria-labelledby="hiring-title">
  <div class="hiring-inner">
    <div class="hiring-text">
      <p class="hiring-eyebrow reveal-soft">Looking for early teammates · five-person team</p>
      <p class="hiring-title reveal-soft" id="hiring-title" data-stagger="1">Help us <em>luminate</em> economies.</p>
      <p class="hiring-sub reveal-soft" data-stagger="2">Undergrad and graduate students across engineering, ML, data, economic impact modeling, marketing, and sales. We mentor people who are persistent. Unpaid early-stage roles.</p>
      <div class="hiring-ctas reveal-soft" data-stagger="3">
        <a href="/join" class="btn">See roles + apply</a>
      </div>
    </div>
    <div class="hiring-graph" aria-hidden="true">
      <!-- Procedurally generated each cycle by the script below.
           The viewBox is fixed; the contents (root, 2-4 inner
           branches, 1-4 children per branch) regenerate every ~7s
           so visitors who linger see the team graph evolve
           rather than loop the same shape. -->
      <svg id="hgSvg" viewBox="0 0 240 220" preserveAspectRatio="xMidYMid meet"></svg>
    </div>
  </div>
</aside>

<script is:inline>
  /* Procedural team-graph generator. The growth motion is a single
     drawing gesture: a stroke-dashoffset line extends from an
     existing node out to a new position, and the new dot fades in
     at the line's terminus exactly as it arrives — no "floating
     in" dots disconnected from their edges.
     The active branching point ("focal" node) walks outward over
     time: after 1-3 spawns from one focal, the focal jumps to a
     recent leaf so the next spawns branch from somewhere fresh.
     Old growth fades out quietly when total live nodes exceeds a
     soft cap, so the graph keeps evolving without resetting.
     Honors prefers-reduced-motion by drawing one static seed. */
  (function () {
    const svg = document.getElementById('hgSvg');
    if (!svg) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const W = 240, H = 220;
    const reducedMotion = window.matchMedia
      && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const rand = (a, b) => a + Math.random() * (b - a);
    const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
    const dist = (a, b) => Math.hypot(a.x - b.x, a.y - b.y);

    /** @type {Array<{node: SVGCircleElement, edge: SVGLineElement|null, parent: number, x: number, y: number, r: number, gen: number, childCount: number}|null>} */
    const nodes = [];
    let generation = 0;
    const SOFT_CAP = 20;

    const layerEdges = document.createElementNS(SVG_NS, 'g');
    const layerNodes = document.createElementNS(SVG_NS, 'g');
    svg.appendChild(layerEdges);
    svg.appendChild(layerNodes);

    function mkCircle(x, y, r, fill, className) {
      const c = document.createElementNS(SVG_NS, 'circle');
      c.setAttribute('cx', String(x));
      c.setAttribute('cy', String(y));
      c.setAttribute('r', String(r));
      c.setAttribute('fill', fill);
      if (className) c.setAttribute('class', className);
      layerNodes.appendChild(c);
      return c;
    }
    function mkLine(x1, y1, x2, y2) {
      const l = document.createElementNS(SVG_NS, 'line');
      l.setAttribute('x1', String(x1));
      l.setAttribute('y1', String(y1));
      l.setAttribute('x2', String(x2));
      l.setAttribute('y2', String(y2));
      l.setAttribute('stroke', 'currentColor');
      l.setAttribute('stroke-width', '1');
      l.setAttribute('stroke-linecap', 'butt');
      l.setAttribute('fill', 'none');
      layerEdges.appendChild(l);
      return l;
    }

    // Spawn a new node connected to nodes[parentIdx]. The line draws
    // from parent → (x,y); the dot fades in at the destination so
    // line and dot read as a single motion (line growing toward a
    // point that materializes as the line arrives).
    function spawnNode(parentIdx, x, y, r) {
      const parent = parentIdx >= 0 ? nodes[parentIdx] : null;
      const edge = parent ? mkLine(parent.x, parent.y, x, y) : null;
      const node = mkCircle(x, y, r, 'currentColor', 'hg-node hg-node--leaf');
      node.style.opacity = '0';
      const entry = { node, edge, parent: parentIdx, x, y, r, gen: ++generation, childCount: 0 };
      const idx = nodes.length;
      nodes.push(entry);
      if (parent) parent.childCount++;

      if (reducedMotion) {
        node.style.opacity = '1';
        return idx;
      }

      const drawMs = 520;
      if (edge) {
        const len = Math.hypot(x - parent.x, y - parent.y);
        edge.setAttribute('stroke-dasharray', String(len));
        edge.setAttribute('stroke-dashoffset', String(len));
        edge.animate(
          [{ strokeDashoffset: len }, { strokeDashoffset: 0 }],
          { duration: drawMs, fill: 'forwards', easing: 'cubic-bezier(.4,.05,.2,1)' }
        );
      }
      // Dot fades in over the LAST 30% of the line draw so it
      // appears as the line arrives at its destination, then briefly
      // flashes gold and settles to navy.
      const dotDelay = edge ? drawMs * 0.7 : 0;
      node.animate(
        [{ opacity: 0 }, { opacity: 1 }],
        { duration: drawMs * 0.3, delay: dotDelay, fill: 'forwards', easing: 'ease-out' }
      );
      node.animate(
        [
          { fill: '#F0A91A', offset: 0 },
          { fill: '#F0A91A', offset: .4 },
          { fill: 'currentColor', offset: 1 },
        ],
        { duration: 900, delay: dotDelay, fill: 'forwards' }
      );
      return idx;
    }

    function fadeOutNode(idx) {
      const entry = nodes[idx];
      if (!entry) return;
      // Don't orphan kids: if this node has live children, skip it
      // and pick a different oldest target.
      if (entry.childCount > 0) return false;
      const cleanup = () => {
        if (entry.edge && entry.edge.parentNode) entry.edge.parentNode.removeChild(entry.edge);
        if (entry.node.parentNode) entry.node.parentNode.removeChild(entry.node);
        const parent = entry.parent >= 0 ? nodes[entry.parent] : null;
        if (parent) parent.childCount--;
        nodes[idx] = null;
      };
      if (reducedMotion) { cleanup(); return true; }
      entry.node.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 600, fill: 'forwards', easing: 'ease-in' });
      if (entry.edge) entry.edge.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 600, fill: 'forwards', easing: 'ease-in' });
      setTimeout(cleanup, 620);
      return true;
    }

    function liveCount() {
      let n = 0;
      for (const e of nodes) if (e) n++;
      return n;
    }

    function tryPosition(parent) {
      // Continue the angle from grandparent → parent so growth
      // pushes outward instead of doubling back.
      const grandparent = parent.parent >= 0 ? nodes[parent.parent] : null;
      const baseAngle = grandparent
        ? Math.atan2(parent.y - grandparent.y, parent.x - grandparent.x)
        : Math.random() * Math.PI * 2;
      for (let attempt = 0; attempt < 14; attempt++) {
        const ang = baseAngle + rand(-0.9, 0.9);
        const d = rand(30, 54);
        const x = clamp(parent.x + Math.cos(ang) * d, 12, W - 12);
        const y = clamp(parent.y + Math.sin(ang) * d, 12, H - 12);
        let tooClose = false;
        for (const e of nodes) {
          if (!e) continue;
          if (dist({ x, y }, e) < 20) { tooClose = true; break; }
        }
        if (!tooClose) return { x, y };
      }
      return null;
    }

    // The focal node walks outward: after 1-3 spawns from the
    // current focal, jump to a recent leaf so the next spawns
    // branch from somewhere fresh. This is what the user sees as
    // "the active branching point moves around the graph."
    let focalIdx = -1;
    let spawnsFromFocal = 0;
    let targetSpawnsBeforeWalk = 2 + Math.floor(Math.random() * 2);

    function chooseNewFocal() {
      // Recent leaves (childCount === 0) preferred. Bias toward
      // newer generations so the walker stays near the perimeter.
      const candidates = [];
      for (let i = 0; i < nodes.length; i++) {
        const e = nodes[i];
        if (!e || e.childCount > 0) continue;
        candidates.push({ i, w: 1 + e.gen });
      }
      if (!candidates.length) return focalIdx;
      const total = candidates.reduce((s, c) => s + c.w, 0);
      let r = Math.random() * total;
      for (const c of candidates) {
        r -= c.w;
        if (r <= 0) return c.i;
      }
      return candidates[candidates.length - 1].i;
    }

    function tick() {
      if (focalIdx < 0 || !nodes[focalIdx]) focalIdx = 0;
      const parent = nodes[focalIdx];
      if (!parent) return;
      const pos = tryPosition(parent);
      if (!pos) {
        // Cul-de-sac: skip to a fresh focal next tick.
        focalIdx = chooseNewFocal();
        spawnsFromFocal = 0;
        targetSpawnsBeforeWalk = 2 + Math.floor(Math.random() * 2);
        return;
      }
      const r = rand(2.7, 4.4);
      spawnNode(focalIdx, pos.x, pos.y, r);
      spawnsFromFocal++;

      if (spawnsFromFocal >= targetSpawnsBeforeWalk) {
        focalIdx = chooseNewFocal();
        spawnsFromFocal = 0;
        targetSpawnsBeforeWalk = 2 + Math.floor(Math.random() * 2);
      }

      // Soft cap: prune the oldest LEAF (childCount === 0) so we
      // never orphan a subtree. Skip the root.
      if (liveCount() > SOFT_CAP) {
        let oldestIdx = -1;
        let oldestGen = Infinity;
        for (let i = 1; i < nodes.length; i++) {
          const e = nodes[i];
          if (!e || e.childCount > 0) continue;
          if (e.gen < oldestGen) { oldestGen = e.gen; oldestIdx = i; }
        }
        if (oldestIdx !== -1) fadeOutNode(oldestIdx);
      }
    }

    // Seed: root at the center, always visible. Mark it as the
    // initial focal node so the first growth grows from here.
    const rootIdx = spawnNode(-1, 120, 110, 6.5);
    nodes[rootIdx].node.setAttribute('class', 'hg-node hg-node--center');
    nodes[rootIdx].node.setAttribute('fill', '#F0A91A');
    nodes[rootIdx].node.style.opacity = '1';
    nodes[rootIdx].node.getAnimations && nodes[rootIdx].node.getAnimations().forEach(a => a.cancel());
    nodes[rootIdx].node.setAttribute('fill', '#F0A91A');
    focalIdx = rootIdx;

    if (!reducedMotion) {
      function schedule() {
        setTimeout(() => { tick(); schedule(); }, 750 + Math.random() * 450);
      }
      schedule();
    }
  })();
</script>


<style>
  .hiring {
    background: var(--cream);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .hiring-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hiring-eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 .55rem;
  }
  .hiring-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    line-height: 1.2;
    letter-spacing: -.018em;
    color: var(--navy);
    margin: 0 0 .6rem;
    max-width: 32ch;
  }
  .hiring-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 600;
    animation: luminate-glow 3.4s ease-in-out infinite;
  }
  @keyframes luminate-glow {
    0%, 100% {
      text-shadow: 0 0 0 rgba(240, 169, 26, 0);
      filter: brightness(1);
    }
    50% {
      text-shadow:
        0 0 12px rgba(240, 169, 26, .5),
        0 0 24px rgba(240, 169, 26, .3);
      filter: brightness(1.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hiring-title em { animation: none; }
  }
  .hiring-sub {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 60ch;
    font-weight: 400;
  }
  .hiring-ctas {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
    margin-top: .25rem;
  }

  /* ---------- Network graph ---------- */
  .hiring-graph {
    color: var(--navy);
    width: 100%;
    max-width: 340px;
    justify-self: end;
  }
  .hiring-graph svg { width: 100%; height: auto; display: block; }

  /* Nodes + edges are positioned and animated entirely from JS now
     (see the inline script at the bottom of this file). CSS only
     supplies the gentle center-pulse and a transform-box hint so
     each circle scales around its own center. */
  .hg-node {
    transform-box: fill-box;
    transform-origin: center;
  }
  .hg-node--center {
    animation: hg-pulse 6s ease-in-out infinite;
  }
  @keyframes hg-pulse {
    0%, 100% { transform: scale(1);   filter: drop-shadow(0 0 0 rgba(240, 169, 26, 0)); }
    50%      { transform: scale(1.15); filter: drop-shadow(0 0 4px rgba(240, 169, 26, .55)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hg-node--center { animation: none !important; }
  }

  @media (max-width: 720px) {
    .hiring-inner { grid-template-columns: 1fr; }
    .hiring-graph { max-width: 260px; margin: 0 auto; justify-self: center; }
  }
</style>
