---
/**
 * Compact recruiting strip. Sits between FAQ and Contact on the
 * homepage, giving /join a contextual entry point without bloating
 * the page or competing with the primary "Request a demo" CTA.
 * Framed as 'Looking for early teammates' (not 'We're hiring') so we
 * don't imply paid roles where there aren't any.
 *
 * Right side carries a small animated network graph that grows from
 * a single node to a team of nodes-with-edges, visualizing the team
 * expansion the banner is asking the visitor to help build.
 */
---
<aside class="hiring" aria-labelledby="hiring-title">
  <div class="hiring-inner">
    <div class="hiring-text">
      <p class="hiring-eyebrow reveal-soft">Looking for early teammates · five-person team</p>
      <p class="hiring-title reveal-soft" id="hiring-title" data-stagger="1">Help us <em>luminate</em> economies.</p>
      <p class="hiring-sub reveal-soft" data-stagger="2">Undergrad and graduate students across engineering, ML, data, economic impact modeling, marketing, and sales. We mentor people who are persistent. Unpaid early-stage roles.</p>
      <div class="hiring-ctas reveal-soft" data-stagger="3">
        <a href="/join" class="btn">See roles + apply</a>
      </div>
    </div>
    <div class="hiring-graph" aria-hidden="true">
      <svg viewBox="0 0 240 220" preserveAspectRatio="xMidYMid meet">
        <!-- Asymmetric team graph. The root is off-center; three tier-2
             branches grow at uneven angles and distances, with uneven
             child counts (2 / 4 / 2) so the shape reads as an organic
             network instead of a symmetric mandala. -->
        <g class="hg-edges" stroke="currentColor" fill="none" stroke-width="1" stroke-linecap="butt">
          <!-- Center → inner ring (3 edges, uneven angles) -->
          <line class="hg-edge hg-edge--t2" x1="115" y1="100" x2="60"  y2="55"  pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t2" x1="115" y1="100" x2="175" y2="85"  pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t2" x1="115" y1="100" x2="92"  y2="158" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <!-- A branch (upper-left tier-2): 2 children -->
          <line class="hg-edge hg-edge--t3" x1="60"  y1="55"  x2="18"  y2="30"  pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t3" x1="60"  y1="55"  x2="22"  y2="98"  pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <!-- B branch (right tier-2, the hub): 4 children -->
          <line class="hg-edge hg-edge--t3" x1="175" y1="85"  x2="222" y2="38"  pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t3" x1="175" y1="85"  x2="228" y2="92"  pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t3" x1="175" y1="85"  x2="212" y2="142" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t3" x1="175" y1="85"  x2="160" y2="172" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <!-- C branch (lower tier-2): 2 children -->
          <line class="hg-edge hg-edge--t3" x1="92"  y1="158" x2="45"  y2="195" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
          <line class="hg-edge hg-edge--t3" x1="92"  y1="158" x2="120" y2="202" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
        </g>
        <g class="hg-nodes">
          <!-- Root (always on, off-center to lean into the asymmetry) -->
          <circle class="hg-node hg-node--center" cx="115" cy="100" r="7" fill="#F0A91A"/>
          <!-- Tier 2: 3 inner-ring nodes, varied radii -->
          <circle class="hg-node hg-node--t2" cx="60"  cy="55"  r="5"   fill="currentColor"/>
          <circle class="hg-node hg-node--t2" cx="175" cy="85"  r="5.4" fill="currentColor"/>
          <circle class="hg-node hg-node--t2" cx="92"  cy="158" r="4.6" fill="currentColor"/>
          <!-- Tier 3: 8 outer nodes (A:2 / B:4 / C:2), varied radii -->
          <circle class="hg-node hg-node--t3" cx="18"  cy="30"  r="3.6" fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="22"  cy="98"  r="3.2" fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="222" cy="38"  r="4"   fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="228" cy="92"  r="3.4" fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="212" cy="142" r="3"   fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="160" cy="172" r="3.6" fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="45"  cy="195" r="3.2" fill="currentColor"/>
          <circle class="hg-node hg-node--t3" cx="120" cy="202" r="3.8" fill="currentColor"/>
        </g>
      </svg>
    </div>
  </div>
</aside>
<style>
  .hiring {
    background: var(--cream);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .hiring-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hiring-eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 .55rem;
  }
  .hiring-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    line-height: 1.2;
    letter-spacing: -.018em;
    color: var(--navy);
    margin: 0 0 .6rem;
    max-width: 32ch;
  }
  .hiring-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 600;
    animation: luminate-glow 3.4s ease-in-out infinite;
  }
  @keyframes luminate-glow {
    0%, 100% {
      text-shadow: 0 0 0 rgba(240, 169, 26, 0);
      filter: brightness(1);
    }
    50% {
      text-shadow:
        0 0 12px rgba(240, 169, 26, .5),
        0 0 24px rgba(240, 169, 26, .3);
      filter: brightness(1.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hiring-title em { animation: none; }
  }
  .hiring-sub {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 60ch;
    font-weight: 400;
  }
  .hiring-ctas {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
    margin-top: .25rem;
  }

  /* ---------- Network graph ---------- */
  .hiring-graph {
    color: var(--navy);
    width: 100%;
    max-width: 340px;
    justify-self: end;
  }
  .hiring-graph svg { width: 100%; height: auto; display: block; }

  /* Center node: gentle pulse so the focal point breathes. */
  .hg-node--center {
    transform-box: fill-box;
    transform-origin: center;
    animation: hg-pulse 6s ease-in-out infinite;
  }
  @keyframes hg-pulse {
    0%, 100% { transform: scale(1);   filter: drop-shadow(0 0 0 rgba(240, 169, 26, 0)); }
    50%      { transform: scale(1.15); filter: drop-shadow(0 0 4px rgba(240, 169, 26, .55)); }
  }

  /* Tier 2 nodes fade in around 1s; tier 3 around 2.5s. The cycle
     restarts at 6s, so the graph "grows" repeatedly. */
  .hg-node--t2, .hg-node--t3 {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: hg-spawn 6s ease-out infinite;
  }
  .hg-node--t2 { animation-delay: 1.0s; }
  .hg-node--t3 { animation-delay: 2.5s; }
  /* Stagger within each tier so individual nodes don't pop together. */
  /* :nth-of-type counts all <circle> elements (the tag, not the class).
     Layout: 1 center + 3 tier-2 + 8 tier-3 = circles 1..12. */
  .hg-node--t2:nth-of-type(2)  { animation-delay: 1.00s; }
  .hg-node--t2:nth-of-type(3)  { animation-delay: 1.18s; }
  .hg-node--t2:nth-of-type(4)  { animation-delay: 1.36s; }
  .hg-node--t3:nth-of-type(5)  { animation-delay: 2.55s; }
  .hg-node--t3:nth-of-type(6)  { animation-delay: 2.68s; }
  .hg-node--t3:nth-of-type(7)  { animation-delay: 2.78s; }
  .hg-node--t3:nth-of-type(8)  { animation-delay: 2.92s; }
  .hg-node--t3:nth-of-type(9)  { animation-delay: 3.08s; }
  .hg-node--t3:nth-of-type(10) { animation-delay: 3.20s; }
  .hg-node--t3:nth-of-type(11) { animation-delay: 3.35s; }
  .hg-node--t3:nth-of-type(12) { animation-delay: 3.48s; }
  @keyframes hg-spawn {
    0%      { opacity: 0; transform: scale(.3); }
    15%     { opacity: 1; transform: scale(1.25); }
    25%     { opacity: 1; transform: scale(1);    fill: #F0A91A; }
    35%     { opacity: 1; transform: scale(1);    fill: currentColor; }
    90%     { opacity: 1; }
    100%    { opacity: 0; }
  }

  /* Edges draw in just before their target node spawns. */
  .hg-edge { animation: hg-draw 6s ease-out infinite; }
  .hg-edge--t2 { animation-delay: .9s; }
  .hg-edge--t3 { animation-delay: 2.4s; }
  /* Edge layout: 3 tier-2 edges + 8 tier-3 edges = 11 lines. The
     tier-3 group is split 2 / 4 / 2 across the three branches, so
     stagger times mirror that asymmetric branching. */
  .hg-edges line:nth-of-type(2)  { animation-delay: 1.10s; }
  .hg-edges line:nth-of-type(3)  { animation-delay: 1.22s; }
  .hg-edges line:nth-of-type(4)  { animation-delay: 2.45s; }
  .hg-edges line:nth-of-type(5)  { animation-delay: 2.55s; }
  .hg-edges line:nth-of-type(6)  { animation-delay: 2.62s; }
  .hg-edges line:nth-of-type(7)  { animation-delay: 2.72s; }
  .hg-edges line:nth-of-type(8)  { animation-delay: 2.82s; }
  .hg-edges line:nth-of-type(9)  { animation-delay: 2.92s; }
  .hg-edges line:nth-of-type(10) { animation-delay: 3.05s; }
  .hg-edges line:nth-of-type(11) { animation-delay: 3.18s; }
  @keyframes hg-draw {
    0%      { stroke-dashoffset: 100; opacity: .9; }
    14%     { stroke-dashoffset: 0;   opacity: .9; }
    90%     { stroke-dashoffset: 0;   opacity: .9; }
    100%    { stroke-dashoffset: 0;   opacity: 0;  }
  }

  @media (prefers-reduced-motion: reduce) {
    .hg-node--center, .hg-node--t2, .hg-node--t3, .hg-edge { animation: none !important; }
    .hg-node--t2, .hg-node--t3 { opacity: 1; transform: none; }
    .hg-edge { stroke-dashoffset: 0; }
  }

  @media (max-width: 720px) {
    .hiring-inner { grid-template-columns: 1fr; }
    .hiring-graph { max-width: 260px; margin: 0 auto; justify-self: center; }
  }
</style>
