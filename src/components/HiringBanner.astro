---
/**
 * Compact recruiting strip. Sits between FAQ and Contact on the
 * homepage, giving /join a contextual entry point without bloating
 * the page or competing with the primary "Request a demo" CTA.
 * Framed as 'Looking for early teammates' (not 'We're hiring') so we
 * don't imply paid roles where there aren't any.
 *
 * Right side carries a small animated network graph that grows from
 * a single node to a team of nodes-with-edges, visualizing the team
 * expansion the banner is asking the visitor to help build.
 */
---
<aside class="hiring" aria-labelledby="hiring-title">
  <div class="hiring-inner">
    <div class="hiring-text">
      <p class="hiring-eyebrow reveal-soft">Looking for early teammates · five-person team</p>
      <p class="hiring-title reveal-soft" id="hiring-title" data-stagger="1">Help us <em>luminate</em> economies.</p>
      <p class="hiring-sub reveal-soft" data-stagger="2">Undergrad and graduate students across engineering, ML, data, economic impact modeling, marketing, and sales. We mentor people who are persistent. Unpaid early-stage roles.</p>
      <div class="hiring-ctas reveal-soft" data-stagger="3">
        <a href="/join" class="btn">See roles + apply</a>
      </div>
    </div>
    <div class="hiring-graph" aria-hidden="true">
      <!-- Procedurally generated each cycle by the script below.
           The viewBox is fixed; the contents (root, 2-4 inner
           branches, 1-4 children per branch) regenerate every ~7s
           so visitors who linger see the team graph evolve
           rather than loop the same shape. -->
      <svg id="hgSvg" viewBox="0 0 240 220" preserveAspectRatio="xMidYMid meet"></svg>
    </div>
  </div>
</aside>

<script is:inline>
  /* Procedural team-graph generator. Builds a random asymmetric tree
     (1 root + 2-4 inner branches + 1-4 children per branch) directly
     in SVG, animates the spawn over ~5s, holds briefly, then fades
     out and regenerates a fresh tree. Every cycle is a different
     shape, so visitors who linger don't loop the same image.
     Respects prefers-reduced-motion: paints one static tree, no
     cycle, no animation. */
  (function () {
    const svg = document.getElementById('hgSvg');
    if (!svg) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const W = 240, H = 220;
    const reducedMotion = window.matchMedia
      && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const rand = (a, b) => a + Math.random() * (b - a);
    const randInt = (a, b) => Math.floor(rand(a, b + 1));

    function generate() {
      const root = { x: rand(105, 135), y: rand(95, 115) };
      const branchCount = randInt(2, 4);
      // Spread branches around the root in random angle buckets so
      // they don't bunch up.
      const baseAngle = rand(0, Math.PI * 2);
      const bucket = (Math.PI * 2) / branchCount;
      const branches = [];
      for (let i = 0; i < branchCount; i++) {
        const ang = baseAngle + bucket * i + rand(-0.45, 0.45);
        const dist = rand(48, 75);
        const bx = clamp(root.x + Math.cos(ang) * dist, 22, W - 22);
        const by = clamp(root.y + Math.sin(ang) * dist, 22, H - 22);
        const childCount = randInt(1, 4);
        const children = [];
        const childBase = ang;
        const childBucket = Math.PI / Math.max(childCount, 1);
        for (let j = 0; j < childCount; j++) {
          const cAng = childBase + childBucket * (j - (childCount - 1) / 2) + rand(-0.4, 0.4);
          const cDist = rand(36, 58);
          children.push({
            x: clamp(bx + Math.cos(cAng) * cDist, 10, W - 10),
            y: clamp(by + Math.sin(cAng) * cDist, 10, H - 10),
            r: rand(2.8, 4.2),
          });
        }
        branches.push({ x: bx, y: by, r: rand(4.4, 5.6), children });
      }
      return { root, branches };
    }

    function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

    function mkCircle(cx, cy, r, fill, className) {
      const c = document.createElementNS(SVG_NS, 'circle');
      c.setAttribute('cx', String(cx));
      c.setAttribute('cy', String(cy));
      c.setAttribute('r', String(r));
      c.setAttribute('fill', fill);
      if (className) c.setAttribute('class', className);
      return c;
    }
    function mkLine(x1, y1, x2, y2) {
      const l = document.createElementNS(SVG_NS, 'line');
      l.setAttribute('x1', String(x1));
      l.setAttribute('y1', String(y1));
      l.setAttribute('x2', String(x2));
      l.setAttribute('y2', String(y2));
      l.setAttribute('stroke', 'currentColor');
      l.setAttribute('stroke-width', '1');
      l.setAttribute('stroke-linecap', 'butt');
      l.setAttribute('fill', 'none');
      return l;
    }

    function render(graph) {
      // Clear
      while (svg.firstChild) svg.removeChild(svg.firstChild);
      const edges = document.createElementNS(SVG_NS, 'g');
      const nodes = document.createElementNS(SVG_NS, 'g');
      svg.appendChild(edges);
      svg.appendChild(nodes);

      // Root: always visible immediately
      nodes.appendChild(mkCircle(graph.root.x, graph.root.y, 6.5, '#F0A91A', 'hg-node hg-node--center'));

      // Build animation timeline. The Web Animations API gives us
      // per-element control without hand-rolling CSS keyframes for
      // a variable number of nodes.
      const T = reducedMotion ? 0 : 1; // 0 disables transitions

      // Tier 2: inner branches
      graph.branches.forEach((b, i) => {
        const edge = mkLine(graph.root.x, graph.root.y, b.x, b.y);
        const len = Math.hypot(b.x - graph.root.x, b.y - graph.root.y);
        edge.setAttribute('stroke-dasharray', String(len));
        edge.setAttribute('stroke-dashoffset', String(reducedMotion ? 0 : len));
        edges.appendChild(edge);
        const node = mkCircle(b.x, b.y, b.r, 'currentColor', 'hg-node hg-node--t2');
        node.style.opacity = reducedMotion ? '1' : '0';
        nodes.appendChild(node);
        if (!reducedMotion) {
          const delay = 700 + i * 180;
          edge.animate(
            [{ strokeDashoffset: len }, { strokeDashoffset: 0 }],
            { duration: 500 * T, delay, fill: 'forwards', easing: 'ease-out' }
          );
          spawn(node, delay + 350);
        }
      });

      // Tier 3: children
      graph.branches.forEach((b, i) => {
        b.children.forEach((c, j) => {
          const edge = mkLine(b.x, b.y, c.x, c.y);
          const len = Math.hypot(c.x - b.x, c.y - b.y);
          edge.setAttribute('stroke-dasharray', String(len));
          edge.setAttribute('stroke-dashoffset', String(reducedMotion ? 0 : len));
          edges.appendChild(edge);
          const node = mkCircle(c.x, c.y, c.r, 'currentColor', 'hg-node hg-node--t3');
          node.style.opacity = reducedMotion ? '1' : '0';
          nodes.appendChild(node);
          if (!reducedMotion) {
            const delay = 2000 + i * 240 + j * 130;
            edge.animate(
              [{ strokeDashoffset: len }, { strokeDashoffset: 0 }],
              { duration: 420 * T, delay, fill: 'forwards', easing: 'ease-out' }
            );
            spawn(node, delay + 300);
          }
        });
      });

      // Fade everything out at the end of the cycle, then regenerate.
      if (!reducedMotion) {
        const fadeDelay = 5200;
        const fadeDur = 600;
        Array.from(edges.children).forEach(el => {
          el.animate(
            [{ opacity: 1 }, { opacity: 0 }],
            { duration: fadeDur, delay: fadeDelay, fill: 'forwards', easing: 'ease-in' }
          );
        });
        // Skip the center node so the focal point persists between cycles.
        Array.from(nodes.children).slice(1).forEach(el => {
          el.animate(
            [{ opacity: 1 }, { opacity: 0 }],
            { duration: fadeDur, delay: fadeDelay, fill: 'forwards', easing: 'ease-in' }
          );
        });
      }
    }

    function spawn(el, delay) {
      // Scale in + brief gold flash, then settle to navy.
      el.animate(
        [
          { opacity: 0, transform: 'scale(.3)' },
          { opacity: 1, transform: 'scale(1.25)', offset: .35 },
          { opacity: 1, transform: 'scale(1)' },
        ],
        { duration: 520, delay, fill: 'forwards', easing: 'ease-out' }
      );
      el.animate(
        [
          { fill: '#F0A91A', offset: 0 },
          { fill: '#F0A91A', offset: .5 },
          { fill: 'currentColor', offset: 1 },
        ],
        { duration: 900, delay, fill: 'forwards' }
      );
    }

    function cycle() {
      render(generate());
    }
    cycle();
    if (!reducedMotion) {
      // Match render()'s fade-out timing: 5200ms delay + 600ms fade
      // = ~5800ms; regenerate ~6000ms in for a clean handoff.
      setInterval(cycle, 6000);
    }
  })();
</script>
<style>
  .hiring {
    background: var(--cream);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .hiring-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hiring-eyebrow {
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 .55rem;
  }
  .hiring-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    line-height: 1.2;
    letter-spacing: -.018em;
    color: var(--navy);
    margin: 0 0 .6rem;
    max-width: 32ch;
  }
  .hiring-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 600;
    animation: luminate-glow 3.4s ease-in-out infinite;
  }
  @keyframes luminate-glow {
    0%, 100% {
      text-shadow: 0 0 0 rgba(240, 169, 26, 0);
      filter: brightness(1);
    }
    50% {
      text-shadow:
        0 0 12px rgba(240, 169, 26, .5),
        0 0 24px rgba(240, 169, 26, .3);
      filter: brightness(1.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hiring-title em { animation: none; }
  }
  .hiring-sub {
    font-family: var(--font-sans);
    font-size: .94rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 1.2rem;
    max-width: 60ch;
    font-weight: 400;
  }
  .hiring-ctas {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
    margin-top: .25rem;
  }

  /* ---------- Network graph ---------- */
  .hiring-graph {
    color: var(--navy);
    width: 100%;
    max-width: 340px;
    justify-self: end;
  }
  .hiring-graph svg { width: 100%; height: auto; display: block; }

  /* Nodes + edges are positioned and animated entirely from JS now
     (see the inline script at the bottom of this file). CSS only
     supplies the gentle center-pulse and a transform-box hint so
     each circle scales around its own center. */
  .hg-node {
    transform-box: fill-box;
    transform-origin: center;
  }
  .hg-node--center {
    animation: hg-pulse 6s ease-in-out infinite;
  }
  @keyframes hg-pulse {
    0%, 100% { transform: scale(1);   filter: drop-shadow(0 0 0 rgba(240, 169, 26, 0)); }
    50%      { transform: scale(1.15); filter: drop-shadow(0 0 4px rgba(240, 169, 26, .55)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hg-node--center { animation: none !important; }
  }

  @media (max-width: 720px) {
    .hiring-inner { grid-template-columns: 1fr; }
    .hiring-graph { max-width: 260px; margin: 0 auto; justify-self: center; }
  }
</style>
