---
/**
 * Cedar — combined explainer (left) + live "Ask Cedar" chat (right).
 * The chat sits where empty space used to be on this section so a
 * visitor reading about Cedar can immediately try it without scrolling
 * to a separate Q&A surface.
 */
import '../styles/cedar.css';
import IconUpload from './icons/IconUpload.astro';
import IconSurfaceAssumption from './icons/IconSurfaceAssumption.astro';
import IconSourceRecord from './icons/IconSourceRecord.astro';
import FAQSection from './FAQSection.astro';
---
<section class="cedar-about" id="cedar">
  <div class="cedar-about__inner">
    <div class="cedar-about__left">
      <p class="cedar-about__byline">Cedar</p>
      <h2 class="cedar-about__lede">
        AI for the unglamorous parts of economic impact analysis.
      </h2>
      <p class="cedar-about__intro">
        Cedar is Lumecon's AI analyst. It reads messy data, surfaces every assumption for your sign-off, and reshapes the study for the audience in front of you.
      </p>
      <p class="cedar-about__body">
        Because Cedar is RAG-based, answers stay grounded in your actual files, not generic output. Cedar does the heavy lift; your team stays in control of what the study says.
      </p>
      <ol class="cedar-steps" aria-label="What Cedar does">
        <li class="cedar-step">
          <details class="cedar-step__details">
            <summary class="cedar-step__summary">
              <span class="cedar-step__icon"><IconUpload /></span>
              <h3 class="cedar-step__head">Works with the data you actually have</h3>
              <span class="cedar-step__chev" aria-hidden="true"></span>
            </summary>
            <p class="cedar-step__body">Budgets, payroll, council agendas, board reports, audits, and grant filings. Cedar turns messy departmental files into usable study inputs, no matter what shape they arrive in.</p>
          </details>
        </li>
        <li class="cedar-step">
          <details class="cedar-step__details">
            <summary class="cedar-step__summary">
              <span class="cedar-step__icon"><IconSurfaceAssumption /></span>
              <h3 class="cedar-step__head">Shows its work before it runs</h3>
              <span class="cedar-step__chev" aria-hidden="true"></span>
            </summary>
            <p class="cedar-step__body">Every multiplier, regional bridge, and base-year choice is named with a plain-English rationale. You confirm, adjust, or override, and the audit trail builds as the study moves.</p>
          </details>
        </li>
        <li class="cedar-step">
          <details class="cedar-step__details">
            <summary class="cedar-step__summary">
              <span class="cedar-step__icon"><IconSourceRecord /></span>
              <h3 class="cedar-step__head">Adapts the same analysis to every audience</h3>
              <span class="cedar-step__chev" aria-hidden="true"></span>
            </summary>
            <p class="cedar-step__body">Council meeting, grant filing, board memo, or public release. Cedar redraws the same result for the next use case, without your team copying numbers across five different decks.</p>
          </details>
        </li>
      </ol>
    </div>
    <aside class="cedar-about__right" aria-label="Ask Cedar">
      <FAQSection compact={true} />
    </aside>
  </div>
</section>
