---
import '../styles/cedar.css';
---
<section class="cedar" id="cedar">
  <div class="cedar-panel paper-tex paper-tex-dark">
    <div style="font-size:.58rem;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem" class="r">THE EXPERIENCE</div>
    <h2 class="r d1">Cedar</h2>
    <div class="cedar-subtitle r d2">Your AI thought partner for economic and policy analysis.</div>
    <div class="cedar-motto r d3">We won't think for you.<br>We think with you.</div>
  </div>
  <div class="cedar-text">
    <p class="r">Cedar&trade; is Lumecon's AI-powered assistant for economic and policy analysis. It works with messy, real-world data, clearly telling you what it needs and why, and walks you through each step so you can understand economic impact, test assumptions, and make informed strategic decisions. No consultant or overpriced legacy software. Just you, your data, and a thought partner designed to support rigorous analysis without fabricating results. Cedar operates in secure, isolated environments, working only with the data you provide and preserving context across analyses.</p>
  </div>
  <div class="cedar-chat">
    <div class="chat-demo sd" id="chatDemo">
      <div class="chat-header">
        <div class="chat-dot"></div>
        <div class="chat-title">Cedar</div>
      </div>
      <div class="chat-body" id="chatBody"></div>
      <div class="chat-footer">Demo reflects current training and testing as of March 2026</div>
    </div>
  </div>
</section>

<script>
  // Cedar chat demo
  const conversations = [
    [{from:'system',text:'\u{1F4C4} AuditedFinancials_FY2025.pdf uploaded\n\u{1F4C4} Payroll_Summary_Q4.xlsx uploaded'},{from:'cedar',text:"Reading your files now. I found $9.7M total operating revenue (income statement, p. 12) and $6.4M payroll (Q4 spreadsheet). 218 FTE. Can you confirm?"},{from:'user',text:"Revenue is right but payroll should be $6.8M \u2014 the file doesn\u2019t include benefits."},{from:'cedar',text:"Updated. Here are your results:\n\nDirect: 218 jobs, $6.8M labor income \u2014 your organization\u2019s footprint.\nIndirect: 74 jobs, $2.9M \u2014 your suppliers and vendors.\nInduced: 51 jobs, $1.8M \u2014 household spending rippling through the economy.\n\nTotal: 343 jobs and $11.5M in labor income supported across the region."}],
    [{from:'user',text:"We\u2019ve uploaded our financials from 2019 through 2025. Can Cedar compare impact over time?"},{from:'cedar',text:"Absolutely. I\u2019ve run each year through the model with inflation-adjusted dollars (2025 base):"},{from:'cedar',html:'<div class="chat-table">2019 \u2014 $8.1M \u00b7 247 jobs<br>2020 \u2014 $6.3M \u00b7 198 jobs<br>2021 \u2014 $7.9M \u00b7 231 jobs<br>2022 \u2014 $9.4M \u00b7 274 jobs<br>2023 \u2014 $10.1M \u00b7 289 jobs<br>2024 \u2014 $10.8M \u00b7 312 jobs<br>2025 \u2014 $11.5M \u00b7 343 jobs</div>'},{from:'cedar',text:"Over seven years, your organization has supported over $64M in cumulative regional economic activity."},{from:'user',text:"Nobody\u2019s ever shown us this before."},{from:'cedar',text:"Most studies are one-time snapshots. Lumecon stores your models so you can track impact over time \u2014 the trajectory, not just a single number."}],
    [{from:'system',text:'\u{1F4C4} PayrollSummary.pdf uploaded\n\u{1F4C4} AnnualReport_2024.pdf uploaded\n\u{1F4F7} Revenue_Printout.jpg uploaded'},{from:'cedar',text:"Two files are readable. The third is a photo \u2014 I can\u2019t auto-extract from it. I need two numbers: total gross revenue and FTE count."},{from:'user',text:"$4.6M revenue, 38 FTEs. Is this secure? It\u2019s sensitive financial data."},{from:'cedar',text:"Your data is processed in a secure environment. No inputted data is shared across users, and your account maintains its own context so you can continue your analysis across sessions. Ready to confirm the values I extracted from your other files?"}],
    [{from:'cedar',text:"Welcome back. What would you like to work on?"},{from:'cedar',text:"Options:\n1) Review your results\n2) Work on your report\n3) Explore your assumptions"},{from:'user',text:"Report. I need help with the executive summary."},{from:'cedar',text:"The strongest summaries lead with community impact \u2014 who benefits and how \u2014 then back it up with numbers. Write a draft sentence and I\u2019ll give you feedback."},{from:'user',text:"Our operations supported over 340 jobs and $11M in economic activity in 2025."},{from:'cedar',text:"Good start. I\u2019d lead with the people: \"In 2025, our operations sustained livelihoods for over 340 families across the region.\" Then follow with the $11M. Funders and councils respond to people first, numbers second. Want to keep refining?"}],
    [{from:'user',text:"We\u2019re presenting to tribal council next week to request continued funding. Can you help me frame the results?"},{from:'cedar',text:"Lumecon is the only economic impact tool that models the unique structures of tribal governments, enterprises, and reservation economies \u2014 so these numbers actually reflect how your nation\u2019s economy works, not a generic US county model. For a council audience, I\u2019d frame it around three things:"},{from:'cedar',text:"1) Sovereignty \u2014 your enterprise keeps $6.8M circulating within the nation rather than leaving.\n2) Livelihoods \u2014 343 families depend on the economic activity your operations generate.\n3) Leverage \u2014 every $1 the nation invests generates $1.69 in total regional impact."},{from:'user',text:"That leverage number is powerful. Where does it come from?"},{from:'cedar',text:"It\u2019s your fiscal multiplier \u2014 total impact ($11.5M) divided by direct labor income ($6.8M). Your spending doesn\u2019t stop at payroll. It ripples through suppliers, households, and local businesses."}],
    [{from:'user',text:"We\u2019re thinking about expanding \u2014 adding a new facility and about 20 FTE. Can Cedar model that?"},{from:'cedar',text:"I can run a scenario analysis. I\u2019ll need:\n\n\u2022 Estimated annual payroll for the 20 new positions\n\u2022 Estimated construction or capital expenditure\n\u2022 Any new supplier contracts"},{from:'user',text:"About $1.4M in new payroll, $3.2M construction over two years, and maybe $400K in new vendor contracts annually."},{from:'cedar',html:'<div class="chat-table">Current baseline \u2014 343 jobs \u00b7 $11.5M<br>+ Expansion (steady state) \u2014 +38 jobs \u00b7 +$2.1M<br>+ Construction phase \u2014 +27 temp jobs \u00b7 +$1.6M/yr<br><br>Projected total \u2014 381 jobs \u00b7 $13.6M</div>'},{from:'cedar',text:"The 20 direct hires generate 18 additional indirect and induced jobs. During the two-year build, you\u2019d temporarily support another 27. That\u2019s the kind of number that justifies the capital ask."}],
    [{from:'user',text:"I\u2019m writing the economic impact section of our annual report. Here\u2019s my draft: \u201CIn 2025, our organization supported 343 jobs and $11.5M in economic activity across the region.\u201D"},{from:'cedar',text:"Solid foundation. Two things worth considering:\n\nFirst, leading with people tends to land better with mixed audiences \u2014 \"sustained livelihoods for over 340 families\" hits differently than a jobs number.\n\nSecond, your year-over-year growth is significant \u2014 39% since 2019, through a pandemic. That trajectory can strengthen the narrative. Would you like to include it?"},{from:'user',text:"Yeah, I think the growth angle is strong. Should I?"},{from:'cedar',text:"I\u2019d recommend it. Something like: \"reflecting sustained growth even through the disruptions of 2020\" gives readers the recovery arc without belaboring it. Write a next draft with those and I\u2019ll refine."}],
    [{from:'user',text:"The board is considering cutting our community outreach program to save $800K. Can we model what that would cost the region?"},{from:'cedar',text:"I have your current analysis on file. Based on that data, I can model the outreach program as a standalone component. Running two scenarios side by side:"},{from:'cedar',html:'<div class="chat-table">Keep program \u2014 12 direct jobs \u00b7 $800K payroll<br>\u2003Total impact \u2014 19 jobs \u00b7 $1.3M<br><br>Cut program \u2014 \u221212 direct jobs \u00b7 \u2212$800K payroll<br>\u2003Total loss \u2014 \u221219 jobs \u00b7 \u2212$1.3M</div>'},{from:'user',text:"So we\u2019d save $800K but lose $1.3M in regional impact?"},{from:'cedar',text:"Exactly. The $800K in direct savings costs the region $1.3M in total economic activity and eliminates 19 jobs \u2014 not just the 12 on your payroll, but 7 more through supplier and household spending. Whether to cut is your board\u2019s call, but now they can see the tradeoff clearly."}]
  ];

  const chatBody = document.getElementById('chatBody')!;
  const chatDemo = document.getElementById('chatDemo')!;
  let convIdx = 0;
  let chatRunning = false;

  function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  function showTyping(from: string) {
    const t = document.createElement('div');
    t.className = 'chat-typing';
    t.style.alignSelf = from === 'user' ? 'flex-end' : 'flex-start';
    t.innerHTML = '<span></span><span></span><span></span>';
    chatBody.appendChild(t);
    chatBody.scrollTop = chatBody.scrollHeight;
    return t;
  }

  async function playConversation() {
    chatBody.innerHTML = '';
    const conv = conversations[convIdx];
    for (let i = 0; i < conv.length; i++) {
      const m = conv[i] as any;
      if (m.from === 'system') {
        const el = document.createElement('div');
        el.className = 'chat-msg chat-msg--system';
        el.style.whiteSpace = 'pre-line';
        el.textContent = m.text;
        chatBody.appendChild(el);
        requestAnimationFrame(() => { requestAnimationFrame(() => { el.classList.add('show'); }); });
        chatBody.scrollTop = chatBody.scrollHeight;
        await sleep(800);
        continue;
      }
      const typing = showTyping(m.from);
      await sleep(m.from === 'cedar' ? 1800 : 1100);
      typing.remove();
      const el = document.createElement('div');
      el.className = 'chat-msg chat-msg--' + m.from;
      const label = m.from === 'cedar' ? 'Cedar' : 'You';
      let content = '<div class="sender">' + label + '</div>';
      if (m.html) { content += m.html; } else { content += m.text.replace(/\n/g, '<br>'); }
      el.innerHTML = content;
      chatBody.appendChild(el);
      requestAnimationFrame(() => { requestAnimationFrame(() => { el.classList.add('show'); }); });
      chatBody.scrollTop = chatBody.scrollHeight;
      await sleep(1100);
    }
    await sleep(9000);
    convIdx = (convIdx + 1) % conversations.length;
    playConversation();
  }

  const chatObs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting && !chatRunning) {
        chatRunning = true;
        setTimeout(playConversation, 600);
        chatObs.unobserve(e.target);
      }
    });
  }, { threshold: .2 });
  chatObs.observe(chatDemo);
</script>
