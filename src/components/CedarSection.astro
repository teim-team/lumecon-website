---
/**
 * Cedar — one statement, one supporting line, one CTA.
 */
import '../styles/cedar.css';
---
<section class="cedar-about" id="cedar">
  <div class="cedar-about__inner">
    <p class="cedar-about__byline">Cedar</p>
    <h2 class="cedar-about__lede">
      An AI assistant for messy data, across departments.
    </h2>
    <p class="cedar-about__body">
      Cedar reads what you upload &mdash; budgets, payroll detail, council agendas, chapter audits &mdash; surfaces each assumption the model is about to use, and documents every source and method as the run completes. So the results are traceable, and reviewers can verify the work.
    </p>
    <a href="#contact" class="btn btn--ghost">Ask us about Cedar</a>
  </div>
</section>
