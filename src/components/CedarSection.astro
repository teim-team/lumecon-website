---
import '../styles/cedar.css';
---
<section class="cedar" id="cedar">
  <div class="cedar-panel">
    <p class="cedar-eyebrow">The experience.</p>
    <h2 class="cedar-display reveal">Cedar.</h2>
    <p class="cedar-subtitle reveal delay-2">An AI thought partner for economic and policy analysis.</p>
    <p class="cedar-motto reveal delay-3">We won&rsquo;t think for you.<br><em>We think with you.</em></p>
  </div>
  <div class="cedar-text">
    <p class="cedar-body reveal">Cedar&trade; is Lumecon&rsquo;s AI assistant for economic and policy analysis. It works with messy, real-world data, clearly telling you what it needs and why, and walks you through each step so you can understand economic impact, test assumptions, and make informed strategic decisions. No consultant or overpriced legacy software &mdash; just you, your data, and a thought partner designed to support rigorous analysis without fabricating results. Cedar operates in secure, isolated environments, working only with the data you provide and preserving context across analyses.</p>
  </div>
  <div class="cedar-chat">
    <div class="chat-demo reveal-diagonal" id="chatDemo">
      <div class="chat-header">
        <div class="chat-dot"></div>
        <div class="chat-title">Cedar</div>
      </div>
      <div class="chat-body" id="chatBody" aria-live="polite" aria-label="Cedar AI demo conversation">
        <div class="chat-skeleton" id="chatSkeleton">
          <div class="chat-skeleton-hint">Demo will play automatically</div>
          <div class="chat-skeleton-line"></div>
          <div class="chat-skeleton-line"></div>
          <div class="chat-skeleton-line"></div>
          <div class="chat-skeleton-line"></div>
          <div class="chat-skeleton-line"></div>
        </div>
      </div>
      <div class="chat-controls" id="chatControls">
        <button class="chat-ctrl-btn" id="chatPrev" aria-label="Previous conversation">Prev</button>
        <span class="chat-conv-indicator" id="chatIndicator">1 / 7</span>
        <button class="chat-ctrl-btn" id="chatNext" aria-label="Next conversation">Next</button>
        <button class="chat-ctrl-btn" id="chatPause" aria-label="Pause demo">Pause</button>
      </div>
      <div class="chat-footer">Demo reflects current training and testing as of May 2026</div>
    </div>
  </div>
</section>

<script>
  import { conversations } from '../data/cedar-conversations';

  // Chat demo timing constants
  const TYPING_DELAY_CEDAR = 1800;
  const TYPING_DELAY_USER = 1100;
  const MESSAGE_PAUSE = 1100;
  const SYSTEM_MESSAGE_PAUSE = 800;
  const AUTO_ADVANCE_DELAY = 9000;
  const PAUSE_CHECK_INTERVAL = 200;
  const INITIAL_PLAY_DELAY = 600;
  const INTERSECTION_THRESHOLD = 0.2;

  (function() {
    const chatBody = document.getElementById('chatBody');
    const chatDemo = document.getElementById('chatDemo');
    const chatPause = document.getElementById('chatPause');
    const chatPrev = document.getElementById('chatPrev');
    const chatNext = document.getElementById('chatNext');
    const chatIndicator = document.getElementById('chatIndicator');
    const chatSkeleton = document.getElementById('chatSkeleton');
    if (!chatBody || !chatDemo || !chatPause || !chatPrev || !chatNext || !chatIndicator || !chatSkeleton) return;

    let convIdx = Math.floor(Math.random() * conversations.length);
    let chatRunning = false;
    let paused = false;
    let abortController: AbortController | null = null;

    const updateIndicator = () => {
      chatIndicator.textContent = (convIdx + 1) + ' / ' + conversations.length;
    };

    const sleep = (ms: number, signal?: AbortSignal): Promise<void> => {
      return new Promise((resolve, reject) => {
        const timer = setTimeout(resolve, ms);
        if (signal) {
          signal.addEventListener('abort', () => { clearTimeout(timer); reject(new DOMException('Aborted', 'AbortError')); });
        }
      });
    };

    const showTyping = (from: string) => {
      const t = document.createElement('div');
      t.className = 'chat-typing';
      t.style.alignSelf = from === 'user' ? 'flex-end' : 'flex-start';
      t.innerHTML = '<span></span><span></span><span></span>';
      chatBody.appendChild(t);
      chatBody.scrollTop = chatBody.scrollHeight;
      return t;
    };

    const playConversation = async () => {
      abortController = new AbortController();
      const signal = abortController.signal;
      chatSkeleton.style.display = 'none';
      chatBody.innerHTML = '';
      updateIndicator();
      const conv = conversations[convIdx];
      try {
        for (let i = 0; i < conv.length; i++) {
          while (paused) { await sleep(PAUSE_CHECK_INTERVAL, signal); }
          const m = conv[i];
          if (m.from === 'system') {
            const el = document.createElement('div');
            el.className = 'chat-msg chat-msg--system';
            el.style.whiteSpace = 'pre-line';
            el.textContent = m.text ?? '';
            chatBody.appendChild(el);
            requestAnimationFrame(() => { requestAnimationFrame(() => { el.classList.add('show'); }); });
            chatBody.scrollTop = chatBody.scrollHeight;
            await sleep(SYSTEM_MESSAGE_PAUSE, signal);
            continue;
          }
          const typing = showTyping(m.from);
          await sleep(m.from === 'cedar' ? TYPING_DELAY_CEDAR : TYPING_DELAY_USER, signal);
          typing.remove();
          const el = document.createElement('div');
          el.className = 'chat-msg chat-msg--' + m.from;
          const label = m.from === 'cedar' ? 'Cedar' : 'You';
          let content = '<div class="sender">' + label + '</div>';
          if (m.html) { content += m.html; } else { content += (m.text ?? '').replace(/\n/g, '<br>'); }
          el.innerHTML = content;
          chatBody.appendChild(el);
          requestAnimationFrame(() => { requestAnimationFrame(() => { el.classList.add('show'); }); });
          chatBody.scrollTop = chatBody.scrollHeight;
          await sleep(MESSAGE_PAUSE, signal);
        }
        await sleep(AUTO_ADVANCE_DELAY, signal);
        convIdx = (convIdx + 1) % conversations.length;
        playConversation();
      } catch (e: any) {
        if (e.name !== 'AbortError') throw e;
      }
    };

    const jumpTo = (idx: number) => {
      convIdx = ((idx % conversations.length) + conversations.length) % conversations.length;
      if (abortController) abortController.abort();
      paused = false;
      chatPause.textContent = 'Pause';
      chatPause.classList.remove('active');
      playConversation();
    };

    chatPrev.addEventListener('click', () => jumpTo(convIdx - 1));
    chatNext.addEventListener('click', () => jumpTo(convIdx + 1));
    chatPause.addEventListener('click', () => {
      paused = !paused;
      chatPause.textContent = paused ? 'Play' : 'Pause';
      chatPause.classList.toggle('active', paused);
    });

    const chatObs = new IntersectionObserver(es => {
      es.forEach(e => {
        if (e.isIntersecting && !chatRunning) {
          chatRunning = true;
          setTimeout(playConversation, INITIAL_PLAY_DELAY);
          chatObs.unobserve(e.target);
        }
      });
    }, { threshold: INTERSECTION_THRESHOLD });
    chatObs.observe(chatDemo);
  })();
</script>
