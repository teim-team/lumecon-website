---
const { class: className = '' } = Astro.props as { class?: string };
---

<svg
  class={`icon icon--source-record ${className}`}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
>
  <rect
    x="6"
    y="4.5"
    width="12"
    height="15"
    stroke="currentColor"
    stroke-width="1.25"
    stroke-linejoin="miter"></rect>
  <circle
    class="icon-record__bullet icon-record__bullet--a"
    cx="8.4"
    cy="9"
    r="0.65"
    fill="currentColor"></circle>
  <circle
    class="icon-record__bullet icon-record__bullet--b"
    cx="8.4"
    cy="13.25"
    r="0.65"
    fill="currentColor"></circle>
  <path
    class="icon-record__line icon-record__line--a"
    d="M10.25 9H15.5"
    stroke="currentColor"
    stroke-width="1.25"
    pathLength="100"
    stroke-dasharray="100"></path>
  <path
    class="icon-record__line icon-record__line--b"
    d="M10.25 13.25H15"
    stroke="currentColor"
    stroke-width="1.25"
    pathLength="100"
    stroke-dasharray="100"></path>
  <circle class="icon-record__check" cx="16.5" cy="17.75" r="1.5" fill="#0FB5A5"></circle>
</svg>
