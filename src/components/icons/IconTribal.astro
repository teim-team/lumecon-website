---
const { class: className = '' } = Astro.props as { class?: string };
---

<svg
  class={`icon icon--tribal ${className}`}
  viewBox="0 0 24 24"
  fill="currentColor"
  aria-hidden="true"
>
  <!-- Filled state silhouette (outer rectangle) with the
       reservation polygon as a white inner cut-out so the whole
       state body changes colour on hover. Community-node dots
       inside the reservation pulse via icon-tribal-pulse. -->
  <rect x="3" y="4" width="18" height="16" rx=".4"></rect>
  <path d="M7.5 8.5 L13.5 7 L16.5 10.5 L15 15.5 L9.5 16.5 L6.5 12 Z" fill="var(--white)"></path>
  <circle class="icon-tribal__dot icon-tribal__dot--a" cx="11" cy="10" r="1.05" fill="currentColor"
  ></circle>
  <circle class="icon-tribal__dot icon-tribal__dot--b" cx="9.5" cy="13" r="1.05" fill="currentColor"
  ></circle>
  <circle
    class="icon-tribal__dot icon-tribal__dot--c"
    cx="13.2"
    cy="13.4"
    r="1.05"
    fill="currentColor"></circle>
</svg>
