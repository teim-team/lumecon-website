---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon icon--tribal ${className}`} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <!-- Outer rectangle = surrounding jurisdiction (county / state).
       Inner polygon = the reservation, intentionally off-center to
       read as "a sovereign nation sitting within a larger boundary"
       rather than a free-floating shape. -->
  <rect x="3" y="4" width="18" height="16" stroke="currentColor" stroke-width="1.25" stroke-linejoin="miter"/>
  <path d="M7.5 8.5 L13.5 7 L16.5 10.5 L15 15.5 L9.5 16.5 L6.5 12 Z"
        stroke="currentColor" stroke-width="1.25" stroke-linejoin="miter"/>
  <!-- Three community-node dots that pulse in sequence -->
  <circle class="icon-tribal__dot icon-tribal__dot--a" cx="11" cy="10" r="1.05" fill="currentColor"/>
  <circle class="icon-tribal__dot icon-tribal__dot--b" cx="9.5"  cy="13" r="1.05" fill="currentColor"/>
  <circle class="icon-tribal__dot icon-tribal__dot--c" cx="13.2" cy="13.4" r="1.05" fill="currentColor"/>
</svg>
