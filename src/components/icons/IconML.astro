---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon icon--ml ${className}`} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <!-- Monitor frame -->
  <rect x="3" y="4.5" width="18" height="12" rx="1.4" stroke="currentColor" stroke-width="1.25" stroke-linejoin="miter"/>
  <line x1="3" y1="7.5" x2="21" y2="7.5" stroke="currentColor" stroke-width="1"/>
  <!-- Stand -->
  <line x1="9" y1="20" x2="15" y2="20" stroke="currentColor" stroke-width="1.25" stroke-linecap="butt"/>
  <line x1="12" y1="16.5" x2="12" y2="20" stroke="currentColor" stroke-width="1"/>
  <!-- Window-control dots -->
  <circle cx="5" cy="6" r=".55" fill="currentColor"/>
  <circle cx="6.7" cy="6" r=".55" fill="currentColor"/>
  <circle cx="8.4" cy="6" r=".55" fill="currentColor"/>
  <!-- Three code lines that "type out" (gold caret on the active one) -->
  <line class="icon-ml__line icon-ml__line--a" x1="5.5" y1="10" x2="13" y2="10" stroke="currentColor" stroke-width="1" stroke-linecap="butt"/>
  <line class="icon-ml__line icon-ml__line--b" x1="5.5" y1="12" x2="11" y2="12" stroke="currentColor" stroke-width="1" stroke-linecap="butt"/>
  <line class="icon-ml__line icon-ml__line--c" x1="5.5" y1="14" x2="15" y2="14" stroke="currentColor" stroke-width="1" stroke-linecap="butt"/>
  <rect class="icon-ml__caret" x="13.5" y="9.3" width=".9" height="1.4" fill="#F0A91A"/>
</svg>
