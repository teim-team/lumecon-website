---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon icon--shift ${className}`} viewBox="0 0 100 100" fill="none" aria-hidden="true">
  <!-- A small network — a gold root with three asymmetric branches
       to navy leaves, two of which fork to a second tier. A gold
       'pulse' travels outward through the edges in sequence,
       lighting each leaf as it arrives, then loops. Same visual
       language as the hiring banner's team graph so the page reads
       cohesively. -->
  <!-- Edges (drawn under nodes) -->
  <line class="icon-shift__edge icon-shift__edge--a" x1="50" y1="50" x2="22" y2="28" stroke="currentColor" stroke-width="1.6" stroke-linecap="butt"
        pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
  <line class="icon-shift__edge icon-shift__edge--b" x1="50" y1="50" x2="86" y2="32" stroke="currentColor" stroke-width="1.6" stroke-linecap="butt"
        pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
  <line class="icon-shift__edge icon-shift__edge--c" x1="50" y1="50" x2="56" y2="92" stroke="currentColor" stroke-width="1.6" stroke-linecap="butt"
        pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
  <line class="icon-shift__edge icon-shift__edge--d" x1="86" y1="32" x2="92" y2="62" stroke="currentColor" stroke-width="1.4" stroke-linecap="butt"
        pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
  <line class="icon-shift__edge icon-shift__edge--e" x1="22" y1="28" x2="14" y2="58" stroke="currentColor" stroke-width="1.4" stroke-linecap="butt"
        pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>

  <!-- Leaves (navy, fade in as their edges arrive) -->
  <circle class="icon-shift__leaf icon-shift__leaf--a" cx="22" cy="28" r="5"   fill="currentColor"/>
  <circle class="icon-shift__leaf icon-shift__leaf--b" cx="86" cy="32" r="5.5" fill="currentColor"/>
  <circle class="icon-shift__leaf icon-shift__leaf--c" cx="56" cy="92" r="4.5" fill="currentColor"/>
  <circle class="icon-shift__leaf icon-shift__leaf--d" cx="92" cy="62" r="4"   fill="currentColor"/>
  <circle class="icon-shift__leaf icon-shift__leaf--e" cx="14" cy="58" r="4"   fill="currentColor"/>

  <!-- Gold root, always visible, gently pulses. -->
  <circle class="icon-shift__root" cx="50" cy="50" r="8" fill="#F0A91A"/>
</svg>
