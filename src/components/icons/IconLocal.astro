---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon icon--local ${className}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
  <!-- Filled city-block silhouette. The whole 13x13 panel is the
       icon body so the entire shape transitions colour on tile
       hover, rather than only a thin grid outline. White cut-outs
       trace the streets between the nine blocks. -->
  <rect x="5.5" y="5.5" width="13" height="13" rx=".4"/>
  <line x1="9.83"  y1="5.5"  x2="9.83"  y2="18.5" stroke="var(--white)" stroke-width="1"/>
  <line x1="14.16" y1="5.5"  x2="14.16" y2="18.5" stroke="var(--white)" stroke-width="1"/>
  <line x1="5.5"   y1="9.83"  x2="18.5" y2="9.83"  stroke="var(--white)" stroke-width="1"/>
  <line x1="5.5"   y1="14.16" x2="18.5" y2="14.16" stroke="var(--white)" stroke-width="1"/>
  <!-- Scanning "active locality" dot. Stays white so it always
       reads against the filled panel; the existing scan animation
       walks it through the 3x3 grid. -->
  <circle class="icon-local__dot" cx="7.66" cy="7.66" r="1.25" fill="var(--white)"/>
</svg>
