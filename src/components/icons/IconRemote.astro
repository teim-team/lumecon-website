---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon ${className}`} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.25"/>
  <ellipse cx="12" cy="12" rx="3.5" ry="8" stroke="currentColor" stroke-width="1.25"/>
  <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.25"/>
  <circle cx="12" cy="9" r="1.3" fill="#F0A91A"/>
</svg>
