---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon icon--surface ${className}`} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <!-- Three text lines being scanned -->
  <path class="icon-surface__line icon-surface__line--a" d="M3.5 7H15" stroke="currentColor" stroke-width="1.25" stroke-linecap="butt"/>
  <path class="icon-surface__line icon-surface__line--b" d="M3.5 11H17" stroke="currentColor" stroke-width="1.25" stroke-linecap="butt"/>
  <path class="icon-surface__line icon-surface__line--c" d="M3.5 15H13" stroke="currentColor" stroke-width="1.25" stroke-linecap="butt"/>

  <!-- Magnifying glass: lens + handle. The whole group pans across the
       text lines; a gold dot pulses under the lens when it lands on an
       "assumption". -->
  <g class="icon-surface__lens">
    <circle cx="9" cy="11" r="3.6" stroke="currentColor" stroke-width="1.35" fill="var(--paper, #fbf6ec)"/>
    <line x1="11.55" y1="13.55" x2="15.5" y2="17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="butt"/>
    <circle class="icon-surface__hit" cx="9" cy="11" r="1.2" fill="#0FB5A5"/>
  </g>
</svg>
