---
const { class: className = '' } = Astro.props as { class?: string };
---

<svg class={`icon icon--ripple ${className}`} viewBox="0 0 100 100" fill="none" aria-hidden="true">
  <!-- Three concentric rings ripple outward from a fixed gold center.
       Echoes the Lumecon logo mark: light radiating outward, the
       'illumination' the headline literally describes. -->
  <circle
    class="icon-ripple__ring icon-ripple__ring--a"
    cx="50"
    cy="50"
    r="20"
    stroke="currentColor"
    stroke-width="1.4"
    fill="none"></circle>
  <circle
    class="icon-ripple__ring icon-ripple__ring--b"
    cx="50"
    cy="50"
    r="20"
    stroke="currentColor"
    stroke-width="1.4"
    fill="none"></circle>
  <circle
    class="icon-ripple__ring icon-ripple__ring--c"
    cx="50"
    cy="50"
    r="20"
    stroke="currentColor"
    stroke-width="1.4"
    fill="none"></circle>
  <circle class="icon-ripple__core" cx="50" cy="50" r="6" fill="#0FB5A5"></circle>
</svg>
