---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon icon--arborist ${className}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
  <!-- Filled state body so the whole panel transitions colour on
       tile hover, matching IconLocal / IconTribal / IconGlobal. -->
  <rect x="3" y="4" width="18" height="16" rx=".4"/>
  <!-- Tree canopy (white cut-out so it reads against the filled panel) -->
  <circle cx="12" cy="9.5" r="3.4" fill="var(--white)"/>
  <circle cx="9.4"  cy="10.6" r="2.4" fill="var(--white)"/>
  <circle cx="14.6" cy="10.6" r="2.4" fill="var(--white)"/>
  <!-- Trunk -->
  <rect x="11.4" y="11.4" width="1.2" height="5" fill="var(--white)"/>
  <!-- Support stakes (the binding) — two vertical strokes flanking
       the trunk plus a crossbar, the cue that distinguishes this
       from a plain tree icon. -->
  <line x1="9.6"  y1="12.8" x2="9.6"  y2="17.2" stroke="var(--white)" stroke-width=".9"/>
  <line x1="14.4" y1="12.8" x2="14.4" y2="17.2" stroke="var(--white)" stroke-width=".9"/>
  <line x1="9.6"  y1="14.6" x2="14.4" y2="14.6" stroke="var(--white)" stroke-width=".75"/>
</svg>
