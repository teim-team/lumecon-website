---
const { class: className = '' } = Astro.props as { class?: string };
---

<svg class={`icon icon--upload ${className}`} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <rect
    x="6.25"
    y="7.25"
    width="11.5"
    height="11.5"
    stroke="currentColor"
    stroke-width="1.25"
    stroke-linejoin="miter"></rect>
  <g class="icon-upload__arrow">
    <path d="M12 5.75V2.25" stroke="currentColor" stroke-width="1.25"></path>
    <path
      d="M10.1 4.15L12 2.25L13.9 4.15"
      stroke="currentColor"
      stroke-width="1.25"
      stroke-linejoin="miter"></path>
  </g>
  <circle class="icon-upload__dot" cx="12" cy="7.25" r="1.5" fill="currentColor"></circle>
</svg>
