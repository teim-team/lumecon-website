---
const { class: className = '' } = Astro.props as { class?: string };
---
<svg class={`icon ${className}`} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <!-- Sigma (Σ) — the canonical mark of summation / aggregation,
       which is the heart of input-output modeling. Gold dot at the
       fold marks the multiplier hub. -->
  <path d="M16.5 5H8L13 12L8 19H16.5" stroke="currentColor" stroke-width="1.25" stroke-linejoin="miter" stroke-linecap="butt"/>
  <circle cx="13" cy="12" r="1.4" fill="#F0A91A"/>
</svg>
