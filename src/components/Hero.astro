---
import { site } from '../config';
import '../styles/hero.css';
const { local, tribal, global: globalProduct } = site.products;
---
<section class="hero" id="top">
  <div class="hero-grid">
    <figure class="hero-mark" aria-hidden="true">
      <svg class="hero-lines" viewBox="0 0 720 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <radialGradient id="heroGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#F2D67A" stop-opacity=".85"/>
            <stop offset="55%" stop-color="#C49A3C" stop-opacity=".14"/>
            <stop offset="100%" stop-color="#C49A3C" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <path class="hero-line hero-line--d1" d="M-60 200 C 140 130, 260 280, 420 210 S 660 340, 820 250" />
        <path class="hero-line hero-line--d2" d="M-60 480 C 120 430, 260 600, 420 490 S 660 660, 820 560" />
        <path class="hero-line hero-line--solid" d="M-80 800 Q 160 600, 340 560 T 760 380" />
        <circle class="hero-glow" cx="340" cy="500" r="140" fill="url(#heroGlow)" />
        <circle class="hero-spark" cx="340" cy="500" r="4" />
      </svg>
      <img class="hero-mark__img" src="/brand/lumecon-logo-mark-transparent.png" alt="" width="380" height="260" />
    </figure>

    <div class="hero-text">
      <h1 class="hero-wordmark" id="heroWordmark" aria-label="Lumecon — a portmanteau of luminate and economies">
        <span class="hw-cap">L</span><span class="hw-cap">U</span><span class="hw-cap">M</span><span class="hw-tail hw-tail--inate">inate</span><span class="hw-gap" aria-hidden="true"> </span><span class="hw-cap">E</span><span class="hw-cap">C</span><span class="hw-cap">O</span><span class="hw-cap">N</span><span class="hw-tail hw-tail--omies">omies</span>
      </h1>
      <p class="hero-tagline">portmanteau &middot; <em>luminate</em> + <em>economies</em></p>
      <hr class="hero-rule" />
      <p class="hero-pitch">Economic and policy analysis software for governments.</p>
      <p class="hero-lede">
        Lumecon Inc. is the parent brand for three platforms &mdash; serving local, tribal, and global economies through affordable, web-based modeling that organizations of any size can act on.
      </p>
      <div class="hero-actions">
        <a href="#products" class="btn">See the platforms</a>
        <a href="#contact" class="btn btn--ghost">Partner with us</a>
      </div>
    </div>
  </div>
</section>

<script>
  /* Portmanteau loop. After the hero has settled, ease LUMECON open
     into LUMinate eCONomies, hold, ease shut, hold longer, repeat.
     Slower than a typical UI animation — this is editorial pacing,
     not a marquee. Disabled under prefers-reduced-motion. */
  (function () {
    const mark = document.getElementById('heroWordmark');
    if (!mark) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      mark.classList.add('is-open');
      return;
    }
    const OPEN_HOLD = 3600;
    const CLOSE_HOLD = 5200;
    const FIRST_DELAY = 1900;
    let timer: number | undefined;
    const open = () => {
      mark.classList.add('is-open');
      timer = window.setTimeout(close, OPEN_HOLD);
    };
    const close = () => {
      mark.classList.remove('is-open');
      timer = window.setTimeout(open, CLOSE_HOLD);
    };
    timer = window.setTimeout(open, FIRST_DELAY);
    mark.addEventListener('pointerenter', () => { if (timer) window.clearTimeout(timer); });
    mark.addEventListener('pointerleave', () => { timer = window.setTimeout(close, OPEN_HOLD); });
  })();
</script>
