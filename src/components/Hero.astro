  // California (~12)
  pala:             ['Pala Reservation', 'Pala'],
  rincon:           ['Rincon Reservation', 'Rincon'],
  sycuan:           ['Sycuan'],
  viejas:           ['Viejas'],
  soboba:           ['Soboba'],
  tule_river:       ['Tule River'],
  hoopa:            ['Hoopa Valley'],
  yurok:            ['Yurok'],
  cabazon:          ['Cabazon'],
  san_pasqual:      ['San Pasqual'],
  bishop_paiute:    ['Bishop Reservation', 'Bishop'],
  chemehuevi:       ['Chemehuevi'],
  // Arizona (~10)
  gila_river:       ['Gila River'],
