  ak_chin:          ['Maricopa (Ak Chin)', 'Ak Chin', 'Ak-Chin'],
  pascua_yaqui:     ['Pascua Pueblo Yaqui', 'Pascua Yaqui'],
  hualapai:         ['Hualapai'],
