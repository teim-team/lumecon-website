---
/**
 * Hero — Lumecon brand + live impact study with Cedar in the margin.
 *
 * Hybrid layout: the map dominates, the result text sits in clean
 * editorial type beneath it, and Cedar is a quiet expander you can
 * open to ask a follow-up question. AIANNH boundaries from Census
 * TIGER/Line are clickable — picking one runs a tribal-economy
 * study with framing tailored to the tribal land, while clicking
 * any state runs a state-level study with randomized activity.
 */
import { geoPath } from 'd3-geo';
import { mesh, feature } from 'topojson-client';
// @ts-ignore — us-atlas ships JSON, not TS
import usAtlas from 'us-atlas/states-albers-10m.json' with { type: 'json' };
// @ts-ignore — generated data, no .d.ts
import { CENSUS_TRIBAL_LANDS } from '../data/tribalLands.generated.js';
import '../styles/hero.css';

const VBX = 70, VBY = 60, VBW = 850, VBH = 510;
const path = geoPath();
// @ts-ignore
const statesFC: any = feature(usAtlas, usAtlas.objects.states);
// @ts-ignore
const stateBordersD = path(mesh(usAtlas, usAtlas.objects.states, (a: any, b: any) => a !== b));
// @ts-ignore
const nationOutlineD = path(mesh(usAtlas, usAtlas.objects.states, (a: any, b: any) => a === b));

// County border mesh — a single path of every county boundary.
// Loaded from us-atlas/counties-albers-10m.json (separate import keeps
// the heavier file out of the bundle when only states are visible).
// @ts-ignore
import countiesAtlas from 'us-atlas/counties-albers-10m.json' with { type: 'json' };
// @ts-ignore
const countyBordersD = path(mesh(countiesAtlas, countiesAtlas.objects.counties, (a: any, b: any) => a !== b));

const stateData = statesFC.features.map((f: any) => {
  const [cx, cy] = path.centroid(f);
  return { id: f.id, name: f.properties.name, d: path(f), cx: +cx.toFixed(1), cy: +cy.toFixed(1) };
});

const STATE_CODES: Record<string, string> = {
  '01':'AL','02':'AK','04':'AZ','05':'AR','06':'CA','08':'CO','09':'CT','10':'DE','11':'DC',
  '12':'FL','13':'GA','15':'HI','16':'ID','17':'IL','18':'IN','19':'IA','20':'KS','21':'KY',
  '22':'LA','23':'ME','24':'MD','25':'MA','26':'MI','27':'MN','28':'MS','29':'MO','30':'MT',
  '31':'NE','32':'NV','33':'NH','34':'NJ','35':'NM','36':'NY','37':'NC','38':'ND','39':'OH',
  '40':'OK','41':'OR','42':'PA','44':'RI','45':'SC','46':'SD','47':'TN','48':'TX','49':'UT',
  '50':'VT','51':'VA','53':'WA','54':'WV','55':'WI','56':'WY',
};
const CODE_TO_ID = Object.fromEntries(Object.entries(STATE_CODES).map(([id, code]) => [code, id]));

/* AIANNH polygons — clickable now (used to be decorative). Filter to
   ones with a usable path + centroid. Each one gets the FIPS state-id
   of its containing state so the ring shading targets the right state. */
const aiannh = (CENSUS_TRIBAL_LANDS as any[])
  .filter(l => l.pathD && l.x != null && l.y != null && l.fips)
  .map((l: any) => ({
    id: l.id,
    name: l.name,
    shortName: l.shortName || l.name,
    fips: l.fips,
    category: l.category,
    pathD: l.pathD,
    x: l.x,
    y: l.y,
  }));

const statesJson = JSON.stringify(
  stateData.reduce((acc: any, s: any) => { acc[s.id] = { name: s.name, cx: s.cx, cy: s.cy, code: STATE_CODES[s.id] || '' }; return acc; }, {})
);
const codeMapJson = JSON.stringify(CODE_TO_ID);
---
<section class="hero" id="top">
  <!-- Brand statement: large wordmark, one position, one CTA. -->
  <div class="hero-brand">
    <a href="/" class="hero-mark" aria-label="Lumecon Inc.">
      <img src="/brand/lumecon-logo-horizontal-transparent.png" alt="Lumecon" width="560" height="98" />
    </a>
    <h1 class="hero-statement">
      Your work changes the economy around it. We make that change measurable.
    </h1>
    <p class="hero-sub">
      Lumecon turns budgets, programs, and policies into the jobs they support, the dollars they circulate, and the second-order consequences your council, board, and funders need to see. Built for governments and mission-driven organizations, in software they can run themselves.
    </p>
    <div class="hero-cta">
      <a href="#workspace" class="btn">See it run</a>
      <a href="#contact" class="btn btn--ghost">Request a demo</a>
    </div>
  </div>

  <div class="workspace" id="workspace">
    <header class="workspace__bar">
      <span class="workspace__title">
        <img class="workspace__mark" src="/brand/lumecon-logo-mark-transparent.png" alt="" width="22" height="22" aria-hidden="true" />
        <span class="workspace__title-text">Live impact study</span>
        <span class="workspace__divider" aria-hidden="true"></span>
        <span class="workspace__region" id="workspaceRegion" aria-live="polite">Hover any state</span>
      </span>
      <span class="workspace__sub">
        <button type="button" class="workspace__again" id="workspaceAgain" aria-label="Run another study">Run again</button>
        <span class="workspace__sub-divider" aria-hidden="true"></span>
        <span class="workspace__dot" id="workspaceStatus" aria-hidden="true"></span>
        <span class="workspace__sub-text" id="workspaceStatusLabel">Idle</span>
      </span>
    </header>

    <div class="workspace__body">

  <!-- Layer filters — control which geography is visible/clickable -->
  <div class="workspace-filters" role="tablist" aria-label="Map layer">
    <button type="button" class="wfilter is-active" data-layer="states"  role="tab" aria-selected="true">States</button>
    <button type="button" class="wfilter"           data-layer="counties" role="tab" aria-selected="false">Counties</button>
    <button type="button" class="wfilter"           data-layer="tribal"   role="tab" aria-selected="false">Tribal lands</button>
  </div>

  <!-- Map: dominant, full-width. AIANNH polygons are clickable. -->
  <figure class="hero-stage" id="heroStage" aria-label="Interactive map. Hover any state or tribal land to inspect; click to run a study there.">
    <svg class="hero-map" id="heroMap" viewBox={`${VBX} ${VBY} ${VBW} ${VBH}`} preserveAspectRatio="xMidYMid meet" role="img">
      <defs>
        <radialGradient id="hGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%"  stop-color="#F2D67A" stop-opacity=".95"/>
          <stop offset="55%" stop-color="#C49A3C" stop-opacity=".18"/>
          <stop offset="100%" stop-color="#C49A3C" stop-opacity="0"/>
        </radialGradient>
        <pattern id="hGrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0E1530" stroke-width=".4" stroke-opacity=".07" />
        </pattern>
      </defs>

      <!-- Cartographic graticule under everything -->
      <rect class="hero-map__grid" x={VBX} y={VBY} width={VBW} height={VBH} fill="url(#hGrid)" />
      </defs>

      <path class="hero-map__fill" d={nationOutlineD} />

      <g class="hero-map__states">
        {stateData.map((s: any) => (
          <path
            class="hero-state"
            d={s.d}
            data-id={s.id}
            data-cx={s.cx}
            data-cy={s.cy}
            tabindex="0"
            role="button"
            aria-label={s.name}
          ></path>
        ))}
      </g>

      <!-- AIANNH overlay: interactive. Clicking one runs a tribal-economy
           study; hovering shows the tribal-land name in the tooltip. -->
      <g class="hero-map__aiannh">
        {aiannh.map((land: any) => (
          <path
            class={`hero-aiannh hero-aiannh--${land.category}`}
            d={land.pathD}
            data-name={land.name}
            data-short={land.shortName}
            data-fips={land.fips}
            data-cx={land.x}
            data-cy={land.y}
            data-category={land.category}
            tabindex="0"
            role="button"
            aria-label={`Tribal land: ${land.name}`}
          ></path>
        ))}
      </g>

      <path class="hero-map__county-borders" d={countyBordersD} />
      <path class="hero-map__borders" d={stateBordersD} />
      <path class="hero-map__outline" d={nationOutlineD} />

      <g class="hero-source" id="heroSource">
        <circle class="hero-glow"  cx="0" cy="0" r="120" fill="url(#hGlow)" />
        <circle class="hero-ring"  data-ring="1" cx="0" cy="0" r="14" />
        <circle class="hero-ring"  data-ring="2" cx="0" cy="0" r="14" />
        <circle class="hero-ring"  data-ring="3" cx="0" cy="0" r="14" />
        <circle class="hero-spark"      cx="0" cy="0" r="6" />
        <circle class="hero-spark__core" cx="0" cy="0" r="2.4" />
      </g>

      <!-- Floating value labels populated by JS over each lit state -->
      <g class="hero-value-layer" id="heroValueLayer" aria-hidden="true"></g>

      <!-- Source callout: name pinned next to the source dot -->
      <g class="hero-source-callout" id="heroSourceCallout" aria-hidden="true">
        <line class="hero-callout__leader" x1="0" y1="0" x2="0" y2="0" />
        <g class="hero-callout__plate">
          <rect class="hero-callout__bg" x="0" y="0" rx="3" ry="3" width="0" height="22" />
          <text class="hero-callout__txt" x="0" y="0" dominant-baseline="middle"></text>
        </g>
      </g>
    </svg>

    <div class="hero-tooltip" id="heroTooltip" role="tooltip" aria-hidden="true">
      <span class="hero-tooltip__name" id="ttName">&mdash;</span>
      <span class="hero-tooltip__hint" id="ttHint">click to run a study here</span>
    </div>
  </figure>

  <!-- Activity chip — names what's running -->
  <p class="workspace-activity" id="workspaceActivity" aria-live="polite">&nbsp;</p>

  <!-- Live figures — the only text inside the workspace -->
  <dl class="hero-figs" aria-label="Result of the running impact study">
    <div class="hero-fig"><dt>Direct</dt>   <dd id="figDirect">&mdash;</dd></div>
    <div class="hero-fig"><dt>Indirect</dt> <dd id="figIndirect">&mdash;</dd></div>
    <div class="hero-fig"><dt>Induced</dt>  <dd id="figInduced">&mdash;</dd></div>
    <div class="hero-fig hero-fig--total hero-fig--derived" id="figTotalCell"><dt>Total impact</dt> <dd id="figTotal">&mdash;</dd></div>
    <div class="hero-fig hero-fig--derived" id="figJobsCell"><dt>Jobs</dt> <dd id="figJobs">&mdash;</dd></div>
  </dl>

    </div>

    <footer class="workspace__foot">
      <span class="workspace-legend">
        <span class="workspace-legend__sw workspace-legend__sw--source"></span>
        Lit area is where the activity happens. The expanding rings are a visual ripple, not a literal map of indirect or induced effects, which the table below quantifies.
      </span>
      <span class="workspace-attr">Geography: Census TIGER/Line. Multipliers illustrative.</span>
    </footer>
  </div>


  <script type="application/json" id="heroStates"  set:html={statesJson}></script>
  <script type="application/json" id="heroCodeMap" set:html={codeMapJson}></script>
</section>

<script>
  type StateInfo = { name: string; cx: number; cy: number; code: string };
  const states: Record<string, StateInfo> = JSON.parse((document.getElementById('heroStates') as HTMLScriptElement).textContent || '{}');
  const codeMap: Record<string, string> = JSON.parse((document.getElementById('heroCodeMap') as HTMLScriptElement).textContent || '{}');

  /* Activities + amounts: 5 × 5 = 25 combinations per region, plus a
     tribal-specific catalog of verbs Cedar uses when an AIANNH polygon
     is the source. */
  /* Multipliers per activity type, used both by the named SCENES
     and the click-on-state generic runs. */
  const ACTIVITIES = [
    { id: 'build',   label: 'capital construction', indirect: 0.62, induced: 0.38, jobsPerM: 8.9  },
    { id: 'payroll', label: 'operations payroll',   indirect: 0.48, induced: 0.71, jobsPerM: 11.4 },
    { id: 'grant',   label: 'grant pass-through',   indirect: 0.35, induced: 0.55, jobsPerM: 6.2  },
    { id: 'tourism', label: 'visitor spending',     indirect: 0.51, induced: 0.63, jobsPerM: 13.1 },
    { id: 'energy',  label: 'energy project',       indirect: 0.58, induced: 0.42, jobsPerM: 7.6  },
  ] as const;
  const AMOUNTS = [
    { v: 1_000_000,  label: '$1M'  },
    { v: 5_000_000,  label: '$5M'  },
    { v: 12_000_000, label: '$12M' },
    { v: 20_000_000, label: '$20M' },
    { v: 50_000_000, label: '$50M' },
  ] as const;

  /* Named example impact studies. Each one is a real-feeling project
     with location, sentence form, and the activity profile baked in.
     The auto-cycle plays through these so a visitor sees concrete
     examples instead of abstract verb + region tokens. */
  type Scene = {
    state: string;
    project: string;
    location: string;
    chip: string;
    sentence: string;
    amount: typeof AMOUNTS[number];
    activity: typeof ACTIVITIES[number];
  };
  const SCENES: Scene[] = [
    {
      state: '53',
      project: 'A new community health clinic',
      location: 'Pierce County, WA',
      chip: 'Community health clinic · Pierce County, WA · $5M operations',
      sentence: 'A new community health clinic opens in Pierce County, WA, supported by $5M of operating funds.',
      amount: AMOUNTS[1], activity: ACTIVITIES[1],
    },
    {
      state: '48',
      project: 'A workforce expansion at a state university',
      location: 'Travis County, TX',
      chip: 'University workforce expansion · Travis County, TX · $20M payroll',
      sentence: 'A state university expands its workforce in Travis County, TX, with $20M of new operating payroll.',
      amount: AMOUNTS[3], activity: ACTIVITIES[1],
    },
    {
      state: '41',
      project: 'A solar array on tribal lands',
      location: 'Umatilla Reservation, OR',
      chip: 'Tribal solar array · Umatilla Reservation, OR · $12M energy project',
      sentence: 'A tribal government commissions a solar array on the Umatilla Reservation in Oregon, a $12M energy project.',
      amount: AMOUNTS[2], activity: ACTIVITIES[4],
    },
    {
      state: '27',
      project: 'A casino and lodging expansion',
      location: 'Mille Lacs, MN',
      chip: 'Casino expansion · Mille Lacs, MN · $50M capital build',
      sentence: 'A tribal enterprise breaks ground on a $50M casino and lodging expansion in Mille Lacs, MN.',
      amount: AMOUNTS[4], activity: ACTIVITIES[0],
    },
    {
      state: '39',
      project: 'A federal grant to a regional CDFI',
      location: 'Cuyahoga County, OH',
      chip: 'Federal grant pass-through · Cuyahoga County, OH · $5M',
      sentence: 'A federal grant of $5M passes through to a regional CDFI serving Cuyahoga County, OH.',
      amount: AMOUNTS[1], activity: ACTIVITIES[2],
    },
  ];

  const ADJ_RADIUS = { indirect: 220, induced: 480 };

  const stage   = document.getElementById('heroStage') as HTMLElement | null;
  const tooltip = document.getElementById('heroTooltip') as HTMLElement | null;
  const ttName  = document.getElementById('ttName');
  const ttHint  = document.getElementById('ttHint');
  const source  = document.getElementById('heroSource');
  const figD    = document.getElementById('figDirect');
  const figI    = document.getElementById('figIndirect');
  const figU    = document.getElementById('figInduced');
  const figT    = document.getElementById('figTotal');
  const figJ    = document.getElementById('figJobs');
  const figTotalCell = document.getElementById('figTotalCell');
  const figJobsCell  = document.getElementById('figJobsCell');

  if (stage && source && figD && figI && figU && figT && figJ && tooltip && ttName) {

    const wait = (ms: number) => new Promise<void>(r => window.setTimeout(r, ms));
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);

    const fmt = (n: number) =>
      n >= 1_000_000 ? '$' + (n / 1_000_000).toFixed(n >= 10_000_000 ? 1 : 2).replace(/\.0$/, '') + 'M'
      : n >= 1_000   ? '$' + Math.round(n / 1_000) + 'K'
      :                '$' + Math.round(n);

    const tickTo = (el: HTMLElement, target: number, prefix = '', dur = 1100) => {
      const start = performance.now();
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        el.textContent = prefix + fmt(target * ease(t));
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const tickInt = (el: HTMLElement, target: number, prefix = '', dur = 1100) => {
      const start = performance.now();
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        el.textContent = prefix + Math.round(target * ease(t)).toLocaleString();
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    // setLine: no-op now that the narration line is removed; kept so
    // existing call sites compile and silently do nothing.
    const setLine = (_text: string) => { /* no narration line in DOM */ };

    /* Draw +value labels on the lit states of a given ring (0/1/2).
       Picks up to 4 states by largest centroid-distance-from-source
       so the labels don't all stack in one corner. Each label gets
       its own SVG <g> appended to the value layer. */
    /* Light only the source state. Indirect (supply chain) and induced
       (household) effects don't have a clean geographic story at this
       resolution: indirect spreads to wherever suppliers are, induced
       is mostly local where workers live. The expanding ripple circles
       below are an abstract metaphor; the table beneath the map is
       where the actual breakdown lives. */
    const lightSource = (id: string) => {
      stage.querySelectorAll<HTMLElement>('.hero-state').forEach(el => {
        if (el.dataset.id === id) el.dataset.ring = '0';
        else el.removeAttribute('data-ring');
      });
    };

    // Kept for backward-compat with other call sites; now a no-op-ish
    // wrapper that just lights the source. The neighbor-distance pass
    // is gone.
    const shadeNeighbors = (id: string) => {
      lightSource(id);
      // The original implementation also distance-bucketed every
      // other state into ring 1 / ring 2; intentionally removed.
    };

    const moveSource = (cx: number, cy: number) => {
      source.querySelectorAll<SVGCircleElement>('circle').forEach(c => {
        c.setAttribute('cx', String(cx));
        c.setAttribute('cy', String(cy));
      });
    };

    /* ---------- run a study ---------- */
    let runId = 0;
    let cycleTimer: number | undefined;

    type RunOpts = {
      activity?: typeof ACTIVITIES[number];
      amount?: typeof AMOUNTS[number];
      framing?: string;
      chip?: string;
      sourcePoint?: { cx: number; cy: number };
    };

    const runStudy = async (stateId: string, opts?: RunOpts) => {
      runId += 1; const me = runId;
      const s = states[stateId]; if (!s) return;

      const activity = opts?.activity ?? ACTIVITIES[Math.floor(Math.random() * ACTIVITIES.length)];
      const amount   = opts?.amount   ?? AMOUNTS[1 + Math.floor(Math.random() * (AMOUNTS.length - 1))];
      const framing  = opts?.framing  ?? `A ${amount.label} ${activity.label} in ${s.name}.`;
      const src      = opts?.sourcePoint ?? { cx: s.cx, cy: s.cy };

      stage.dataset.run = '';
      stage.dataset.ring = '';
      figTotalCell?.classList.remove('is-filled');
      figJobsCell?.classList.remove('is-filled');
      [figD, figI, figU, figT, figJ].forEach(el => { if (el) el.textContent = '—'; });

      // Clear any prior value labels + callout
      const vlayer = document.getElementById('heroValueLayer');
      if (vlayer) vlayer.innerHTML = '';
      const callout = document.getElementById('heroSourceCallout');
      if (callout) callout.classList.remove('is-on');

      shadeNeighbors(stateId);
      moveSource(src.cx, src.cy);
      stage.dataset.run = '1';

      const wsStatus = document.getElementById('workspaceStatus');
      const wsLabel = document.getElementById('workspaceStatusLabel');
      const wsRegion = document.getElementById('workspaceRegion');
      const wsActivity = document.getElementById('workspaceActivity');
      if (wsStatus) wsStatus.dataset.state = 'running';
      if (wsLabel) wsLabel.textContent = 'Running';
      if (wsRegion) wsRegion.textContent = framing.includes('(') ? framing : s.name;
      if (wsActivity) {
        wsActivity.textContent = opts?.chip ?? `${amount.label} ${activity.label} in ${s.name}`;
      }

      // Source callout: pin the region name next to the source dot
      const calloutEl = document.getElementById('heroSourceCallout');
      if (calloutEl) {
        const leader = calloutEl.querySelector<SVGLineElement>('.hero-callout__leader');
        const bg = calloutEl.querySelector<SVGRectElement>('.hero-callout__bg');
        const txt = calloutEl.querySelector<SVGTextElement>('.hero-callout__txt');
        if (leader && bg && txt) {
          txt.textContent = s.name;
          const tx = src.cx + 18;
          const ty = src.cy - 18;
          const w = (s.name.length * 6.6) + 16;
          bg.setAttribute('x', String(tx)); bg.setAttribute('y', String(ty - 11));
          bg.setAttribute('width', String(w));
          txt.setAttribute('x', String(tx + 8));
          txt.setAttribute('y', String(ty));
          leader.setAttribute('x1', String(src.cx));
          leader.setAttribute('y1', String(src.cy));
          leader.setAttribute('x2', String(tx));
          leader.setAttribute('y2', String(ty));
          calloutEl.classList.add('is-on');
        }
      }

      setLine(`${framing}. A <em>${activity.label}</em> of <strong>${amount.label}</strong>.`);
      if (runId !== me) return;

      stage.dataset.ring = '1';
      await wait(550);
      tickTo(figD as HTMLElement, amount.v, '', 950);
      await wait(1900);
      if (runId !== me) return;
      stage.dataset.ring = '2';
      const indirect = amount.v * activity.indirect;
      tickTo(figI as HTMLElement, indirect, '+ ', 950);

      await wait(2000);
      if (runId !== me) return;
      stage.dataset.ring = '3';
      const induced = amount.v * activity.induced;
      tickTo(figU as HTMLElement, induced, '+ ', 950);

      await wait(2000);
      if (runId !== me) return;
      stage.dataset.ring = '4';
      const total = amount.v + indirect + induced;
      const jobs = Math.round((total / 1_000_000) * activity.jobsPerM);
      figTotalCell?.classList.add('is-filled');
      figJobsCell?.classList.add('is-filled');
      tickTo(figT as HTMLElement, total, '', 1150);
      tickInt(figJ as HTMLElement, jobs, '≈ ', 950);
      setLine(`That sum, with every multiplier sourced and the assumption ledger attached, is your study.`);

      const wsStatusDone = document.getElementById('workspaceStatus');
      const wsLabelDone = document.getElementById('workspaceStatusLabel');
      if (wsStatusDone) wsStatusDone.dataset.state = 'complete';
      if (wsLabelDone) wsLabelDone.textContent = 'Complete';
    };

    let sceneIdx = 0;
    const cycle = async () => {
      const scene = SCENES[sceneIdx % SCENES.length];
      await runStudy(scene.state, {
        activity: scene.activity,
        amount: scene.amount,
        framing: scene.sentence,
        chip: scene.chip,
      });
      sceneIdx += 1;
      cycleTimer = window.setTimeout(cycle, 6800);
    };

    /* ---------- Hover tooltip ---------- */
    const placeTooltip = (e: MouseEvent | FocusEvent) => {
      const rect = stage.getBoundingClientRect();
      let x: number, y: number;
      if ('clientX' in e) {
        x = (e as MouseEvent).clientX - rect.left;
        y = (e as MouseEvent).clientY - rect.top;
      } else {
        const t = (e.target as Element).getBoundingClientRect();
        x = (t.left + t.width / 2) - rect.left;
        y = (t.top + t.height / 2) - rect.top;
      }
      tooltip.style.transform = `translate(${x}px, ${y}px)`;
    };

    const setTooltip = (name: string, hint: string) => {
      ttName.textContent = name;
      if (ttHint) ttHint.textContent = hint;
    };

    /* ---------- Layer filters (States / Counties / Tribal) ---------- */
    document.querySelectorAll<HTMLButtonElement>('.wfilter').forEach(btn => {
      btn.addEventListener('click', () => {
        const layer = btn.dataset.layer || 'states';
        document.querySelectorAll<HTMLButtonElement>('.wfilter').forEach(b => {
          const on = b === btn;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        if (stage) stage.dataset.layer = layer;
      });
    });

    /* ---------- "Run again" button ---------- */
    const wsAgain = document.getElementById('workspaceAgain');
    if (wsAgain) {
      wsAgain.addEventListener('click', async () => {
        if (cycleTimer) window.clearTimeout(cycleTimer);
        const ids = Object.keys(states);
        const pick = ids[Math.floor(Math.random() * ids.length)];
        await runStudy(pick);
        cycleTimer = window.setTimeout(cycle, 6800);
      });
    }

    /* ---------- state click + hover ---------- */
    stage.querySelectorAll<HTMLElement>('.hero-state').forEach(el => {
      el.addEventListener('mouseenter', (e) => {
        const id = el.dataset.id; if (!id) return;
        setTooltip(states[id]?.name || '', 'click to run a study here');
        tooltip.classList.add('is-on');
        placeTooltip(e);
        const wsRegion = document.getElementById('workspaceRegion');
        if (wsRegion && stage.dataset.run !== '1') wsRegion.textContent = states[id]?.name || '';
      });
      el.addEventListener('mousemove', (e) => placeTooltip(e));
      el.addEventListener('mouseleave', () => tooltip.classList.remove('is-on'));
      el.addEventListener('focus', (e) => {
        const id = el.dataset.id; if (!id) return;
        setTooltip(states[id]?.name || '', 'press Enter to run a study here');
        tooltip.classList.add('is-on');
        placeTooltip(e);
      });
      el.addEventListener('blur', () => tooltip.classList.remove('is-on'));

      const start = async () => {
        const id = el.dataset.id; if (!id) return;
        if (cycleTimer) window.clearTimeout(cycleTimer);
        await runStudy(id);
        cycleTimer = window.setTimeout(cycle, 6800);
      };
      el.addEventListener('click', start);
      el.addEventListener('keydown', (e) => {
        const k = (e as KeyboardEvent).key;
        if (k === 'Enter' || k === ' ') { e.preventDefault(); start(); }
      });
    });

    /* ---------- AIANNH click + hover ---------- */
    stage.querySelectorAll<HTMLElement>('.hero-aiannh').forEach(el => {
      el.addEventListener('mouseenter', (e) => {
        setTooltip(el.dataset.name || 'Tribal land', 'click to run a tribal-economy study');
        tooltip.classList.add('is-on');
        placeTooltip(e);
      });
      el.addEventListener('mousemove', (e) => placeTooltip(e));
      el.addEventListener('mouseleave', () => tooltip.classList.remove('is-on'));
      el.addEventListener('focus', (e) => {
        setTooltip(el.dataset.name || 'Tribal land', 'press Enter to run a tribal-economy study');
        tooltip.classList.add('is-on');
        placeTooltip(e);
      });
      el.addEventListener('blur', () => tooltip.classList.remove('is-on'));

      const start = async () => {
        const fips = el.dataset.fips; if (!fips) return;
        const cx = parseFloat(el.dataset.cx || '0');
        const cy = parseFloat(el.dataset.cy || '0');
        const tribalName = el.dataset.short || el.dataset.name || 'a tribal land';
        if (cycleTimer) window.clearTimeout(cycleTimer);
        const activity = ACTIVITIES[Math.floor(Math.random() * ACTIVITIES.length)];
        const amount   = AMOUNTS[1 + Math.floor(Math.random() * (AMOUNTS.length - 1))];
        const framing  = `A ${amount.label} tribal project on the ${tribalName}.`;
        const chip = `${tribalName} · ${amount.label} ${activity.label}`;
        await runStudy(fips, { activity, amount, framing, chip, sourcePoint: { cx, cy } });
        cycleTimer = window.setTimeout(cycle, 6800);
      };
      el.addEventListener('click', start);
      el.addEventListener('keydown', (e) => {
        const k = (e as KeyboardEvent).key;
        if (k === 'Enter' || k === ' ') { e.preventDefault(); start(); }
      });
    });

    /* ---------- IP geolocation kickoff ---------- */
    const GEO_KEY = 'lumecon:geo';
    const GEO_TTL_MS = 30 * 24 * 60 * 60 * 1000;
    const readCachedState = (): string | null => {
      try {
        const raw = localStorage.getItem(GEO_KEY); if (!raw) return null;
        const { code, at } = JSON.parse(raw) as { code: string; at: number };
        if (!code || Date.now() - at > GEO_TTL_MS) return null;
        return codeMap[code] || null;
      } catch { return null; }
    };
    const detectStateId = async (): Promise<string | null> => {
      const cached = readCachedState(); if (cached) return cached;
      try {
        const ctrl = new AbortController();
        const t = window.setTimeout(() => ctrl.abort(), 2200);
        const r = await fetch('https://ipapi.co/json/', { signal: ctrl.signal, headers: { 'Accept': 'application/json' } });
        window.clearTimeout(t);
        if (!r.ok) return null;
        const j = await r.json();
        const code: string | undefined = j && (j.region_code || j.region_code_iso3166_2);
        const country: string | undefined = j && (j.country_code || j.country);
        if (country !== 'US' || !code) return null;
        try { localStorage.setItem(GEO_KEY, JSON.stringify({ code, at: Date.now() })); } catch {}
        return codeMap[code] || null;
      } catch { return null; }
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const s = states['53']; if (s) { moveSource(s.cx, s.cy); shadeNeighbors('53'); }
      figD!.textContent = fmt(5_000_000);
    } else {
      detectStateId().then(async (sid) => {
        if (sid && states[sid]) {
          const activity = ACTIVITIES[Math.floor(Math.random() * ACTIVITIES.length)];
          const amount   = AMOUNTS[1 + Math.floor(Math.random() * (AMOUNTS.length - 1))];
          const framing  = `A ${amount.label} ${activity.label} in ${states[sid].name}, near you.`;
          const chip = `${amount.label} ${activity.label} in ${states[sid].name}`;
          await runStudy(sid, { activity, amount, framing, chip });
          cycleTimer = window.setTimeout(cycle, 6800);
        } else {
          cycleTimer = window.setTimeout(cycle, 900);
        }
      });
    }
  }
</script>
