---
import '../styles/hero.css';
---
<section class="hero" id="top">
  <div class="hero-text">
    <div class="hero-brand" id="heroBrand">Lumecon</div>
    <div class="hero-tagline">We luminate economies&trade;</div>
    <h1>Economic and policy analysis anyone can act on</h1>
    <div class="hero-accent"></div>
    <p class="hero-body"><strong>Lumecon&trade; is an economic and policy analysis platform, offering specialized products for local, tribal, and global economic impact and policy analysis.</strong></p>
    <p class="hero-body">We deliver novel modeling methods through affordable, web-based annual subscriptions so organizations of any size can access the caliber of analysis that once required expensive consultants and legacy software. Built by social scientists, government professionals, and software engineers, Lumecon makes economies more visible and policy more actionable. <em>Patent pending.</em></p>
    <div class="hero-actions" id="heroActions">
      <a href="#products" class="btn">Our Products</a>
      <a href="#cedar" class="btn">Cedar</a>
      <a href="#contact" class="btn">Partner With Us</a>
    </div>
  </div>
  <div class="hero-panel" id="heroPanel">
    <canvas id="topoCanvas" aria-label="Animated topographic map visualization"></canvas>
    <div class="hero-panel-hint">Click to regenerate</div>
  </div>
</section>

<script>
  // Hero brand letter animation
  (function() {
    const b = document.getElementById('heroBrand');
    if (!b || b.querySelector('.fl')) return;
    const t = (b.textContent || '').trim();
    b.textContent = '';
    const L: HTMLSpanElement[] = [];
    for (let i = 0; i < t.length; i++) {
      const s = document.createElement('span');
      s.className = 'fl';
      s.textContent = t[i];
      s.style.setProperty('--d', (.05 + i * .065) + 's');
      b.appendChild(s);
      L.push(s);
    }
    setTimeout(() => {
      L.forEach((s, i) => {
        s.style.setProperty('--pd', (i * .35) + 's');
        s.classList.add('go');
      });
    }, (.05 + t.length * .065 + .55) * 1000);
  })();
</script>

<script>
  // Magnetic cursor effect on hero buttons
  const MAGNETIC_STRENGTH = 0.15;
  const MAGNETIC_RESET_DURATION = 400; // ms
  const MAGNETIC_EASING = 'cubic-bezier(.22,1,.36,1)';

  (function() {
    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    if (isTouchDevice) return;
    const actions = document.getElementById('heroActions');
    if (!actions) return;
    actions.querySelectorAll('.btn').forEach(btn => {
      const el = btn as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = (e.clientX - cx) * MAGNETIC_STRENGTH;
        const dy = (e.clientY - cy) * MAGNETIC_STRENGTH;
        el.style.transform = `translate(${dx}px, ${dy}px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
        el.style.transition = `transform ${MAGNETIC_RESET_DURATION / 1000}s ${MAGNETIC_EASING}`;
        setTimeout(() => { el.style.transition = ''; }, MAGNETIC_RESET_DURATION);
      });
      el.addEventListener('mouseenter', () => {
        el.style.transition = 'none';
      });
    });
  })();
</script>

<script>
  import { initTopoCanvas } from '../scripts/topo-canvas';
  initTopoCanvas();
</script>
