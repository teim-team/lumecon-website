---
import '../styles/hero.css';
---
<section class="hero" id="top">
  <div class="hero-text">
    <div class="hero-brand" id="heroBrand">Lumecon</div>
    <div class="hero-tagline">We luminate economies&trade;</div>
    <h1>Economic and policy analysis anyone can act on</h1>
    <div class="hero-accent"></div>
    <p class="hero-body"><strong>Lumecon&trade; is an economic and policy analysis platform, offering specialized products for local, tribal, and global economic impact and policy analysis.</strong></p>
    <p class="hero-body">We deliver novel modeling methods through affordable, web-based annual subscriptions so organizations of any size can access the caliber of analysis that once required expensive consultants and legacy software. Built by social scientists, government professionals, and software engineers, Lumecon makes economies more visible and policy more actionable. <em>Patent pending.</em></p>
    <div class="hero-actions">
      <a href="#products" class="btn">Our Products</a>
      <a href="#cedar" class="btn">Cedar</a>
      <a href="#contact" class="btn">Partner With Us</a>
    </div>
  </div>
  <div class="hero-panel" id="heroPanel">
    <canvas id="topoCanvas"></canvas>
    <div class="hero-panel-hint">Click to regenerate</div>
  </div>
</section>

<script>
  // Hero brand letter animation
  (function() {
    const b = document.getElementById('heroBrand');
    if (!b) return;
    const t = b.textContent!.trim();
    b.textContent = '';
    const L: HTMLSpanElement[] = [];
    for (let i = 0; i < t.length; i++) {
      const s = document.createElement('span');
      s.className = 'fl';
      s.textContent = t[i];
      s.style.setProperty('--d', (.05 + i * .065) + 's');
      b.appendChild(s);
      L.push(s);
    }
    setTimeout(() => {
      L.forEach((s, i) => {
        s.style.setProperty('--pd', (i * .35) + 's');
        s.classList.add('go');
      });
    }, (.05 + t.length * .065 + .55) * 1000);
  })();
</script>

<script>
  // Canvas topographic animation
  (function(){var c=document.getElementById('topoCanvas') as HTMLCanvasElement;if(!c)return;var x=c.getContext('2d')!,dp=window.devicePixelRatio||1,W:number,H:number,t=0,R:any[]=[],B:any[]=[],D:any[]=[],rp:any[]=[];function rs(){var r=c.parentElement!.getBoundingClientRect();W=r.width;H=r.height;c.width=W*dp;c.height=H*dp;c.style.width=W+'px';c.style.height=H+'px';x.setTransform(dp,0,0,dp,0,0);bM()}function pS(s:number){var p=-20;switch(s){case 0:return{x:Math.random()*W,y:p};case 1:return{x:W-p,y:Math.random()*H};case 2:return{x:Math.random()*W,y:H-p};case 3:return{x:p,y:Math.random()*H}}return{x:0,y:0}}function cR(ax:number,ay:number,bx:number,by:number,w:number,sg?:number){var p=[];sg=sg||(6+~~(Math.random()*4));var dx=bx-ax,dy=by-ay,l=Math.sqrt(dx*dx+dy*dy)||1,nx=-dy/l,ny=dx/l,dr=0;for(var i=0;i<=sg;i++){var tt=i/sg,xx=ax+dx*tt,yy=ay+dy*tt;if(i>0&&i<sg){dr+=(Math.random()-.5)*w*.35;dr*=.8;var o=dr+Math.sin(tt*Math.PI*.8)*w*.25;xx+=nx*o;yy+=ny*o}p.push({x:xx,y:yy})}return p}function dS(p:any[]){if(p.length<2)return;x.beginPath();x.moveTo(p[0].x,p[0].y);if(p.length===2){x.lineTo(p[1].x,p[1].y);x.stroke();return}for(var i=1;i<p.length-1;i++){var xc=(p[i].x+p[i+1].x)/2,yc=(p[i].y+p[i+1].y)/2;x.quadraticCurveTo(p[i].x,p[i].y,xc,yc)}x.lineTo(p[p.length-1].x,p[p.length-1].y);x.stroke()}function sP(p:any[],tt:number){if(p.length<2)return p[0];var tl=0,sl=[];for(var i=1;i<p.length;i++){var dx=p[i].x-p[i-1].x,dy=p[i].y-p[i-1].y;sl.push(Math.sqrt(dx*dx+dy*dy));tl+=sl[sl.length-1]}var tg=tt*tl,ac=0;for(var i=0;i<sl.length;i++){if(ac+sl[i]>=tg){var lt=(tg-ac)/sl[i];return{x:p[i].x+(p[i+1].x-p[i].x)*lt,y:p[i].y+(p[i+1].y-p[i].y)*lt}}ac+=sl[i]}return p[p.length-1]}function sA(p:any[],tt:number){var a=sP(p,Math.max(0,tt-.02)),b=sP(p,Math.min(1,tt+.02));return Math.atan2(b.y-a.y,b.x-a.x)}function nR(xx:number,yy:number,m:number){var b:any=null,bd=m*m;for(var i=0;i<R.length;i++){var p=R[i].pts;for(var j=0;j<p.length;j++){var dx=p[j].x-xx,dy=p[j].y-yy,d=dx*dx+dy*dy;if(d<bd){bd=d;b=p[j]}}}return b}
function bM(){R=[];B=[];D=[];rp=[];for(var i=0;i<12+~~(Math.random()*5);i++){var s1=~~(Math.random()*4),s2=(s1+1+~~(Math.random()*2))%4,a=pS(s1),b=pS(s2);R.push({pts:cR(a.x,a.y,b.x,b.y,70+Math.random()*110),w:1.8+Math.random()*1.6,o:.13+Math.random()*.06,la:1})}var mc=R.length;for(var i=0;i<30+~~(Math.random()*15);i++){var mr=R[~~(Math.random()*mc)],tt=.05+Math.random()*.9,p=sP(mr.pts,tt),ag=sA(mr.pts,tt)+(.3+Math.random()*1.1)*(Math.random()<.5?1:-1),bl=50+Math.random()*150,ex=p.x+Math.cos(ag)*bl,ey=p.y+Math.sin(ag)*bl,sn=nR(ex,ey,60);if(sn){ex=sn.x;ey=sn.y}R.push({pts:cR(p.x,p.y,ex,ey,20+Math.random()*45,4+~~(Math.random()*3)),w:.7+Math.random()*.8,o:.055+Math.random()*.04,la:2})}var l2=R.length;for(var i=0;i<60+~~(Math.random()*30);i++){var sr=R[~~(Math.random()*l2)],tt=Math.random(),p=sP(sr.pts,tt),ag=sA(sr.pts,tt)+(.3+Math.random()*1.2)*(Math.random()<.5?1:-1),ln=18+Math.random()*70,ex=p.x+Math.cos(ag)*ln,ey=p.y+Math.sin(ag)*ln,sn=nR(ex,ey,35);if(sn){ex=sn.x;ey=sn.y}R.push({pts:cR(p.x,p.y,ex,ey,8+Math.random()*20,3+~~(Math.random()*2)),w:.3+Math.random()*.4,o:.03+Math.random()*.03,la:3})}var l3=R.length;for(var i=0;i<110+~~(Math.random()*60);i++){var sr=R[~~(Math.random()*l3)],tt=Math.random(),p=sP(sr.pts,tt),ag=Math.random()*Math.PI*2,ln=5+Math.random()*25,ex=p.x+Math.cos(ag)*ln,ey=p.y+Math.sin(ag)*ln,sn=nR(ex,ey,20);if(sn){ex=sn.x;ey=sn.y}var md={x:(p.x+ex)/2+(Math.random()-.5)*4,y:(p.y+ey)/2+(Math.random()-.5)*4};R.push({pts:[{x:p.x,y:p.y},md,{x:ex,y:ey}],w:.2+Math.random()*.2,o:.02+Math.random()*.018,la:4})}for(var i=0;i<180+~~(Math.random()*100);i++){var sr=R[~~(Math.random()*R.length)],tt=Math.random(),p=sP(sr.pts,tt),ag=Math.random()*Math.PI*2,ln=3+Math.random()*14,ex=p.x+Math.cos(ag)*ln,ey=p.y+Math.sin(ag)*ln,sn=nR(ex,ey,12);if(sn){ex=sn.x;ey=sn.y}R.push({pts:[{x:p.x,y:p.y},{x:ex,y:ey}],w:.1+Math.random()*.12,o:.012+Math.random()*.012,la:5})}var cX=6,cY=5,cW=W/cX,cH=H/cY;for(var gy=0;gy<cY;gy++)for(var gx=0;gx<cX;gx++){var nc=1+~~(Math.random()*2.5);for(var cc=0;cc<nc;cc++){var cx=gx*cW+Math.random()*cW,cy=gy*cH+Math.random()*cH,rr=nR(cx,cy,80);if(rr){cx=rr.x+(Math.random()-.5)*25;cy=rr.y+(Math.random()-.5)*25}var ca=Math.random()*Math.PI,nb=4+~~(Math.random()*12),ux=cx,uy=cy;for(var bb=0;bb<nb;bb++){var bw=3+Math.random()*16,bh=2+Math.random()*11,ba=ca+(Math.random()-.5)*.4,cs=Math.cos(ba),sn2=Math.sin(ba),j=function(){return(Math.random()-.5)*1.2},pts;pts=[{x:ux+j(),y:uy+j()},{x:ux+cs*bw+j(),y:uy+sn2*bw+j()},{x:ux+cs*bw-sn2*bh+j(),y:uy+sn2*bw+cs*bh+j()},{x:ux-sn2*bh+j(),y:uy+cs*bh+j()}];var bx2=ux+cs*bw*.5-sn2*bh*.5,by2=uy+sn2*bw*.5+cs*bh*.5;B.push({pts:pts,cx:bx2,cy:by2});var r2=Math.random();if(r2<.4){ux+=cs*(bw+1)+(Math.random()-.5)*2;uy+=sn2*(bw+1)+(Math.random()-.5)*2}else if(r2<.7){ux+=-sn2*(bh+1)+(Math.random()-.5)*2;uy+=cs*(bh+1)+(Math.random()-.5)*2}else{ux+=cs*bw*.5-sn2*(bh+1)+(Math.random()-.5)*3;uy+=sn2*bw*.5+cs*(bh+1)+(Math.random()-.5)*3}}}}for(var i=0;i<B.length;i++){var bl=B[i],dn=Math.random(),n:number;if(dn>.87)n=12+~~(Math.random()*20);else if(dn>.5)n=3+~~(Math.random()*7);else if(dn>.2)n=1+~~(Math.random()*2);else n=0;for(var d=0;d<n;d++){var sp=dn>.87?1.5+Math.random()*3:1+Math.random()*5;D.push({x:bl.cx+(Math.random()-.5)*sp*2,y:bl.cy+(Math.random()-.5)*sp*2,sz:.3+Math.random()*1.1,ph:Math.random()*Math.PI*2,bs:.3+Math.random()*2.5,sh:.8+Math.random()*2,it:.4+Math.random()*.6,lp:Math.random()*Math.PI*2,ls:.03+Math.random()*.12,cr:dn>.87&&Math.random()<.1})}}for(var i=0;i<25;i++)D.push({x:Math.random()*W,y:Math.random()*H,sz:.2+Math.random()*.5,ph:Math.random()*Math.PI*2,bs:.2+Math.random(),sh:1,it:.1+Math.random()*.2,lp:Math.random()*Math.PI*2,ls:.02+Math.random()*.06,cr:false})}
function spRp(xx:number,yy:number){rp.push({x:xx,y:yy,r:0,mr:10+Math.random()*22,sp:14+Math.random()*22,op:.2+Math.random()*.2})}
function dr(){t+=.016;x.clearRect(0,0,W,H);for(var i=0;i<B.length;i++){var bl=B[i].pts;x.beginPath();x.moveTo(bl[0].x,bl[0].y);for(var j=1;j<bl.length;j++)x.lineTo(bl[j].x,bl[j].y);x.closePath();x.fillStyle='rgba(255,252,247,0.022)';x.fill();x.strokeStyle='rgba(255,252,247,0.042)';x.lineWidth=.3;x.stroke()}x.lineCap='round';x.lineJoin='round';for(var la=5;la>=1;la--)for(var i=0;i<R.length;i++){var r=R[i];if(r.la!==la)continue;x.lineWidth=r.w;x.strokeStyle='rgba(255,252,247,'+r.o+')';dS(r.pts)}for(var i=rp.length-1;i>=0;i--){var r=rp[i];r.r+=r.sp*.016;var lf=r.r/r.mr;if(lf>1){rp.splice(i,1);continue}x.beginPath();x.arc(r.x,r.y,r.r,0,Math.PI*2);x.strokeStyle='rgba(196,154,60,'+(r.op*(1-lf)*(1-lf))+')';x.lineWidth=.8*(1-lf*.5);x.stroke()}for(var i=0;i<D.length;i++){var d=D[i],lf=Math.sin(t*d.ls+d.lp);if(lf<0)continue;var raw=(Math.sin(t*d.bs+d.ph)+1)*.5,bk=Math.pow(raw,d.sh),br=d.it*bk*lf;if(br<.01)continue;var sz=d.sz*(.7+bk*.3);if(d.cr&&bk>.9&&Math.random()<.003)spRp(d.x,d.y);if(br>.3&&sz>.6){var gr=sz*5,gd=x.createRadialGradient(d.x,d.y,0,d.x,d.y,gr);gd.addColorStop(0,'rgba(196,154,60,'+(br*.12)+')');gd.addColorStop(1,'rgba(196,154,60,0)');x.beginPath();x.arc(d.x,d.y,gr,0,Math.PI*2);x.fillStyle=gd;x.fill()}x.beginPath();x.arc(d.x,d.y,sz,0,Math.PI*2);x.fillStyle='rgba(196,154,60,'+br+')';x.fill();if(br>.5){x.beginPath();x.arc(d.x,d.y,sz*.3,0,Math.PI*2);x.fillStyle='rgba(255,245,220,'+(br*.5)+')';x.fill()}}requestAnimationFrame(dr)}
window.addEventListener('resize',rs);rs();dr();document.getElementById('heroPanel')!.addEventListener('click',function(){bM()})})();
</script>
