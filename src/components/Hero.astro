---
/**
 * Lumecon Inc. hero — the luminating map.
 *
 * This page exists to answer one question: what is economic impact
 * analysis? The hero answers it by *showing* one. A live US map sits
 * full-bleed behind the wordmark. Two spending sources emit ripples
 * — Direct, Indirect, Induced. As each ripple expands, the states
 * it crosses *luminate*: a gold wash blooms across them, then fades.
 * The brand promise — "we luminate economies" — is the demo.
 */
import { geoPath, geoCentroid } from 'd3-geo';
import { mesh, feature } from 'topojson-client';
// @ts-ignore — us-atlas ships JSON, not TS
import usAtlas from 'us-atlas/states-albers-10m.json' with { type: 'json' };
import '../styles/hero.css';

const VIEWBOX_W = 975;
const VIEWBOX_H = 610;

const path = geoPath();
// @ts-ignore
const statesFC: any = feature(usAtlas, usAtlas.objects.states);
// @ts-ignore
const stateBordersD = path(mesh(usAtlas, usAtlas.objects.states, (a: any, b: any) => a !== b));
// @ts-ignore
const nationOutlineD = path(mesh(usAtlas, usAtlas.objects.states, (a: any, b: any) => a === b));

/* Two spending sources anchor the ripple animation. Coordinates are
   in the projected albers-USA viewbox so they line up with the state
   mesh without us projecting anything ourselves. */
const sources = [
  { id: 's-east', cx: 760, cy: 250 },
  { id: 's-west', cx: 240, cy: 330 },
];

/* For each state, compute distance from its centroid to the nearest
   spending source and bucket it into one of three rings. The CSS
   animation steps states through gold-luminance in three waves —
   close states light first (Direct), mid next (Indirect), far last
   (Induced). The whole sequence is one editorial cycle. */
const RING_RADII = [180, 360, 560];
const stateFeatures = statesFC.features.map((f: any) => {
  const c = geoCentroid(f);
  const projected = path.centroid(f);
  const [cx, cy] = projected;
  const dist = Math.min(...sources.map(s => Math.hypot(s.cx - cx, s.cy - cy)));
  const ring = dist < RING_RADII[0] ? 0 : dist < RING_RADII[1] ? 1 : 2;
  const d = path(f);
  return { id: f.id, name: f.properties.name, d, ring, dist };
});
---
<section class="hero" id="top">
  <figure class="hero-map" aria-label="Animated map of the United States demonstrating how an economic impact study ripples outward from spending sources">
    <svg
      class="hero-map__svg"
      viewBox={`0 0 ${VIEWBOX_W} ${VIEWBOX_H}`}
      preserveAspectRatio="xMidYMid slice"
      role="img"
    >
      <defs>
        <radialGradient id="lumGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%"  stop-color="#F2D67A" stop-opacity=".95"/>
          <stop offset="55%" stop-color="#C49A3C" stop-opacity=".22"/>
          <stop offset="100%" stop-color="#C49A3C" stop-opacity="0"/>
        </radialGradient>
        <filter id="softGlow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="2.2" />
        </filter>
      </defs>

      <path class="hero-map__fill" d={nationOutlineD} />

      <g class="hero-map__states" aria-hidden="true">
        {stateFeatures.map((s: any, i: number) => (
          <path
            class={`hero-map__state hero-map__state--ring-${s.ring}`}
            d={s.d}
            style={`--lum-delay:${(s.dist / 4 + (i % 7) * 80).toFixed(0)}ms`}
            data-state={s.id}
          />
        ))}
      </g>

      <path class="hero-map__borders" d={stateBordersD} />
      <path class="hero-map__outline" d={nationOutlineD} />

      {sources.map((s, i) => (
        <g class={`hero-source hero-source--${s.id}`} style={`--src-delay:${i * 600}ms`}>
          <circle class="hero-glow"     cx={s.cx} cy={s.cy} r="120" fill="url(#lumGlow)" />
          <circle class="hero-ring hero-ring--r1" cx={s.cx} cy={s.cy} r="14" />
          <circle class="hero-ring hero-ring--r2" cx={s.cx} cy={s.cy} r="14" />
          <circle class="hero-ring hero-ring--r3" cx={s.cx} cy={s.cy} r="14" />
          <circle class="hero-spark"    cx={s.cx} cy={s.cy} r="5" filter="url(#softGlow)" />
          <circle class="hero-spark__core" cx={s.cx} cy={s.cy} r="2.2" />
        </g>
      ))}
    </svg>
  </figure>

  <div class="hero-overlay">
    <div class="hero-text">
      <h1 class="hero-wordmark" id="heroWordmark" aria-label="Lumecon — a portmanteau of luminate and economies">
        <span class="hw-cap">L</span><span class="hw-cap">U</span><span class="hw-cap">M</span><span class="hw-tail hw-tail--inate">inate</span><span class="hw-gap" aria-hidden="true"> </span><span class="hw-cap">E</span><span class="hw-cap">C</span><span class="hw-cap">O</span><span class="hw-cap">N</span><span class="hw-tail hw-tail--omies">omies</span>
      </h1>
      <p class="hero-tagline">We <em>luminate</em> economies<sup>&trade;</sup></p>
      <hr class="hero-rule" />
      <p class="hero-pitch">
        Watch a dollar move. A spending source emits a wave; supplier purchases follow; household wages follow them. That sum &mdash; the shaded swath &mdash; is an economic impact study.
      </p>
      <div class="hero-actions">
        <a href="#how" class="btn">Read the rings</a>
        <a href="#products" class="btn btn--ghost">See the platforms</a>
      </div>
    </div>
  </div>
</section>

<script>
  /* Portmanteau loop. After ~2s, ease LUMECON open into
     LUMinate eCONomies. Hold, ease shut, hold longer, repeat —
     editorial pacing, not a marquee. Pauses on hover. */
  (function () {
    const mark = document.getElementById('heroWordmark');
    if (!mark) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      mark.classList.add('is-open');
      return;
    }
    const OPEN_HOLD = 3800;
    const CLOSE_HOLD = 5400;
    const FIRST_DELAY = 2100;
    let timer: number | undefined;
    const open  = () => { mark.classList.add('is-open');    timer = window.setTimeout(close, OPEN_HOLD); };
    const close = () => { mark.classList.remove('is-open'); timer = window.setTimeout(open,  CLOSE_HOLD); };
    timer = window.setTimeout(open, FIRST_DELAY);
    mark.addEventListener('pointerenter', () => { if (timer) window.clearTimeout(timer); mark.classList.add('is-open'); });
    mark.addEventListener('pointerleave', () => { timer = window.setTimeout(close, OPEN_HOLD); });
  })();
</script>
