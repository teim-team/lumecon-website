---
/**
 * Hero — Lumecon brand + live impact study with Cedar in the margin.
 *
 * Hybrid layout: the map dominates, the result text sits in clean
 * editorial type beneath it, and Cedar is a quiet expander you can
 * open to ask a follow-up question. AIANNH boundaries from Census
 * TIGER/Line are clickable — picking one runs a tribal-economy
 * study with framing tailored to the tribal land, while clicking
 * any state runs a state-level study with randomized activity.
 */
import { geoPath } from 'd3-geo';
import { mesh, feature } from 'topojson-client';
// @ts-ignore — us-atlas ships JSON, not TS
import usAtlas from 'us-atlas/states-albers-10m.json' with { type: 'json' };
// @ts-ignore — generated data, no .d.ts
import { CENSUS_TRIBAL_LANDS } from '../data/tribalLands.generated.js';
import '../styles/hero.css';

const VBX = 70, VBY = 60, VBW = 850, VBH = 510;
const path = geoPath();
// @ts-ignore
const statesFC: any = feature(usAtlas, usAtlas.objects.states);
// @ts-ignore
const stateBordersD = path(mesh(usAtlas, usAtlas.objects.states, (a: any, b: any) => a !== b));
// @ts-ignore
const nationOutlineD = path(mesh(usAtlas, usAtlas.objects.states, (a: any, b: any) => a === b));

// County border mesh — a single path of every county boundary.
// Loaded from us-atlas/counties-albers-10m.json (separate import keeps
// the heavier file out of the bundle when only states are visible).
// @ts-ignore
import countiesAtlas from 'us-atlas/counties-albers-10m.json' with { type: 'json' };
// @ts-ignore
const countyBordersD = path(mesh(countiesAtlas, countiesAtlas.objects.counties, (a: any, b: any) => a !== b));

const stateData = statesFC.features.map((f: any) => {
  const [cx, cy] = path.centroid(f);
  return { id: f.id, name: f.properties.name, d: path(f), cx: +cx.toFixed(1), cy: +cy.toFixed(1) };
});

const STATE_CODES: Record<string, string> = {
  '01':'AL','02':'AK','04':'AZ','05':'AR','06':'CA','08':'CO','09':'CT','10':'DE','11':'DC',
  '12':'FL','13':'GA','15':'HI','16':'ID','17':'IL','18':'IN','19':'IA','20':'KS','21':'KY',
  '22':'LA','23':'ME','24':'MD','25':'MA','26':'MI','27':'MN','28':'MS','29':'MO','30':'MT',
  '31':'NE','32':'NV','33':'NH','34':'NJ','35':'NM','36':'NY','37':'NC','38':'ND','39':'OH',
  '40':'OK','41':'OR','42':'PA','44':'RI','45':'SC','46':'SD','47':'TN','48':'TX','49':'UT',
  '50':'VT','51':'VA','53':'WA','54':'WV','55':'WI','56':'WY',
};
const CODE_TO_ID = Object.fromEntries(Object.entries(STATE_CODES).map(([id, code]) => [code, id]));

/* AIANNH polygons — clickable now (used to be decorative). Filter to
   ones with a usable path + centroid. Each one gets the FIPS state-id
   of its containing state so the ring shading targets the right state. */
const aiannh = (CENSUS_TRIBAL_LANDS as any[])
  .filter(l => l.pathD && l.x != null && l.y != null && l.fips)
  .map((l: any) => ({
    id: l.id,
    name: l.name,
    shortName: l.shortName || l.name,
    fips: l.fips,
    category: l.category,
    pathD: l.pathD,
    x: l.x,
    y: l.y,
  }));

const statesJson = JSON.stringify(
  stateData.reduce((acc: any, s: any) => { acc[s.id] = { name: s.name, cx: s.cx, cy: s.cy, code: STATE_CODES[s.id] || '' }; return acc; }, {})
);
const codeMapJson = JSON.stringify(CODE_TO_ID);

/* Tribal lookup — a curated subset of AIANNH features keyed by a
   short slug, so client-side reservation scenes can resolve to a
   real centroid pulled from Census TIGER/Line. The candidates list
   per slug uses includes() matching so name variations work. */
const TRIBAL_SCENE_KEYS: Record<string, string[]> = {
  navajo:           ['Navajo Nation'],
  mille_lacs:       ['Mille Lacs'],
  umatilla:         ['Umatilla'],
  cherokee_ok:      ['Cherokee Nation', 'Cherokee'],
  yakama:           ['Yakama'],
  standing_rock:    ['Standing Rock'],
  pine_ridge:       ['Pine Ridge', 'Oglala'],
  eastern_cherokee: ['Eastern Band', 'Cherokee Indian Reservation'],
  hopi:             ['Hopi'],
  tohono:           ["Tohono O'odham", 'Tohono'],
  fort_peck:        ['Fort Peck'],
  oneida_ny:        ['Oneida'],
};
const tribalLookup: Record<string, { name: string; cx: number; cy: number; fips: string }> = {};
for (const [slug, candidates] of Object.entries(TRIBAL_SCENE_KEYS)) {
  for (const c of candidates) {
    const found = aiannh.find((t: any) => t.name && t.name.toLowerCase().includes(c.toLowerCase()));
    if (found) {
      tribalLookup[slug] = { name: found.shortName || found.name, cx: found.x, cy: found.y, fips: found.fips };
      break;
    }
  }
}
const tribalLookupJson = JSON.stringify(tribalLookup);
---
<section class="hero" id="top">
  <!-- Brand statement: large wordmark, one position, one CTA. -->
  <div class="hero-brand">
    <a href="/" class="hero-mark" aria-label="Lumecon Inc.">
      <img src="/brand/lumecon-logo-horizontal-transparent.png" alt="Lumecon" width="560" height="98" />
    </a>
    <h1 class="hero-statement">
      Your work changes the economy around it. We make that change measurable.
    </h1>
    <p class="hero-sub">
      Economic impact analysis software for governments and mission-driven organizations. We replace the consultant, the overpriced legacy software, and the data silos that block impact studies.
    </p>
    <ul class="hero-proof" aria-label="Proof points">
      <li>Built at Cornell</li>
      <li>Patent-pending tribal model</li>
      <li>Alternative to IMPLAN, RIMS II, REMI</li>
    </ul>
    <div class="hero-cta">
      <a href="#workspace" class="btn">See it run</a>
      <a href="#contact" class="btn btn--ghost">Request a demo</a>
    </div>
  </div>

  <div class="workspace" id="workspace">
    <header class="workspace__bar">
      <span class="workspace__title">
        <img class="workspace__mark" src="/brand/lumecon-logo-mark-transparent.png" alt="" width="22" height="22" aria-hidden="true" />
        <span class="workspace__title-text">Live impact study</span>
        <span class="workspace__divider" aria-hidden="true"></span>
        <span class="workspace__region" id="workspaceRegion" aria-live="polite">Hover any state</span>
      </span>
      <span class="workspace__sub">
        <span class="workspace__study-id" id="workspaceStudyId" aria-label="Study identifier">STUDY 001</span>
        <span class="workspace__sub-divider" aria-hidden="true"></span>
        <button type="button" class="workspace__again" id="workspaceAgain" aria-label="Run a new study">New study</button>
        <span class="workspace__sub-divider" aria-hidden="true"></span>
        <span class="workspace__dot" id="workspaceStatus" aria-hidden="true"></span>
        <span class="workspace__sub-text" id="workspaceStatusLabel">Idle</span>
      </span>
    </header>

    <div class="workspace__body">

  <!-- Layer filters — control which geography is visible/clickable -->
  <div class="workspace-filters" role="tablist" aria-label="Map layer">
    <button type="button" class="wfilter is-active" data-layer="states"  role="tab" aria-selected="true">States</button>
    <button type="button" class="wfilter"           data-layer="counties" role="tab" aria-selected="false">Counties</button>
    <button type="button" class="wfilter"           data-layer="tribal"   role="tab" aria-selected="false">Tribal lands</button>
  </div>

  <!-- Map: dominant, full-width. AIANNH polygons are clickable. -->
  <figure class="hero-stage" id="heroStage" aria-label="Interactive map. Hover any state or tribal land to inspect; click to run a study there.">
    <svg class="hero-map" id="heroMap" viewBox={`${VBX} ${VBY} ${VBW} ${VBH}`} preserveAspectRatio="xMidYMid meet" role="img">
      <defs>
        <radialGradient id="hGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%"  stop-color="#F2D67A" stop-opacity=".95"/>
          <stop offset="55%" stop-color="#C49A3C" stop-opacity=".18"/>
          <stop offset="100%" stop-color="#C49A3C" stop-opacity="0"/>
        </radialGradient>
        <pattern id="hGrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0E1530" stroke-width=".4" stroke-opacity=".07" />
        </pattern>
      </defs>

      <!-- Cartographic graticule under everything -->
      <rect class="hero-map__grid" x={VBX} y={VBY} width={VBW} height={VBH} fill="url(#hGrid)" />

      <path class="hero-map__fill" d={nationOutlineD} />

      <g class="hero-map__states">
        {stateData.map((s: any) => (
          <path
            class="hero-state"
            d={s.d}
            data-id={s.id}
            data-cx={s.cx}
            data-cy={s.cy}
            tabindex="0"
            role="button"
            aria-label={s.name}
          ></path>
        ))}
      </g>

      <!-- AIANNH overlay: interactive. Clicking one runs a tribal-economy
           study; hovering shows the tribal-land name in the tooltip. -->
      <g class="hero-map__aiannh">
        {aiannh.map((land: any) => (
          <path
            class={`hero-aiannh hero-aiannh--${land.category}`}
            d={land.pathD}
            data-name={land.name}
            data-short={land.shortName}
            data-fips={land.fips}
            data-cx={land.x}
            data-cy={land.y}
            data-category={land.category}
            tabindex="0"
            role="button"
            aria-label={`Tribal land: ${land.name}`}
          ></path>
        ))}
      </g>

      <path class="hero-map__county-borders" d={countyBordersD} />
      <path class="hero-map__borders" d={stateBordersD} />
      <path class="hero-map__outline" d={nationOutlineD} />

      <g class="hero-source" id="heroSource">
        <circle class="hero-glow"  cx="0" cy="0" r="120" fill="url(#hGlow)" />
        <circle class="hero-ring"  data-ring="1" cx="0" cy="0" r="14" />
        <circle class="hero-ring"  data-ring="2" cx="0" cy="0" r="14" />
        <circle class="hero-ring"  data-ring="3" cx="0" cy="0" r="14" />
        <circle class="hero-spark"      cx="0" cy="0" r="6" />
        <circle class="hero-spark__core" cx="0" cy="0" r="2.4" />
      </g>

      <!-- Detail layers: synthesized supplier + household point clouds
           rendered around the source when the map is zoomed in.
           Populated by JS; cleared between runs. The flow lines fade
           in as thin paths from source to a subset of nearby points. -->
      <g class="hero-flow-layer" id="heroFlowLayer" aria-hidden="true"></g>
      <g class="hero-supplier-layer" id="heroSupplierLayer" aria-hidden="true"></g>
      <g class="hero-household-layer" id="heroHouseholdLayer" aria-hidden="true"></g>

      <!-- Floating value labels populated by JS over each lit state -->
      <g class="hero-value-layer" id="heroValueLayer" aria-hidden="true"></g>

      <!-- Source callout: name pinned next to the source dot -->
      <g class="hero-source-callout" id="heroSourceCallout" aria-hidden="true">
        <line class="hero-callout__leader" x1="0" y1="0" x2="0" y2="0" />
        <g class="hero-callout__plate">
          <rect class="hero-callout__bg" x="0" y="0" rx="3" ry="3" width="0" height="22" />
          <text class="hero-callout__txt" x="0" y="0" dominant-baseline="middle"></text>
        </g>
      </g>
    </svg>

    <button type="button" class="hero-zoomout" id="heroZoomOut" aria-label="Back to overview">← Overview</button>

    <div class="hero-tooltip" id="heroTooltip" role="tooltip" aria-hidden="true">
      <span class="hero-tooltip__name" id="ttName">&mdash;</span>
      <span class="hero-tooltip__hint" id="ttHint">click to run a study here</span>
    </div>
  </figure>

  <!-- Activity chip — names what's running -->
  <p class="workspace-activity" id="workspaceActivity" aria-live="polite">&nbsp;</p>

  <!-- Live figures — the only text inside the workspace -->
  <dl class="hero-figs" aria-label="Result of the running impact study">
    <div class="hero-fig" data-k="direct"><dt>Direct</dt>   <dd id="figDirect">&mdash;</dd></div>
    <div class="hero-fig" data-k="indirect"><dt>Indirect</dt> <dd id="figIndirect">&mdash;</dd></div>
    <div class="hero-fig" data-k="induced"><dt>Induced</dt>  <dd id="figInduced">&mdash;</dd></div>
    <div class="hero-fig hero-fig--total hero-fig--derived" id="figTotalCell" data-k="total"><dt>Total impact</dt> <dd id="figTotal">&mdash;</dd></div>
    <div class="hero-fig hero-fig--derived" id="figJobsCell" data-k="jobs"><dt>Jobs</dt> <dd id="figJobs">&mdash;</dd></div>
  </dl>

    </div>

    <footer class="workspace__foot">
      <span class="workspace-legend">
        <span class="workspace-legend__key">
          <span class="workspace-legend__sw workspace-legend__sw--source"></span>Activity
          <span class="workspace-legend__sw workspace-legend__sw--supplier"></span>Suppliers
          <span class="workspace-legend__sw workspace-legend__sw--household"></span>Households
        </span>
        <span class="workspace-legend__note">Detail dots are an illustrative distribution. The table to the right is the full breakdown.</span>
      </span>
      <span class="workspace-attr">Geography: Census TIGER/Line. Multipliers illustrative.</span>
    </footer>
  </div>


  <script type="application/json" id="heroStates"   set:html={statesJson}></script>
  <script type="application/json" id="heroCodeMap"  set:html={codeMapJson}></script>
  <script type="application/json" id="heroTribal"   set:html={tribalLookupJson}></script>
</section>

<script>
  type StateInfo = { name: string; cx: number; cy: number; code: string };
  type TribalLand = { name: string; cx: number; cy: number; fips: string };
  const states: Record<string, StateInfo> = JSON.parse((document.getElementById('heroStates') as HTMLScriptElement).textContent || '{}');
  const codeMap: Record<string, string> = JSON.parse((document.getElementById('heroCodeMap') as HTMLScriptElement).textContent || '{}');
  const tribalLookup: Record<string, TribalLand> = JSON.parse((document.getElementById('heroTribal') as HTMLScriptElement).textContent || '{}');

  /* Activity multipliers. The click-on-state fallback picks from
     ACTIVITIES at random; the named SCENES below reference individual
     activity records directly via ACT for richer-feeling variety. */
  const ACTIVITIES = [
    { id: 'build',   label: 'capital construction', indirect: 0.62, induced: 0.38, jobsPerM: 8.9  },
    { id: 'payroll', label: 'operations payroll',   indirect: 0.48, induced: 0.71, jobsPerM: 11.4 },
    { id: 'grant',   label: 'grant pass-through',   indirect: 0.35, induced: 0.55, jobsPerM: 6.2  },
    { id: 'tourism', label: 'visitor spending',     indirect: 0.51, induced: 0.63, jobsPerM: 13.1 },
    { id: 'energy',  label: 'energy project',       indirect: 0.58, induced: 0.42, jobsPerM: 7.6  },
  ] as const;
  const AMOUNTS = [
    { v: 1_000_000,  label: '$1M'  },
    { v: 5_000_000,  label: '$5M'  },
    { v: 12_000_000, label: '$12M' },
    { v: 20_000_000, label: '$20M' },
    { v: 50_000_000, label: '$50M' },
  ] as const;
  /* Extended activity catalog. Each profile carries its own indirect /
     induced / jobsPerM coefficients so two construction projects don't
     produce identical totals. Used only by the named scenes. */
  const ACT = {
    build:       { id: 'build',       label: 'capital construction',      indirect: 0.62, induced: 0.38, jobsPerM: 8.9  },
    ops:         { id: 'payroll',     label: 'operations payroll',        indirect: 0.48, induced: 0.71, jobsPerM: 11.4 },
    grant:       { id: 'grant',       label: 'grant pass-through',        indirect: 0.35, induced: 0.55, jobsPerM: 6.2  },
    tourism:     { id: 'tourism',     label: 'visitor spending',          indirect: 0.51, induced: 0.63, jobsPerM: 13.1 },
    energy:      { id: 'energy',      label: 'energy project',            indirect: 0.58, induced: 0.42, jobsPerM: 7.6  },
    broadband:   { id: 'broadband',   label: 'broadband buildout',        indirect: 0.54, induced: 0.46, jobsPerM: 8.2  },
    workforce:   { id: 'workforce',   label: 'workforce training',        indirect: 0.30, induced: 0.62, jobsPerM: 10.8 },
    housing:     { id: 'housing',     label: 'housing development',       indirect: 0.61, induced: 0.43, jobsPerM: 9.4  },
    health:      { id: 'health',      label: 'health operations',         indirect: 0.46, induced: 0.73, jobsPerM: 12.6 },
    transit:     { id: 'transit',     label: 'transit capital project',   indirect: 0.59, induced: 0.41, jobsPerM: 8.1  },
    culture:     { id: 'culture',     label: 'cultural facility',         indirect: 0.43, induced: 0.55, jobsPerM: 9.8  },
    agriculture: { id: 'agriculture', label: 'agricultural development',  indirect: 0.52, induced: 0.51, jobsPerM: 10.5 },
    ports:       { id: 'ports',       label: 'port modernization',        indirect: 0.57, induced: 0.45, jobsPerM: 8.4  },
    water:       { id: 'water',       label: 'water infrastructure',      indirect: 0.60, induced: 0.40, jobsPerM: 7.8  },
    coastal:     { id: 'coastal',     label: 'coastal restoration',       indirect: 0.55, induced: 0.42, jobsPerM: 9.1  },
    research:    { id: 'research',    label: 'research operations',       indirect: 0.42, induced: 0.69, jobsPerM: 11.9 },
  } as const;
  type Amount = { v: number; label: string };
  type Activity = typeof ACT[keyof typeof ACT];

  /* Named example impact studies grouped by level. The auto-cycle
     plays through all of them shuffled; the "New study" button rotates
     through the levels deliberately (state → county → reservation) so
     a clicker sees the system handles every scope. */
  type Scene = {
    level: 'state' | 'county' | 'reservation';
    state?: string;      // FIPS, for state/county scenes
    tribalKey?: string;  // lookup key, for reservation scenes
    chip: string;
    sentence: string;
    amount: Amount;
    activity: Activity;
  };
  const STATE_SCENES: Scene[] = [
    { level: 'state', state: '48', amount: { v: 47_600_000, label: '$47.6M' }, activity: ACT.build,
      chip: 'STATE · Highway expansion · Texas',
      sentence: 'Texas advances a $47.6M state highway expansion across three corridors.' },
    { level: 'state', state: '06', amount: { v: 215_400_000, label: '$215.4M' }, activity: ACT.energy,
      chip: 'STATE · Climate resilience bond · California',
      sentence: 'California issues a $215.4M climate resilience bond, distributing capital to county-level mitigation projects.' },
    { level: 'state', state: '36', amount: { v: 87_300_000, label: '$87.3M' }, activity: ACT.health,
      chip: 'STATE · Mental health infrastructure · New York',
      sentence: 'New York funds an $87.3M expansion of state-run mental health facilities.' },
    { level: 'state', state: '12', amount: { v: 34_100_000, label: '$34.1M' }, activity: ACT.ops,
      chip: 'STATE · Hurricane preparedness · Florida',
      sentence: 'Florida appropriates $34.1M to its state hurricane preparedness program.' },
    { level: 'state', state: '17', amount: { v: 23_400_000, label: '$23.4M' }, activity: ACT.grant,
      chip: 'STATE · Pension stabilization · Illinois',
      sentence: 'Illinois directs $23.4M to a state pension stabilization plan, with downstream spending flowing through retiree households.' },
    { level: 'state', state: '39', amount: { v: 11_500_000, label: '$11.5M' }, activity: ACT.health,
      chip: 'STATE · Opioid response program · Ohio',
      sentence: 'Ohio launches an $11.5M state opioid response program.' },
    { level: 'state', state: '26', amount: { v: 63_700_000, label: '$63.7M' }, activity: ACT.water,
      chip: 'STATE · Water infrastructure · Michigan',
      sentence: 'Michigan funds $63.7M of state water infrastructure upgrades.' },
    { level: 'state', state: '42', amount: { v: 7_400_000, label: '$7.4M' }, activity: ACT.workforce,
      chip: 'STATE · Apprenticeship program · Pennsylvania',
      sentence: 'Pennsylvania expands a $7.4M state higher-ed apprenticeship program.' },
    { level: 'state', state: '37', amount: { v: 19_100_000, label: '$19.1M' }, activity: ACT.broadband,
      chip: 'STATE · Rural broadband · North Carolina',
      sentence: 'North Carolina rolls out $19.1M of state rural broadband investment.' },
    { level: 'state', state: '41', amount: { v: 4_200_000, label: '$4.2M' }, activity: ACT.build,
      chip: 'STATE · Seismic retrofit · Oregon',
      sentence: 'Oregon funds a $4.2M state seismic retrofit program for public buildings.' },
    { level: 'state', state: '08', amount: { v: 26_000_000, label: '$26M' }, activity: ACT.build,
      chip: 'STATE · Wildfire mitigation · Colorado',
      sentence: 'Colorado commits $26M to a state wildfire mitigation program.' },
    { level: 'state', state: '53', amount: { v: 14_600_000, label: '$14.6M' }, activity: ACT.ports,
      chip: 'STATE · Ferry capital plan · Washington',
      sentence: 'Washington advances a $14.6M state ferry capital plan.' },
  ];
  const COUNTY_SCENES: Scene[] = [
    { level: 'county', state: '53', amount: { v: 5_000_000, label: '$5M' }, activity: ACT.health,
      chip: 'COUNTY · Community health clinic · Pierce County, WA',
      sentence: 'A new community health clinic opens in Pierce County, WA, supported by $5M of operating funds.' },
    { level: 'county', state: '48', amount: { v: 20_300_000, label: '$20.3M' }, activity: ACT.ops,
      chip: 'COUNTY · University workforce expansion · Travis County, TX',
      sentence: 'A state university expands its workforce in Travis County, TX, with $20.3M of new operating payroll.' },
    { level: 'county', state: '39', amount: { v: 4_800_000, label: '$4.8M' }, activity: ACT.grant,
      chip: 'COUNTY · Federal grant pass-through · Cuyahoga County, OH',
      sentence: 'A $4.8M federal grant passes through to a regional CDFI serving Cuyahoga County, OH.' },
    { level: 'county', state: '53', amount: { v: 52_400_000, label: '$52.4M' }, activity: ACT.transit,
      chip: 'COUNTY · Light rail extension · King County, WA',
      sentence: 'A regional transit authority extends a light rail line through King County, WA, a $52.4M capital project.' },
    { level: 'county', state: '47', amount: { v: 3_500_000, label: '$3.5M' }, activity: ACT.tourism,
      chip: 'COUNTY · Music tourism program · Davidson County, TN',
      sentence: 'Davidson County, TN expands a music tourism program, generating $3.5M in visitor spending across local businesses.' },
    { level: 'county', state: '02', amount: { v: 11_800_000, label: '$11.8M' }, activity: ACT.build,
      chip: 'COUNTY · Fish processing facility · Aleutians East, AK',
      sentence: 'A new fish processing facility opens in the Aleutians East Borough, Alaska, an $11.8M capital build.' },
    { level: 'county', state: '42', amount: { v: 1_200_000, label: '$1.2M' }, activity: ACT.workforce,
      chip: 'COUNTY · Workforce training · Allegheny County, PA',
      sentence: 'Allegheny County, PA launches a $1.2M workforce training program targeting advanced manufacturing.' },
    { level: 'county', state: '31', amount: { v: 18_700_000, label: '$18.7M' }, activity: ACT.energy,
      chip: 'COUNTY · Wind farm · Cherry County, NE',
      sentence: 'An $18.7M wind farm comes online in Cherry County, NE, with construction and operations spread across the county.' },
    { level: 'county', state: '04', amount: { v: 4_500_000, label: '$4.5M' }, activity: ACT.culture,
      chip: 'COUNTY · Library system expansion · Maricopa County, AZ',
      sentence: 'Maricopa County, AZ funds a $4.5M expansion of its public library system.' },
    { level: 'county', state: '36', amount: { v: 24_000_000, label: '$24M' }, activity: ACT.housing,
      chip: 'COUNTY · Affordable housing · Bronx County, NY',
      sentence: 'A $24M affordable housing development breaks ground in the Bronx, NY.' },
    { level: 'county', state: '22', amount: { v: 51_000_000, label: '$51M' }, activity: ACT.tourism,
      chip: 'COUNTY · Convention center · Orleans Parish, LA',
      sentence: 'Orleans Parish renovates its convention center, a $51M capital project tied to the regional tourism economy.' },
    { level: 'county', state: '37', amount: { v: 19_300_000, label: '$19.3M' }, activity: ACT.build,
