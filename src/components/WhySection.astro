---
/**
 * Why this matters — a single stat strip, three statements.
 * Replaces the longer-form Why with three short positions.
 */
import '../styles/why.css';
---
<section class="why" id="how">
  <div class="why-inner">
    <div class="why-stat">
      <p class="why-stat__k">Replaces the consultant.</p>
      <p class="why-stat__v">Run impact studies in-house, on your own data, when the question gets asked &mdash; not three weeks later.</p>
    </div>
    <div class="why-stat">
      <p class="why-stat__k">Real-time data.</p>
      <p class="why-stat__v">Administrative and high-frequency sources, not national averages from a 2017 input-output table.</p>
    </div>
    <div class="why-stat">
      <p class="why-stat__k">Results you can trust.</p>
      <p class="why-stat__v">Every assumption, source, and method is documented so reviewers can verify the work.</p>
    </div>
  </div>
</section>
