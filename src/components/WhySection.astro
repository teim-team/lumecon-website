---
/**
 * Why — one statement, one supporting line, one CTA.
 * Pfizer/Merck pattern: no prose, no card grids.
 */
import '../styles/why.css';
---
<section class="why" id="how">
  <div class="why-inner">
    <p class="why-stamp">Why an impact study</p>
    <h2 class="why-lede">
      Numbers that hold up in front of councils, boards, and funders.
    </h2>
    <p class="why-body">
      An economic impact study is the work of finding one number, and the assumption ledger behind it, before the question gets asked.
    </p>
    <a href="#products" class="btn btn--ghost">See the platforms</a>
  </div>
</section>
