---
/**
 * Hero workflow — one continuous flowing SVG showing what a Lumecon
 * study looks like, end to end:
 *
 *   harmonize your economic data  ──▶  Cedar runs the economic
 *   impact analysis  ──▶  See your economic impact
 *
 * Three stations along a single horizontal flow rail. Each station
 * has its own self-contained transformation animation that loops on
 * a 6s cycle, synchronized to traveling ticks along the rail and a
 * label glow beneath each station.
 *
 * Station 1: three differently-coloured input spreadsheets shrink
 * and slide into a single harmonized output with rows of mixed
 * colours.
 * Station 2: monitor with the cedar tree on the LEFT and a small
 * computation panel on the RIGHT — sliding bars and ticking text
 * suggest active processing.
 * Station 3: three clean phases — first the casino opens and lights
 * up, then the parking lot stripes appear and three cars pull in,
 * then the gas station builds with a car at the pump. Dollar signs
 * trickle up as the parcel densifies.
 *
 * All line-art, all CSS animations, respects prefers-reduced-motion.
 */
---
<figure class="hero-flow" aria-label="How a Lumecon study runs">
  <svg
    class="hero-flow__svg"
    viewBox="0 0 720 130"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-hidden="true"
  >
    <line class="hf-rail" x1="60" y1="65" x2="660" y2="65"
          stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"
          stroke-dasharray="3 6" />

    <circle class="hf-tick hf-tick--a" cx="60" cy="65" r="3" fill="var(--accent)"/>
    <circle class="hf-tick hf-tick--b" cx="60" cy="65" r="3" fill="var(--accent)"/>
    <circle class="hf-tick hf-tick--c" cx="60" cy="65" r="3" fill="var(--accent)"/>

    <!-- ===== Station 1: three sheets merge + transform into one ===== -->
    <g class="hf-station hf-station--src" transform="translate(60 65)">
      <circle class="hf-station__halo" r="42" fill="var(--accent)" opacity="0"/>

      <!-- Three input sheets, each a different size + orientation
           + tilt so they read as messy / non-uniform data. The
           messier the inputs look, the clearer the merge moment
           when they collapse into one harmonized sheet. -->
      <g class="hf-in hf-in--a" transform="rotate(-6 -22 -20)">
        <rect x="-34" y="-26" width="20" height="11" rx="1.5" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <line x1="-31" y1="-22.5" x2="-17" y2="-22.5" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-31" y1="-20"   x2="-21" y2="-20"   stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-31" y1="-17.5" x2="-19" y2="-17.5" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round"/>
      </g>
      <g class="hf-in hf-in--b" transform="rotate(4 -24 0)">
        <rect x="-34" y="-9" width="14" height="14" rx="1.5" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <line x1="-31" y1="-5" x2="-22" y2="-5" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-31" y1="-2" x2="-25" y2="-2" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-31" y1="1"  x2="-23" y2="1"  stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"/>
      </g>
      <g class="hf-in hf-in--c" transform="rotate(-3 -25 18)">
        <rect x="-32" y="9" width="12" height="18" rx="1.5" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <line x1="-29" y1="12" x2="-22" y2="12" stroke="var(--cedar)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-29" y1="15" x2="-24" y2="15" stroke="var(--cedar)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-29" y1="18" x2="-22" y2="18" stroke="var(--cedar)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-29" y1="21" x2="-26" y2="21" stroke="var(--cedar)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-29" y1="24" x2="-22" y2="24" stroke="var(--cedar)" stroke-width="1.5" stroke-linecap="round"/>
      </g>

      <g class="hf-out">
        <rect x="-4" y="-26" width="36" height="52" rx="2" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5" stroke-linejoin="miter"/>
        <rect x="-4" y="-26" width="36" height="6" fill="var(--accent)" opacity=".22" stroke="none"/>
        <line x1="8"  y1="-20" x2="8"  y2="26" stroke="var(--navy)" stroke-width=".7" stroke-opacity=".35"/>
        <line x1="20" y1="-20" x2="20" y2="26" stroke="var(--navy)" stroke-width=".7" stroke-opacity=".35"/>
        <rect class="hf-out__row hf-out__row--1" x="-1" y="-17" width="34" height="2.5" rx=".4" fill="var(--gold)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--2" x="-1" y="-12" width="34" height="2.5" rx=".4" fill="var(--accent)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--3" x="-1" y="-7"  width="34" height="2.5" rx=".4" fill="var(--cedar)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--4" x="-1" y="-2"  width="34" height="2.5" rx=".4" fill="var(--gold)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--5" x="-1" y="3"   width="34" height="2.5" rx=".4" fill="var(--accent)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--6" x="-1" y="8"   width="34" height="2.5" rx=".4" fill="var(--cedar)" opacity="0"/>
      </g>
    </g>

    <!-- ===== Station 2: Cedar processes inside a monitor ===== -->
    <g class="hf-station hf-station--cedar" transform="translate(360 65)">
      <circle class="hf-station__halo" r="48" fill="var(--cedar)" opacity="0"/>

      <g class="hf-cedar" stroke="var(--navy)" stroke-width="1.4" stroke-linejoin="miter" fill="none">
        <rect x="-38" y="-30" width="76" height="46" rx="2" fill="var(--white)"/>
        <line x1="0" y1="16" x2="0" y2="22" stroke-width="2" stroke-linecap="butt"/>
        <line x1="-12" y1="22" x2="12" y2="22" stroke-width="2" stroke-linecap="round"/>
        <line x1="-38" y1="-23" x2="38" y2="-23" stroke-width="1"/>
        <circle cx="-33" cy="-26.5" r=".9" fill="var(--navy)" stroke="none"/>
        <circle cx="-29" cy="-26.5" r=".9" fill="var(--navy)" stroke="none"/>
        <circle cx="-25" cy="-26.5" r=".9" fill="var(--navy)" stroke="none"/>
      </g>

      <!-- Cedar tree on the LEFT side of the monitor. -->
      <g class="hf-cedar__tree" fill="var(--cedar)" stroke="var(--cedar)" stroke-width="1.4" stroke-linejoin="miter">
        <path d="M-22 -16 L-26 -10 L-24 -10 L-27 -5 L-25 -5 L-29 0 L-15 0 L-19 -5 L-17 -5 L-20 -10 L-18 -10 Z"/>
        <rect x="-23" y="0" width="2" height="3" stroke="none"/>
      </g>

      <!-- Computation panel on the RIGHT. First a loading spinner
           (Cedar starting up), then the bar chart fills in, then the
           output ticks below. The three phases run in sequence. -->
      <g class="hf-compute" stroke="none">
        <!-- Computer-style loading screen: a "LOADING" label above an
             indeterminate progress bar with a fill block that slides
             back and forth, plus animated dots. Reads as software
             loading at icon scale where a spinner gets too dim. -->
        <g class="hf-loading">
          <text x="13" y="-6" font-family="JetBrains Mono, ui-monospace, monospace" font-weight="600" font-size="3.4" letter-spacing=".12em" fill="var(--ink-2)" text-anchor="middle">LOADING</text>
          <g class="hf-load-dots" font-family="JetBrains Mono, ui-monospace, monospace" font-weight="700" font-size="3.4" fill="var(--cedar)">
            <text class="hf-load-dot hf-load-dot--a" x="22" y="-6">.</text>
            <text class="hf-load-dot hf-load-dot--b" x="23.5" y="-6">.</text>
            <text class="hf-load-dot hf-load-dot--c" x="25" y="-6">.</text>
          </g>
          <rect x="1" y="-2" width="24" height="3.5" rx="1.2" fill="var(--paper)" stroke="var(--rule)" stroke-width=".6"/>
          <rect class="hf-load-fill" x="1" y="-2" width="10" height="3.5" rx="1.2" fill="var(--cedar)"/>
          <g class="hf-load-pct" font-family="JetBrains Mono, ui-monospace, monospace" font-weight="600" font-size="3" fill="var(--ink-3)" text-anchor="middle">
            <text x="13" y="9">42%</text>
          </g>
        </g>
        <!-- Bar chart: appears after the hourglass clears. -->
        <line class="hf-baseline" x1="-8" y1="2" x2="32" y2="2" stroke="var(--navy)" stroke-width=".8" stroke-opacity=".4"/>
        <rect class="hf-bar hf-bar--a" x="-6"  y="-2" width="5" height="4"  rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--b" x="2"   y="-6" width="5" height="8"  rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--c" x="10"  y="-4" width="5" height="6"  rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--d" x="18"  y="-9" width="5" height="11" rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--e" x="26"  y="-7" width="5" height="9"  rx=".4" fill="var(--accent)"/>
        <g stroke="var(--cedar)" stroke-width="1.2" stroke-linecap="round">
          <line class="hf-line hf-line--a" x1="-6" y1="7"  x2="-6" y2="7"/>
          <line class="hf-line hf-line--b" x1="-6" y1="11" x2="-6" y2="11"/>
          <line class="hf-line hf-line--c" x1="-6" y1="15" x2="-6" y2="15"/>
        </g>
      </g>
    </g>

    <!-- ===== Station 3: blank land → casino + neighbourhood + gas
                          station, with dollars trickling up faster
                          as the density grows. ===== -->
    <g class="hf-station hf-station--map" transform="translate(660 65)">
      <circle class="hf-station__halo" r="48" fill="var(--gold)" opacity="0"/>

      <!-- Region outline (the empty land). Always visible; the
           cycle starts with this and nothing else, so the eye
           reads a blank parcel before anything is built. -->
      <path class="hf-imp__region"
            d="M-36 -26 L-22 -30 L-8 -28 L8 -30 L24 -26 L36 -18 L40 -4 L38 10 L30 22 L14 28 L-2 26 L-18 28 L-32 22 L-40 6 L-38 -8 Z"
            fill="var(--paper)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter" stroke-opacity=".55"/>

      <!-- Horizontal road across the parcel: separates the casino /
           buildings on top from the gas station / tree / parking
           below. Center stripe + asphalt strip read as a road. -->
      <g class="hf-road">
        <rect x="-38" y="10" width="78" height="4" fill="var(--paper)" stroke="var(--navy)" stroke-width=".5" stroke-opacity=".25"/>
        <line x1="-36" y1="12" x2="38" y2="12" stroke="var(--ink-3)" stroke-width=".4" stroke-dasharray="2 2" stroke-opacity=".55"/>
      </g>

      <!-- ===== Casino: the source of activity. Builds in chunks:
                base slab, body, marquee + lettering, windows lighting
                up, and a tealed grand entrance. ===== -->
      <g class="hf-imp__src">
        <!-- Foundation slab — sits the casino on the parcel so it
             doesn't look like it floats above the road. -->
        <rect class="hf-casino__base" x="-33" y="4.5" width="26" height="2" rx=".3"
              fill="var(--ink-5, #c6c8d0)" stroke="var(--navy)" stroke-width=".5" stroke-opacity=".55"/>

        <!-- Main body. -->
        <rect class="hf-casino__body" x="-32" y="-17.5" width="24" height="22" rx=".5"
              fill="var(--white)" stroke="var(--navy)" stroke-width="1.4" stroke-linejoin="miter"/>

        <!-- Marquee band with the lit "CASINO" wordmark. -->
        <rect class="hf-casino__marquee" x="-32" y="-22" width="24" height="4.8"
              fill="var(--gold)" stroke="var(--navy)" stroke-width="1.3"/>
        <text class="hf-casino__name" x="-20" y="-18.4"
              font-family="Inter, system-ui, sans-serif" font-weight="800" font-size="3.9" letter-spacing=".14em"
              fill="var(--navy)" text-anchor="middle">CASINO</text>

        <!-- Window grid: 2 rows of 4. Each window lights up in sequence
             so the building reads as opening floor by floor. -->
        <g class="hf-casino__windows">
          <rect class="hf-casino__win hf-casino__win--1" x="-29" y="-14" width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--2" x="-24" y="-14" width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--3" x="-19" y="-14" width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--4" x="-14" y="-14" width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--5" x="-29" y="-9"  width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--6" x="-24" y="-9"  width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--7" x="-19" y="-9"  width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--8" x="-14" y="-9"  width="2.6" height="2.6" rx=".15" fill="var(--ink-3)"/>
        </g>

        <!-- Arched grand entrance with a curved teal awning + dark
             door. Slim gold step at the base for the polished look. -->
        <g class="hf-casino__door">
          <path d="M-25 4.5 L-25 -1 A 5 4 0 0 1 -15 -1 L-15 4.5 Z"
                fill="var(--accent)" stroke="var(--navy)" stroke-width="1.2" stroke-linejoin="miter"/>
          <rect x="-22.5" y=".5" width="5" height="4" fill="var(--navy)"/>
          <rect x="-22.5" y="2.4" width="5" height=".5" fill="var(--gold)" stroke="none"/>
        </g>
      </g>

      <!-- ===== Casino parking lot in front of the casino. Asphalt
                strip with 4 painted stripes carving out 3 spots. The
                lot, stripes, and arrival arrow paint in together;
                cars then drive in from the left along the road.

                Each car uses a TWO-GROUP pattern: the OUTER <g> with
                a transform="translate(x y)" attribute pins its final
                parking spot, and the INNER .hf-car group runs the
                CSS slide-in animation. CSS transform on the inner
                group is composed relative to the outer attribute,
                so animation and SVG positioning don't fight. ===== -->
      <g class="hf-grow hf-grow--lot">
        <rect x="-34" y="5.5" width="28" height="4.5" rx=".4" fill="var(--ink-5, #c6c8d0)" stroke="var(--navy)" stroke-width=".5" stroke-opacity=".55"/>
        <g stroke="var(--white)" stroke-width=".8" stroke-opacity=".95">
          <line x1="-32" y1="5.8" x2="-32" y2="9.7"/>
          <line x1="-24" y1="5.8" x2="-24" y2="9.7"/>
          <line x1="-16" y1="5.8" x2="-16" y2="9.7"/>
          <line x1="-8"  y1="5.8" x2="-8"  y2="9.7"/>
        </g>
      </g>
      <g transform="translate(-28 8.5)">
        <g class="hf-car hf-car--lot-a">
          <rect x="-3" y="-1.5" width="6" height="2.5" rx=".7" fill="var(--terra)" stroke="var(--navy)" stroke-width=".8"/>
          <path d="M-2 -1.5 L-1 -2.6 L1 -2.6 L2 -1.5" fill="var(--terra)" stroke="var(--navy)" stroke-width=".8" stroke-linejoin="miter"/>
          <rect x="-1.8" y="-2.4" width="3.6" height="1" rx=".2" fill="rgba(255,255,255,.55)" stroke="none"/>
          <circle cx="-1.8" cy="1.1" r=".9" fill="var(--navy)"/>
          <circle cx="1.8"  cy="1.1" r=".9" fill="var(--navy)"/>
        </g>
      </g>
      <g transform="translate(-20 8.5)">
        <g class="hf-car hf-car--lot-b">
          <rect x="-3" y="-1.5" width="6" height="2.5" rx=".7" fill="var(--accent)" stroke="var(--navy)" stroke-width=".8"/>
          <path d="M-2 -1.5 L-1 -2.6 L1 -2.6 L2 -1.5" fill="var(--accent)" stroke="var(--navy)" stroke-width=".8" stroke-linejoin="miter"/>
          <rect x="-1.8" y="-2.4" width="3.6" height="1" rx=".2" fill="rgba(255,255,255,.55)" stroke="none"/>
          <circle cx="-1.8" cy="1.1" r=".9" fill="var(--navy)"/>
          <circle cx="1.8"  cy="1.1" r=".9" fill="var(--navy)"/>
        </g>
      </g>
      <g transform="translate(-12 8.5)">
        <g class="hf-car hf-car--lot-c">
          <rect x="-3" y="-1.5" width="6" height="2.5" rx=".7" fill="var(--purple)" stroke="var(--navy)" stroke-width=".8"/>
          <path d="M-2 -1.5 L-1 -2.6 L1 -2.6 L2 -1.5" fill="var(--purple)" stroke="var(--navy)" stroke-width=".8" stroke-linejoin="miter"/>
          <rect x="-1.8" y="-2.4" width="3.6" height="1" rx=".2" fill="rgba(255,255,255,.55)" stroke="none"/>
          <circle cx="-1.8" cy="1.1" r=".9" fill="var(--navy)"/>
          <circle cx="1.8"  cy="1.1" r=".9" fill="var(--navy)"/>
        </g>
      </g>

      <!-- ===== Drive-through gas station on the upper-right side of
                the parcel. Wide gold canopy on two posts, two fuel
                pumps under the canopy, a car driving through. No
                separate convenience-store building — the canopy IS
                the gas station. ===== -->
      <!-- Concrete pad under the canopy + pump island, painted black
           with a subtle stripe so the surface reads as "gas station"
           apron, distinct from the asphalt road below. -->
      <g class="hf-build hf-build--gas-pad">
        <rect x="10" y="-3" width="30" height="13" rx=".5" fill="var(--ink-5, #c6c8d0)" stroke="var(--navy)" stroke-width=".5" stroke-opacity=".55"/>
      </g>
      <!-- Canopy: wide flat gold roof on two slim posts. GAS sign
           runs along the front edge. -->
      <g class="hf-build hf-build--gas-canopy">
        <rect x="9" y="-9" width="32" height="4" rx=".4" fill="var(--gold)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <text x="25" y="-6.1" font-family="Inter, sans-serif" font-weight="800" font-size="3" letter-spacing=".18em" fill="var(--navy)" text-anchor="middle">GAS</text>
        <line x1="12" y1="-5" x2="12" y2="10" stroke="var(--navy)" stroke-width="1.3"/>
        <line x1="38" y1="-5" x2="38" y2="10" stroke="var(--navy)" stroke-width="1.3"/>
      </g>
      <!-- Two fuel pumps standing on the concrete pad between the
           posts. Each pump is a small navy column with a gold cap
           (the screen / nozzle holder). -->
      <g class="hf-build hf-build--gas-pumps">
        <g>
          <rect x="17.2" y="2" width="2.6" height="6" rx=".3" fill="var(--white)" stroke="var(--navy)" stroke-width=".8"/>
          <rect x="17.2" y="2" width="2.6" height="1.5" fill="var(--gold)" stroke="var(--navy)" stroke-width=".7"/>
        </g>
        <g>
          <rect x="30.2" y="2" width="2.6" height="6" rx=".3" fill="var(--white)" stroke="var(--navy)" stroke-width=".8"/>
          <rect x="30.2" y="2" width="2.6" height="1.5" fill="var(--gold)" stroke="var(--navy)" stroke-width=".7"/>
        </g>
      </g>
      <!-- Car driving through the canopy: enters from the right, ends
           up parked between the two pumps. Two-group pattern again so
           the slide-in animation composes with the outer position. -->
      <g transform="translate(25 6)">
        <g class="hf-car hf-car--gas">
          <rect x="-3" y="-1.5" width="6" height="2.5" rx=".7" fill="var(--cedar)" stroke="var(--navy)" stroke-width=".8"/>
          <path d="M-2 -1.5 L-1 -2.6 L1 -2.6 L2 -1.5" fill="var(--cedar)" stroke="var(--navy)" stroke-width=".8" stroke-linejoin="miter"/>
          <rect x="-1.8" y="-2.4" width="3.6" height="1" rx=".2" fill="rgba(255,255,255,.55)" stroke="none"/>
          <circle cx="-1.8" cy="1.1" r=".9" fill="var(--navy)"/>
          <circle cx="1.8"  cy="1.1" r=".9" fill="var(--navy)"/>
        </g>
      </g>

      <!-- ===== Dollar signs trickling up. Eight individual $
                tags with staggered rises and varying sizes; the
                stream accelerates toward the end of the cycle. ===== -->
      <g class="hf-imp__dollars" font-family="JetBrains Mono, ui-monospace, monospace" font-weight="700">
        <text class="hf-dollar hf-dollar--1" x="-20" y="-2"  font-size="5"   fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--2" x="-6"  y="-4"  font-size="6"   fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--3" x="10"  y="-4"  font-size="5.5" fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--4" x="22"  y="-6"  font-size="6.5" fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--5" x="-14" y="0"   font-size="4.5" fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--6" x="2"   y="-8"  font-size="5"   fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--7" x="20"  y="2"   font-size="5"   fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--8" x="32"  y="0"   font-size="6"   fill="var(--gold)">$</text>
      </g>
    </g>
  </svg>

  <ol class="hero-flow__labels" aria-label="Study stages">
    <li class="hero-flow__label">Harmonize your economic data</li>
    <li class="hero-flow__label">Cedar runs the economic impact analysis</li>
    <li class="hero-flow__label">Prove your economic impact</li>
  </ol>
</figure>

<style>
  .hero-flow {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 760px;
  }
  .hero-flow__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-flow__labels {
    list-style: none;
    padding: 0;
    margin: .35rem 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: .6rem;
  }
  .hero-flow__label {
    font-family: var(--font-mono);
    font-size: .66rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--ink-3);
    text-align: center;
    line-height: 1.3;
    animation: hf-label-glow 7s ease-in-out infinite;
    text-shadow: 0 0 0 transparent;
  }
  .hero-flow__label:nth-child(1) { animation-delay: 0s; }
  .hero-flow__label:nth-child(2) { animation-delay: 1.6s; --label-accent: var(--cedar); }
  .hero-flow__label:nth-child(3) { animation-delay: 3.8s; --label-accent: var(--gold); }
  @keyframes hf-label-glow {
    0%, 25%   { color: var(--ink-3); text-shadow: 0 0 0 transparent; }
    5%        { color: var(--navy);  text-shadow: 0 0 12px var(--label-accent, var(--accent)); }
    16%       { color: var(--navy);  text-shadow: 0 0 4px var(--label-accent, var(--accent)); }
    100%      { color: var(--ink-3); text-shadow: 0 0 0 transparent; }
  }

  /* ---------- Traveling ticks ---------- */
  @keyframes hf-tick-run {
    0%   { transform: translateX(0);     opacity: 0; r: 2.4; }
    8%   { opacity: 1; }
    50%  {                                r: 3.4; }
    92%  { opacity: 1; }
    100% { transform: translateX(600px); opacity: 0; r: 2.4; }
  }
  .hf-tick {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-tick-run 7s linear infinite;
  }
  .hf-tick--a { animation-delay: 0s; }
  .hf-tick--b { animation-delay: 2.3s; }
  .hf-tick--c { animation-delay: 4.6s; }

  /* ---------- Halo pulses ---------- */
  .hf-station__halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-halo 7s ease-in-out infinite;
  }
  .hf-station--src   .hf-station__halo { animation-delay: 0s; }
  .hf-station--cedar .hf-station__halo { animation-delay: 1.6s; }
  .hf-station--map   .hf-station__halo { animation-delay: 3.8s; }
  @keyframes hf-halo {
    0%, 25%  { opacity: 0;   transform: scale(.6); }
    4%       { opacity: .2;  transform: scale(1);  }
    14%      { opacity: 0;   transform: scale(1.18);}
    100%     { opacity: 0; }
  }

  /* ---------- Sequential pipeline timing across a 7s loop ----
     0.0 – 1.6s   Station 1: messy inputs harmonize into output
     1.6 – 4.0s   Station 2: hourglass → bars → output lines
     3.8 – 6.7s   Station 3: casino builds slowly, ecosystem grows,
                              dollars rise
     The handoffs overlap by ~200ms so each station's finish
     visibly feeds the next station's start. */

  /* ---------- Station 1: messy data → harmonized output ----------
     0-3%:   inputs slip in from the right (re-entry).
     3-19%:  inputs hold on the left in their three colours.
     19-26%: inputs shrink + slide toward the merge point.
     26-77%: output spreadsheet visible (frame stays put), rows fill
                in sequence. Output persists during Cedar's processing.
     77-82%: output fades out, cycle resets.

     Output uses opacity-only — the document frame stays anchored
     while the harmonized rows fill in, so it reads as data being
     added to a stationary document rather than a document growing. */
  .hf-in {
    transform-box: fill-box;
    transform-origin: 0 50%;
    animation: hf-in-merge 7s ease-in-out infinite;
  }
  .hf-in--a { animation-delay: 0s; }
  .hf-in--b { animation-delay: .08s; }
  .hf-in--c { animation-delay: .16s; }
  @keyframes hf-in-merge {
    0%       { opacity: 0; transform: translate(22px, 0) scale(.35); }
    4%, 19%  { opacity: 1; transform: translate(0, 0)    scale(1);   }
    23%      { opacity: 1; transform: translate(8px, 0)  scale(.9);  }
    28%, 100% { opacity: 0; transform: translate(22px, 0) scale(.35); }
  }
  .hf-out {
    opacity: 0;
    animation: hf-out-show 7s ease-in-out infinite;
  }
  @keyframes hf-out-show {
    0%, 26%  { opacity: 0; }
    33%, 77% { opacity: 1; }
    82%, 100% { opacity: 0; }
  }
  .hf-out__row {
    transform-box: fill-box;
    transform-origin: left center;
    animation: hf-out-row 7s ease-in-out infinite;
  }
  .hf-out__row--1 { animation-delay: .45s; }
  .hf-out__row--2 { animation-delay: .55s; }
  .hf-out__row--3 { animation-delay: .65s; }
  .hf-out__row--4 { animation-delay: .75s; }
  .hf-out__row--5 { animation-delay: .85s; }
  .hf-out__row--6 { animation-delay: .95s; }
  @keyframes hf-out-row {
    0%, 28%  { opacity: 0; transform: scaleX(0); }
    36%, 78% { opacity: 1; transform: scaleX(1); }
    82%, 100% { opacity: 0; transform: scaleX(0); }
  }

  /* ---------- Station 2: hourglass → bars → output lines ----
     Cedar's narrative inside the cycle:
       1.6s  Tree pulses as Cedar wakes up.
       1.6s  Hourglass appears (Cedar is "thinking").
       2.5s  Hourglass fades. Bars begin to fill.
       3.2s  Output lines extend rightward.
       4.0s  Cedar's pass is complete; everything holds.
       ~5s   Output lines retract; Cedar resets. */
  .hf-cedar__tree {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-cedar-pulse 7s ease-in-out infinite;
    animation-delay: 1.6s;
  }
  @keyframes hf-cedar-pulse {
    0%, 100% { transform: scale(1);    }
    3%       { transform: scale(1.08); }
    14%      { transform: scale(1);    }
  }

  /* Loading spinner: visible at the start of Cedar's phase, then
     fades out so the bars can take over. The arc spins continuously
     on its own short loop (independent of the 7s master loop) so it
     reads as a real computer spinner. */
  .hf-loading {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: hf-loading-show 7s ease-in-out infinite;
    animation-delay: 1.6s;
  }
  @keyframes hf-loading-show {
    0%       { opacity: 0; transform: scale(.6); }
    2%       { opacity: 1; transform: scale(1);  }
    13%      { opacity: 1; }
    18%      { opacity: 0; transform: scale(.7); }
    100%     { opacity: 0; }
  }
  /* Indeterminate progress fill: slides left-to-right and back,
     ~1.4s loop so the motion reads as active loading. */
  .hf-load-fill {
    transform-box: fill-box;
    transform-origin: left center;
    animation: hf-load-fill 1.4s ease-in-out infinite;
  }
  @keyframes hf-load-fill {
    0%   { transform: translateX(0)  scaleX(1); }
    50%  { transform: translateX(14px) scaleX(1); }
    100% { transform: translateX(0)  scaleX(1); }
  }
  /* Trailing dots after "LOADING" — each blinks in sequence. */
  .hf-load-dot {
    animation: hf-load-dot 1.2s ease-in-out infinite;
  }
  .hf-load-dot--a { animation-delay: 0s;   }
  .hf-load-dot--b { animation-delay: .15s; }
  .hf-load-dot--c { animation-delay: .30s; }
  @keyframes hf-load-dot {
    0%, 30%   { opacity: .25; }
    50%       { opacity: 1;   }
    80%, 100% { opacity: .25; }
  }
  /* Baseline + bars: hidden during the hourglass, then appear. */
  .hf-baseline {
    opacity: 0;
    animation: hf-baseline-show 7s ease-in-out infinite;
    animation-delay: 1.6s;
  }
  @keyframes hf-baseline-show {
    0%, 18%  { opacity: 0; }
    25%, 78% { opacity: .4; }
    85%, 100% { opacity: 0; }
  }
  .hf-bar {
    transform-box: fill-box;
    transform-origin: center bottom;
    animation: hf-bar-grow 7s ease-in-out infinite;
    opacity: 0;
  }
  .hf-bar--a { animation-delay: 2.5s; }
  .hf-bar--b { animation-delay: 2.6s; }
  .hf-bar--c { animation-delay: 2.7s; }
  .hf-bar--d { animation-delay: 2.8s; }
  .hf-bar--e { animation-delay: 2.9s; }
  @keyframes hf-bar-grow {
    0%       { opacity: 0; transform: scaleY(.1); }
    8%       { opacity: 1; transform: scaleY(1);  }
    50%      { opacity: 1; transform: scaleY(1);  }
    62%, 100% { opacity: 0; transform: scaleY(.1); }
  }
  .hf-line {
    opacity: 0;
    animation: hf-line-out 7s ease-in-out infinite;
  }
  .hf-line--a { animation-delay: 3.1s; }
  .hf-line--b { animation-delay: 3.2s; }
  .hf-line--c { animation-delay: 3.3s; }
  @keyframes hf-line-out {
    0%       { x2: -6;  opacity: 0; }
    8%       { opacity: 1; }
    18%      { x2: 32;  opacity: .9; }
    45%      { x2: 32;  opacity: .9; }
    55%, 100% { x2: -6;  opacity: 0; }
  }

  /* ---------- Station 3: empty parcel → chunky construction ----------
     The parcel starts blank (just the outline + road). Three clean
     phases play in sequence; every piece uses
     animation-fill-mode: backwards so it stays hidden before its
     delay elapses (otherwise CSS would render it in its final state
     until the animation kicks in, and the parcel would look
     pre-built on page load).

     Master cycle 7s:
       Phase 1  CASINO BUILDS (3.80s – 4.95s)
         3.80s  Foundation slab appears
         3.95s  Body rises into place
         4.10s  Marquee snaps on + CASINO lettering glows in
         4.45s  Windows light up one by one across two rows
         4.80s  Entrance + awning pop
       Phase 2  PARKING LOT + CARS (4.95s – 5.85s)
         4.95s  Asphalt pad + painted stripes paint in
         5.20s  First car drives in from the left
         5.40s  Second car follows
         5.60s  Third car follows
       Phase 3  GAS STATION (5.85s – 6.85s)
         5.85s  Concrete pad lays down
         5.95s  Canopy + posts + GAS sign drop in
         6.15s  Two fuel pumps pop in
         6.40s  Car drives in from the right and stops at the pump
       Tail (6.85s – 7.00s)
         6.85s  Dollar signs trickle up; cycle resets at 7.00s. */

  /* Shared base for every "chunk-in" piece. backwards fill mode is
     what makes the parcel start empty. */
  .hf-imp__src,
  .hf-casino__base,
  .hf-casino__body,
  .hf-casino__marquee,
  .hf-casino__name,
  .hf-casino__win,
  .hf-casino__door,
  .hf-build,
  .hf-grow,
  .hf-car {
    transform-box: fill-box;
    transform-origin: center;
    animation-duration: 7s;
    animation-iteration-count: infinite;
    animation-fill-mode: backwards;
  }

  /* Casino: the outer .hf-imp__src group is always present (its
     children animate individually). It carries the cycle-out fade
     so the whole casino disappears together at the end. */
  .hf-imp__src {
    opacity: 1;
    animation-name: hf-cycle-out;
    animation-timing-function: ease-in-out;
    animation-delay: 0s;
  }

  /* Casino sub-chunks. Each piece pops in with a snappy scale-bounce
     so the building reads as constructing in stages. */
  .hf-casino__base,
  .hf-casino__body,
  .hf-casino__door {
    opacity: 0;
    animation-name: hf-chunk;
    animation-timing-function: cubic-bezier(.22, 1.4, .4, 1);
  }
  .hf-casino__base { animation-delay: 3.80s; }
  .hf-casino__body { animation-delay: 3.95s; }
  .hf-casino__door { animation-delay: 4.80s; }

  /* Marquee fills gold once the body is up. Driven separately so the
     colour change reads as "lights coming on". */
  .hf-casino__marquee {
    opacity: 0;
    fill: var(--ink-3);
    animation-name: hf-marquee-light;
    animation-timing-function: ease-out;
    animation-delay: 4.10s;
  }
  @keyframes hf-marquee-light {
    0%       { opacity: 0; fill: var(--ink-3); }
    4%       { opacity: 1; fill: var(--ink-3); }
    8%, 85%  { opacity: 1; fill: var(--gold);  }
    92%, 100% { opacity: 0; fill: var(--ink-3); }
  }
  .hf-casino__name {
    opacity: 0;
    animation-name: hf-fade-hold;
    animation-timing-function: ease-out;
    animation-delay: 4.20s;
  }
  @keyframes hf-fade-hold {
    0%, 4%   { opacity: 0; }
    8%, 85%  { opacity: 1; }
    92%, 100% { opacity: 0; }
  }

  /* Windows light up in sequence as the casino opens floor by floor.
     8 windows, staggered. */
  .hf-casino__win {
    opacity: 0;
    fill: var(--ink-3);
    animation-name: hf-window-light;
    animation-timing-function: ease-out;
  }
  .hf-casino__win--1 { animation-delay: 4.45s; }
  .hf-casino__win--2 { animation-delay: 4.55s; }
  .hf-casino__win--3 { animation-delay: 4.65s; }
  .hf-casino__win--4 { animation-delay: 4.75s; }
  .hf-casino__win--5 { animation-delay: 4.50s; }
  .hf-casino__win--6 { animation-delay: 4.60s; }
  .hf-casino__win--7 { animation-delay: 4.70s; }
  .hf-casino__win--8 { animation-delay: 4.80s; }
  @keyframes hf-window-light {
    0%       { opacity: 0; fill: var(--ink-3); }
    5%       { opacity: 1; fill: var(--ink-3); }
    10%, 85% { opacity: 1; fill: var(--gold);  }
    92%, 100% { opacity: 0; fill: var(--ink-3); }
  }

  /* Drive-through gas station chunks: pad, canopy, pumps. Each pops
     in with the same snappy scale-bounce as the casino chunks. */
  .hf-build {
    opacity: 0;
    animation-name: hf-chunk;
    animation-timing-function: cubic-bezier(.22, 1.4, .4, 1);
  }
  .hf-build--gas-pad    { animation-delay: 5.85s; }
  .hf-build--gas-canopy { animation-delay: 5.95s; }
  .hf-build--gas-pumps  { animation-delay: 6.15s; }

  /* Slabs (the casino parking lot) fade in together. */
  .hf-grow {
    opacity: 0;
    animation-name: hf-slab;
    animation-timing-function: ease-out;
  }
  .hf-grow--lot { animation-delay: 4.95s; }

  /* Cars use a two-group pattern: the OUTER <g> with
     transform="translate(x y)" pins each car's final position, the
     INNER .hf-car carries the slide-in animation. CSS transform on
     the inner group composes with the outer attribute, so the car
     can slide in from off-parcel without losing its parking spot.

     Casino-lot cars enter from the LEFT (along the road), driving
     to the right into their spots. Gas-station car enters from the
     RIGHT (off-parcel) and pulls left into the canopy. */
  .hf-car {
    opacity: 0;
    animation-timing-function: cubic-bezier(.2, .8, .25, 1);
  }
  .hf-car--lot-a,
  .hf-car--lot-b,
  .hf-car--lot-c { animation-name: hf-car-drive-right; }
  .hf-car--gas { animation-name: hf-car-drive-left; }
  .hf-car--lot-a { animation-delay: 5.20s; }
  .hf-car--lot-b { animation-delay: 5.40s; }
  .hf-car--lot-c { animation-delay: 5.60s; }
  .hf-car--gas   { animation-delay: 6.40s; }
  @keyframes hf-car-drive-right {
    0%        { opacity: 0; transform: translateX(-30px); }
    4%        { opacity: 1; }
    14%, 80%  { opacity: 1; transform: translateX(0); }
    90%, 100% { opacity: 0; transform: translateX(0); }
  }
  @keyframes hf-car-drive-left {
    0%        { opacity: 0; transform: translateX(28px); }
    4%        { opacity: 1; }
    14%, 80%  { opacity: 1; transform: translateX(0); }
    90%, 100% { opacity: 0; transform: translateX(0); }
  }

  /* ---- Shared keyframes for the chunky construction ---- */
  @keyframes hf-chunk {
    0%       { opacity: 0; transform: scale(.45); }
    4%       { opacity: 1; transform: scale(1.10); }
    8%, 88%  { opacity: 1; transform: scale(1); }
    96%, 100% { opacity: 0; transform: scale(.45); }
  }
  @keyframes hf-slab {
    0%        { opacity: 0; }
    4%, 88%   { opacity: 1; }
    96%, 100% { opacity: 0; }
  }
  @keyframes hf-cycle-out {
    0%, 88%   { opacity: 1; }
    96%, 100% { opacity: 0; }
  }

  /* Dollar signs trickle up from the new development. The stream
     accelerates toward the end of the cycle as the parcel densifies. */
  .hf-dollar {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: hf-dollar-rise 7s ease-out infinite;
  }
  .hf-dollar--1 { animation-delay: 6.35s; }
  .hf-dollar--2 { animation-delay: 6.45s; }
  .hf-dollar--3 { animation-delay: 6.55s; }
  .hf-dollar--4 { animation-delay: 6.65s; }
  .hf-dollar--5 { animation-delay: 6.75s; }
  .hf-dollar--6 { animation-delay: 6.85s; }
  .hf-dollar--7 { animation-delay: 6.95s; }
  .hf-dollar--8 { animation-delay: 7.00s; }
  @keyframes hf-dollar-rise {
    0%       { opacity: 0; transform: translateY(0)    scale(.4); }
    8%       { opacity: 1; transform: translateY(-4px) scale(1);  }
    40%      { opacity: 1; transform: translateY(-12px) scale(1); }
    65%, 100% { opacity: 0; transform: translateY(-22px) scale(.7); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hf-tick, .hf-station__halo,
    .hf-in, .hf-out, .hf-out__row,
    .hf-cedar__tree, .hf-bar, .hf-line,
    .hf-loading, .hf-load-fill, .hf-load-dot, .hf-baseline,
    .hf-imp__src, .hf-casino__base, .hf-casino__body, .hf-casino__door,
    .hf-casino__marquee, .hf-casino__name, .hf-casino__win,
    .hf-build, .hf-grow, .hf-car, .hf-dollar,
    .hero-flow__label { animation: none; }
    .hf-tick { opacity: 0; }
    .hf-in    { opacity: 1; transform: none; }
    .hf-out   { opacity: 1; }
    .hf-bar   { transform: none; opacity: 1; }
    .hf-line  { opacity: 1; }
    .hf-loading  { opacity: 0; }
    .hf-baseline { opacity: .4; }
    .hf-imp__src, .hf-casino__base, .hf-casino__body, .hf-casino__door,
    .hf-build, .hf-grow, .hf-car { opacity: 1; transform: none; }
    .hf-casino__marquee { opacity: 1; fill: var(--gold); }
    .hf-casino__name    { opacity: 1; }
    .hf-casino__win { opacity: 1; fill: var(--gold); }
    .hf-dollar { opacity: 0; }
    .hero-flow__label { color: var(--ink-3); }
  }

  @media (max-width: 600px) {
    .hero-flow__labels { gap: .3rem; margin-top: .25rem; }
    .hero-flow__label { font-size: .56rem; letter-spacing: .05em; }
  }
</style>
