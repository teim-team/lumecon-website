---
/**
 * Hero workflow: three-step explainer at the top of the page.
 * Replaces the big LUMECON wordmark (already in the nav) so the
 * hero opens with what an economic impact study actually looks
 * like instead of a brand restatement.
 *
 * Each step is a tile with an animated SVG icon and a one-line
 * label. Connectors between tiles read as the flow direction:
 *   Harmonize data  →  Cedar runs the analysis  →  See your impact
 *
 * Animations are CSS-driven and respect prefers-reduced-motion.
 */
---
<ol class="hero-flow" aria-label="How a Lumecon study runs">
  <li class="hero-flow__step">
    <div class="hero-flow__icon hero-flow__icon--data" aria-hidden="true">
      <svg viewBox="0 0 64 56" fill="none">
        <!-- Three source docs sliding into a merged stack on the right. -->
        <g class="hf-data__src hf-data__src--a">
          <rect x="3" y="6" width="14" height="18" rx="1.5" fill="var(--white)" stroke="currentColor" stroke-width="1.4"/>
          <line x1="6" y1="11" x2="14" y2="11" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
          <line x1="6" y1="14" x2="14" y2="14" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
          <line x1="6" y1="17" x2="12" y2="17" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
        </g>
        <g class="hf-data__src hf-data__src--b">
          <rect x="3" y="22" width="14" height="18" rx="1.5" fill="var(--white)" stroke="currentColor" stroke-width="1.4"/>
          <line x1="6" y1="27" x2="14" y2="27" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
          <line x1="6" y1="30" x2="14" y2="30" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
          <line x1="6" y1="33" x2="13" y2="33" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
        </g>
        <g class="hf-data__src hf-data__src--c">
          <rect x="3" y="38" width="14" height="14" rx="1.5" fill="var(--white)" stroke="currentColor" stroke-width="1.4"/>
          <line x1="6" y1="43" x2="14" y2="43" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
          <line x1="6" y1="46" x2="13" y2="46" stroke="currentColor" stroke-width="1" stroke-opacity=".6"/>
        </g>
        <!-- Merge arrow + harmonized output stack. -->
        <path class="hf-data__arrow" d="M22 28 L36 28" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-dasharray="20" stroke-dashoffset="20"/>
        <polyline class="hf-data__arrow-head" points="33,25 36,28 33,31" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="miter"/>
        <g class="hf-data__out">
          <rect x="40" y="14" width="20" height="28" rx="2" fill="var(--white)" stroke="currentColor" stroke-width="1.5"/>
          <rect x="43" y="19" width="14" height="3" rx=".4" fill="var(--accent)" opacity=".7"/>
          <rect x="43" y="24" width="14" height="3" rx=".4" fill="var(--accent)" opacity=".55"/>
          <rect x="43" y="29" width="10" height="3" rx=".4" fill="var(--accent)" opacity=".4"/>
          <rect x="43" y="34" width="14" height="3" rx=".4" fill="var(--accent)" opacity=".25"/>
        </g>
      </svg>
    </div>
    <p class="hero-flow__label">Harmonize your data</p>
  </li>

  <span class="hero-flow__rail" aria-hidden="true"></span>

  <li class="hero-flow__step">
    <div class="hero-flow__icon hero-flow__icon--cedar" aria-hidden="true">
      <svg viewBox="0 0 64 56" fill="none">
        <!-- Cedar tree silhouette + data ticks streaming into it. -->
        <g class="hf-cedar__ticks">
          <circle class="hf-cedar__tick hf-cedar__tick--a" cx="6" cy="14" r="1.4" fill="currentColor"/>
          <circle class="hf-cedar__tick hf-cedar__tick--b" cx="8" cy="28" r="1.4" fill="currentColor"/>
          <circle class="hf-cedar__tick hf-cedar__tick--c" cx="6" cy="42" r="1.4" fill="currentColor"/>
        </g>
        <g class="hf-cedar__tree">
          <path d="M32 6 L22 20 L26 20 L18 32 L24 32 L14 46 L50 46 L40 32 L46 32 L38 20 L42 20 Z"
                fill="var(--cedar)" stroke="var(--cedar)" stroke-width="1.2" stroke-linejoin="miter"/>
          <rect x="30" y="46" width="4" height="5" fill="var(--navy)"/>
        </g>
        <!-- Soft pulse aura behind the tree. -->
        <circle class="hf-cedar__aura" cx="32" cy="28" r="20" fill="var(--cedar)" opacity="0"/>
      </svg>
    </div>
    <p class="hero-flow__label">Cedar runs the analysis</p>
  </li>

  <span class="hero-flow__rail" aria-hidden="true"></span>

  <li class="hero-flow__step">
    <div class="hero-flow__icon hero-flow__icon--map" aria-hidden="true">
      <svg viewBox="0 0 64 56" fill="none">
        <!-- Schematic U.S. outline with regions lighting up in sequence. -->
        <path d="M5 18 L10 11 L18 9 L26 12 L34 9 L42 11 L52 11 L58 16 L58 22 L60 28 L56 34 L52 38 L46 41 L40 38 L34 41 L26 40 L18 42 L12 38 L8 32 L5 26 Z"
              fill="var(--paper)" stroke="currentColor" stroke-width="1.4" stroke-linejoin="miter"/>
        <!-- Region tints: three illustrative regions that pulse in sequence. -->
        <path class="hf-map__r hf-map__r--src" d="M28 18 L36 18 L38 26 L33 32 L26 30 L24 22 Z" fill="var(--gold)" opacity="0"/>
        <path class="hf-map__r hf-map__r--a" d="M14 14 L24 14 L26 22 L20 28 L12 26 L10 18 Z" fill="var(--accent)" opacity="0"/>
        <path class="hf-map__r hf-map__r--b" d="M38 17 L48 16 L52 22 L48 30 L40 28 L36 22 Z" fill="var(--accent)" opacity="0"/>
        <!-- Value chip near the source region. -->
        <g class="hf-map__chip">
          <rect x="28" y="36" width="20" height="9" rx="1.5" fill="var(--white)" stroke="var(--gold)" stroke-width=".7"/>
          <text x="38" y="42.4" font-family="JetBrains Mono, monospace" font-size="5.2" font-weight="600" fill="var(--navy)" text-anchor="middle">$24M</text>
        </g>
      </svg>
    </div>
    <p class="hero-flow__label">See your impact</p>
  </li>
</ol>

<style>
  .hero-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: stretch;
    gap: clamp(.6rem, 1.6vw, 1.4rem);
    width: 100%;
    max-width: 760px;
  }
  .hero-flow__step {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: .65rem;
    padding: 1rem .9rem 1.1rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 12px;
    color: var(--ink-2);
    transition: transform .2s var(--ease), box-shadow .2s var(--ease);
  }
  .hero-flow__step:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -10px rgba(10, 15, 38, .15);
  }
  .hero-flow__icon {
    width: 100%;
    max-width: 84px;
    aspect-ratio: 64 / 56;
    color: var(--navy);
  }
  .hero-flow__icon svg { width: 100%; height: 100%; display: block; }
  .hero-flow__label {
    font-family: var(--font-sans);
    font-size: .82rem;
    font-weight: 500;
    color: var(--navy);
    letter-spacing: -.005em;
    margin: 0;
    line-height: 1.25;
  }
  /* Rails between tiles: thin teal hairline with a trailing arrow head. */
  .hero-flow__rail {
    flex: 0 0 auto;
    align-self: center;
    width: clamp(.8rem, 2vw, 1.6rem);
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent) 30%, var(--accent) 70%, transparent);
    position: relative;
  }
  .hero-flow__rail::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    width: 6px;
    height: 6px;
    border-right: 1.5px solid var(--accent);
    border-bottom: 1.5px solid var(--accent);
    transform: translate(0, -50%) rotate(-45deg);
  }

  /* ---------- Step 1: data harmonization ---------- */
  .hf-data__src {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-data-slide 5.4s var(--ease) infinite;
  }
  .hf-data__src--b { animation-delay: .25s; }
  .hf-data__src--c { animation-delay: .5s; }
  @keyframes hf-data-slide {
    0%, 12%   { transform: translate(-2px, 0); opacity: .85; }
    36%, 64%  { transform: translate(0, 0);    opacity: 1;   }
    88%, 100% { transform: translate(-2px, 0); opacity: .85; }
  }
  .hf-data__arrow {
    animation: hf-data-arrow 5.4s var(--ease) infinite;
  }
  @keyframes hf-data-arrow {
    0%, 30%   { stroke-dashoffset: 20; }
    50%, 80%  { stroke-dashoffset: 0;  }
    100%      { stroke-dashoffset: 20; }
  }
  .hf-data__arrow-head { opacity: 0; animation: hf-data-head 5.4s var(--ease) infinite; }
  @keyframes hf-data-head {
    0%, 45% { opacity: 0; }
    55%, 80% { opacity: 1; }
    100% { opacity: 0; }
  }
  .hf-data__out {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-data-out 5.4s var(--ease) infinite;
  }
  @keyframes hf-data-out {
    0%, 55%  { opacity: .35; transform: scale(.96); }
    70%, 92% { opacity: 1;   transform: scale(1);   }
    100%     { opacity: .35; transform: scale(.96); }
  }

  /* ---------- Step 2: Cedar analysis ---------- */
  .hf-cedar__tick {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-cedar-flow 3.2s ease-in-out infinite;
    opacity: 0;
  }
  .hf-cedar__tick--b { animation-delay: .25s; }
  .hf-cedar__tick--c { animation-delay: .5s; }
  @keyframes hf-cedar-flow {
    0%   { transform: translate(0, 0);   opacity: 0; }
    25%  { opacity: 1; }
    70%  { transform: translate(20px, 0); opacity: 0; }
    100% { transform: translate(20px, 0); opacity: 0; }
  }
  .hf-cedar__aura {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-cedar-aura 3.2s ease-in-out infinite;
  }
  @keyframes hf-cedar-aura {
    0%, 100% { opacity: 0;   transform: scale(.6); }
    55%      { opacity: .18; transform: scale(1);  }
    80%      { opacity: 0;   transform: scale(1.1);}
  }
  .hf-cedar__tree {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-cedar-pulse 3.2s ease-in-out infinite;
  }
  @keyframes hf-cedar-pulse {
    0%, 100% { transform: scale(1); }
    55%      { transform: scale(1.04); }
  }

  /* ---------- Step 3: impact map ---------- */
  .hf-map__r {
    transform-box: fill-box;
    transform-origin: center;
  }
  .hf-map__r--src { animation: hf-map-src 4s ease-in-out infinite; }
  .hf-map__r--a   { animation: hf-map-r   4s ease-in-out infinite; animation-delay: .4s; }
  .hf-map__r--b   { animation: hf-map-r   4s ease-in-out infinite; animation-delay: .7s; }
  @keyframes hf-map-src {
    0%, 100% { opacity: 0;  }
    20%, 90% { opacity: .85; }
  }
  @keyframes hf-map-r {
    0%, 100% { opacity: 0;   }
    30%, 90% { opacity: .35; }
  }
  .hf-map__chip {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: hf-map-chip 4s ease-in-out infinite;
    animation-delay: .8s;
  }
  @keyframes hf-map-chip {
    0%, 20%  { opacity: 0; transform: translate(0, 3px); }
    45%, 90% { opacity: 1; transform: translate(0, 0);   }
    100%     { opacity: 0; transform: translate(0, 3px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hf-data__src, .hf-data__arrow, .hf-data__arrow-head, .hf-data__out,
    .hf-cedar__tick, .hf-cedar__aura, .hf-cedar__tree,
    .hf-map__r, .hf-map__chip { animation: none; }
    .hf-cedar__tick { opacity: 1; }
    .hf-map__r--src { opacity: .85; }
    .hf-map__r--a, .hf-map__r--b { opacity: .35; }
    .hf-map__chip { opacity: 1; }
  }

  @media (max-width: 600px) {
    .hero-flow { gap: .4rem; }
    .hero-flow__step { padding: .8rem .55rem .85rem; gap: .5rem; border-radius: 10px; }
    .hero-flow__icon { max-width: 60px; }
    .hero-flow__label { font-size: .72rem; line-height: 1.2; }
    .hero-flow__rail { width: .5rem; }
    .hero-flow__rail::after { width: 5px; height: 5px; }
  }
</style>
