---
/**
 * Hero workflow — one continuous flowing SVG showing what a Lumecon
 * study looks like, end to end:
 *
 *   sources ──▶ Cedar ──▶ impact map
 *
 * Three stations along a single horizontal flow rail. Data ticks
 * travel along the rail continuously, fading in on the left, getting
 * absorbed by Cedar in the middle, and falling out as a lit-up
 * region on the right. Each station pulses subtly as the data
 * arrives. All line-art (stroke-only) to match the rest of the
 * site's icon system; teal flow line ties into the UI accent.
 *
 * Respects prefers-reduced-motion. CSS-only — no JS.
 */
---
<figure class="hero-flow" aria-label="How a Lumecon study runs">
  <svg
    class="hero-flow__svg"
    viewBox="0 0 720 120"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-hidden="true"
  >
    <!-- Continuous flow rail. Dashed so the eye reads movement
         even when the traveling dots aren't visible. -->
    <line class="hf-rail" x1="60" y1="60" x2="660" y2="60"
          stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"
          stroke-dasharray="3 6" />

    <!-- Three traveling dots staggered around the loop so there's
         always a tick in flight somewhere along the rail. -->
    <circle class="hf-tick hf-tick--a" cx="60" cy="60" r="3" fill="var(--accent)"/>
    <circle class="hf-tick hf-tick--b" cx="60" cy="60" r="3" fill="var(--accent)"/>
    <circle class="hf-tick hf-tick--c" cx="60" cy="60" r="3" fill="var(--accent)"/>

    <!-- ===== Station 1: sources / data harmonization ===== -->
    <g class="hf-station hf-station--src" transform="translate(60 60)">
      <circle class="hf-station__halo" r="34" fill="var(--accent)" opacity="0"/>
      <g class="hf-src" stroke="var(--navy)" stroke-width="1.4" stroke-linejoin="miter" fill="var(--white)">
        <rect class="hf-src__doc hf-src__doc--a" x="-22" y="-26" width="20" height="26" rx="1.5"/>
        <rect class="hf-src__doc hf-src__doc--b" x="-12" y="-22" width="20" height="26" rx="1.5"/>
        <rect class="hf-src__doc hf-src__doc--c" x="-2"  y="-18" width="20" height="26" rx="1.5"/>
      </g>
      <g stroke="var(--navy)" stroke-width=".9" stroke-opacity=".55">
        <line x1="2"  y1="-13" x2="14" y2="-13"/>
        <line x1="2"  y1="-9"  x2="14" y2="-9"/>
        <line x1="2"  y1="-5"  x2="11" y2="-5"/>
      </g>
    </g>

    <!-- ===== Station 2: Cedar runs the model ===== -->
    <g class="hf-station hf-station--cedar" transform="translate(360 60)">
      <circle class="hf-station__halo" r="40" fill="var(--cedar)" opacity="0"/>
      <!-- Layered conifer outline. Reads as a real cedar, matches the
           refined mark used on the FAB and the chat avatar. -->
      <g class="hf-tree" stroke="var(--cedar)" stroke-width="1.6" stroke-linejoin="miter" fill="none">
        <path d="M0 -32 L-8 -18 L-4 -18 L-12 -6 L-6 -6 L-16 8 L16 8 L6 -6 L12 -6 L4 -18 L8 -18 Z"
              fill="var(--white)"/>
        <line x1="0" y1="8" x2="0" y2="16" stroke-width="2" stroke-linecap="butt"/>
      </g>
      <!-- Inner glow that pulses with the data arrival cadence. -->
      <circle class="hf-tree__pulse" r="3" cx="0" cy="-8" fill="var(--cedar-light)" opacity="0"/>
    </g>

    <!-- ===== Station 3: impact map ===== -->
    <g class="hf-station hf-station--map" transform="translate(660 60)">
      <circle class="hf-station__halo" r="38" fill="var(--gold)" opacity="0"/>
      <g class="hf-map" stroke="var(--navy)" stroke-width="1.4" stroke-linejoin="miter" fill="none">
        <!-- Schematic country outline -->
        <path class="hf-map__land"
              d="M-32 -18 L-26 -22 L-18 -22 L-10 -24 L-2 -22 L8 -24 L18 -22 L26 -18 L30 -10 L32 -2 L28 8 L22 14 L12 14 L4 12 L-4 14 L-14 12 L-22 10 L-30 4 L-32 -8 Z"
              fill="var(--paper)"/>
        <!-- Source region (gold) -->
        <path class="hf-map__src" d="M-4 -14 L8 -14 L12 -6 L4 0 L-6 -2 Z"
              fill="var(--gold)" fill-opacity="0"/>
        <!-- Two spillover regions (teal) -->
        <path class="hf-map__r hf-map__r--a" d="M-22 -12 L-10 -12 L-6 -4 L-14 4 L-24 0 Z"
              fill="var(--accent)" fill-opacity="0"/>
        <path class="hf-map__r hf-map__r--b" d="M12 -10 L24 -10 L26 -2 L18 6 L10 0 Z"
              fill="var(--accent)" fill-opacity="0"/>
      </g>
    </g>
  </svg>

  <!-- Labels below the SVG, aligned to each station's x position. -->
  <ol class="hero-flow__labels" aria-label="Study stages">
    <li class="hero-flow__label">Harmonize your data</li>
    <li class="hero-flow__label">Cedar runs the analysis</li>
    <li class="hero-flow__label">See your impact</li>
  </ol>
</figure>

<style>
  .hero-flow {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 760px;
  }
  .hero-flow__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Labels are an editorial row beneath the SVG. They mirror the
     SVG's three station positions (12% / 50% / 88%) so they line up
     under the icons even as the figure scales. */
  .hero-flow__labels {
    list-style: none;
    padding: 0;
    margin: .35rem 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: .6rem;
  }
  .hero-flow__label {
    font-family: var(--font-mono);
    font-size: .68rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--ink-3);
    text-align: center;
    line-height: 1.3;
  }
  .hero-flow__label:nth-child(2) { color: var(--cedar); }

  /* ---------- Continuous flow: traveling ticks along the rail ----------
     Each tick scrolls left-to-right across the whole 600-unit rail,
     staggered so a dot is always in flight. Opacity dips at the
     extremes so the tick "enters" and "exits" gracefully. */
  @keyframes hf-tick-run {
    0%   { transform: translateX(0);      opacity: 0; r: 2.4; }
    8%   { opacity: 1; }
    50%  {                                 r: 3.4; }
    92%  { opacity: 1; }
    100% { transform: translateX(600px);  opacity: 0; r: 2.4; }
  }
  .hf-tick {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-tick-run 4.8s linear infinite;
  }
  .hf-tick--a { animation-delay: 0s; }
  .hf-tick--b { animation-delay: 1.6s; }
  .hf-tick--c { animation-delay: 3.2s; }

  /* ---------- Station halo pulses ----------
     Each station's halo flashes when a tick passes through it,
     timed to the dot stagger. 4.8s cycle, halo blooms ~.3s every
     1.6s as the next tick arrives. */
  .hf-station__halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-halo 4.8s ease-in-out infinite;
  }
  .hf-station--src   .hf-station__halo { animation-delay: 0s; }
  .hf-station--cedar .hf-station__halo { animation-delay: 1.6s; }
  .hf-station--map   .hf-station__halo { animation-delay: 3.2s; }
  @keyframes hf-halo {
    0%, 25%   { opacity: 0;   transform: scale(.6); }
    5%        { opacity: .22; transform: scale(1);  }
    15%       { opacity: 0;   transform: scale(1.15);}
    100%      { opacity: 0; }
  }

  /* ---------- Station 1: source docs shuffle in to be harmonized ---------- */
  .hf-src__doc {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-src-settle 4.8s ease-in-out infinite;
  }
  .hf-src__doc--b { animation-delay: .12s; }
  .hf-src__doc--c { animation-delay: .24s; }
  @keyframes hf-src-settle {
    0%, 100% { transform: translate(-3px, 2px); }
    6%, 18%  { transform: translate(0, 0);      }
  }

  /* ---------- Station 2: Cedar pulse ---------- */
  .hf-tree {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-tree-pulse 4.8s ease-in-out infinite;
    animation-delay: 1.55s;
  }
  @keyframes hf-tree-pulse {
    0%, 100% { transform: scale(1); }
    4%       { transform: scale(1.06); }
    14%      { transform: scale(1); }
  }
  .hf-tree__pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-tree-spark 4.8s ease-in-out infinite;
    animation-delay: 1.55s;
  }
  @keyframes hf-tree-spark {
    0%, 100% { opacity: 0; r: 2;   }
    4%       { opacity: 1; r: 4.5; }
    18%      { opacity: 0; r: 8;   }
  }

  /* ---------- Station 3: regions light up in sequence ---------- */
  .hf-map__src,
  .hf-map__r {
    transform-box: fill-box;
    transform-origin: center;
  }
  .hf-map__src { animation: hf-map-src 4.8s ease-in-out infinite; animation-delay: 3.15s; }
  .hf-map__r--a { animation: hf-map-r   4.8s ease-in-out infinite; animation-delay: 3.4s;  }
  .hf-map__r--b { animation: hf-map-r   4.8s ease-in-out infinite; animation-delay: 3.55s; }
  @keyframes hf-map-src {
    0%, 100% { fill-opacity: 0; }
    8%, 35%  { fill-opacity: .9; }
    50%, 95% { fill-opacity: .6; }
  }
  @keyframes hf-map-r {
    0%, 100% { fill-opacity: 0; }
    12%, 95% { fill-opacity: .45; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hf-tick, .hf-station__halo,
    .hf-src__doc, .hf-tree, .hf-tree__pulse,
    .hf-map__src, .hf-map__r { animation: none; }
    .hf-tick { opacity: 0; }
    .hf-map__src { fill-opacity: .8; }
    .hf-map__r { fill-opacity: .4; }
  }

  /* Compact on phones: tighter aspect, smaller labels. */
  @media (max-width: 600px) {
    .hero-flow__labels { gap: .35rem; margin-top: .25rem; }
    .hero-flow__label { font-size: .58rem; letter-spacing: .06em; }
  }
</style>
