---
/**
 * Hero workflow — one continuous flowing SVG showing what a Lumecon
 * study looks like, end to end:
 *
 *   harmonize your economic data  ──▶  Cedar runs the economic
 *   impact analysis  ──▶  See your economic impact
 *
 * Three stations along a single horizontal flow rail. Each station
 * has its own self-contained transformation animation that loops on
 * a 6s cycle, synchronized to traveling ticks along the rail and a
 * label glow beneath each station.
 *
 * Station 1: three differently-coloured input spreadsheets shrink
 * and slide into a single harmonized output with rows of mixed
 * colours.
 * Station 2: monitor with the cedar tree on the LEFT and a small
 * computation panel on the RIGHT — sliding bars and ticking text
 * suggest active processing.
 * Station 3: a business marker (the source) sits next to two
 * houses (neighbours) separated by a diagonal scribble line; waves
 * radiate from the business and wash over the houses.
 *
 * All line-art, all CSS animations, respects prefers-reduced-motion.
 */
---
<figure class="hero-flow" aria-label="How a Lumecon study runs">
  <svg
    class="hero-flow__svg"
    viewBox="0 0 720 130"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-hidden="true"
  >
    <line class="hf-rail" x1="60" y1="65" x2="660" y2="65"
          stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"
          stroke-dasharray="3 6" />

    <circle class="hf-tick hf-tick--a" cx="60" cy="65" r="3" fill="var(--accent)"/>
    <circle class="hf-tick hf-tick--b" cx="60" cy="65" r="3" fill="var(--accent)"/>
    <circle class="hf-tick hf-tick--c" cx="60" cy="65" r="3" fill="var(--accent)"/>

    <!-- ===== Station 1: three sheets merge + transform into one ===== -->
    <g class="hf-station hf-station--src" transform="translate(60 65)">
      <circle class="hf-station__halo" r="42" fill="var(--accent)" opacity="0"/>

      <g class="hf-in hf-in--a">
        <rect x="-32" y="-26" width="16" height="14" rx="1.5" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <line x1="-29" y1="-22" x2="-19" y2="-22" stroke="var(--gold)" stroke-width="1.4" stroke-linecap="round"/>
        <line x1="-29" y1="-19" x2="-23" y2="-19" stroke="var(--gold)" stroke-width="1.4" stroke-linecap="round"/>
        <line x1="-29" y1="-16" x2="-19" y2="-16" stroke="var(--gold)" stroke-width="1.4" stroke-linecap="round"/>
      </g>
      <g class="hf-in hf-in--b">
        <rect x="-32" y="-7" width="16" height="14" rx="1.5" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <line x1="-29" y1="-3" x2="-17" y2="-3" stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"/>
        <line x1="-29" y1="0"  x2="-21" y2="0"  stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"/>
        <line x1="-29" y1="3"  x2="-17" y2="3"  stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"/>
      </g>
      <g class="hf-in hf-in--c">
        <rect x="-32" y="12" width="16" height="14" rx="1.5" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <line x1="-29" y1="16" x2="-19" y2="16" stroke="var(--cedar)" stroke-width="1.4" stroke-linecap="round"/>
        <line x1="-29" y1="19" x2="-25" y2="19" stroke="var(--cedar)" stroke-width="1.4" stroke-linecap="round"/>
        <line x1="-29" y1="22" x2="-19" y2="22" stroke="var(--cedar)" stroke-width="1.4" stroke-linecap="round"/>
      </g>

      <g class="hf-out">
        <rect x="-4" y="-26" width="36" height="52" rx="2" fill="var(--white)" stroke="var(--navy)" stroke-width="1.5" stroke-linejoin="miter"/>
        <rect x="-4" y="-26" width="36" height="6" fill="var(--accent)" opacity=".22" stroke="none"/>
        <line x1="8"  y1="-20" x2="8"  y2="26" stroke="var(--navy)" stroke-width=".7" stroke-opacity=".35"/>
        <line x1="20" y1="-20" x2="20" y2="26" stroke="var(--navy)" stroke-width=".7" stroke-opacity=".35"/>
        <rect class="hf-out__row hf-out__row--1" x="-1" y="-17" width="34" height="2.5" rx=".4" fill="var(--gold)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--2" x="-1" y="-12" width="34" height="2.5" rx=".4" fill="var(--accent)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--3" x="-1" y="-7"  width="34" height="2.5" rx=".4" fill="var(--cedar)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--4" x="-1" y="-2"  width="34" height="2.5" rx=".4" fill="var(--gold)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--5" x="-1" y="3"   width="34" height="2.5" rx=".4" fill="var(--accent)" opacity="0"/>
        <rect class="hf-out__row hf-out__row--6" x="-1" y="8"   width="34" height="2.5" rx=".4" fill="var(--cedar)" opacity="0"/>
      </g>
    </g>

    <!-- ===== Station 2: Cedar processes inside a monitor ===== -->
    <g class="hf-station hf-station--cedar" transform="translate(360 65)">
      <circle class="hf-station__halo" r="48" fill="var(--cedar)" opacity="0"/>

      <g class="hf-cedar" stroke="var(--navy)" stroke-width="1.4" stroke-linejoin="miter" fill="none">
        <rect x="-38" y="-30" width="76" height="46" rx="2" fill="var(--white)"/>
        <line x1="0" y1="16" x2="0" y2="22" stroke-width="2" stroke-linecap="butt"/>
        <line x1="-12" y1="22" x2="12" y2="22" stroke-width="2" stroke-linecap="round"/>
        <line x1="-38" y1="-23" x2="38" y2="-23" stroke-width="1"/>
        <circle cx="-33" cy="-26.5" r=".9" fill="var(--navy)" stroke="none"/>
        <circle cx="-29" cy="-26.5" r=".9" fill="var(--navy)" stroke="none"/>
        <circle cx="-25" cy="-26.5" r=".9" fill="var(--navy)" stroke="none"/>
      </g>

      <!-- Cedar tree on the LEFT side of the monitor. -->
      <g class="hf-cedar__tree" fill="var(--cedar)" stroke="var(--cedar)" stroke-width="1.4" stroke-linejoin="miter">
        <path d="M-22 -16 L-26 -10 L-24 -10 L-27 -5 L-25 -5 L-29 0 L-15 0 L-19 -5 L-17 -5 L-20 -10 L-18 -10 Z"/>
        <rect x="-23" y="0" width="2" height="3" stroke="none"/>
      </g>

      <!-- Computation panel on the RIGHT. -->
      <g class="hf-compute" stroke="none">
        <line x1="-8" y1="2" x2="32" y2="2" stroke="var(--navy)" stroke-width=".8" stroke-opacity=".4"/>
        <rect class="hf-bar hf-bar--a" x="-6"  y="-2" width="5" height="4"  rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--b" x="2"   y="-6" width="5" height="8"  rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--c" x="10"  y="-4" width="5" height="6"  rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--d" x="18"  y="-9" width="5" height="11" rx=".4" fill="var(--accent)"/>
        <rect class="hf-bar hf-bar--e" x="26"  y="-7" width="5" height="9"  rx=".4" fill="var(--accent)"/>
        <g stroke="var(--cedar)" stroke-width="1.2" stroke-linecap="round">
          <line class="hf-line hf-line--a" x1="-6" y1="7"  x2="-6" y2="7"/>
          <line class="hf-line hf-line--b" x1="-6" y1="11" x2="-6" y2="11"/>
          <line class="hf-line hf-line--c" x1="-6" y1="15" x2="-6" y2="15"/>
        </g>
      </g>
    </g>

    <!-- ===== Station 3: casino opens → neighbourhood grows ===== -->
    <g class="hf-station hf-station--map" transform="translate(660 65)">
      <circle class="hf-station__halo" r="46" fill="var(--gold)" opacity="0"/>

      <!-- Region outline + dashed sub-boundary. -->
      <path class="hf-imp__region"
            d="M-36 -22 L-22 -28 L-8 -26 L8 -28 L24 -24 L36 -16 L40 -4 L36 8 L28 22 L14 28 L-2 26 L-18 28 L-32 20 L-40 6 L-38 -8 Z"
            fill="var(--paper)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter" stroke-opacity=".55"/>
      <line class="hf-imp__divider" x1="-2" y1="-26" x2="6" y2="26"
            stroke="var(--navy)" stroke-width=".8" stroke-opacity=".28"
            stroke-dasharray="2 3" stroke-linecap="round"/>

      <!-- ===== Casino: builds in fast, then the lit marquee and
                window grid turn on in sequence. ===== -->
      <g class="hf-imp__src">
        <!-- Pylon + marquee sign on top. -->
        <line x1="-15" y1="-21" x2="-15" y2="-17" stroke="var(--navy)" stroke-width="1.2"/>
        <rect class="hf-casino__marquee" x="-26" y="-25" width="22" height="4" rx="1"
              fill="var(--gold)" stroke="var(--navy)" stroke-width="1.2"/>
        <!-- Main casino body. -->
        <rect x="-30" y="-17" width="26" height="19" rx=".5"
              fill="var(--white)" stroke="var(--navy)" stroke-width="1.4" stroke-linejoin="miter"/>
        <!-- Two rows of windows — dark by default, light up one by
             one as the casino "opens for business". -->
        <g class="hf-casino__windows">
          <rect class="hf-casino__win hf-casino__win--1" x="-27" y="-13.5" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--2" x="-22" y="-13.5" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--3" x="-17" y="-13.5" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--4" x="-12" y="-13.5" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--5"  x="-7"  y="-13.5" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--6"  x="-27" y="-8" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--7"  x="-22" y="-8" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--8"  x="-17" y="-8" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--9"  x="-12" y="-8" width="3" height="3" fill="var(--ink-3)"/>
          <rect class="hf-casino__win hf-casino__win--10" x="-7"  y="-8" width="3" height="3" fill="var(--ink-3)"/>
        </g>
        <!-- Entrance awning + door. -->
        <rect x="-21" y="-3.5" width="12" height="2" fill="var(--accent)" stroke="var(--navy)" stroke-width="1"/>
        <rect x="-18" y="-1.5" width="6" height="3.5" fill="var(--navy)" stroke="none"/>
      </g>

      <!-- ===== Cars pulling up to the casino entrance. ===== -->
      <g class="hf-car hf-car--a" transform="translate(-22 6)">
        <rect x="-4" y="-2" width="8" height="3" rx=".7" fill="var(--terra)" stroke="var(--navy)" stroke-width=".9"/>
        <path d="M-3 -2 L-1.5 -3.5 L1.5 -3.5 L3 -2" fill="var(--terra)" stroke="var(--navy)" stroke-width=".9" stroke-linejoin="miter"/>
        <circle cx="-2.5" cy="1" r="1" fill="var(--navy)"/>
        <circle cx="2.5"  cy="1" r="1" fill="var(--navy)"/>
      </g>
      <g class="hf-car hf-car--b" transform="translate(-12 7)">
        <rect x="-4" y="-2" width="8" height="3" rx=".7" fill="var(--accent)" stroke="var(--navy)" stroke-width=".9"/>
        <path d="M-3 -2 L-1.5 -3.5 L1.5 -3.5 L3 -2" fill="var(--accent)" stroke="var(--navy)" stroke-width=".9" stroke-linejoin="miter"/>
        <circle cx="-2.5" cy="1" r="1" fill="var(--navy)"/>
        <circle cx="2.5"  cy="1" r="1" fill="var(--navy)"/>
      </g>

      <!-- ===== Neighbourhood that develops around the casino. ===== -->
      <g class="hf-grow hf-grow--house-a">
        <path d="M8 -8 L16 -16 L24 -8 Z" fill="var(--terra-light)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <rect x="9" y="-8" width="14" height="10" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <rect x="20" y="-14" width="2.5" height="4" fill="var(--navy)" stroke="none"/>
        <rect x="14" y="-3" width="3" height="5" fill="var(--navy)" stroke="none"/>
        <rect x="11" y="-6" width="2" height="2" fill="var(--gold)" stroke="none"/>
      </g>
      <g class="hf-grow hf-grow--house-b">
        <path d="M22 6 L28 0 L34 6 Z" fill="var(--terra-light)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <rect x="23" y="6" width="10" height="9" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <rect x="30" y="1" width="2.2" height="3.5" fill="var(--navy)" stroke="none"/>
        <rect x="26" y="9" width="3" height="5" fill="var(--navy)" stroke="none"/>
        <rect x="30" y="8" width="2" height="2" fill="var(--gold)" stroke="none"/>
      </g>
      <g class="hf-grow hf-grow--shop">
        <rect x="-6" y="14" width="10" height="8" fill="var(--white)" stroke="var(--navy)" stroke-width="1.3" stroke-linejoin="miter"/>
        <rect x="-6" y="11" width="10" height="3" fill="var(--accent)" stroke="var(--navy)" stroke-width="1.1" stroke-linejoin="miter"/>
        <rect x="-3" y="17" width="2.5" height="5" fill="var(--navy)" stroke="none"/>
        <rect x="1"  y="16" width="2.5" height="2.5" fill="var(--gold)" stroke="none"/>
      </g>
      <g class="hf-grow hf-grow--tree">
        <path d="M16 16 L13 22 L19 22 Z" fill="var(--cedar)" stroke="var(--cedar)" stroke-width="1.1" stroke-linejoin="miter"/>
        <path d="M16 19 L12 25 L20 25 Z" fill="var(--cedar)" stroke="var(--cedar)" stroke-width="1.1" stroke-linejoin="miter"/>
        <rect x="15.2" y="25" width="1.6" height="2" fill="var(--navy)" stroke="none"/>
      </g>

      <!-- ===== Dollar signs floating up: the dollars the new
                  business pulls into the region. ===== -->
      <g class="hf-imp__dollars" font-family="JetBrains Mono, ui-monospace, monospace" font-weight="700">
        <text class="hf-dollar hf-dollar--1" x="-18" y="-2" font-size="6"  fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--2" x="-2"  y="-4" font-size="7"  fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--3" x="14"  y="-2" font-size="6"  fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--4" x="-12" y="2"  font-size="5"  fill="var(--gold)">$</text>
        <text class="hf-dollar hf-dollar--5" x="26"  y="-4" font-size="6"  fill="var(--gold)">$</text>
      </g>
    </g>
  </svg>

  <ol class="hero-flow__labels" aria-label="Study stages">
    <li class="hero-flow__label">Harmonize your economic data</li>
    <li class="hero-flow__label">Cedar runs the economic impact analysis</li>
    <li class="hero-flow__label">See your economic impact</li>
  </ol>
</figure>

<style>
  .hero-flow {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 760px;
  }
  .hero-flow__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-flow__labels {
    list-style: none;
    padding: 0;
    margin: .35rem 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: .6rem;
  }
  .hero-flow__label {
    font-family: var(--font-mono);
    font-size: .66rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--ink-3);
    text-align: center;
    line-height: 1.3;
    animation: hf-label-glow 6s ease-in-out infinite;
    text-shadow: 0 0 0 transparent;
  }
  .hero-flow__label:nth-child(1) { animation-delay: 0s; }
  .hero-flow__label:nth-child(2) { animation-delay: 2s; --label-accent: var(--cedar); }
  .hero-flow__label:nth-child(3) { animation-delay: 4s; --label-accent: var(--gold); }
  @keyframes hf-label-glow {
    0%, 25%   { color: var(--ink-3); text-shadow: 0 0 0 transparent; }
    5%        { color: var(--navy);  text-shadow: 0 0 12px var(--label-accent, var(--accent)); }
    16%       { color: var(--navy);  text-shadow: 0 0 4px var(--label-accent, var(--accent)); }
    100%      { color: var(--ink-3); text-shadow: 0 0 0 transparent; }
  }

  /* ---------- Traveling ticks ---------- */
  @keyframes hf-tick-run {
    0%   { transform: translateX(0);     opacity: 0; r: 2.4; }
    8%   { opacity: 1; }
    50%  {                                r: 3.4; }
    92%  { opacity: 1; }
    100% { transform: translateX(600px); opacity: 0; r: 2.4; }
  }
  .hf-tick {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-tick-run 6s linear infinite;
  }
  .hf-tick--a { animation-delay: 0s; }
  .hf-tick--b { animation-delay: 2s; }
  .hf-tick--c { animation-delay: 4s; }

  /* ---------- Halo pulses ---------- */
  .hf-station__halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-halo 6s ease-in-out infinite;
  }
  .hf-station--src   .hf-station__halo { animation-delay: 0s; }
  .hf-station--cedar .hf-station__halo { animation-delay: 2s; }
  .hf-station--map   .hf-station__halo { animation-delay: 4s; }
  @keyframes hf-halo {
    0%, 25%  { opacity: 0;   transform: scale(.6); }
    4%       { opacity: .2;  transform: scale(1);  }
    14%      { opacity: 0;   transform: scale(1.18);}
    100%     { opacity: 0; }
  }

  /* ---------- Station 1: merge + transform ----------
     0-8%:   inputs fade in from the right (re-entry from the
             previous cycle's merged state).
     8-28%:  inputs sit on the left in their three colours.
     28-44%: inputs shrink + slide rightward (the merge moment).
     44-52%: brief beat before the output appears.
     52-90%: output spreadsheet expands, rows fill in sequence
             with mixed colours.
     90-100%: output collapses; cycle restarts. */
  .hf-in {
    transform-box: fill-box;
    transform-origin: 0 50%;
    animation: hf-in-merge 6s ease-in-out infinite;
  }
  .hf-in--a { animation-delay: 0s; }
  .hf-in--b { animation-delay: .08s; }
  .hf-in--c { animation-delay: .16s; }
  @keyframes hf-in-merge {
    0%       { opacity: 0; transform: translate(22px, 0) scale(.35); }
    8%, 28%  { opacity: 1; transform: translate(0, 0)    scale(1);   }
    38%      { opacity: 1; transform: translate(8px, 0)  scale(.9);  }
    46%, 100% { opacity: 0; transform: translate(22px, 0) scale(.35); }
  }
  .hf-out {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-out-grow 6s ease-in-out infinite;
  }
  @keyframes hf-out-grow {
    0%, 44%  { opacity: 0; transform: scaleY(.4); }
    54%      { opacity: 1; transform: scaleY(1);  }
    88%      { opacity: 1; transform: scaleY(1);  }
    96%, 100% { opacity: 0; transform: scaleY(.4); }
  }
  .hf-out__row {
    transform-box: fill-box;
    transform-origin: left center;
    animation: hf-out-row 6s ease-in-out infinite;
  }
  .hf-out__row--1 { animation-delay: .55s; }
  .hf-out__row--2 { animation-delay: .65s; }
  .hf-out__row--3 { animation-delay: .75s; }
  .hf-out__row--4 { animation-delay: .85s; }
  .hf-out__row--5 { animation-delay: .95s; }
  .hf-out__row--6 { animation-delay: 1.05s; }
  @keyframes hf-out-row {
    0%, 50%  { opacity: 0; transform: scaleX(0); }
    60%, 88% { opacity: 1; transform: scaleX(1); }
    100%     { opacity: 0; transform: scaleX(0); }
  }

  /* ---------- Station 2: Cedar + active computation ---------- */
  .hf-cedar__tree {
    transform-box: fill-box;
    transform-origin: center;
    animation: hf-cedar-pulse 6s ease-in-out infinite;
    animation-delay: 2s;
  }
  @keyframes hf-cedar-pulse {
    0%, 100% { transform: scale(1);    }
    4%       { transform: scale(1.08); }
    18%      { transform: scale(1);    }
  }
  .hf-bar {
    transform-box: fill-box;
    transform-origin: center bottom;
    animation: hf-bar-grow 6s ease-in-out infinite;
  }
  .hf-bar--a { animation-delay: 2s;   }
  .hf-bar--b { animation-delay: 2.1s; }
  .hf-bar--c { animation-delay: 2.2s; }
  .hf-bar--d { animation-delay: 2.3s; }
  .hf-bar--e { animation-delay: 2.4s; }
  @keyframes hf-bar-grow {
    0%, 30%  { transform: scaleY(.15); opacity: .35; }
    45%, 90% { transform: scaleY(1);   opacity: 1;   }
    100%     { transform: scaleY(.15); opacity: .35; }
  }
  .hf-line {
    animation: hf-line-out 6s ease-in-out infinite;
  }
  .hf-line--a { animation-delay: 2.4s; }
  .hf-line--b { animation-delay: 2.55s; }
  .hf-line--c { animation-delay: 2.7s; }
  @keyframes hf-line-out {
    0%, 38%  { x2: -6;  opacity: 0; }
    52%      { opacity: 1; }
    65%, 90% { x2: 32;  opacity: .9; }
    100%     { x2: -6;  opacity: 0; }
  }

  /* ---------- Station 3: casino opens, neighbourhood grows ----
     Inside the 6s station loop (Station 3 starts at 4s in cycle):
       0.00s  Empty region.
       0.05s  Casino body scales up from ground (built fast).
       0.35s  Marquee on top lights up gold.
       0.40s+ Window grid lights up window-by-window in a wave.
       0.65s  Cars pull up to the entrance.
       0.85s  House A appears.
       1.15s  House B appears.
       1.45s  Shop appears.
       1.75s  Tree appears.
       2.10s  Dollar signs start floating up from the new
              development, staggered.
       Steady state ~3 seconds, then fade for reset. */

  /* Casino body builds up from the ground. */
  .hf-imp__src {
